      b.raw("<div");
      b.raw(" class=\"wrap split\"");
      b.raw(">");
      b.raw("\n            ");
      b.raw("<div");
      b.raw(" class=\"copy\"");
      b.raw(">");
      b.raw("\n                ");
      b.raw("<p");
      b.raw(" class=\"eyebrow\"");
      b.raw(">");
      b.raw("Code beside the UI");
      b.raw("</p>");
      b.raw("\n                ");
      b.raw("<h2");
      b.raw(">");
      b.raw("Markup and logic in one file");
      b.raw("</h2>");
      b.raw("\n                ");
      b.raw("<p");
      b.raw(" class=\"lede\"");
      b.raw(">");
      b.raw("The clicks are ");
      b.raw("<strong");
      b.raw(">");
      b.raw("updates");
      b.raw("</strong>");
      b.raw(", the render is a ");
      b.raw("<strong");
      b.raw(">");
      b.raw("query");
      b.raw("</strong>");
      b.raw(". State lives in ");
      b.raw("<code");
      b.raw(">");
      b.raw("@code");
      b.raw("</code>");
      b.raw(" right next to the buttons that change it — and persists across calls in your canister.");
      b.raw("</p>");
      b.raw("\n                ");
      b.raw("<ul");
      b.raw(">");
      b.raw("\n                    ");
      b.raw("<li");
      b.raw(">");
      b.raw("Bake handler args server-side with ");
      b.raw("<code");
      b.raw(">");
      b.raw("@click=\"increment(1)\"");
      b.raw("</code>");
      b.raw("</li>");
      b.raw("\n                    ");
      b.raw("<li");
      b.raw(">");
      b.raw("Interpolate state inline with ");
      b.raw("<code");
      b.raw(">");
      b.raw("@count");
      b.raw("</code>");
      b.raw("</li>");
      b.raw("\n                    ");
      b.raw("<li");
      b.raw(">");
      b.raw("State persists in the canister across calls");
      b.raw("</li>");
      b.raw("\n                    ");
      b.raw("<li");
      b.raw(">");
      b.raw("Compiles straight to a Motoko actor");
      b.raw("</li>");
      b.raw("\n                ");
      b.raw("</ul>");
      b.raw("\n            ");
      b.raw("</div>");
      b.raw("\n            ");
      b.raw("<div");
      b.raw(" class=\"code-window\"");
