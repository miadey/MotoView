    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "MotoView — Write Motoko. Ship interactive, SEO-friendly ICP apps." };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "MotoView — Write Motoko. Ship interactive, SEO-friendly ICP apps."; description = "MotoView is a Motoko-native, server-driven UI framework for Internet Computer canisters. Write .mview files, compile to Motoko, deploy with dfx. No frontend JavaScript."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx;  };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch mvH {
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };


  let DocDef : MV.Page = {
    route = "/docs/{slug}";
    layout = "DocLayout";
    authorize = false;
    role = "";
    cacheable = true;
    onLoad = DocPage.mvOnLoad;
    render = DocPage.mvRender;
    title = DocPage.mvTitle;
    head = DocPage.mvHead;
    dispatch = DocPage.mvDispatch;
    takeErrors = DocPage.mvTakeErrors;
    takeEffects = DocPage.mvTakeEffects;
    takeRedirect = DocPage.mvTakeRedirect;
  };
  let DocsIndexDef : MV.Page = {
    route = "/docs";
    layout = "DocLayout";
    authorize = false;
    role = "";
    cacheable = true;
    onLoad = DocsIndexPage.mvOnLoad;
    render = DocsIndexPage.mvRender;
    title = DocsIndexPage.mvTitle;
    head = DocsIndexPage.mvHead;
    dispatch = DocsIndexPage.mvDispatch;
    takeErrors = DocsIndexPage.mvTakeErrors;
    takeEffects = DocsIndexPage.mvTakeEffects;
    takeRedirect = DocsIndexPage.mvTakeRedirect;
  };
  let HomeDef : MV.Page = {
