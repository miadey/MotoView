      b.raw("</div>");
      b.raw("\n                    ");
      b.raw("<h3");
      b.raw(">");
      b.raw("Certified &amp; persistent");
      b.raw("</h3>");
      b.raw("\n                    ");
      b.raw("<p");
      b.raw(">");
      b.raw("Cacheable pages serve as certified queries; services opt into upgrade-stable persistence. Internet Identity login ships in the box.");
      b.raw("</p>");
      b.raw("\n                ");
      b.raw("</div>");
      b.raw("\n            ");
      b.raw("</div>");
      b.raw("\n        ");
