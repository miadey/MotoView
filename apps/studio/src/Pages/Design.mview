@page "/"
@layout StudioLayout
@title "Design surface — MotokoStudio"
@description "Design MotoView apps with AI, always bound to the backend: one type-checked .mview artifact (template + @code handlers + typed state), gated by the unbypassable compiler."

<header class="ds-head">
    <div>
        <h1 class="st-h1">Design surface</h1>
        <p class="st-lede">
            Design MotoView apps as ONE type-checked artifact: a <code>.mview</code> file holding template
            markup, <code>@@code</code> handlers, and typed state — always bound to the canister backend.
            The canvas is a scaffold; the source pane is the source of truth.
        </p>
    </div>
    <span class="st-flag" title="No on-canister LLM. The visual editor is a placeholder.">⚑ scaffold</span>
</header>

<div class="ds-split">

    <!-- LEFT: visual canvas placeholder (interface-only / scaffold) -->
    <section class="st-card ds-canvas">
        <div class="ds-pane-bar">
            <span class="ds-pane-title">Canvas</span>
            <span class="st-flag">⚑ visual editor: placeholder</span>
        </div>
        <div class="ds-canvas-stage" role="img" aria-label="Design canvas placeholder">
            <div class="ds-ghost ds-ghost-h1"></div>
            <div class="ds-ghost ds-ghost-p"></div>
            <div class="ds-ghost ds-ghost-p ds-short"></div>
            <div class="ds-ghost-btn">Button</div>
            <p class="ds-canvas-note">
                Drag-and-drop visual editing is a planned scaffold. Today the <strong>source pane</strong>
                on the right is authoritative — it is what the compiler gate validates and what deploys.
            </p>
        </div>
    </section>

    <!-- RIGHT: the .mview source pane, bound to the studio session -->
    <section class="st-card ds-source">
        <div class="ds-pane-bar">
            <span class="ds-pane-title">@(project.name) <span class="ds-file">.mview</span></span>
            @if saveable {
                <Badge type="success">saveable · gate passed</Badge>
            } else {
                <Badge type="warning">@gateLabel</Badge>
            }
        </div>
        <pre class="st-code ds-source-text">@project.source</pre>
        <div class="ds-gate">
            <p class="ds-gate-line">
                <strong>Gate:</strong> a <code>.mview</code> can only be saved when
                <code>motoview check</code> AND <code>motoview lint</code> both pass.
                Run <code>tools/studio/validate.sh</code> to enforce it — the compiler is the authority, not the AI.
            </p>
            <p class="ds-gate-meta">
                check: @gateCheck · lint: @gateLint
            </p>
        </div>
    </section>

</div>

<section class="st-card">
    <h2 class="ds-h2">The loop</h2>
    <ol class="ds-loop">
        <li><strong>Prompt</strong> — describe the page; the binding palette is the project's real Motoko service signatures.</li>
        <li><strong>Generate</strong> — an OFF-canister, design-time LLM call emits ONE complete <code>.mview</code> (template + <code>@@code</code> + typed state). There is no on-canister model.</li>
        <li><strong>Validate gate</strong> — <code>tools/studio/validate.sh</code> runs <code>check</code> + <code>lint</code>; a failing artifact is refused. Security-by-construction.</li>
        <li><strong>Deploy</strong> — <code>dfx deploy</code> to a local replica.</li>
        <li><strong>Preview</strong> — the <a href="/preview">live preview</a> page embeds the running canister.</li>
    </ol>
    <p class="st-note">
        Honest dependencies: AI generation needs an external (off-canister) LLM endpoint; live preview needs a
        running <code>dfx</code> replica. See <code>tools/studio/README.md</code> and <code>tools/studio/generate.md</code>.
    </p>
</section>

<style>
    .ds-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;
        margin-bottom: var(--spacingVerticalL); }
    .ds-split { display: grid; grid-template-columns: 1fr 1.15fr; gap: var(--spacingHorizontalL);
        align-items: start; }
    .ds-pane-bar { display: flex; align-items: center; justify-content: space-between;
        margin-bottom: var(--spacingVerticalM); padding-bottom: var(--spacingVerticalS);
        border-bottom: 1px solid var(--colorNeutralStroke3); }
    .ds-pane-title { font-weight: var(--fontWeightSemibold); font-size: var(--fontSizeBase300); }
    .ds-file { color: var(--colorNeutralForeground4); font-weight: var(--fontWeightRegular); }

    .ds-canvas-stage { background: var(--colorNeutralBackground3);
        border: 1px dashed var(--colorNeutralStroke2); border-radius: var(--borderRadiusMedium);
        padding: var(--spacingVerticalXL) var(--spacingHorizontalL); min-height: 220px; }
    .ds-ghost { background: var(--colorNeutralStroke2); border-radius: 6px; opacity: .7; }
    .ds-ghost-h1 { height: 22px; width: 55%; margin-bottom: 14px; }
    .ds-ghost-p { height: 12px; width: 90%; margin-bottom: 8px; }
    .ds-ghost-p.ds-short { width: 65%; }
    .ds-ghost-btn { display: inline-block; margin-top: 16px; padding: .4rem .9rem; color: #fff;
        background: var(--colorBrandBackground); border-radius: var(--borderRadiusMedium);
        font-size: var(--fontSizeBase200); opacity: .85; }
    .ds-canvas-note { margin: var(--spacingVerticalL) 0 0; color: var(--colorNeutralForeground4);
        font-size: var(--fontSizeBase200); }

    .ds-source-text { max-height: 360px; white-space: pre; }
    .ds-gate { margin-top: var(--spacingVerticalM); }
    .ds-gate-line { margin: 0 0 .35rem; font-size: var(--fontSizeBase200); color: var(--colorNeutralForeground3); }
    .ds-gate-meta { margin: 0; font-size: var(--fontSizeBase200); color: var(--colorNeutralForeground4);
        font-family: var(--fontFamilyMonospace, monospace); }

    .ds-h2 { margin: 0 0 var(--spacingVerticalM); font-size: var(--fontSizeBase500); }
    .ds-loop { margin: 0 0 var(--spacingVerticalM); padding-left: 1.2rem; color: var(--colorNeutralForeground2);
        font-size: var(--fontSizeBase300); line-height: 1.9; }

    @media (max-width: 820px) { .ds-split { grid-template-columns: 1fr; } }
</style>

@code {
    var project : Studio.Project = { name = "untitled"; source = ""; lastGate = null; updated = 0 };
    var saveable : Bool = false;
    var gateCheck : Text = "not run";
    var gateLint : Text = "not run";
    var gateLabel : Text = "not validated";

    func onLoad(ctx : Context) {
        // Show the live design-time session. If nothing is open yet, seed the
        // session with the honest, lint-clean starter so the surface is never
        // empty — exactly the source a fresh `motoview new` page would hold.
        let p = switch (Studio.get("untitled")) {
            case (?existing) { existing };
            case null { Studio.open("untitled", Studio.starterSource) };
        };
        project := p;
        switch (p.lastGate) {
            case (?g) {
                saveable := Studio.saveable(g);
                gateCheck := if (g.checkPassed) "pass" else "FAIL";
                gateLint := if (g.lintPassed) "pass" else "FAIL";
                gateLabel := if (saveable) "saveable" else "blocked by gate";
            };
            case null {
                saveable := false;
                gateCheck := "not run";
                gateLint := "not run";
                gateLabel := "not validated — run validate.sh";
            };
        };
    };
}
