{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bzzz",
  "version": "0.1.0",
  "identifier": "chat.bzzz.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bzzz",
        "label": "main",
        "width": 1200,
        "height": 820,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "url": "https://YOUR_CANISTER_ID.icp0.io/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
