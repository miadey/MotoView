      b.raw("\n    .fn-wrap { max-width: 820px; margin: 0 auto; color: #1a1a1a; }\n\n    .fn-head { display: flex; align-items: center; gap: .45rem; font-size: .85rem; margin-bottom: 1rem; }\n    .fn-crumb { color: #0088CC; text-decoration: none; font-weight: 600; }\n    .fn-crumb:hover { text-decoration: underline; }\n    .fn-crumb-sep { color: #c4c9ce; }\n    .fn-crumb-cur { color: #6b7177; font-weight: 600; }\n\n    .fn-card { padding: 1.5rem 1.6rem 1.7rem; }\n    .fn-title { margin: 0 0 .3rem; font-size: 1.55rem; letter-spacing: -.01em; }\n    .fn-lede { margin: 0 0 1.4rem; color: #6b7177; }\n\n    .fn-field { margin-bottom: 1.3rem; }\n    .fn-label { display: block; font-weight: 700; font-size: .9rem; margin-bottom: .4rem; color: #2b2f33; }\n    .fn-hint { margin: .4rem 0 0; color: #8a9097; font-size: .8rem; }\n    .fn-hint code { background: #f1f3f5; border-radius: 4px; padding: .05rem .3rem; font-size: .92em; color: #5c6166; }\n\n    .fn-cats { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: .55rem; }\n    .fn-cat { display: flex; align-items: center; gap: .5rem; padding: .55rem .7rem; border-radius: 10px;\n        border: 1.5px solid #e3e6e9; background: #fff; cursor: pointer; transition: border-color .12s ease, background .12s ease; }\n    .fn-cat:hover { border-color: #b9c0c6; background: #fbfcfd; }\n    .fn-cat.is-sel,\n    .fn-cat:has(input:checked) { border-color: #6d28d9; background: #f6f2fe; box-shadow: 0 0 0 1px #6d28d9 inset; }\n    .fn-cat input { position: absolute; opacity: 0; width: 0; height: 0; }\n    .fn-cat-sq { width: 14px; height: 14px; border-radius: 3px; background: var(--c, #9aa0a6); flex: 0 0 14px; }\n    .fn-cat-name { font-size: .9rem; font-weight: 600; color: #2b2f33; }\n\n    .fn-actions { display: flex; align-items: center; gap: 1rem; margin-top: 1.5rem; padding-top: 1.2rem; border-top: 1px solid #eef0f2; }\n    .fn-cancel { color: #8a9097; text-decoration: none; font-weight: 600; font-size: .9rem; }\n    .fn-cancel:hover { color: #5c6166; }\n\n    .fn-gate { padding: 2.2rem 2rem; text-align: center; }\n    .fn-gate h1 { margin: 0 0 .5rem; font-size: 1.45rem; }\n    .fn-gate p { color: #6b7177; margin: 0 0 1.2rem; }\n    .fn-gate-btn { display: inline-block; background: #6d28d9; color: #fff; text-decoration: none;\n        font-weight: 700; padding: .55rem 1.1rem; border-radius: 10px; }\n    .fn-gate-btn:hover { background: #5b21b6; }\n\n    @media (max-width: 540px) {\n        .fn-card { padding: 1.2rem 1.1rem 1.4rem; }\n        .fn-cats { grid-template-columns: 1fr; }\n    }\n");
      b.raw("</style>");
      b.raw("\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "New topic — Bzzz Forum" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "New topic — Bzzz Forum"; description = "Start a new discussion on the Bzzz forum: pick a category, add tags and write your post."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "body")) { case (?mvV) { body := mvV }; case null {} };
      switch (mvFormGet(ctx, "tags")) { case (?mvV) { tags := mvV }; case null {} };
      switch (mvFormGet(ctx, "title")) { case (?mvV) { title := mvV }; case null {} };
      switch mvH {
        case "create" { create(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/ForumTopic.mview
  // ===== Page: ForumTopic (/forum/t/{id:Nat}) =====
  let ForumTopicPage = object {
    var id : Nat = 0;
    var exists : Bool = false;
    var categoryId : Nat = 0;
    var topicTitle : Text = "Topic";
    var topicDescription : Text = "A discussion on the Bzzz forum.";
    var catName : Text = "";
    var catColor : Text = "#9aa0a6";
    var tags : [Text] = [];
    var hasTags : Bool = false;
    var pinned : Bool = false;
    var closed : Bool = false;
    var solved : Bool = false;
    var acceptedId : Nat = 0;
    var views : Nat = 0;
    var replyCount : Nat = 0;
    var activity : Text = "";
    var isAuthor : Bool = false;
    var signedIn : Bool = false;
    var posts : [Forum.Post] = [];
    var me : Principal = Principal.fromText("2vxsx-fae");
    var body : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        Forum.bumpView(id);
        load(ctx);
    };
    func load(ctx : Context) {
        me := ctx.caller;
        signedIn := Identity.isBound(ctx.caller);
        switch (Forum.topic(id)) {
            case (?t) {
                exists := true;
                categoryId := t.categoryId;
                topicTitle := t.title;
                topicDescription := "Discussion: " # t.title # " — on the Bzzz forum.";
                catName := Forum.categoryName(t.categoryId);
                catColor := Forum.categoryColor(t.categoryId);
                tags := t.tags;
                hasTags := t.tags.size() > 0;
                pinned := t.pinned;
                closed := t.closed;
                acceptedId := t.acceptedPostId;
                solved := t.acceptedPostId != 0;
                views := t.views;
                isAuthor := t.author == ctx.caller;
                activity := Forum.topicActivity(id);
                replyCount := Forum.replyCount(id);
                posts := Forum.posts(id);
            };
            case null {
                exists := false;
            };
        };
    };
    func avatarFor(p : Principal) : Text { Identity.avatarOf(p) };
    func when(at : Int) : Text { Forum.relativeTime(at) };
    func isOp(replyToPost : Nat) : Bool { replyToPost == 0 };
    func canAccept(replyToPost : Nat) : Bool { isAuthor and replyToPost != 0 };
    func isAccepted(postId : Nat) : Bool { postId != 0 and postId == acceptedId };
    func hasLikes(n : Nat) : Bool { n > 0 };
    func postClass(postId : Nat) : Text { if (isAccepted(postId)) "is-accepted" else "" };
    func likedBy(postId : Nat) : Bool { Forum.hasLiked(me, postId) };
    func toggleLike(ctx : Context, postId : Nat) : () {
        ignore Forum.like(ctx.caller, postId);
        load(ctx);
    };
    func acceptPost(ctx : Context, postId : Nat) : () {
        if (Forum.accept(ctx.caller, id, postId)) {
            toast("Marked as the solution.");
        } else {
            toast("Only the topic author can accept an answer.");
        };
        load(ctx);
    };
    func unaccept(ctx : Context) : () {
        ignore Forum.accept(ctx.caller, id, 0);
        toast("Solution cleared.");
        load(ctx);
    };
    func clearSolution(ctx : Context) : () {
        ignore Forum.accept(ctx.caller, id, 0);
        toast("Solution cleared.");
        load(ctx);
    };
    func togglePin(ctx : Context) : () {
        ignore Forum.setPinned(ctx.caller, id, not pinned);
        load(ctx);
    };
    func toggleClose(ctx : Context) : () {
        ignore Forum.setClosed(ctx.caller, id, not closed);
        load(ctx);
    };
    func submitReply(ctx : Context) : () {
         mvErrors.clear(); if (body == "") { mvErrors.add(("body", "Write a reply before posting.")) }; if (mvErrors.size() > 0) { return }; 
        let handle = Identity.handleOf(ctx.caller);
        let pid = Forum.reply(ctx.caller, handle, id, body, 0);
        if (pid == 0) {
            toast("This topic is closed.");
        } else {
            body := "";
            toast("Reply posted.");
        };
        load(ctx);
        if (pid != 0) { scrollTo("#post-" # Nat.toText(pid)) };
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      id := mvNat(mvParamGet(ctx, "id"));
      b.raw("<div");
      b.raw(" class=\"ft-wrap\"");
      b.raw(">");
      b.raw("\n\n");
      if (exists) {
        b.raw("\n\n    ");
        b.raw("<header");
        b.raw(" class=\"ft-head\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"ft-cat\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(" class=\"ft-cat-sq\"");
        b.raw(" style=\"");
        b.raw("--c:");
        b.text(catColor);
        b.raw("\"");
        b.raw(">");
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("<a");
        b.raw(" class=\"ft-cat-name\"");
        b.raw(" href=\"");
        b.raw("/forum/c/");
        b.text(Nat.toText(categoryId));
        b.raw("\"");
        b.raw(">");
        b.text(catName);
        b.raw("</a>");
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("<h1");
        b.raw(" class=\"ft-title\"");
        b.raw(">");
        b.raw("\n            ");
        if (pinned) {
          b.raw(" ");
          b.raw("<span");
          b.raw(" class=\"ft-glyph\"");
          b.raw(" title=\"Pinned\"");
          b.raw(">");
          b.raw("📌");
          b.raw("</span>");
          b.raw(" ");
        };
        b.raw("\n            ");
        if (closed) {
          b.raw(" ");
          b.raw("<span");
          b.raw(" class=\"ft-glyph\"");
          b.raw(" title=\"Closed\"");
          b.raw(">");
          b.raw("🔒");
          b.raw("</span>");
          b.raw(" ");
        };
        b.raw("\n            ");
        if (solved) {
          b.raw(" ");
          b.raw("<span");
          b.raw(" class=\"ft-glyph\"");
          b.raw(" title=\"Solved\"");
          b.raw(">");
          b.raw("✅");
          b.raw("</span>");
          b.raw(" ");
        };
        b.raw("\n            ");
        b.text(topicTitle);
        b.raw("\n        ");
        b.raw("</h1>");
        b.raw("\n        ");
        if (hasTags) {
          b.raw("\n            ");
          b.raw("<div");
          b.raw(" class=\"ft-tags\"");
          b.raw(">");
          b.raw("\n                ");
          for (t in (tags).vals()) {
            b.raw("\n                    ");
            b.raw("<span");
            b.raw(" class=\"ft-tag\"");
            b.raw(">");
            b.text(Html.unquote(debug_show(t)));
            b.raw("</span>");
            b.raw("\n                ");
          };
          b.raw("\n            ");
          b.raw("</div>");
          b.raw("\n        ");
        };
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"ft-sub\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(">");
        b.text(Nat.toText(replyCount));
        b.raw(" replies");
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(" class=\"ft-dot\"");
        b.raw(">");
        b.raw("·");
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(">");
        b.text(Nat.toText(views));
        b.raw(" views");
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(" class=\"ft-dot\"");
        b.raw(">");
        b.raw("·");
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(">");
        b.raw("last activity ");
        b.text(activity);
        b.raw("</span>");
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n    ");
        b.raw("</header>");
        b.raw("\n\n    ");
        if (isAuthor) {
          b.raw("\n        ");
          b.raw("<div");
          b.raw(" class=\"ft-mod\"");
          b.raw(">");
          b.raw("\n            ");
          b.raw("<span");
          b.raw(" class=\"ft-mod-label\"");
          b.raw(">");
          b.raw("Topic controls");
          b.raw("</span>");
          b.raw("\n            ");
          if (pinned) {
            b.raw("\n                ");
            b.raw("<button");
            b.raw(" class=\"ft-mod-btn\"");
            b.raw(" data-mv-handler=\"togglePin\" data-mv-event=\"click\"");
            b.raw(">");
            b.raw("Unpin");
            b.raw("</button>");
            b.raw("\n            ");
          } else {
            b.raw("\n                ");
            b.raw("<button");
            b.raw(" class=\"ft-mod-btn\"");
            b.raw(" data-mv-handler=\"togglePin\" data-mv-event=\"click\"");
            b.raw(">");
            b.raw("Pin");
            b.raw("</button>");
            b.raw("\n            ");
          };
          b.raw("\n            ");
          if (closed) {
            b.raw("\n                ");
            b.raw("<button");
            b.raw(" class=\"ft-mod-btn\"");
            b.raw(" data-mv-handler=\"toggleClose\" data-mv-event=\"click\"");
            b.raw(">");
            b.raw("Reopen");
            b.raw("</button>");
            b.raw("\n            ");
          } else {
            b.raw("\n                ");
            b.raw("<button");
            b.raw(" class=\"ft-mod-btn\"");
            b.raw(" data-mv-handler=\"toggleClose\" data-mv-event=\"click\"");
            b.raw(">");
            b.raw("Close");
            b.raw("</button>");
            b.raw("\n            ");
          };
          b.raw("\n            ");
          if (solved) {
            b.raw("\n                ");
            b.raw("<button");
            b.raw(" class=\"ft-mod-btn\"");
            b.raw(" data-mv-handler=\"clearSolution\" data-mv-event=\"click\"");
            b.raw(">");
            b.raw("Clear solution");
            b.raw("</button>");
            b.raw("\n            ");
          };
          b.raw("\n        ");
          b.raw("</div>");
          b.raw("\n    ");
        };
        b.raw("\n\n    ");
        b.raw("<div");
        b.raw(" class=\"ft-stream\"");
        b.raw(">");
        b.raw("\n        ");
        for (p in (posts).vals()) {
          b.raw("\n            ");
          b.raw("<article");
          b.raw(" class=\"");
          b.raw("ft-post ");
          b.text(postClass(p.id));
          b.raw("\"");
          b.raw(" id=\"");
          b.raw("post-");
          b.text(Html.unquote(debug_show(p.id)));
          b.raw("\"");
          b.raw(">");
          b.raw("\n                ");
          if (isAccepted(p.id)) {
            b.raw("\n                    ");
            b.raw("<div");
            b.raw(" class=\"ft-solution-tag\"");
            b.raw(">");
            b.raw("✅ Solution");
            b.raw("</div>");
            b.raw("\n                ");
          };
          b.raw("\n                ");
          b.raw("<div");
          b.raw(" class=\"ft-post-row\"");
          b.raw(">");
          b.raw("\n                    ");
          b.raw("<div");
          b.raw(" class=\"ft-avatar\"");
          b.raw(">");
          b.text(avatarFor(p.author));
          b.raw("</div>");
          b.raw("\n                    ");
          b.raw("<div");
          b.raw(" class=\"ft-post-main\"");
          b.raw(">");
          b.raw("\n                        ");
          b.raw("<div");
          b.raw(" class=\"ft-post-head\"");
          b.raw(">");
          b.raw("\n                            ");
          b.raw("<span");
          b.raw(" class=\"ft-handle\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(p.authorHandle)));
          b.raw("</span>");
          b.raw("\n                            ");
          if (isOp(p.replyToPost)) {
            b.raw("\n                                ");
            b.raw("<span");
            b.raw(" class=\"ft-op-badge\"");
            b.raw(">");
            b.raw("OP");
            b.raw("</span>");
            b.raw("\n                            ");
          };
          b.raw("\n                            ");
          b.raw("<span");
          b.raw(" class=\"ft-when\"");
          b.raw(">");
          b.text(when(p.at));
          b.raw("</span>");
          b.raw("\n                        ");
          b.raw("</div>");
          b.raw("\n                        ");
          b.raw("<div");
          b.raw(" class=\"ft-body\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(p.body)));
          b.raw("</div>");
          b.raw("\n                        ");
          b.raw("<div");
          b.raw(" class=\"ft-actions\"");
          b.raw(">");
          b.raw("\n                            ");
          if (likedBy(p.id)) {
            b.raw("\n                                ");
            b.raw("<button");
            b.raw(" class=\"ft-act ft-liked\"");
            b.raw(" title=\"Unlike\"");
            b.raw(" data-mv-handler=\"toggleLike\" data-mv-event=\"click\"");
            b.attr("data-mv-arg0", Html.unquote(debug_show(p.id)));
            b.raw(">");
            b.raw("\n                                    ");
            b.raw("<span");
            b.raw(" class=\"ft-heart\"");
            b.raw(">");
            b.raw("♥");
            b.raw("</span>");
            b.raw("\n                                    ");
            b.raw("<span");
            b.raw(" class=\"ft-count\"");
            b.raw(">");
            b.text(Html.unquote(debug_show(p.likeCount)));
            b.raw("</span>");
            b.raw("\n                                ");
            b.raw("</button>");
            b.raw("\n                            ");
          } else {
            b.raw("\n                                ");
            b.raw("<button");
            b.raw(" class=\"ft-act\"");
            b.raw(" title=\"Like\"");
            b.raw(" data-mv-handler=\"toggleLike\" data-mv-event=\"click\"");
            b.attr("data-mv-arg0", Html.unquote(debug_show(p.id)));
            b.raw(">");
            b.raw("\n                                    ");
            b.raw("<span");
            b.raw(" class=\"ft-heart\"");
            b.raw(">");
            b.raw("♡");
            b.raw("</span>");
            b.raw("\n                                    ");
            if (hasLikes(p.likeCount)) {
              b.raw("\n                                        ");
              b.raw("<span");
              b.raw(" class=\"ft-count\"");
              b.raw(">");
              b.text(Html.unquote(debug_show(p.likeCount)));
              b.raw("</span>");
              b.raw("\n                                    ");
            };
            b.raw("\n                                ");
            b.raw("</button>");
            b.raw("\n                            ");
          };
          b.raw("\n                            ");
          b.raw("<a");
          b.raw(" class=\"ft-act\"");
          b.raw(" href=\"#reply\"");
          b.raw(" title=\"Reply\"");
          b.raw(">");
          b.raw("↩ Reply");
          b.raw("</a>");
          b.raw("\n                            ");
          if (isAccepted(p.id)) {
            b.raw("\n                                ");
            if (isAuthor) {
              b.raw("\n                                    ");
              b.raw("<button");
              b.raw(" class=\"ft-act ft-act-accepted\"");
              b.raw(" title=\"Unmark solution\"");
              b.raw(" data-mv-handler=\"unaccept\" data-mv-event=\"click\"");
              b.raw(">");
              b.raw("✓ Solution");
              b.raw("</button>");
              b.raw("\n                                ");
            };
            b.raw("\n                            ");
          } else if (canAccept(p.replyToPost)) {
            b.raw("\n                                ");
            b.raw("<button");
            b.raw(" class=\"ft-act ft-act-accept\"");
            b.raw(" title=\"Mark as solution\"");
            b.raw(" data-mv-handler=\"acceptPost\" data-mv-event=\"click\"");
            b.attr("data-mv-arg0", Html.unquote(debug_show(p.id)));
            b.raw(">");
            b.raw("Accept answer");
            b.raw("</button>");
            b.raw("\n                            ");
          };
          b.raw("\n                        ");
          b.raw("</div>");
          b.raw("\n                    ");
          b.raw("</div>");
          b.raw("\n                ");
          b.raw("</div>");
          b.raw("\n            ");
          b.raw("</article>");
          b.raw("\n        ");
        };
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n\n    ");
        if (closed) {
          b.raw("\n        ");
          b.raw("<div");
          b.raw(" class=\"ft-closed-note\"");
          b.raw(">");
          b.raw("\n            🔒 This topic is closed. New replies are disabled.\n        ");
          b.raw("</div>");
          b.raw("\n    ");
        } else {
          b.raw("\n        ");
          b.raw("<div");
          b.raw(" class=\"ft-composer bz-card\"");
          b.raw(" id=\"reply\"");
          b.raw(">");
          b.raw("\n            ");
          b.raw("<h3");
          b.raw(" class=\"ft-composer-title\"");
          b.raw(">");
          b.raw("Reply");
          b.raw("</h3>");
          b.raw("\n            ");
          if (signedIn) {
            b.raw("\n                ");
            b.raw("<form");
            b.raw(" novalidate");
            b.raw(" data-mv-handler=\"submitReply\" data-mv-event=\"submit\"");
            b.raw(" data-mv-secure=\"1\"");
            b.attr("data-mv-token", ctx.mintToken("submitReply", "body"));
            b.raw(" data-mv-schema=\"body\"");
            b.raw(">");
            b.raw("\n                    ");
            if (mvErrors.size() > 0) {
              b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
              for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
              b.raw("</ul></div>");
            };
            b.raw("\n                    ");
            b.raw("<div class=\"mv-field\">");
            b.raw("<label>Your reply *</label>");
            b.raw("<textarea class=\"mv-textarea\" name=\"body\" data-mv-key=\"body\"");
            b.raw(" required");
            b.raw(">");
            b.text(body);
            b.raw("</textarea>");
            for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "body") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
            b.raw("</div>");
            b.raw("\n                    ");
            b.raw("<div");
            b.raw(" class=\"ft-composer-actions\"");
            b.raw(">");
            b.raw("\n                        ");
            b.raw("<button type=\"submit\" class=\"mv-btn mv-btn-primary\"");
            b.raw(">");
            b.raw("Reply");
            b.raw("</button>");
            b.raw("\n                    ");
            b.raw("</div>");
            b.raw("\n                ");
            b.raw("</form>");
            b.raw("\n            ");
          } else {
            b.raw("\n                ");
            b.raw("<p");
            b.raw(" class=\"ft-signin-note\"");
            b.raw(">");
            b.raw("Pick a handle on ");
            b.raw("<a");
            b.raw(" href=\"/me\"");
            b.raw(">");
            b.raw("your profile");
            b.raw("</a>");
            b.raw(" to join the discussion.");
            b.raw("</p>");
            b.raw("\n            ");
          };
          b.raw("\n        ");
          b.raw("</div>");
          b.raw("\n    ");
        };
        b.raw("\n\n");
      } else {
        b.raw("\n\n    ");
        b.raw("<div");
        b.raw(" class=\"ft-empty bz-card\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<h2");
        b.raw(">");
        b.raw("Topic not found");
        b.raw("</h2>");
        b.raw("\n        ");
        b.raw("<p");
        b.raw(">");
        b.raw("This topic doesn't exist or may have been removed.");
        b.raw("</p>");
        b.raw("\n        ");
        b.raw("<a");
        b.raw(" class=\"ft-back\"");
        b.raw(" href=\"/forum\"");
        b.raw(">");
        b.raw("← Back to the forum");
        b.raw("</a>");
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n\n");
      };
      b.raw("\n\n");
      b.raw("</div>");
      b.raw("\n\n");
      b.raw("<style");
      b.raw(">");
      b.raw("\n    .ft-wrap { max-width: 1100px; margin: 0 auto; color: #1a1a1a; }\n\n    .ft-head { padding: 0 0 1rem; border-bottom: 1px solid #e9ecef; margin-bottom: 1.25rem; }\n    .ft-cat { display: flex; align-items: center; gap: .45rem; margin-bottom: .55rem; }\n    .ft-cat-sq { width: 13px; height: 13px; border-radius: 3px; background: var(--c, #9aa0a6); display: inline-block; }\n    .ft-cat-name { color: #6b7177; text-decoration: none; font-size: .85rem; font-weight: 600; }\n    .ft-cat-name:hover { color: #0088CC; }\n    .ft-title { margin: 0; font-size: 1.7rem; line-height: 1.25; letter-spacing: -.01em; font-weight: 700; }\n    .ft-glyph { font-size: 1.15rem; margin-right: .2rem; }\n    .ft-tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: .7rem; }\n    .ft-tag { background: #f1f3f5; color: #5c6166; font-size: .76rem; padding: .18rem .55rem; border-radius: 999px; border: 1px solid #e3e6e9; }\n    .ft-sub { margin-top: .7rem; color: #8a9097; font-size: .82rem; display: flex; flex-wrap: wrap; gap: .4rem; align-items: center; }\n    .ft-dot { color: #c4c9ce; }\n\n    .ft-mod { display: flex; flex-wrap: wrap; align-items: center; gap: .5rem; margin-bottom: 1.1rem;\n        background: #fff8f0; border: 1px solid #ffe2c2; border-radius: 10px; padding: .55rem .8rem; }\n    .ft-mod-label { font-size: .78rem; font-weight: 700; color: #b3621a; margin-right: .25rem; text-transform: uppercase; letter-spacing: .03em; }\n    .ft-mod-btn { background: #fff; border: 1px solid #e3a76a; color: #b3621a; border-radius: 8px;\n        padding: .32rem .7rem; font-size: .82rem; font-weight: 600; cursor: pointer; }\n    .ft-mod-btn:hover { background: #F15A24; border-color: #F15A24; color: #fff; }\n\n    .ft-stream { display: flex; flex-direction: column; gap: 0; }\n    .ft-post { background: #fff; border-bottom: 1px solid #ededed; padding: 1.15rem .25rem 1.25rem; position: relative; }\n    .ft-post:first-child { padding-top: .25rem; }\n    .ft-post.is-accepted { background: #f3fbf3; border: 1px solid #b7e3b7; border-radius: 12px;\n        margin: .4rem 0; padding: .9rem 1rem 1.1rem; }\n\n    .ft-solution-tag { display: inline-flex; align-items: center; gap: .3rem; color: #fff;\n        background: #009900; font-size: .74rem; font-weight: 700; padding: .2rem .6rem;\n        border-radius: 999px; margin-bottom: .6rem; letter-spacing: .02em; }\n\n    .ft-post-row { display: flex; gap: .9rem; align-items: flex-start; }\n    .ft-avatar { width: 45px; height: 45px; border-radius: 50%; flex: 0 0 45px;\n        display: grid; place-items: center; font-size: 1.35rem;\n        background: linear-gradient(135deg, #ede7fb, #e2d9fa); box-shadow: inset 0 0 0 1px rgba(109,40,217,.12); }\n    .ft-post-main { flex: 1; min-width: 0; }\n    .ft-post-head { display: flex; align-items: baseline; flex-wrap: wrap; gap: .5rem; margin-bottom: .35rem; }\n    .ft-handle { font-weight: 700; color: #1a1a1a; font-size: .98rem; }\n    .ft-op-badge { font-size: .66rem; font-weight: 700; color: #6d28d9; background: #ede7fb;\n        border-radius: 4px; padding: .08rem .35rem; text-transform: uppercase; letter-spacing: .04em; }\n    .ft-when { color: #9aa0a6; font-size: .8rem; }\n    .ft-body { color: #2b2f33; line-height: 1.62; font-size: .96rem; white-space: pre-wrap; word-wrap: break-word; }\n\n    .ft-actions { display: flex; align-items: center; gap: .3rem; margin-top: .8rem; flex-wrap: wrap; }\n    .ft-act { display: inline-flex; align-items: center; gap: .28rem; background: transparent; border: none;\n        color: #8a9097; font-size: .84rem; font-weight: 600; padding: .3rem .55rem; border-radius: 7px;\n        cursor: pointer; text-decoration: none; }\n    .ft-act:hover { background: #f1f3f5; color: #5c6166; }\n    .ft-heart { font-size: 1rem; line-height: 1; }\n    .ft-act.ft-liked { color: #fa6c8d; }\n    .ft-act.ft-liked:hover { background: #fff0f3; }\n    .ft-count { font-variant-numeric: tabular-nums; }\n    .ft-act-accept { color: #009900; }\n    .ft-act-accept:hover { background: #eafaea; color: #007a00; }\n    .ft-act-accepted { color: #009900; }\n\n    .ft-closed-note { margin-top: 1.5rem; background: #fbf3f3; border: 1px solid #f0d6d6; color: #9a4040;\n        border-radius: 12px; padding: 1rem 1.2rem; font-weight: 600; text-align: center; }\n\n    .ft-composer { margin-top: 1.75rem; padding: 1.2rem 1.3rem 1.4rem; }\n    .ft-composer-title { margin: 0 0 .7rem; font-size: 1.1rem; }\n    .ft-composer-actions { margin-top: .7rem; }\n    .ft-signin-note { color: #6b7177; margin: 0; }\n    .ft-signin-note a { color: #0088CC; }\n\n    .ft-empty { padding: 2.5rem 2rem; text-align: center; }\n    .ft-empty h2 { margin: 0 0 .5rem; }\n    .ft-empty p { color: #6b7177; margin: 0 0 1rem; }\n    .ft-back { color: #0088CC; text-decoration: none; font-weight: 600; }\n\n    @media (max-width: 640px) {\n        .ft-title { font-size: 1.35rem; }\n        .ft-avatar { width: 38px; height: 38px; flex-basis: 38px; font-size: 1.1rem; }\n        .ft-post-row { gap: .65rem; }\n    }\n");
      b.raw("</style>");
      b.raw("\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); Html.unquote(debug_show((topicTitle # " — Bzzz Forum"))) };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); { title = Html.unquote(debug_show((topicTitle # " — Bzzz Forum"))); description = topicDescription; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      id := mvNat(mvParamGet(ctx, "id"));
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "body")) { case (?mvV) { body := mvV }; case null {} };
      switch mvH {
        case "toggleLike" { toggleLike(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "acceptPost" { acceptPost(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "unaccept" { unaccept(ctx) };
        case "clearSolution" { clearSolution(ctx) };
        case "togglePin" { togglePin(ctx) };
        case "toggleClose" { toggleClose(ctx) };
        case "submitReply" { submitReply(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Greet.mview
  // ===== Page: Greet (/greet/{name}) =====
  let GreetPage = object {
    var name : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      name := mvParamGet(ctx, "name");
      b.raw("<section");
      b.raw(" class=\"bz-hero\"");
      b.raw(">");
      b.raw("<h1");
      b.raw(">");
      b.raw("Hello, ");
      b.text(name);
      b.raw(" 👋");
      b.raw("</h1>");
      b.raw("\n");
      b.raw("<p");
      b.raw(">");
      b.raw("This parameterized public page is certified with a wildcard (/greet/&lt;*&gt;) and served as a fast certified query — any name under /greet is covered by one cert entry.");
      b.raw("</p>");
      b.raw("</section>");
      b.raw("\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; name := mvParamGet(ctx, "name"); "Hello" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; name := mvParamGet(ctx, "name"); { title = "Hello"; description = "A public, parameterized page served as a certified query via a wildcard."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; name := mvParamGet(ctx, "name");  };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      name := mvParamGet(ctx, "name");
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch mvH {
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Home.mview
  // ===== Page: Home (/) =====
  let HomePage = object {
    var bound : Bool = false;
    var me : Text = "";
    var avatar : Text = "";
    var memberCount : Nat = 0;
    var handle : Text = "";
    var display : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        bound := Identity.isBound(ctx.caller);
        me := Identity.handleOf(ctx.caller);
        avatar := Identity.avatarOf(ctx.caller);
        memberCount := Identity.count();
    };
    func claim(ctx : Context) : () {
         mvErrors.clear(); if (handle == "") { mvErrors.add(("handle", "Choose a handle.")) }; if (handle.size() < 2) { mvErrors.add(("handle", "Handle must be at least 2 characters.")) }; if (mvErrors.size() > 0) { return }; 
        if (Identity.bind(ctx.caller, handle, display)) {
            bound := true;
            me := Identity.handleOf(ctx.caller);
            avatar := Identity.avatarOf(ctx.caller);
            memberCount := Identity.count();
            toast("Welcome to Bzzz, " # me # "!");
        } else {
            toast("That handle is taken — try another.");
        };
    };
