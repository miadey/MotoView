        b.raw(">");
        b.raw("Activity");
        b.raw("</th>");
        b.raw("\n                    ");
        b.raw("</tr>");
        b.raw("\n                ");
        b.raw("</thead>");
        b.raw("\n                ");
        b.raw("<tbody");
        b.raw(">");
        b.raw("\n                    ");
        for (t in (topics).vals()) {
          b.raw("\n                        ");
          b.raw("<tr");
          b.raw(" class=\"fr-row\"");
          b.raw(">");
          b.raw("\n                            ");
          b.raw("<td");
          b.raw(" class=\"fr-td-topic\"");
          b.raw(">");
          b.raw("\n                                ");
          b.raw("<a");
          b.raw(" class=\"fr-title\"");
          b.raw(" href=\"");
          b.raw("/forum/t/");
          b.text(Html.unquote(debug_show(t.id)));
          b.raw("\"");
          b.raw(">");
          b.text(glyphs(t.id));
          b.text(Html.unquote(debug_show(t.title)));
          b.raw("</a>");
          b.raw("\n                                ");
          b.raw("<div");
          b.raw(" class=\"fr-meta\"");
          b.raw(">");
          b.raw("\n                                    ");
          b.raw("<a");
          b.raw(" class=\"fr-badge\"");
          b.raw(" href=\"");
          b.raw("/forum/c/");
          b.text(Html.unquote(debug_show(t.categoryId)));
          b.raw("\"");
          b.raw(">");
          b.raw("\n                                        ");
          b.raw("<span");
          b.raw(" class=\"fr-sq fr-sq-sm\"");
          b.raw(" style=\"");
          b.raw("background:");
          b.text(catColor(t.categoryId));
          b.raw("\"");
          b.raw(">");
          b.raw("</span>");
          b.raw("\n                                        ");
          b.raw("<span");
          b.raw(" class=\"fr-badge-name\"");
          b.raw(">");
          b.text(catName(t.categoryId));
          b.raw("</span>");
          b.raw("\n                                    ");
          b.raw("</a>");
          b.raw("\n                                    ");
          for (tag in (t.tags).vals()) {
            b.raw("\n                                        ");
            b.raw("<span");
            b.raw(" class=\"fr-pill\"");
            b.raw(">");
            b.text(Html.unquote(debug_show(tag)));
            b.raw("</span>");
            b.raw("\n                                    ");
          };
          b.raw("\n                                ");
          b.raw("</div>");
          b.raw("\n                            ");
          b.raw("</td>");
