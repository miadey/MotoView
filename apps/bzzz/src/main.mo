      b.raw("<style");
      b.raw(">");
      b.raw("\n    .fr-wrap { max-width: 1100px; margin: 0 auto; color: #1a1a1a; }\n\n    .fr-subnav { display: flex; align-items: center; gap: .25rem; flex-wrap: wrap;\n        border-bottom: 1px solid #e3e5e8; padding: .25rem 0 .5rem; margin-bottom: 1rem; }\n    .fr-tab { text-decoration: none; color: #555; font-weight: 600; font-size: .95rem;\n        padding: .45rem .7rem; border-radius: 8px; }\n    .fr-tab:hover { background: #eef0f2; color: #1a1a1a; }\n    .fr-tab.active { color: #1a1a1a; background: #e7eef5; }\n    .fr-subnav-spacer { flex: 1; }\n    .fr-newbtn { text-decoration: none; background: #0088CC; color: #fff; font-weight: 700;\n        font-size: .9rem; padding: .5rem .9rem; border-radius: 8px; }\n    .fr-newbtn:hover { background: #0077b3; color: #fff; }\n\n    .fr-section { margin: 1.5rem 0; }\n    .fr-section-h { font-size: 1.05rem; margin: 0 0 .6rem; color: #1a1a1a; font-weight: 700; }\n    .fr-empty { background: #fff; border: 1px solid #e3e5e8; border-radius: 10px;\n        padding: 1.5rem; text-align: center; color: #6c757d; }\n    .fr-empty a { color: #0088CC; text-decoration: none; font-weight: 600; }\n\n    .fr-cats { display: grid; grid-template-columns: repeat(2, 1fr); gap: .5rem;\n        background: #fff; border: 1px solid #e3e5e8; border-radius: 10px; padding: .5rem; }\n    .fr-cat { display: flex; gap: .7rem; align-items: flex-start; padding: .7rem .8rem;\n        border-radius: 8px; text-decoration: none; color: inherit; }\n    .fr-cat:hover { background: #f5f6f7; }\n    .fr-cat-body { display: flex; flex-direction: column; gap: .15rem; min-width: 0; }\n    .fr-cat-name { font-weight: 700; color: #1a1a1a; font-size: .98rem; }\n    .fr-cat-desc { font-size: .85rem; color: #6c757d; }\n    .fr-cat-counts { font-size: .78rem; color: #9aa0a6; margin-top: .15rem; }\n\n    .fr-sq { display: inline-block; width: 16px; height: 16px; border-radius: 3px; flex: none; }\n    .fr-sq-sm { width: 11px; height: 11px; border-radius: 2px; vertical-align: middle; }\n\n    .fr-table { width: 100%; border-collapse: collapse; background: #fff;\n        border: 1px solid #e3e5e8; border-radius: 10px; overflow: hidden; }\n    .fr-table thead th { text-align: left; font-size: .78rem; text-transform: uppercase;\n        letter-spacing: .03em; color: #9aa0a6; font-weight: 700; padding: .6rem .8rem;\n        border-bottom: 1px solid #e3e5e8; background: #f8f9fa; }\n    .fr-th-num { text-align: right; width: 80px; }\n    .fr-th-act { text-align: right; width: 120px; }\n    .fr-row td { padding: .8rem; border-bottom: 1px solid #f0f1f2; vertical-align: top; }\n    .fr-row:last-child td { border-bottom: none; }\n    .fr-row:hover { background: #fafbfc; }\n\n    .fr-title { font-weight: 700; color: #1a1a1a; text-decoration: none; font-size: 1rem;\n        line-height: 1.35; }\n    .fr-title:hover { color: #0088CC; }\n    .fr-meta { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; margin-top: .4rem; }\n    .fr-badge { display: inline-flex; align-items: center; gap: .35rem; text-decoration: none;\n        background: #f1f3f4; border-radius: 6px; padding: .15rem .45rem; font-size: .8rem;\n        color: #444; font-weight: 600; }\n    .fr-badge:hover { background: #e7eef5; }\n    .fr-pill { display: inline-block; background: #f1f3f4; color: #6c757d; border-radius: 999px;\n        padding: .1rem .55rem; font-size: .76rem; font-weight: 600; }\n\n    .fr-td-num { text-align: right; color: #6c757d; font-weight: 600; font-size: .92rem;\n        white-space: nowrap; }\n    .fr-td-act { text-align: right; color: #9aa0a6; font-size: .85rem; white-space: nowrap; }\n\n    @media (max-width: 720px) {\n        .fr-cats { grid-template-columns: 1fr; }\n        .fr-th-num, .fr-td-num { width: 56px; }\n        .fr-th-act, .fr-td-act { display: none; }\n        .fr-row td:nth-child(3) { display: none; }\n        .fr-table thead th:nth-child(3) { display: none; }\n    }\n");
      b.raw("</style>");
      b.raw("\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Forum — Bzzz community discussions" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Forum — Bzzz community discussions"; description = "Browse categories and the latest topics on the Bzzz forum — a Discourse-style on-chain discussion board running on the Internet Computer."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch mvH {
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/ForumCategory.mview
  // ===== Page: ForumCategory (/forum/c/{id:Nat}) =====
  let ForumCategoryPage = object {
    var id : Nat = 0;
    var found : Bool = false;
    var catName : Text = "Category";
    var catDesc : Text = "";
    var catDescription : Text = "Topics on the Bzzz forum — a Discourse-style on-chain discussion board running on the Internet Computer.";
    var catColor : Text = "#9aa0a6";
    var topicCount : Nat = 0;
    var postCount : Nat = 0;
    var topics : [Forum.Topic] = [];
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        switch (Forum.category(id)) {
            case (?c) {
                found := true;
                catName := c.name;
                catDesc := c.description;
                catDescription := "Topics in the " # c.name # " category on the Bzzz forum — a Discourse-style on-chain discussion board running on the Internet Computer.";
                catColor := c.color;
                topicCount := c.topicCount;
                postCount := c.postCount;
            };
            case null {
                found := false;
                catName := "Category";
            };
        };
        topics := Forum.topics(id);
    };
    func glyphs(tid : Nat) : Text { Forum.statusGlyphs(tid) };
    func replies(tid : Nat) : Nat { Forum.replyCount(tid) };
    func activity(tid : Nat) : Text { Forum.topicActivity(tid) };
    func catColorOf(cid : Nat) : Text { Forum.categoryColor(cid) };
    func catNameOf(cid : Nat) : Text { Forum.categoryName(cid) };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      id := mvNat(mvParamGet(ctx, "id"));
      b.raw("<div");
      b.raw(" class=\"fr-wrap\"");
      b.raw(">");
      b.raw("\n    ");
      b.raw("<nav");
      b.raw(" class=\"fr-subnav\"");
      b.raw(">");
      b.raw("\n        ");
      b.raw("<a");
      b.raw(" class=\"fr-tab\"");
      b.raw(" href=\"/forum\"");
      b.raw(">");
      b.raw("Latest");
      b.raw("</a>");
      b.raw("\n        ");
      b.raw("<a");
      b.raw(" class=\"fr-tab\"");
      b.raw(" href=\"/forum?sort=new\"");
      b.raw(">");
      b.raw("New");
      b.raw("</a>");
      b.raw("\n        ");
      b.raw("<a");
      b.raw(" class=\"fr-tab\"");
      b.raw(" href=\"/forum?sort=top\"");
      b.raw(">");
      b.raw("Top");
      b.raw("</a>");
      b.raw("\n        ");
      b.raw("<a");
      b.raw(" class=\"fr-tab\"");
      b.raw(" href=\"/forum#categories\"");
      b.raw(">");
      b.raw("Categories");
      b.raw("</a>");
      b.raw("\n        ");
      b.raw("<span");
      b.raw(" class=\"fr-subnav-spacer\"");
      b.raw(">");
      b.raw("</span>");
      b.raw("\n        ");
      b.raw("<a");
      b.raw(" class=\"fr-newbtn\"");
      b.raw(" href=\"/forum/new\"");
      b.raw(">");
      b.raw("+ New Topic");
      b.raw("</a>");
      b.raw("\n    ");
      b.raw("</nav>");
      b.raw("\n\n    ");
      if (found) {
        b.raw("\n        ");
        b.raw("<header");
        b.raw(" class=\"fr-cat-head\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(" class=\"fr-sq fr-sq-lg\"");
        b.raw(" style=\"");
        b.raw("background:");
        b.text(catColor);
        b.raw("\"");
        b.raw(">");
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"fr-cat-head-body\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<h1");
        b.raw(" class=\"fr-cat-head-name\"");
        b.raw(">");
        b.text(catName);
        b.raw("</h1>");
        b.raw("\n                ");
        b.raw("<p");
        b.raw(" class=\"fr-cat-head-desc\"");
        b.raw(">");
        b.text(catDesc);
        b.raw("</p>");
        b.raw("\n                ");
        b.raw("<p");
        b.raw(" class=\"fr-cat-head-counts\"");
        b.raw(">");
        b.text(Nat.toText(topicCount));
        b.raw(" topics · ");
        b.text(Nat.toText(postCount));
        b.raw(" posts");
        b.raw("</p>");
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n            ");
        b.raw("<a");
        b.raw(" class=\"fr-newbtn\"");
        b.raw(" href=\"/forum/new\"");
        b.raw(">");
        b.raw("+ New Topic");
        b.raw("</a>");
        b.raw("\n        ");
        b.raw("</header>");
        b.raw("\n\n        ");
        b.raw("<section");
        b.raw(" class=\"fr-section\"");
        b.raw(">");
        b.raw("\n            ");
        if ((topics.size() == 0)) {
          b.raw("\n                ");
          b.raw("<div");
          b.raw(" class=\"fr-empty\"");
          b.raw(">");
          b.raw("No topics in this category yet. ");
          b.raw("<a");
          b.raw(" href=\"/forum/new\"");
          b.raw(">");
          b.raw("Start the first one →");
          b.raw("</a>");
          b.raw("</div>");
          b.raw("\n            ");
        } else {
          b.raw("\n                ");
          b.raw("<table");
          b.raw(" class=\"fr-table\"");
          b.raw(">");
          b.raw("\n                    ");
          b.raw("<thead");
          b.raw(">");
          b.raw("\n                        ");
          b.raw("<tr");
          b.raw(">");
          b.raw("\n                            ");
          b.raw("<th");
          b.raw(" class=\"fr-th-topic\"");
          b.raw(">");
          b.raw("Topic");
          b.raw("</th>");
          b.raw("\n                            ");
          b.raw("<th");
          b.raw(" class=\"fr-th-num\"");
          b.raw(">");
          b.raw("Replies");
          b.raw("</th>");
          b.raw("\n                            ");
          b.raw("<th");
          b.raw(" class=\"fr-th-num\"");
          b.raw(">");
          b.raw("Views");
          b.raw("</th>");
          b.raw("\n                            ");
          b.raw("<th");
          b.raw(" class=\"fr-th-act\"");
          b.raw(">");
          b.raw("Activity");
          b.raw("</th>");
          b.raw("\n                        ");
          b.raw("</tr>");
          b.raw("\n                    ");
          b.raw("</thead>");
          b.raw("\n                    ");
          b.raw("<tbody");
          b.raw(">");
          b.raw("\n                        ");
          for (t in (topics).vals()) {
            b.raw("\n                            ");
            b.raw("<tr");
            b.raw(" class=\"fr-row\"");
            b.raw(">");
            b.raw("\n                                ");
            b.raw("<td");
            b.raw(" class=\"fr-td-topic\"");
            b.raw(">");
            b.raw("\n                                    ");
            b.raw("<a");
            b.raw(" class=\"fr-title\"");
            b.raw(" href=\"");
            b.raw("/forum/t/");
            b.text(Html.unquote(debug_show(t.id)));
            b.raw("\"");
            b.raw(">");
            b.text(glyphs(t.id));
            b.text(Html.unquote(debug_show(t.title)));
            b.raw("</a>");
            b.raw("\n                                    ");
            b.raw("<div");
            b.raw(" class=\"fr-meta\"");
            b.raw(">");
            b.raw("\n                                        ");
            b.raw("<a");
            b.raw(" class=\"fr-badge\"");
            b.raw(" href=\"");
            b.raw("/forum/c/");
            b.text(Html.unquote(debug_show(t.categoryId)));
            b.raw("\"");
            b.raw(">");
            b.raw("\n                                            ");
            b.raw("<span");
            b.raw(" class=\"fr-sq fr-sq-sm\"");
            b.raw(" style=\"");
            b.raw("background:");
            b.text(catColorOf(t.categoryId));
            b.raw("\"");
            b.raw(">");
            b.raw("</span>");
            b.raw("\n                                            ");
            b.raw("<span");
            b.raw(" class=\"fr-badge-name\"");
            b.raw(">");
            b.text(catNameOf(t.categoryId));
            b.raw("</span>");
            b.raw("\n                                        ");
            b.raw("</a>");
            b.raw("\n                                        ");
            for (tag in (t.tags).vals()) {
              b.raw("\n                                            ");
              b.raw("<span");
              b.raw(" class=\"fr-pill\"");
              b.raw(">");
              b.text(Html.unquote(debug_show(tag)));
              b.raw("</span>");
              b.raw("\n                                        ");
            };
            b.raw("\n                                    ");
            b.raw("</div>");
            b.raw("\n                                ");
            b.raw("</td>");
            b.raw("\n                                ");
            b.raw("<td");
            b.raw(" class=\"fr-td-num\"");
            b.raw(">");
            b.text(Nat.toText(replies(t.id)));
            b.raw("</td>");
            b.raw("\n                                ");
            b.raw("<td");
            b.raw(" class=\"fr-td-num\"");
            b.raw(">");
            b.text(Html.unquote(debug_show(t.views)));
            b.raw("</td>");
            b.raw("\n                                ");
            b.raw("<td");
            b.raw(" class=\"fr-td-act\"");
            b.raw(">");
            b.text(activity(t.id));
            b.raw("</td>");
            b.raw("\n                            ");
            b.raw("</tr>");
            b.raw("\n                        ");
          };
          b.raw("\n                    ");
          b.raw("</tbody>");
          b.raw("\n                ");
          b.raw("</table>");
          b.raw("\n            ");
        };
        b.raw("\n        ");
        b.raw("</section>");
        b.raw("\n    ");
      } else {
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"fr-empty\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<p");
        b.raw(">");
        b.raw("That category doesn't exist.");
        b.raw("</p>");
        b.raw("\n            ");
        b.raw("<a");
        b.raw(" href=\"/forum\"");
        b.raw(">");
        b.raw("← Back to the forum");
        b.raw("</a>");
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n    ");
      };
      b.raw("\n");
      b.raw("</div>");
      b.raw("\n\n");
      b.raw("<style");
      b.raw(">");
      b.raw("\n    .fr-wrap { max-width: 1100px; margin: 0 auto; color: #1a1a1a; }\n\n    .fr-subnav { display: flex; align-items: center; gap: .25rem; flex-wrap: wrap;\n        border-bottom: 1px solid #e3e5e8; padding: .25rem 0 .5rem; margin-bottom: 1rem; }\n    .fr-tab { text-decoration: none; color: #555; font-weight: 600; font-size: .95rem;\n        padding: .45rem .7rem; border-radius: 8px; }\n    .fr-tab:hover { background: #eef0f2; color: #1a1a1a; }\n    .fr-tab.active { color: #1a1a1a; background: #e7eef5; }\n    .fr-subnav-spacer { flex: 1; }\n    .fr-newbtn { text-decoration: none; background: #0088CC; color: #fff; font-weight: 700;\n        font-size: .9rem; padding: .5rem .9rem; border-radius: 8px; white-space: nowrap; }\n    .fr-newbtn:hover { background: #0077b3; color: #fff; }\n\n    .fr-cat-head { display: flex; align-items: flex-start; gap: 1rem; background: #fff;\n        border: 1px solid #e3e5e8; border-radius: 10px; padding: 1.1rem 1.2rem; margin-bottom: 1rem; }\n    .fr-cat-head-body { flex: 1; min-width: 0; }\n    .fr-cat-head-name { margin: 0; font-size: 1.4rem; color: #1a1a1a; font-weight: 800; }\n    .fr-cat-head-desc { margin: .25rem 0 0; color: #6c757d; font-size: .95rem; }\n    .fr-cat-head-counts { margin: .4rem 0 0; color: #9aa0a6; font-size: .82rem; }\n\n    .fr-sq { display: inline-block; width: 16px; height: 16px; border-radius: 3px; flex: none; }\n    .fr-sq-sm { width: 11px; height: 11px; border-radius: 2px; vertical-align: middle; }\n    .fr-sq-lg { width: 32px; height: 32px; border-radius: 5px; margin-top: .2rem; }\n\n    .fr-section { margin: 1.5rem 0; }\n    .fr-empty { background: #fff; border: 1px solid #e3e5e8; border-radius: 10px;\n        padding: 1.5rem; text-align: center; color: #6c757d; }\n    .fr-empty a { color: #0088CC; text-decoration: none; font-weight: 600; }\n\n    .fr-table { width: 100%; border-collapse: collapse; background: #fff;\n        border: 1px solid #e3e5e8; border-radius: 10px; overflow: hidden; }\n    .fr-table thead th { text-align: left; font-size: .78rem; text-transform: uppercase;\n        letter-spacing: .03em; color: #9aa0a6; font-weight: 700; padding: .6rem .8rem;\n        border-bottom: 1px solid #e3e5e8; background: #f8f9fa; }\n    .fr-th-num { text-align: right; width: 80px; }\n    .fr-th-act { text-align: right; width: 120px; }\n    .fr-row td { padding: .8rem; border-bottom: 1px solid #f0f1f2; vertical-align: top; }\n    .fr-row:last-child td { border-bottom: none; }\n    .fr-row:hover { background: #fafbfc; }\n\n    .fr-title { font-weight: 700; color: #1a1a1a; text-decoration: none; font-size: 1rem;\n        line-height: 1.35; }\n    .fr-title:hover { color: #0088CC; }\n    .fr-meta { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; margin-top: .4rem; }\n    .fr-badge { display: inline-flex; align-items: center; gap: .35rem; text-decoration: none;\n        background: #f1f3f4; border-radius: 6px; padding: .15rem .45rem; font-size: .8rem;\n        color: #444; font-weight: 600; }\n    .fr-badge:hover { background: #e7eef5; }\n    .fr-pill { display: inline-block; background: #f1f3f4; color: #6c757d; border-radius: 999px;\n        padding: .1rem .55rem; font-size: .76rem; font-weight: 600; }\n\n    .fr-td-num { text-align: right; color: #6c757d; font-weight: 600; font-size: .92rem;\n        white-space: nowrap; }\n    .fr-td-act { text-align: right; color: #9aa0a6; font-size: .85rem; white-space: nowrap; }\n\n    @media (max-width: 720px) {\n        .fr-th-act, .fr-td-act { display: none; }\n        .fr-row td:nth-child(3) { display: none; }\n        .fr-table thead th:nth-child(3) { display: none; }\n        .fr-cat-head { flex-wrap: wrap; }\n    }\n");
      b.raw("</style>");
      b.raw("\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); "@catName — Bzzz forum category" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); { title = "@catName — Bzzz forum category"; description = "@catDescription"; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      id := mvNat(mvParamGet(ctx, "id"));
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch mvH {
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/ForumNew.mview
  // ===== Page: ForumNew (/forum/new) =====
  let ForumNewPage = object {
    var signedIn : Bool = false;
    var cats : [Forum.Category] = [];
    var title : Text = "";
    var tags : Text = "";
    var body : Text = "";
    var categoryId : Nat = 0;
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        signedIn := Identity.isBound(ctx.caller);
        cats := Forum.categories();
        if (categoryId == 0 and cats.size() > 0) {
            categoryId := cats[0].id;
        };
    };
    func isSelected(cid : Nat) : Bool { cid == categoryId };
    func catSelClass(cid : Nat) : Text { if (cid == categoryId) "is-sel" else "" };
    func selectedCatHint() : Text {
        if (categoryId == 0) { return "Choose where this topic belongs." };
        "Posting in " # Forum.categoryName(categoryId) # ".";
    };
    func parseTags(raw : Text) : [Text] {
        let parts = Iter.toArray(Text.split(raw, #char ','));
        let buf = Buffer.Buffer<Text>(parts.size());
        for (p in parts.vals()) {
            let t = Text.trim(p, #char ' ');
            if (t != "") { buf.add(t) };
        };
        Buffer.toArray(buf);
    };
    func chosenCategory(ctx : Context) : Nat {
        for ((k, v) in ctx.form.vals()) {
            if (k == "categoryId") {
                switch (textToNat(v)) { case (?n) { if (n != 0) { return n } }; case null {} };
            };
        };
        if (categoryId != 0) { categoryId } else if (cats.size() > 0) { cats[0].id } else { 1 };
    };
    func textToNat(t : Text) : ?Nat {
        var acc : Nat = 0;
        var any = false;
        for (c in t.chars()) {
            if (c >= '0' and c <= '9') {
                acc := acc * 10 + (Nat32.toNat(Char.toNat32(c) - 48));
                any := true;
            } else { return null };
        };
        if (any) { ?acc } else { null };
    };
    func create(ctx : Context) : () {
         mvErrors.clear(); if (title == "") { mvErrors.add(("title", "Give your topic a title.")) }; if (title.size() < 3) { mvErrors.add(("title", "Title must be at least 3 characters.")) }; if (body == "") { mvErrors.add(("body", "Write something in the body.")) }; if (mvErrors.size() > 0) { return }; 
        let cid = chosenCategory(ctx);
        categoryId := cid;
        let handle = Identity.handleOf(ctx.caller);
        let parsed = parseTags(tags);
        let newId = Forum.createTopic(ctx.caller, handle, cid, title, parsed, body);
        title := "";
        tags := "";
        body := "";
        toast("Topic created!");
        // Land on the freshly created topic (Discourse behavior). mvRedirect is
        // the page object's navigation sink; the runtime turns a non-empty value
        // into a client redirect after dispatch.
        mvRedirect := "/forum/t/" # Nat.toText(newId);
    };
