  };

  // mv:src src/Pages/Channel.mview
  // ===== Page: Channel (/channel/{rid:Nat}) =====
  let ChannelPage = object {
    var rid : Nat = 0;
    var exists : Bool = false;
    var roomName : Text = "channel";
    var serverId : Nat = 0;
    var messages = Chat.messages(0);
    var emojiSet : [Text] = [];
    var typing : [Text] = [];
    var typingText : Text = "";
    var liveCount : Nat = 0;
    var onlineCount : Nat = 0;
    var bound : Bool = false;
    var canMod : Bool = false;
    var locked : Bool = false;
    var muted : Bool = false;
    var myHandle : Text = "";
    var me : Principal = Principal.fromText("2vxsx-fae");
    var replyingTo : Nat = 0;
    var editingId : Nat = 0;
    var openThreadId : Nat = 0;
    var draft : Text = "";
    var editText : Text = "";
    var threadText : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func paramNat(ctx : Context, k : Text) : Nat {
        for ((kk, vv) in ctx.params.vals()) { if (kk == k) { return mvNat(vv) } };
        0;
    };
    func onLoad(ctx : Context) {
        rid := paramNat(ctx, "rid");
        me := ctx.caller;
        bound := Identity.isBound(ctx.caller);
        myHandle := Identity.handleOf(ctx.caller);

        switch (Chat.room(rid)) {
            case null { exists := false };
            case (?r) {
                exists := true;
                roomName := r.name;
                serverId := r.serverId;
            };
        };

        Chat.ping(ctx.caller, myHandle, rid);

        messages := Chat.messages(rid);
        emojiSet := Chat.emojiSet();
        liveCount := Chat.messageCount(rid);
        onlineCount := Chat.onlineCount();

        typing := Chat.typingIn(rid, myHandle);
        typingText := joinHandles(typing);

        locked := Servers.isLocked(rid);
        canMod := Servers.canModerate(serverId, ctx.caller);
        muted := Servers.isMuted(serverId, ctx.caller);
    };
    func authorLabel(handle : Text, author : Principal) : Text {
        if (handle != "") handle else Identity.handleOf(author);
    };
    func avatarFor(p : Principal) : Text { Identity.avatarOf(p) };
    func timeOf(at : Int) : Text { Chat.relativeTime(at) };
    func isMineP(author : Principal) : Bool { author == me };
    func isDel(deleted : Int) : Bool { deleted != 0 };
    func emo(e : Text) : Text { e };
    func reactionsFor(msgId : Nat) : [(Text, Nat)] { Chat.reactions(msgId) };
    func threadCountOf(msgId : Nat) : Nat { Chat.threadCount(msgId) };
    func replySnippet(msgId : Nat) : Text {
        switch (Chat.message(msgId)) {
            case null { "a message" };
            case (?m) {
                let who = if (m.authorHandle != "") m.authorHandle else Identity.handleOf(m.author);
                if (m.deleted != 0) { who # ": (deleted)" }
                else { who # ": " # snippet(m.text) };
            };
        };
    };
    func snippet(t : Text) : Text {
        let chars = Text.toArray(t);
        if (chars.size() <= 40) { t }
        else { Text.fromIter(Array.subArray(chars, 0, 40).vals()) # "…" };
    };
    func joinHandles(hs : [Text]) : Text {
        if (hs.size() == 0) { return "" };
        if (hs.size() == 1) { return hs[0] };
        if (hs.size() == 2) { return hs[0] # " and " # hs[1] };
        Nat.toText(hs.size()) # " people";
    };
    func plural(n : Nat, one : Text, many : Text) : Text {
        if (n == 1) one else many;
    };
    func send(ctx : Context) : () {
         mvErrors.clear(); if (draft == "") { mvErrors.add(("draft", "Type a message.")) }; if (mvErrors.size() > 0) { return }; 
        let roomId = paramNat(ctx, "rid");
        let newId = Chat.post(ctx.caller, Identity.handleOf(ctx.caller), roomId, draft, replyingTo);
        if (newId == 0) {
            toast("Could not send — channel may be missing.");
            return;
        };
        draft := "";
        replyingTo := 0;
        scrollTo("#ch-stream");
    };
    func react(ctx : Context, msgId : Nat, emoji : Text) : () {
        ignore Chat.react(ctx.caller, msgId, emoji);
    };
    func startReply(id : Nat) : () {
        replyingTo := id;
        focusOn("#draft");
    };
    func cancelReply() : () { replyingTo := 0; };
    func startEdit(ctx : Context, id : Nat) : () {
        switch (Chat.message(id)) {
            case (?m) { if (m.author == ctx.caller) { editingId := id; editText := m.text } };
            case null {};
        };
    };
    func cancelEdit() : () { editingId := 0; editText := ""; };
    func saveEdit(ctx : Context) : () {
         mvErrors.clear(); if (editText == "") { mvErrors.add(("editText", "Message can't be empty.")) }; if (mvErrors.size() > 0) { return }; 
        if (editingId != 0) {
            ignore Chat.edit(ctx.caller, editingId, editText);
        };
        editingId := 0;
        editText := "";
        toast("Message updated.");
    };
    func del(ctx : Context, id : Nat) : () {
        ignore Chat.del(ctx.caller, id);
        toast("Message deleted.");
    };
    func openThread(id : Nat) : () {
        openThreadId := if (openThreadId == id) 0 else id;
    };
    func postThread(ctx : Context) : () {
         mvErrors.clear(); if (threadText == "") { mvErrors.add(("threadText", "Type a thread reply.")) }; if (mvErrors.size() > 0) { return }; 
        if (openThreadId != 0) {
            ignore Chat.replyThread(ctx.caller, Identity.handleOf(ctx.caller), openThreadId, threadText);
        };
        threadText := "";
        toast("Thread reply posted.");
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      rid := mvNat(mvParamGet(ctx, "rid"));
      if (not exists) {
        b.raw("\n    <div class=\"bz-card ch-missing\">\n        <div class=\"ch-missing-ico\">🚫</div>\n        <h2>Channel not found</h2>\n        <p>This channel does not exist. <a href=\"/servers\">Browse servers</a>.</p>\n    </div>\n");
      } else {
        b.raw("\n    <div class=\"ch-wrap bz-card\">\n        <header class=\"ch-head\">\n            <div class=\"ch-head-main\">\n                <h1><span class=\"ch-hash\">#</span>");
        b.text(roomName);
        b.raw("</h1>\n                <span class=\"ch-sub\">");
        b.text(Nat.toText(liveCount));
        b.raw(" ");
        b.text(plural(liveCount, "message", "messages"));
        b.raw(" · ");
        b.text(Nat.toText(onlineCount));
        b.raw(" online</span>\n            </div>\n            ");
        if (locked) {
          b.raw("\n                <span class=\"ch-lockchip\">🔒 Locked — only moderators can post</span>\n            ");
        };
        b.raw("\n            <a class=\"ch-back\" href=\"/servers/");
        b.text(Nat.toText(serverId));
        b.raw("\">↩ server</a>\n        </header>\n\n        <div class=\"ch-stream\" id=\"ch-stream\">\n            ");
        if (messages.size() == 0) {
          b.raw("\n                <div class=\"ch-empty\">\n                    <div class=\"ch-empty-ico\">👋</div>\n                    <p>No messages yet — say hello in <strong>#");
          b.text(roomName);
          b.raw("</strong>.</p>\n                </div>\n            ");
        } else {
          b.raw("\n                ");
          for (m in (messages).vals()) {
            b.raw("\n                    <article class=\"ch-msg\" id=\"msg-");
            b.text(Html.unquote(debug_show(m.id)));
            b.raw("\">\n                        <div class=\"ch-ava\">");
            b.text(avatarFor(m.author));
            b.raw("</div>\n                        <div class=\"ch-msg-body\">\n                            <div class=\"ch-msg-top\">\n                                <span class=\"ch-author\">");
            b.text(authorLabel(m.authorHandle, m.author));
            b.raw("</span>\n                                <span class=\"ch-time\">");
            b.text(timeOf(m.at));
            b.raw("</span>\n                                ");
            if (m.edited != 0) {
              b.raw(" <span class=\"ch-edited\">(edited)</span> ");
            };
            b.raw("\n                            </div>\n\n                            ");
            if (m.replyTo != 0) {
              b.raw("\n                                <div class=\"ch-reply-ctx\">↪ replying to <span class=\"ch-reply-snip\">");
              b.text(replySnippet(m.replyTo));
              b.raw("</span></div>\n                            ");
            };
            b.raw("\n\n                            ");
            if (isDel(m.deleted)) {
              b.raw("\n                                <div class=\"ch-text ch-deleted\">message deleted</div>\n                            ");
            } else if (editingId == m.id) {
              b.raw("\n                                <form novalidate class=\"ch-edit-form\" data-mv-handler=\"saveEdit\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
              b.attr("data-mv-token", ctx.mintToken("saveEdit", "editText"));
              b.raw(" data-mv-schema=\"editText\">\n                                    <div class=\"mv-field\"><label>Edit message *</label><input type=\"text\" class=\"mv-input\" name=\"editText\" data-mv-key=\"editText\" required");
              b.attr("value", editText);
              b.raw(">");
              for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "editText") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
              b.raw("</div>\n                                    <div class=\"ch-edit-actions\">\n                                        <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Save</button>\n                                        <button type=\"button\" class=\"ch-mini-btn\" data-mv-handler=\"cancelEdit\" data-mv-event=\"click\">Cancel</button>\n                                    </div>\n                                </form>\n                            ");
            } else {
              b.raw("\n                                <div class=\"ch-text\">");
              b.text(Html.unquote(debug_show(m.text)));
              b.raw("</div>\n                            ");
            };
            b.raw("\n\n                            ");
            if (not isDel(m.deleted)) {
              b.raw("\n                                <div class=\"ch-reactions\">\n                                    ");
              for (r in (reactionsFor(m.id)).vals()) {
                b.raw("\n                                        <span class=\"ch-react-pill\">");
                b.text(Html.unquote(debug_show(r.0)));
                b.raw(" ");
                b.text(Html.unquote(debug_show(r.1)));
                b.raw("</span>\n                                    ");
              };
              b.raw("\n                                    <span class=\"ch-react-quick\">\n                                        ");
              for (e in (emojiSet).vals()) {
                b.raw("\n                                            <button class=\"ch-react-btn\" data-mv-handler=\"react\" data-mv-event=\"click\"");
                b.attr("data-mv-arg0", Html.unquote(debug_show(m.id)));
                b.attr("data-mv-arg1", emo(e));
                b.raw(">");
                b.text(e);
                b.raw("</button>\n                                        ");
              };
              b.raw("\n                                    </span>\n                                </div>\n\n                                <div class=\"ch-msg-actions\">\n                                    <button class=\"ch-mini-btn\" data-mv-handler=\"startReply\" data-mv-event=\"click\"");
              b.attr("data-mv-arg0", Html.unquote(debug_show(m.id)));
              b.raw(">Reply</button>\n                                    <button type=\"button\" class=\"ch-mini-btn ch-thread-link\" data-mv-handler=\"openThread\" data-mv-event=\"click\"");
              b.attr("data-mv-arg0", Html.unquote(debug_show(m.id)));
              b.raw(">🧵 Thread (");
              b.text(Nat.toText(threadCountOf(m.id)));
              b.raw(")</button>\n                                    ");
              if (isMineP(m.author)) {
                b.raw("\n                                        <button class=\"ch-mini-btn\" data-mv-handler=\"startEdit\" data-mv-event=\"click\"");
                b.attr("data-mv-arg0", Html.unquote(debug_show(m.id)));
                b.raw(">Edit</button>\n                                        <button class=\"ch-mini-btn ch-mini-danger\" data-mv-handler=\"del\" data-mv-event=\"click\"");
                b.attr("data-mv-arg0", Html.unquote(debug_show(m.id)));
                b.raw(">Delete</button>\n                                    ");
              };
              b.raw("\n                                </div>\n\n                                ");
              if (openThreadId == m.id) {
                b.raw("\n                                    <div class=\"ch-thread\">\n                                        ");
                if (threadCountOf(m.id) == 0) {
                  b.raw("\n                                            <p class=\"ch-thread-empty\">No replies in this thread yet.</p>\n                                        ");
                } else {
                  b.raw("\n                                            ");
                  for (t in (Chat.thread(m.id)).vals()) {
                    b.raw("\n                                                <div class=\"ch-thread-msg\">\n                                                    <span class=\"ch-thread-author\">");
                    b.text(Html.unquote(debug_show(t.handle)));
                    b.raw("</span>\n                                                    <span class=\"ch-thread-time\">");
                    b.text(timeOf(t.at));
                    b.raw("</span>\n                                                    <div class=\"ch-thread-text\">");
                    b.text(Html.unquote(debug_show(t.text)));
                    b.raw("</div>\n                                                </div>\n                                            ");
                  };
                  b.raw("\n                                        ");
                };
                b.raw("\n                                        <form novalidate class=\"ch-thread-form\" data-mv-handler=\"postThread\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
                b.attr("data-mv-token", ctx.mintToken("postThread", "threadText"));
                b.raw(" data-mv-schema=\"threadText\">\n                                            <div class=\"mv-field\"><label>Reply in thread *</label><input type=\"text\" class=\"mv-input\" name=\"threadText\" data-mv-key=\"threadText\" required");
                b.attr("value", threadText);
                b.raw(">");
                for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "threadText") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
                b.raw("</div>\n                                            <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Send</button>\n                                        </form>\n                                    </div>\n                                ");
              };
              b.raw("\n                            ");
            };
            b.raw("\n                        </div>\n                    </article>\n                ");
          };
          b.raw("\n            ");
        };
        b.raw("\n        </div>\n\n        <div class=\"ch-typing\">\n            ");
        if (typing.size() > 0) {
          b.raw("\n                <span class=\"ch-typing-dot\"></span><span class=\"ch-typing-dot\"></span><span class=\"ch-typing-dot\"></span>\n                <span class=\"ch-typing-text\">");
          b.text(typingText);
          b.raw(" is typing…</span>\n            ");
        };
        b.raw("\n        </div>\n\n        ");
        if (replyingTo != 0) {
          b.raw("\n            <div class=\"ch-replybar\">\n                ↪ Replying to <span class=\"ch-reply-snip\">");
          b.text(replySnippet(replyingTo));
          b.raw("</span>\n                <button class=\"ch-mini-btn\" data-mv-handler=\"cancelReply\" data-mv-event=\"click\">✕</button>\n            </div>\n        ");
        };
        b.raw("\n\n        ");
        if (locked and not canMod) {
          b.raw("\n            <div class=\"ch-composer-locked\">This channel is locked. Only moderators can post right now.</div>\n        ");
        } else if (muted) {
          b.raw("\n            <div class=\"ch-composer-locked\">You are muted in this server and cannot post.</div>\n        ");
        } else if (not bound) {
          b.raw("\n            <div class=\"ch-composer-locked\"><a href=\"/me\">Claim a handle</a> to join the conversation.</div>\n        ");
        } else {
          b.raw("\n            <form novalidate class=\"ch-composer\" data-mv-handler=\"send\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
          b.attr("data-mv-token", ctx.mintToken("send", "draft"));
          b.raw(" data-mv-schema=\"draft\">\n                ");
          if (mvErrors.size() > 0) {
            b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
            for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
            b.raw("</ul></div>");
          };
          b.raw("\n                <div class=\"ch-composer-row\">\n                    <div class=\"mv-field\"><label>Type a message *</label><input type=\"text\" class=\"mv-input\" name=\"draft\" data-mv-key=\"draft\" required");
          b.attr("value", draft);
          b.raw(">");
          for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "draft") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
          b.raw("</div>\n                    <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Send</button>\n                </div>\n            </form>\n        ");
        };
        b.raw("\n    </div>\n");
      };
      b.raw("\n\n<style>\n    .ch-missing { text-align:center; padding:2.5rem 1.2rem; }\n    .ch-missing-ico { font-size:2.4rem; }\n    .ch-missing a { color:var(--bz-accent); font-weight:600; }\n\n    .ch-wrap { display:flex; flex-direction:column; height:calc(100vh - var(--bz-nav-h) - 6rem); min-height:520px; overflow:hidden; }\n\n    .ch-head { display:flex; align-items:center; gap:.75rem; padding:.9rem 1.1rem; border-bottom:1px solid var(--mv-border); flex:none; }\n    .ch-head-main { display:flex; flex-direction:column; }\n    .ch-head h1 { margin:0; font-size:1.2rem; letter-spacing:-.01em; }\n    .ch-hash { color:var(--mv-text-soft); }\n    .ch-sub { font-size:.8rem; color:var(--mv-text-soft); }\n    .ch-lockchip { font-size:.75rem; font-weight:600; color:#92400e; background:#fef3c7; padding:.2rem .5rem; border-radius:999px; }\n    .ch-back { margin-left:auto; font-size:.82rem; font-weight:600; color:var(--bz-accent); text-decoration:none; }\n\n    .ch-stream { flex:1; overflow-y:auto; padding:1rem 1.1rem; display:flex; flex-direction:column; gap:.65rem; }\n    .ch-empty { text-align:center; color:var(--mv-text-soft); margin:auto; }\n    .ch-empty-ico { font-size:2rem; }\n\n    .ch-msg { display:flex; gap:.65rem; padding:.35rem .4rem; border-radius:10px; }\n    .ch-msg:hover { background:var(--mv-muted); }\n    .ch-ava { width:38px; height:38px; border-radius:50%; background:var(--mv-muted); display:grid; place-items:center; font-size:1.25rem; flex:none; }\n    .ch-msg-body { min-width:0; flex:1; }\n    .ch-msg-top { display:flex; align-items:baseline; gap:.5rem; }\n    .ch-author { font-weight:800; font-size:.92rem; }\n    .ch-time { font-size:.74rem; color:var(--mv-text-soft); }\n    .ch-edited { font-size:.72rem; color:var(--mv-text-soft); font-style:italic; }\n\n    .ch-reply-ctx { font-size:.78rem; color:var(--mv-text-soft); margin:.1rem 0 .15rem; }\n    .ch-reply-snip { font-style:italic; }\n\n    .ch-text { font-size:.95rem; line-height:1.45; word-wrap:break-word; overflow-wrap:anywhere; }\n    .ch-deleted { color:var(--mv-text-soft); font-style:italic; }\n\n    .ch-reactions { display:flex; flex-wrap:wrap; align-items:center; gap:.3rem; margin-top:.35rem; }\n    .ch-react-pill { font-size:.82rem; background:var(--mv-muted); border:1px solid var(--mv-border); border-radius:999px; padding:.1rem .45rem; }\n    .ch-react-quick { display:inline-flex; gap:.1rem; opacity:0; transition:opacity .12s ease; }\n    .ch-msg:hover .ch-react-quick { opacity:1; }\n    .ch-react-btn { font-size:.9rem; background:transparent; border:1px solid transparent; border-radius:7px; padding:.05rem .25rem; cursor:pointer; }\n    .ch-react-btn:hover { background:var(--mv-surface); border-color:var(--mv-border); }\n\n    .ch-msg-actions { display:flex; gap:.35rem; margin-top:.3rem; opacity:0; transition:opacity .12s ease; }\n    .ch-msg:hover .ch-msg-actions { opacity:1; }\n    .ch-mini-btn { font-size:.74rem; font-weight:600; padding:.18rem .45rem; border-radius:7px; cursor:pointer;\n        border:1px solid var(--mv-border); background:var(--mv-surface); color:var(--mv-text); text-decoration:none; }\n    .ch-mini-btn:hover { background:var(--bz-accent); color:#fff; border-color:var(--bz-accent); }\n    .ch-mini-danger:hover { background:#dc2626; border-color:#dc2626; }\n    .ch-thread-link { color:var(--mv-text-soft); }\n\n    .ch-edit-form { margin:.3rem 0; }\n    .ch-edit-actions { display:flex; gap:.4rem; align-items:center; margin-top:.3rem; }\n\n    .ch-thread { margin-top:.5rem; padding:.6rem .7rem; border-left:3px solid var(--bz-accent); background:var(--mv-muted); border-radius:0 10px 10px 0; }\n    .ch-thread-empty { margin:0 0 .5rem; font-size:.82rem; color:var(--mv-text-soft); }\n    .ch-thread-msg { margin-bottom:.5rem; }\n    .ch-thread-author { font-weight:700; font-size:.84rem; }\n    .ch-thread-time { font-size:.72rem; color:var(--mv-text-soft); margin-left:.4rem; }\n    .ch-thread-text { font-size:.88rem; line-height:1.4; }\n    .ch-thread-form { display:flex; gap:.5rem; align-items:end; margin-top:.4rem; }\n\n    .ch-typing { height:1.2rem; padding:0 1.1rem; display:flex; align-items:center; gap:.2rem; flex:none; }\n    .ch-typing-dot { width:5px; height:5px; border-radius:50%; background:var(--mv-text-soft); animation:chBlink 1.2s infinite ease-in-out; }\n    .ch-typing-dot:nth-child(2) { animation-delay:.2s; }\n    .ch-typing-dot:nth-child(3) { animation-delay:.4s; }\n    .ch-typing-text { font-size:.78rem; color:var(--mv-text-soft); margin-left:.3rem; }\n    @keyframes chBlink { 0%, 80%, 100% { opacity:.3; } 40% { opacity:1; } }\n\n    .ch-replybar { display:flex; align-items:center; gap:.5rem; padding:.5rem 1.1rem; font-size:.82rem;\n        color:var(--mv-text-soft); background:var(--mv-muted); border-top:1px solid var(--mv-border); flex:none; }\n\n    .ch-composer { padding:.8rem 1.1rem; border-top:1px solid var(--mv-border); flex:none; }\n    .ch-composer-row { display:flex; gap:.6rem; align-items:end; }\n    .ch-composer-locked { padding:.9rem 1.1rem; border-top:1px solid var(--mv-border); color:var(--mv-text-soft); font-size:.9rem; flex:none; }\n    .ch-composer-locked a { color:var(--bz-accent); font-weight:600; }\n</style>\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; rid := mvNat(mvParamGet(ctx, "rid")); "#" # roomName # " — Bzzz channel" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; rid := mvNat(mvParamGet(ctx, "rid")); { title = "#" # roomName # " — Bzzz channel"; description = "Live chat in #" # roomName # " on Bzzz — post messages, react, reply and thread in a Discord-style channel running on the Internet Computer."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; rid := mvNat(mvParamGet(ctx, "rid")); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      rid := mvNat(mvParamGet(ctx, "rid"));
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "draft")) { case (?mvV) { draft := mvV }; case null {} };
      switch (mvFormGet(ctx, "editText")) { case (?mvV) { editText := mvV }; case null {} };
      switch (mvFormGet(ctx, "threadText")) { case (?mvV) { threadText := mvV }; case null {} };
      switch mvH {
        case "send" { send(ctx) };
        case "react" { react(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else "")), (if (mvArgs.size() > 1) mvArgs[1] else "")) };
        case "startReply" { startReply(mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "cancelReply" { cancelReply() };
        case "startEdit" { startEdit(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "cancelEdit" { cancelEdit() };
        case "saveEdit" { saveEdit(ctx) };
        case "del" { del(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "openThread" { openThread(mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "postThread" { postThread(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Feed.mview
  // ===== Page: Feed (/feed) =====
  let FeedPage = object {
    var bound : Bool = false;
    var me : Principal = Principal.fromText("2vxsx-fae");
    var meAvatar : Text = "🐝";
    var timeline : [Feed.FeedPost] = [];
    var hasPosts : Bool = false;
    var postCount : Nat = 0;
    var suggestions : [Identity.Profile] = [];
    var hasSuggestions : Bool = false;
    var followingCount : Nat = 0;
    var followerCount : Nat = 0;
    var body : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        me := ctx.caller;
        bound := Identity.isBound(ctx.caller);
        meAvatar := Identity.avatarOf(ctx.caller);

        timeline := Feed.homeTimeline(ctx.caller);
        hasPosts := timeline.size() > 0;
        postCount := Feed.postCount();

        suggestions := whoToFollow(ctx.caller);
        hasSuggestions := suggestions.size() > 0;
        followingCount := Feed.followingCount(ctx.caller);
        followerCount := Feed.followerCount(ctx.caller);
    };
    func whoToFollow(caller : Principal) : [Identity.Profile] {
        let all = Identity.all();
        let keep = Array.filter<Identity.Profile>(all, func(p : Identity.Profile) : Bool {
            p.principal != caller
        });
        if (keep.size() <= 5) { keep } else { Array.subArray(keep, 0, 5) };
    };
    func avatarOf(p : Principal) : Text { Identity.avatarOf(p) };
    func rel(t : Int) : Text { Feed.relativeTime(t) };
    func at(handle : Text) : Text { "@" # handle };
    func remaining() : Nat {
        let n = Text.size(body);
        if (n >= 280) { 0 } else { 280 - n };
    };
    func heart(id : Nat) : Text {
        if (Feed.hasLiked(me, id)) { "❤️" } else { "🤍" };
    };
    func likeClass(id : Nat) : Text {
        if (Feed.hasLiked(me, id)) { "is-on" } else { "" };
    };
    func repostClass(id : Nat) : Text {
        if (Feed.hasReposted(me, id)) { "is-on" } else { "" };
    };
    func followClass(p : Principal) : Text {
        if (Feed.isFollowing(me, p)) { "is-on" } else { "" };
    };
    func followLabel(p : Principal) : Text {
        if (Feed.isFollowing(me, p)) { "Following" } else { "Follow" };
    };
    func post(ctx : Context) : () {
         mvErrors.clear(); if (body == "") { mvErrors.add(("body", "Write something first.")) }; if (mvErrors.size() > 0) { return }; 
        let id = Feed.post(ctx.caller, Identity.handleOf(ctx.caller), body);
        if (id == 0) {
            toast("Couldn't post that — check the length.");
        } else {
            body := "";
            toast("Posted to Bzzz.");
        };
    };
    func like(ctx : Context, id : Nat) : () {
        let _ = Feed.like(ctx.caller, id);
    };
    func repost(ctx : Context, id : Nat) : () {
        let _ = Feed.repost(ctx.caller, id);
    };
    func toggleFollow(ctx : Context, handle : Text) : () {
        switch (Identity.byHandleLookup(handle)) {
            case (?prof) {
                let nowFollowing = Feed.follow(ctx.caller, prof.principal);
                if (nowFollowing) { toast("Following @" # handle); }
                else { toast("Unfollowed @" # handle); };
            };
            case null { toast("Couldn't find that user."); };
        };
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<div class=\"fd-wrap\">\n    <div class=\"fd-main\">\n        <header class=\"fd-head\">\n            <h1>Home</h1>\n            <p class=\"fd-sub\">");
      b.text(Nat.toText(postCount));
      b.raw(" posts on Bzzz · following ");
      b.text(Nat.toText(followingCount));
      b.raw("</p>\n        </header>\n\n        ");
      if (bound) {
        b.raw("\n            <div class=\"fd-composer bz-card\">\n                <div class=\"fd-ava\">");
        b.text(meAvatar);
        b.raw("</div>\n                <form novalidate class=\"fd-composer-form\" data-mv-handler=\"post\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("post", "body"));
        b.raw(" data-mv-schema=\"body\">\n                    ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n                    <div class=\"mv-field\"><label> *</label><textarea class=\"mv-textarea\" name=\"body\" data-mv-key=\"body\" required>");
        b.text(body);
        b.raw("</textarea>");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "body") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n                    <div class=\"fd-composer-foot\">\n                        <span class=\"fd-counter\">");
        b.text(Nat.toText(remaining()));
        b.raw(" left</span>\n                        <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Bzzz it</button>\n                    </div>\n                </form>\n            </div>\n        ");
      } else {
        b.raw("\n            <div class=\"fd-claim bz-card\">\n                <span class=\"fd-claim-ico\">🐝</span>\n                <div>\n                    <strong>Claim a handle to start posting.</strong>\n                    <p>Pick your handle on the <a href=\"/me\">profile</a> page, then come back to share your first Bzzz.</p>\n                </div>\n            </div>\n        ");
      };
      b.raw("\n\n        ");
      if (hasPosts) {
        b.raw("\n            <div class=\"fd-stream\">\n                ");
        for (p in (timeline).vals()) {
          b.raw("\n                    <article class=\"fd-post bz-card\" id=\"post-");
          b.text(Nat.toText(p.id));
          b.raw("\">\n                        <div class=\"fd-ava\">");
          b.text(avatarOf(p.author));
          b.raw("</div>\n                        <div class=\"fd-body\">\n                            <div class=\"fd-post-head\">\n                                <span class=\"fd-handle\">");
          b.text(at(p.authorHandle));
          b.raw("</span>\n                                <span class=\"fd-dot\">·</span>\n                                <span class=\"fd-time\">");
          b.text(rel(p.at));
          b.raw("</span>\n                            </div>\n                            <div class=\"fd-text\">");
          b.text(Html.unquote(debug_show(p.text)));
          b.raw("</div>\n                            <div class=\"fd-actions\">\n                                <a class=\"fd-act\" href=\"/feed\">\n                                    <span class=\"fd-act-ico\">💬</span>\n                                    <span class=\"fd-act-n\">");
          b.text(Nat.toText(p.replyCount));
          b.raw("</span>\n                                </a>\n                                <button class=\"fd-act fd-act-repost ");
          b.text(repostClass(p.id));
          b.raw("\" type=\"button\" title=\"Repost\" data-mv-handler=\"repost\" data-mv-event=\"click\"");
          b.attr("data-mv-arg0", Nat.toText(p.id));
          b.raw(">\n                                    <span class=\"fd-act-ico\">🔁</span>\n                                    <span class=\"fd-act-n\">");
          b.text(Nat.toText(p.reposts));
          b.raw("</span>\n                                </button>\n                                <button class=\"fd-act fd-act-like ");
          b.text(likeClass(p.id));
          b.raw("\" type=\"button\" title=\"Like\" data-mv-handler=\"like\" data-mv-event=\"click\"");
          b.attr("data-mv-arg0", Nat.toText(p.id));
          b.raw(">\n                                    <span class=\"fd-act-ico\">");
          b.text(heart(p.id));
          b.raw("</span>\n                                    <span class=\"fd-act-n\">");
          b.text(Html.unquote(debug_show(p.likes)));
          b.raw("</span>\n                                </button>\n                            </div>\n                        </div>\n                    </article>\n                ");
        };
        b.raw("\n            </div>\n        ");
      } else {
        b.raw("\n            <div class=\"fd-empty bz-card\">\n                <span class=\"fd-empty-ico\">⚡</span>\n                <h3>Your timeline is quiet</h3>\n                <p>Be the first to post, or follow a few people to fill your home feed.</p>\n            </div>\n        ");
      };
      b.raw("\n    </div>\n\n    <aside class=\"fd-rail\">\n        <div class=\"fd-panel bz-card\">\n            <h3 class=\"fd-panel-title\">Who to follow</h3>\n            ");
      if (hasSuggestions) {
        b.raw("\n                <ul class=\"fd-suggest\">\n                    ");
        for (s in (suggestions).vals()) {
          b.raw("\n                        <li class=\"fd-suggest-row\">\n                            <a class=\"fd-suggest-id\" href=\"/u/");
          b.text(s.handle);
          b.raw("\">\n                                <span class=\"fd-ava fd-ava-sm\">");
          b.text(s.avatar);
          b.raw("</span>\n                                <span class=\"fd-suggest-meta\">\n                                    <span class=\"fd-suggest-name\">");
          b.text(Html.unquote(debug_show(s.display)));
          b.raw("</span>\n                                    <span class=\"fd-suggest-handle\">");
          b.text(at(s.handle));
          b.raw("</span>\n                                </span>\n                            </a>\n                            ");
          if (bound) {
            b.raw("\n                                <button class=\"fd-follow ");
            b.text(followClass(s.principal));
            b.raw("\" type=\"button\" data-mv-handler=\"toggleFollow\" data-mv-event=\"click\"");
            b.attr("data-mv-arg0", s.handle);
            b.raw(">");
            b.text(followLabel(s.principal));
            b.raw("</button>\n                            ");
          };
          b.raw("\n                        </li>\n                    ");
        };
        b.raw("\n                </ul>\n            ");
      } else {
        b.raw("\n                <p class=\"fd-panel-empty\">No one else here yet. Invite a friend to Bzzz.</p>\n            ");
      };
      b.raw("\n        </div>\n\n        <div class=\"fd-panel bz-card\">\n            <h3 class=\"fd-panel-title\">Your network</h3>\n            <div class=\"fd-stats\">\n                <div class=\"fd-stat\">\n                    <span class=\"fd-stat-n\">");
      b.text(Nat.toText(followingCount));
      b.raw("</span>\n                    <span class=\"fd-stat-l\">Following</span>\n                </div>\n                <div class=\"fd-stat\">\n                    <span class=\"fd-stat-n\">");
      b.text(Nat.toText(followerCount));
      b.raw("</span>\n                    <span class=\"fd-stat-l\">Followers</span>\n                </div>\n            </div>\n        </div>\n    </aside>\n</div>\n\n<style>\n    .fd-wrap { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 1.25rem; align-items: start; }\n    .fd-main { min-width: 0; display: flex; flex-direction: column; gap: 1rem; }\n\n    .fd-head h1 { margin: 0; font-size: 1.5rem; letter-spacing: -.02em; }\n    .fd-sub { margin: .2rem 0 0; color: var(--mv-text-soft); font-size: .88rem; }\n\n    .fd-composer { display: flex; gap: .75rem; padding: 1rem 1.1rem; }\n    .fd-composer-form { flex: 1; min-width: 0; }\n    .fd-composer-form textarea, .fd-composer-form .mv-input, .fd-composer-form input { width: 100%; box-sizing: border-box; }\n    .fd-composer-foot { display: flex; align-items: center; justify-content: space-between; gap: .75rem; margin-top: .4rem; }\n    .fd-counter { color: var(--mv-text-soft); font-size: .82rem; font-variant-numeric: tabular-nums; }\n\n    .fd-ava { width: 44px; height: 44px; flex: 0 0 44px; border-radius: 50%;\n        background: linear-gradient(135deg, #ede9fe, #f5d0fe); display: grid; place-items: center;\n        font-size: 1.4rem; box-shadow: inset 0 0 0 1px var(--mv-border); }\n    .fd-ava-sm { width: 36px; height: 36px; flex: 0 0 36px; font-size: 1.1rem; }\n\n    .fd-claim { display: flex; align-items: center; gap: .9rem; padding: 1rem 1.2rem; }\n    .fd-claim-ico { font-size: 1.8rem; }\n    .fd-claim strong { display: block; }\n    .fd-claim p { margin: .2rem 0 0; color: var(--mv-text-soft); font-size: .9rem; }\n    .fd-claim a { color: var(--bz-accent); font-weight: 600; text-decoration: none; }\n\n    .fd-stream { display: flex; flex-direction: column; gap: .75rem; }\n    .fd-post { display: flex; gap: .75rem; padding: 1rem 1.1rem; transition: box-shadow .12s ease; }\n    .fd-post:hover { box-shadow: 0 6px 20px rgba(16,16,40,.10); }\n    .fd-body { flex: 1; min-width: 0; }\n    .fd-post-head { display: flex; align-items: baseline; gap: .4rem; font-size: .92rem; }\n    .fd-handle { font-weight: 700; color: var(--mv-text); }\n    .fd-dot { color: var(--mv-text-soft); }\n    .fd-time { color: var(--mv-text-soft); font-size: .85rem; }\n    .fd-text { margin: .25rem 0 .55rem; line-height: 1.45; white-space: pre-wrap; word-wrap: break-word; overflow-wrap: anywhere; }\n\n    .fd-actions { display: flex; gap: 1.4rem; align-items: center; }\n    .fd-act { display: inline-flex; align-items: center; gap: .35rem; background: none; border: 0; cursor: pointer;\n        color: var(--mv-text-soft); font-size: .85rem; padding: .25rem .35rem; border-radius: 999px;\n        text-decoration: none; font: inherit; line-height: 1; transition: color .12s ease, background .12s ease; }\n    .fd-act-ico { font-size: 1rem; }\n    .fd-act-n { font-variant-numeric: tabular-nums; }\n    .fd-act:hover { background: var(--mv-muted); }\n    .fd-act-repost:hover, .fd-act-repost.is-on { color: #16a34a; }\n    .fd-act-like:hover, .fd-act-like.is-on { color: #e11d6b; }\n\n    .fd-empty { text-align: center; padding: 2.5rem 1.5rem; color: var(--mv-text-soft); }\n    .fd-empty-ico { font-size: 2.2rem; display: block; }\n    .fd-empty h3 { margin: .6rem 0 .25rem; color: var(--mv-text); }\n    .fd-empty p { margin: 0; font-size: .9rem; }\n\n    .fd-rail { display: flex; flex-direction: column; gap: 1rem; position: sticky; top: calc(var(--bz-nav-h) + 1.25rem); }\n    .fd-panel { padding: 1rem 1.1rem; }\n    .fd-panel-title { margin: 0 0 .75rem; font-size: 1.05rem; }\n    .fd-panel-empty { margin: 0; color: var(--mv-text-soft); font-size: .88rem; }\n\n    .fd-suggest { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .65rem; }\n    .fd-suggest-row { display: flex; align-items: center; justify-content: space-between; gap: .6rem; }\n    .fd-suggest-id { display: flex; align-items: center; gap: .55rem; text-decoration: none; color: inherit; min-width: 0; }\n    .fd-suggest-meta { display: flex; flex-direction: column; min-width: 0; }\n    .fd-suggest-name { font-weight: 600; font-size: .9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n    .fd-suggest-handle { color: var(--mv-text-soft); font-size: .8rem; }\n    .fd-follow { border: 1px solid var(--bz-accent); background: var(--bz-accent); color: #fff; font-weight: 600;\n        font-size: .8rem; padding: .35rem .8rem; border-radius: 999px; cursor: pointer; white-space: nowrap; }\n    .fd-follow:hover { filter: brightness(1.05); }\n    .fd-follow.is-on { background: transparent; color: var(--bz-accent); }\n\n    .fd-stats { display: flex; gap: 1.5rem; }\n    .fd-stat { display: flex; flex-direction: column; }\n    .fd-stat-n { font-size: 1.35rem; font-weight: 800; letter-spacing: -.02em; font-variant-numeric: tabular-nums; }\n    .fd-stat-l { color: var(--mv-text-soft); font-size: .82rem; }\n\n    @media (max-width: 920px) {\n        .fd-wrap { grid-template-columns: 1fr; }\n        .fd-rail { position: static; order: -1; }\n    }\n</style>\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Feed — Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Feed — Bzzz"; description = "Your Bzzz home timeline. Post short updates, follow people, repost and like — an X-style public feed running entirely on-chain on the Internet Computer."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "body")) { case (?mvV) { body := mvV }; case null {} };
      switch mvH {
        case "post" { post(ctx) };
        case "like" { like(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "repost" { repost(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "toggleFollow" { toggleFollow(ctx, (if (mvArgs.size() > 0) mvArgs[0] else "")) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Forum.mview
  // ===== Page: Forum (/forum) =====
  let ForumPage = object {
    var categories : [Forum.Category] = [];
    var topics : [Forum.Topic] = [];
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        categories := Forum.categories();
        topics := Forum.topicsLatest();
    };
    func glyphs(id : Nat) : Text { Forum.statusGlyphs(id) };
    func replies(id : Nat) : Nat { Forum.replyCount(id) };
    func activity(id : Nat) : Text { Forum.topicActivity(id) };
    func catColor(id : Nat) : Text { Forum.categoryColor(id) };
    func catName(id : Nat) : Text { Forum.categoryName(id) };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<div class=\"fr-wrap\">\n    <nav class=\"fr-subnav\">\n        <a class=\"fr-tab active\" href=\"/forum\">Latest</a>\n        <a class=\"fr-tab\" href=\"/forum?sort=new\">New</a>\n        <a class=\"fr-tab\" href=\"/forum?sort=top\">Top</a>\n        <a class=\"fr-tab\" href=\"#categories\">Categories</a>\n        <span class=\"fr-subnav-spacer\"></span>\n        <a class=\"fr-newbtn\" href=\"/forum/new\">+ New Topic</a>\n    </nav>\n\n    <section id=\"categories\" class=\"fr-section\">\n        <h2 class=\"fr-section-h\">Categories</h2>\n        ");
      if ((categories.size() == 0)) {
        b.raw("\n            <div class=\"fr-empty\">No categories yet.</div>\n        ");
      } else {
        b.raw("\n            <div class=\"fr-cats\">\n                ");
        for (c in (categories).vals()) {
          b.raw("\n                    <a class=\"fr-cat\" href=\"/forum/c/");
          b.text(Nat.toText(c.id));
          b.raw("\">\n                        <span class=\"fr-sq\" style=\"background:");
          b.text(c.color);
          b.raw("\"></span>\n                        <span class=\"fr-cat-body\">\n                            <span class=\"fr-cat-name\">");
          b.text(c.name);
          b.raw("</span>\n                            <span class=\"fr-cat-desc\">");
          b.text(c.description);
          b.raw("</span>\n                            <span class=\"fr-cat-counts\">");
          b.text(Html.unquote(debug_show(c.topicCount)));
          b.raw(" topics · ");
          b.text(Html.unquote(debug_show(c.postCount)));
          b.raw(" posts</span>\n                        </span>\n                    </a>\n                ");
        };
        b.raw("\n            </div>\n        ");
      };
      b.raw("\n    </section>\n\n    <section class=\"fr-section\">\n        <h2 class=\"fr-section-h\">Latest</h2>\n        ");
      if ((topics.size() == 0)) {
        b.raw("\n            <div class=\"fr-empty\">No topics yet. <a href=\"/forum/new\">Start the first one →</a></div>\n        ");
      } else {
        b.raw("\n            <table class=\"fr-table\">\n                <thead>\n                    <tr>\n                        <th class=\"fr-th-topic\">Topic</th>\n                        <th class=\"fr-th-num\">Replies</th>\n                        <th class=\"fr-th-num\">Views</th>\n                        <th class=\"fr-th-act\">Activity</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    ");
        for (t in (topics).vals()) {
          b.raw("\n                        <tr class=\"fr-row\">\n                            <td class=\"fr-td-topic\">\n                                <a class=\"fr-title\" href=\"/forum/t/");
          b.text(Nat.toText(t.id));
          b.raw("\">");
          b.text(glyphs(t.id));
          b.text(t.title);
          b.raw("</a>\n                                <div class=\"fr-meta\">\n                                    <a class=\"fr-badge\" href=\"/forum/c/");
          b.text(Nat.toText(t.categoryId));
          b.raw("\">\n                                        <span class=\"fr-sq fr-sq-sm\" style=\"background:");
          b.text(catColor(t.categoryId));
          b.raw("\"></span>\n                                        <span class=\"fr-badge-name\">");
          b.text(catName(t.categoryId));
          b.raw("</span>\n                                    </a>\n                                    ");
          for (tag in (t.tags).vals()) {
            b.raw("\n                                        <span class=\"fr-pill\">");
            b.text(tag);
            b.raw("</span>\n                                    ");
          };
          b.raw("\n                                </div>\n                            </td>\n                            <td class=\"fr-td-num\">");
          b.text(Nat.toText(replies(t.id)));
          b.raw("</td>\n                            <td class=\"fr-td-num\">");
          b.text(Html.unquote(debug_show(t.views)));
          b.raw("</td>\n                            <td class=\"fr-td-act\">");
          b.text(activity(t.id));
          b.raw("</td>\n                        </tr>\n                    ");
        };
        b.raw("\n                </tbody>\n            </table>\n        ");
      };
      b.raw("\n    </section>\n</div>\n\n<style>\n    .fr-wrap { max-width: 1100px; margin: 0 auto; color: #1a1a1a; }\n\n    .fr-subnav { display: flex; align-items: center; gap: .25rem; flex-wrap: wrap;\n        border-bottom: 1px solid #e3e5e8; padding: .25rem 0 .5rem; margin-bottom: 1rem; }\n    .fr-tab { text-decoration: none; color: #555; font-weight: 600; font-size: .95rem;\n        padding: .45rem .7rem; border-radius: 8px; }\n    .fr-tab:hover { background: #eef0f2; color: #1a1a1a; }\n    .fr-tab.active { color: #1a1a1a; background: #e7eef5; }\n    .fr-subnav-spacer { flex: 1; }\n    .fr-newbtn { text-decoration: none; background: #0088CC; color: #fff; font-weight: 700;\n        font-size: .9rem; padding: .5rem .9rem; border-radius: 8px; }\n    .fr-newbtn:hover { background: #0077b3; color: #fff; }\n\n    .fr-section { margin: 1.5rem 0; }\n    .fr-section-h { font-size: 1.05rem; margin: 0 0 .6rem; color: #1a1a1a; font-weight: 700; }\n    .fr-empty { background: #fff; border: 1px solid #e3e5e8; border-radius: 10px;\n        padding: 1.5rem; text-align: center; color: #6c757d; }\n    .fr-empty a { color: #0088CC; text-decoration: none; font-weight: 600; }\n\n    .fr-cats { display: grid; grid-template-columns: repeat(2, 1fr); gap: .5rem;\n        background: #fff; border: 1px solid #e3e5e8; border-radius: 10px; padding: .5rem; }\n    .fr-cat { display: flex; gap: .7rem; align-items: flex-start; padding: .7rem .8rem;\n        border-radius: 8px; text-decoration: none; color: inherit; }\n    .fr-cat:hover { background: #f5f6f7; }\n    .fr-cat-body { display: flex; flex-direction: column; gap: .15rem; min-width: 0; }\n    .fr-cat-name { font-weight: 700; color: #1a1a1a; font-size: .98rem; }\n    .fr-cat-desc { font-size: .85rem; color: #6c757d; }\n    .fr-cat-counts { font-size: .78rem; color: #9aa0a6; margin-top: .15rem; }\n\n    .fr-sq { display: inline-block; width: 16px; height: 16px; border-radius: 3px; flex: none; }\n    .fr-sq-sm { width: 11px; height: 11px; border-radius: 2px; vertical-align: middle; }\n\n    .fr-table { width: 100%; border-collapse: collapse; background: #fff;\n        border: 1px solid #e3e5e8; border-radius: 10px; overflow: hidden; }\n    .fr-table thead th { text-align: left; font-size: .78rem; text-transform: uppercase;\n        letter-spacing: .03em; color: #9aa0a6; font-weight: 700; padding: .6rem .8rem;\n        border-bottom: 1px solid #e3e5e8; background: #f8f9fa; }\n    .fr-th-num { text-align: right; width: 80px; }\n    .fr-th-act { text-align: right; width: 120px; }\n    .fr-row td { padding: .8rem; border-bottom: 1px solid #f0f1f2; vertical-align: top; }\n    .fr-row:last-child td { border-bottom: none; }\n    .fr-row:hover { background: #fafbfc; }\n\n    .fr-title { font-weight: 700; color: #1a1a1a; text-decoration: none; font-size: 1rem;\n        line-height: 1.35; }\n    .fr-title:hover { color: #0088CC; }\n    .fr-meta { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; margin-top: .4rem; }\n    .fr-badge { display: inline-flex; align-items: center; gap: .35rem; text-decoration: none;\n        background: #f1f3f4; border-radius: 6px; padding: .15rem .45rem; font-size: .8rem;\n        color: #444; font-weight: 600; }\n    .fr-badge:hover { background: #e7eef5; }\n    .fr-pill { display: inline-block; background: #f1f3f4; color: #6c757d; border-radius: 999px;\n        padding: .1rem .55rem; font-size: .76rem; font-weight: 600; }\n\n    .fr-td-num { text-align: right; color: #6c757d; font-weight: 600; font-size: .92rem;\n        white-space: nowrap; }\n    .fr-td-act { text-align: right; color: #9aa0a6; font-size: .85rem; white-space: nowrap; }\n\n    @media (max-width: 720px) {\n        .fr-cats { grid-template-columns: 1fr; }\n        .fr-th-num, .fr-td-num { width: 56px; }\n        .fr-th-act, .fr-td-act { display: none; }\n        .fr-row td:nth-child(3) { display: none; }\n        .fr-table thead th:nth-child(3) { display: none; }\n    }\n</style>\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Forum — Bzzz community discussions" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Forum — Bzzz community discussions"; description = "Browse categories and the latest topics on the Bzzz forum — a Discourse-style on-chain discussion board running on the Internet Computer."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch mvH {
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/ForumCategory.mview
  // ===== Page: ForumCategory (/forum/c/{id:Nat}) =====
  let ForumCategoryPage = object {
    var id : Nat = 0;
    var found : Bool = false;
    var catName : Text = "Category";
    var catDesc : Text = "";
    var catDescription : Text = "Topics on the Bzzz forum — a Discourse-style on-chain discussion board running on the Internet Computer.";
    var catColor : Text = "#9aa0a6";
    var topicCount : Nat = 0;
    var postCount : Nat = 0;
    var topics : [Forum.Topic] = [];
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        switch (Forum.category(id)) {
            case (?c) {
                found := true;
                catName := c.name;
                catDesc := c.description;
                catDescription := "Topics in the " # c.name # " category on the Bzzz forum — a Discourse-style on-chain discussion board running on the Internet Computer.";
                catColor := c.color;
                topicCount := c.topicCount;
                postCount := c.postCount;
            };
            case null {
                found := false;
                catName := "Category";
            };
        };
        topics := Forum.topics(id);
    };
    func glyphs(tid : Nat) : Text { Forum.statusGlyphs(tid) };
    func replies(tid : Nat) : Nat { Forum.replyCount(tid) };
    func activity(tid : Nat) : Text { Forum.topicActivity(tid) };
    func catColorOf(cid : Nat) : Text { Forum.categoryColor(cid) };
    func catNameOf(cid : Nat) : Text { Forum.categoryName(cid) };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      id := mvNat(mvParamGet(ctx, "id"));
      b.raw("<div class=\"fr-wrap\">\n    <nav class=\"fr-subnav\">\n        <a class=\"fr-tab\" href=\"/forum\">Latest</a>\n        <a class=\"fr-tab\" href=\"/forum?sort=new\">New</a>\n        <a class=\"fr-tab\" href=\"/forum?sort=top\">Top</a>\n        <a class=\"fr-tab\" href=\"/forum#categories\">Categories</a>\n        <span class=\"fr-subnav-spacer\"></span>\n        <a class=\"fr-newbtn\" href=\"/forum/new\">+ New Topic</a>\n    </nav>\n\n    ");
      if (found) {
        b.raw("\n        <header class=\"fr-cat-head\">\n            <span class=\"fr-sq fr-sq-lg\" style=\"background:");
        b.text(catColor);
        b.raw("\"></span>\n            <div class=\"fr-cat-head-body\">\n                <h1 class=\"fr-cat-head-name\">");
        b.text(catName);
        b.raw("</h1>\n                <p class=\"fr-cat-head-desc\">");
        b.text(catDesc);
        b.raw("</p>\n                <p class=\"fr-cat-head-counts\">");
        b.text(Nat.toText(topicCount));
        b.raw(" topics · ");
        b.text(Nat.toText(postCount));
        b.raw(" posts</p>\n            </div>\n            <a class=\"fr-newbtn\" href=\"/forum/new\">+ New Topic</a>\n        </header>\n\n        <section class=\"fr-section\">\n            ");
        if ((topics.size() == 0)) {
          b.raw("\n                <div class=\"fr-empty\">No topics in this category yet. <a href=\"/forum/new\">Start the first one →</a></div>\n            ");
        } else {
          b.raw("\n                <table class=\"fr-table\">\n                    <thead>\n                        <tr>\n                            <th class=\"fr-th-topic\">Topic</th>\n                            <th class=\"fr-th-num\">Replies</th>\n                            <th class=\"fr-th-num\">Views</th>\n                            <th class=\"fr-th-act\">Activity</th>\n                        </tr>\n                    </thead>\n                    <tbody>\n                        ");
          for (t in (topics).vals()) {
            b.raw("\n                            <tr class=\"fr-row\">\n                                <td class=\"fr-td-topic\">\n                                    <a class=\"fr-title\" href=\"/forum/t/");
            b.text(Nat.toText(t.id));
            b.raw("\">");
            b.text(glyphs(t.id));
            b.text(t.title);
            b.raw("</a>\n                                    <div class=\"fr-meta\">\n                                        <a class=\"fr-badge\" href=\"/forum/c/");
            b.text(Nat.toText(t.categoryId));
            b.raw("\">\n                                            <span class=\"fr-sq fr-sq-sm\" style=\"background:");
            b.text(catColorOf(t.categoryId));
            b.raw("\"></span>\n                                            <span class=\"fr-badge-name\">");
            b.text(catNameOf(t.categoryId));
            b.raw("</span>\n                                        </a>\n                                        ");
            for (tag in (t.tags).vals()) {
              b.raw("\n                                            <span class=\"fr-pill\">");
              b.text(tag);
              b.raw("</span>\n                                        ");
            };
            b.raw("\n                                    </div>\n                                </td>\n                                <td class=\"fr-td-num\">");
            b.text(Nat.toText(replies(t.id)));
            b.raw("</td>\n                                <td class=\"fr-td-num\">");
            b.text(Html.unquote(debug_show(t.views)));
            b.raw("</td>\n                                <td class=\"fr-td-act\">");
            b.text(activity(t.id));
            b.raw("</td>\n                            </tr>\n                        ");
          };
          b.raw("\n                    </tbody>\n                </table>\n            ");
        };
        b.raw("\n        </section>\n    ");
      } else {
        b.raw("\n        <div class=\"fr-empty\">\n            <p>That category doesn't exist.</p>\n            <a href=\"/forum\">← Back to the forum</a>\n        </div>\n    ");
      };
      b.raw("\n</div>\n\n<style>\n    .fr-wrap { max-width: 1100px; margin: 0 auto; color: #1a1a1a; }\n\n    .fr-subnav { display: flex; align-items: center; gap: .25rem; flex-wrap: wrap;\n        border-bottom: 1px solid #e3e5e8; padding: .25rem 0 .5rem; margin-bottom: 1rem; }\n    .fr-tab { text-decoration: none; color: #555; font-weight: 600; font-size: .95rem;\n        padding: .45rem .7rem; border-radius: 8px; }\n    .fr-tab:hover { background: #eef0f2; color: #1a1a1a; }\n    .fr-tab.active { color: #1a1a1a; background: #e7eef5; }\n    .fr-subnav-spacer { flex: 1; }\n    .fr-newbtn { text-decoration: none; background: #0088CC; color: #fff; font-weight: 700;\n        font-size: .9rem; padding: .5rem .9rem; border-radius: 8px; white-space: nowrap; }\n    .fr-newbtn:hover { background: #0077b3; color: #fff; }\n\n    .fr-cat-head { display: flex; align-items: flex-start; gap: 1rem; background: #fff;\n        border: 1px solid #e3e5e8; border-radius: 10px; padding: 1.1rem 1.2rem; margin-bottom: 1rem; }\n    .fr-cat-head-body { flex: 1; min-width: 0; }\n    .fr-cat-head-name { margin: 0; font-size: 1.4rem; color: #1a1a1a; font-weight: 800; }\n    .fr-cat-head-desc { margin: .25rem 0 0; color: #6c757d; font-size: .95rem; }\n    .fr-cat-head-counts { margin: .4rem 0 0; color: #9aa0a6; font-size: .82rem; }\n\n    .fr-sq { display: inline-block; width: 16px; height: 16px; border-radius: 3px; flex: none; }\n    .fr-sq-sm { width: 11px; height: 11px; border-radius: 2px; vertical-align: middle; }\n    .fr-sq-lg { width: 32px; height: 32px; border-radius: 5px; margin-top: .2rem; }\n\n    .fr-section { margin: 1.5rem 0; }\n    .fr-empty { background: #fff; border: 1px solid #e3e5e8; border-radius: 10px;\n        padding: 1.5rem; text-align: center; color: #6c757d; }\n    .fr-empty a { color: #0088CC; text-decoration: none; font-weight: 600; }\n\n    .fr-table { width: 100%; border-collapse: collapse; background: #fff;\n        border: 1px solid #e3e5e8; border-radius: 10px; overflow: hidden; }\n    .fr-table thead th { text-align: left; font-size: .78rem; text-transform: uppercase;\n        letter-spacing: .03em; color: #9aa0a6; font-weight: 700; padding: .6rem .8rem;\n        border-bottom: 1px solid #e3e5e8; background: #f8f9fa; }\n    .fr-th-num { text-align: right; width: 80px; }\n    .fr-th-act { text-align: right; width: 120px; }\n    .fr-row td { padding: .8rem; border-bottom: 1px solid #f0f1f2; vertical-align: top; }\n    .fr-row:last-child td { border-bottom: none; }\n    .fr-row:hover { background: #fafbfc; }\n\n    .fr-title { font-weight: 700; color: #1a1a1a; text-decoration: none; font-size: 1rem;\n        line-height: 1.35; }\n    .fr-title:hover { color: #0088CC; }\n    .fr-meta { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; margin-top: .4rem; }\n    .fr-badge { display: inline-flex; align-items: center; gap: .35rem; text-decoration: none;\n        background: #f1f3f4; border-radius: 6px; padding: .15rem .45rem; font-size: .8rem;\n        color: #444; font-weight: 600; }\n    .fr-badge:hover { background: #e7eef5; }\n    .fr-pill { display: inline-block; background: #f1f3f4; color: #6c757d; border-radius: 999px;\n        padding: .1rem .55rem; font-size: .76rem; font-weight: 600; }\n\n    .fr-td-num { text-align: right; color: #6c757d; font-weight: 600; font-size: .92rem;\n        white-space: nowrap; }\n    .fr-td-act { text-align: right; color: #9aa0a6; font-size: .85rem; white-space: nowrap; }\n\n    @media (max-width: 720px) {\n        .fr-th-act, .fr-td-act { display: none; }\n        .fr-row td:nth-child(3) { display: none; }\n        .fr-table thead th:nth-child(3) { display: none; }\n        .fr-cat-head { flex-wrap: wrap; }\n    }\n</style>\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); "@catName — Bzzz forum category" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); { title = "@catName — Bzzz forum category"; description = "@catDescription"; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      id := mvNat(mvParamGet(ctx, "id"));
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch mvH {
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/ForumNew.mview
  // ===== Page: ForumNew (/forum/new) =====
  let ForumNewPage = object {
    var signedIn : Bool = false;
    var cats : [Forum.Category] = [];
    var title : Text = "";
    var tags : Text = "";
    var body : Text = "";
    var categoryId : Nat = 0;
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        signedIn := Identity.isBound(ctx.caller);
        cats := Forum.categories();
        if (categoryId == 0 and cats.size() > 0) {
            categoryId := cats[0].id;
        };
    };
    func isSelected(cid : Nat) : Bool { cid == categoryId };
    func catSelClass(cid : Nat) : Text { if (cid == categoryId) "is-sel" else "" };
    func selectedCatHint() : Text {
        if (categoryId == 0) { return "Choose where this topic belongs." };
        "Posting in " # Forum.categoryName(categoryId) # ".";
    };
    func parseTags(raw : Text) : [Text] {
        let parts = Iter.toArray(Text.split(raw, #char ','));
        let buf = Buffer.Buffer<Text>(parts.size());
        for (p in parts.vals()) {
            let t = Text.trim(p, #char ' ');
            if (t != "") { buf.add(t) };
        };
        Buffer.toArray(buf);
    };
    func chosenCategory(ctx : Context) : Nat {
        for ((k, v) in ctx.form.vals()) {
            if (k == "categoryId") {
                switch (textToNat(v)) { case (?n) { if (n != 0) { return n } }; case null {} };
            };
        };
        if (categoryId != 0) { categoryId } else if (cats.size() > 0) { cats[0].id } else { 1 };
    };
    func textToNat(t : Text) : ?Nat {
        var acc : Nat = 0;
        var any = false;
        for (c in t.chars()) {
            if (c >= '0' and c <= '9') {
                acc := acc * 10 + (Nat32.toNat(Char.toNat32(c) - 48));
                any := true;
            } else { return null };
        };
        if (any) { ?acc } else { null };
    };
    func create(ctx : Context) : () {
         mvErrors.clear(); if (title == "") { mvErrors.add(("title", "Give your topic a title.")) }; if (title.size() < 3) { mvErrors.add(("title", "Title must be at least 3 characters.")) }; if (body == "") { mvErrors.add(("body", "Write something in the body.")) }; if (mvErrors.size() > 0) { return }; 
        let cid = chosenCategory(ctx);
        categoryId := cid;
        let handle = Identity.handleOf(ctx.caller);
        let parsed = parseTags(tags);
        let newId = Forum.createTopic(ctx.caller, handle, cid, title, parsed, body);
        title := "";
        tags := "";
        body := "";
        toast("Topic created!");
        // Land on the freshly created topic (Discourse behavior). mvRedirect is
        // the page object's navigation sink; the runtime turns a non-empty value
        // into a client redirect after dispatch.
        mvRedirect := "/forum/t/" # Nat.toText(newId);
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<div class=\"fn-wrap\">\n\n    <header class=\"fn-head\">\n        <a class=\"fn-crumb\" href=\"/forum\">Forum</a>\n        <span class=\"fn-crumb-sep\">›</span>\n        <span class=\"fn-crumb-cur\">New topic</span>\n    </header>\n\n    ");
      if (signedIn) {
        b.raw("\n\n        <div class=\"fn-card bz-card\">\n            <h1 class=\"fn-title\">Create a new topic</h1>\n            <p class=\"fn-lede\">Ask a question, share something you built, or kick off a discussion.</p>\n\n            <form novalidate data-mv-handler=\"create\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("create", "body,categoryId,categoryId,tags,title"));
        b.raw(" data-mv-schema=\"body,categoryId,categoryId,tags,title\">\n                ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n\n                <div class=\"fn-field\">\n                    <label class=\"fn-label\" for=\"fn-title\">Title</label>\n                    <div class=\"mv-field\"><input type=\"text\" class=\"mv-input\" name=\"title\" data-mv-key=\"title\" required");
        b.attr("value", title);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "title") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n                    <p class=\"fn-hint\">A clear, specific title helps people find and answer your topic.</p>\n                </div>\n\n                <div class=\"fn-field\">\n                    <span class=\"fn-label\">Category</span>\n                    <div class=\"fn-cats\">\n                        ");
        for (c in (cats).vals()) {
          b.raw("\n                            <label class=\"fn-cat ");
          b.text(catSelClass(c.id));
          b.raw("\">\n                                ");
          if (isSelected(c.id)) {
            b.raw("\n                                    <input type=\"radio\" name=\"categoryId\"");
            b.attr("value", Nat.toText(c.id));
            b.raw(" checked>\n                                ");
          } else {
            b.raw("\n                                    <input type=\"radio\" name=\"categoryId\"");
            b.attr("value", Nat.toText(c.id));
            b.raw(">\n                                ");
          };
          b.raw("\n                                <span class=\"fn-cat-sq\" style=\"--c:");
          b.text(c.color);
          b.raw("\"></span>\n                                <span class=\"fn-cat-name\">");
          b.text(c.name);
          b.raw("</span>\n                            </label>\n                        ");
        };
        b.raw("\n                    </div>\n                    <p class=\"fn-hint\">");
        b.text(selectedCatHint());
        b.raw("</p>\n                </div>\n\n                <div class=\"fn-field\">\n                    <label class=\"fn-label\" for=\"fn-tags\">Tags</label>\n                    <div class=\"mv-field\"><input type=\"text\" class=\"mv-input\" name=\"tags\" data-mv-key=\"tags\"");
        b.attr("value", tags);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "tags") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n                    <p class=\"fn-hint\">Optional. Comma-separated, e.g. <code>motoko, beginner, dfx</code>.</p>\n                </div>\n\n                <div class=\"fn-field\">\n                    <label class=\"fn-label\" for=\"fn-body\">Body</label>\n                    <div class=\"mv-field\"><textarea class=\"mv-textarea\" name=\"body\" data-mv-key=\"body\" required>");
        b.text(body);
        b.raw("</textarea>");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "body") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n                    <p class=\"fn-hint\">Markdown-ish text. Be descriptive — include what you tried.</p>\n                </div>\n\n                <div class=\"fn-actions\">\n                    <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Create Topic</button>\n                    <a class=\"fn-cancel\" href=\"/forum\">Cancel</a>\n                </div>\n            </form>\n        </div>\n\n    ");
      } else {
        b.raw("\n\n        <div class=\"fn-gate bz-card\">\n            <h1>Pick a handle first</h1>\n            <p>You need a Bzzz handle before you can post a topic.</p>\n            <a class=\"fn-gate-btn\" href=\"/me\">Set up your profile →</a>\n        </div>\n\n    ");
      };
      b.raw("\n\n</div>\n\n<style>\n    .fn-wrap { max-width: 820px; margin: 0 auto; color: #1a1a1a; }\n\n    .fn-head { display: flex; align-items: center; gap: .45rem; font-size: .85rem; margin-bottom: 1rem; }\n    .fn-crumb { color: #0088CC; text-decoration: none; font-weight: 600; }\n    .fn-crumb:hover { text-decoration: underline; }\n    .fn-crumb-sep { color: #c4c9ce; }\n    .fn-crumb-cur { color: #6b7177; font-weight: 600; }\n\n    .fn-card { padding: 1.5rem 1.6rem 1.7rem; }\n    .fn-title { margin: 0 0 .3rem; font-size: 1.55rem; letter-spacing: -.01em; }\n    .fn-lede { margin: 0 0 1.4rem; color: #6b7177; }\n\n    .fn-field { margin-bottom: 1.3rem; }\n    .fn-label { display: block; font-weight: 700; font-size: .9rem; margin-bottom: .4rem; color: #2b2f33; }\n    .fn-hint { margin: .4rem 0 0; color: #8a9097; font-size: .8rem; }\n    .fn-hint code { background: #f1f3f5; border-radius: 4px; padding: .05rem .3rem; font-size: .92em; color: #5c6166; }\n\n    .fn-cats { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: .55rem; }\n    .fn-cat { display: flex; align-items: center; gap: .5rem; padding: .55rem .7rem; border-radius: 10px;\n        border: 1.5px solid #e3e6e9; background: #fff; cursor: pointer; transition: border-color .12s ease, background .12s ease; }\n    .fn-cat:hover { border-color: #b9c0c6; background: #fbfcfd; }\n    .fn-cat.is-sel,\n    .fn-cat:has(input:checked) { border-color: #6d28d9; background: #f6f2fe; box-shadow: 0 0 0 1px #6d28d9 inset; }\n    .fn-cat input { position: absolute; opacity: 0; width: 0; height: 0; }\n    .fn-cat-sq { width: 14px; height: 14px; border-radius: 3px; background: var(--c, #9aa0a6); flex: 0 0 14px; }\n    .fn-cat-name { font-size: .9rem; font-weight: 600; color: #2b2f33; }\n\n    .fn-actions { display: flex; align-items: center; gap: 1rem; margin-top: 1.5rem; padding-top: 1.2rem; border-top: 1px solid #eef0f2; }\n    .fn-cancel { color: #8a9097; text-decoration: none; font-weight: 600; font-size: .9rem; }\n    .fn-cancel:hover { color: #5c6166; }\n\n    .fn-gate { padding: 2.2rem 2rem; text-align: center; }\n    .fn-gate h1 { margin: 0 0 .5rem; font-size: 1.45rem; }\n    .fn-gate p { color: #6b7177; margin: 0 0 1.2rem; }\n    .fn-gate-btn { display: inline-block; background: #6d28d9; color: #fff; text-decoration: none;\n        font-weight: 700; padding: .55rem 1.1rem; border-radius: 10px; }\n    .fn-gate-btn:hover { background: #5b21b6; }\n\n    @media (max-width: 540px) {\n        .fn-card { padding: 1.2rem 1.1rem 1.4rem; }\n        .fn-cats { grid-template-columns: 1fr; }\n    }\n</style>\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "New topic — Bzzz Forum" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "New topic — Bzzz Forum"; description = "Start a new discussion on the Bzzz forum: pick a category, add tags and write your post."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "body")) { case (?mvV) { body := mvV }; case null {} };
      switch (mvFormGet(ctx, "tags")) { case (?mvV) { tags := mvV }; case null {} };
      switch (mvFormGet(ctx, "title")) { case (?mvV) { title := mvV }; case null {} };
      switch mvH {
        case "create" { create(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/ForumTopic.mview
  // ===== Page: ForumTopic (/forum/t/{id:Nat}) =====
  let ForumTopicPage = object {
    var id : Nat = 0;
    var exists : Bool = false;
    var categoryId : Nat = 0;
    var topicTitle : Text = "Topic";
    var topicDescription : Text = "A discussion on the Bzzz forum.";
    var catName : Text = "";
    var catColor : Text = "#9aa0a6";
    var tags : [Text] = [];
    var hasTags : Bool = false;
    var pinned : Bool = false;
    var closed : Bool = false;
    var solved : Bool = false;
    var acceptedId : Nat = 0;
    var views : Nat = 0;
    var replyCount : Nat = 0;
    var activity : Text = "";
    var isAuthor : Bool = false;
    var signedIn : Bool = false;
    var posts : [Forum.Post] = [];
    var me : Principal = Principal.fromText("2vxsx-fae");
    var body : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        Forum.bumpView(id);
        load(ctx);
    };
    func load(ctx : Context) {
        me := ctx.caller;
        signedIn := Identity.isBound(ctx.caller);
        switch (Forum.topic(id)) {
            case (?t) {
                exists := true;
                categoryId := t.categoryId;
                topicTitle := t.title;
                topicDescription := "Discussion: " # t.title # " — on the Bzzz forum.";
                catName := Forum.categoryName(t.categoryId);
                catColor := Forum.categoryColor(t.categoryId);
                tags := t.tags;
                hasTags := t.tags.size() > 0;
                pinned := t.pinned;
                closed := t.closed;
                acceptedId := t.acceptedPostId;
                solved := t.acceptedPostId != 0;
                views := t.views;
                isAuthor := t.author == ctx.caller;
                activity := Forum.topicActivity(id);
                replyCount := Forum.replyCount(id);
                posts := Forum.posts(id);
            };
            case null {
                exists := false;
            };
        };
    };
    func avatarFor(p : Principal) : Text { Identity.avatarOf(p) };
    func when(at : Int) : Text { Forum.relativeTime(at) };
    func isOp(replyToPost : Nat) : Bool { replyToPost == 0 };
    func canAccept(replyToPost : Nat) : Bool { isAuthor and replyToPost != 0 };
    func isAccepted(postId : Nat) : Bool { postId != 0 and postId == acceptedId };
    func hasLikes(n : Nat) : Bool { n > 0 };
    func postClass(postId : Nat) : Text { if (isAccepted(postId)) "is-accepted" else "" };
    func likedBy(postId : Nat) : Bool { Forum.hasLiked(me, postId) };
    func toggleLike(ctx : Context, postId : Nat) : () {
        ignore Forum.like(ctx.caller, postId);
        load(ctx);
    };
    func acceptPost(ctx : Context, postId : Nat) : () {
        if (Forum.accept(ctx.caller, id, postId)) {
            toast("Marked as the solution.");
        } else {
            toast("Only the topic author can accept an answer.");
        };
        load(ctx);
    };
    func unaccept(ctx : Context) : () {
        ignore Forum.accept(ctx.caller, id, 0);
        toast("Solution cleared.");
        load(ctx);
    };
    func clearSolution(ctx : Context) : () {
        ignore Forum.accept(ctx.caller, id, 0);
        toast("Solution cleared.");
        load(ctx);
    };
    func togglePin(ctx : Context) : () {
        ignore Forum.setPinned(ctx.caller, id, not pinned);
        load(ctx);
    };
    func toggleClose(ctx : Context) : () {
        ignore Forum.setClosed(ctx.caller, id, not closed);
        load(ctx);
    };
    func submitReply(ctx : Context) : () {
         mvErrors.clear(); if (body == "") { mvErrors.add(("body", "Write a reply before posting.")) }; if (mvErrors.size() > 0) { return }; 
        let handle = Identity.handleOf(ctx.caller);
        let pid = Forum.reply(ctx.caller, handle, id, body, 0);
        if (pid == 0) {
            toast("This topic is closed.");
        } else {
            body := "";
            toast("Reply posted.");
        };
        load(ctx);
        if (pid != 0) { scrollTo("#post-" # Nat.toText(pid)) };
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      id := mvNat(mvParamGet(ctx, "id"));
      b.raw("<div class=\"ft-wrap\">\n\n");
      if (exists) {
        b.raw("\n\n    <header class=\"ft-head\">\n        <div class=\"ft-cat\">\n            <span class=\"ft-cat-sq\" style=\"--c:");
        b.text(catColor);
        b.raw("\"></span>\n            <a class=\"ft-cat-name\" href=\"/forum/c/");
        b.text(Nat.toText(categoryId));
        b.raw("\">");
        b.text(catName);
        b.raw("</a>\n        </div>\n        <h1 class=\"ft-title\">\n            ");
        if (pinned) {
          b.raw(" <span class=\"ft-glyph\" title=\"Pinned\">📌</span> ");
        };
        b.raw("\n            ");
        if (closed) {
          b.raw(" <span class=\"ft-glyph\" title=\"Closed\">🔒</span> ");
        };
        b.raw("\n            ");
        if (solved) {
          b.raw(" <span class=\"ft-glyph\" title=\"Solved\">✅</span> ");
        };
        b.raw("\n            ");
        b.text(topicTitle);
        b.raw("\n        </h1>\n        ");
        if (hasTags) {
          b.raw("\n            <div class=\"ft-tags\">\n                ");
          for (t in (tags).vals()) {
            b.raw("\n                    <span class=\"ft-tag\">");
            b.text(t);
            b.raw("</span>\n                ");
          };
          b.raw("\n            </div>\n        ");
        };
        b.raw("\n        <div class=\"ft-sub\">\n            <span>");
        b.text(Nat.toText(replyCount));
        b.raw(" replies</span>\n            <span class=\"ft-dot\">·</span>\n            <span>");
        b.text(Nat.toText(views));
        b.raw(" views</span>\n            <span class=\"ft-dot\">·</span>\n            <span>last activity ");
        b.text(activity);
        b.raw("</span>\n        </div>\n    </header>\n\n    ");
        if (isAuthor) {
          b.raw("\n        <div class=\"ft-mod\">\n            <span class=\"ft-mod-label\">Topic controls</span>\n            ");
          if (pinned) {
            b.raw("\n                <button class=\"ft-mod-btn\" data-mv-handler=\"togglePin\" data-mv-event=\"click\">Unpin</button>\n            ");
          } else {
            b.raw("\n                <button class=\"ft-mod-btn\" data-mv-handler=\"togglePin\" data-mv-event=\"click\">Pin</button>\n            ");
          };
          b.raw("\n            ");
          if (closed) {
            b.raw("\n                <button class=\"ft-mod-btn\" data-mv-handler=\"toggleClose\" data-mv-event=\"click\">Reopen</button>\n            ");
          } else {
            b.raw("\n                <button class=\"ft-mod-btn\" data-mv-handler=\"toggleClose\" data-mv-event=\"click\">Close</button>\n            ");
          };
          b.raw("\n            ");
          if (solved) {
            b.raw("\n                <button class=\"ft-mod-btn\" data-mv-handler=\"clearSolution\" data-mv-event=\"click\">Clear solution</button>\n            ");
          };
          b.raw("\n        </div>\n    ");
        };
        b.raw("\n\n    <div class=\"ft-stream\">\n        ");
        for (p in (posts).vals()) {
          b.raw("\n            <article class=\"ft-post ");
          b.text(postClass(p.id));
          b.raw("\" id=\"post-");
          b.text(Nat.toText(p.id));
          b.raw("\">\n                ");
          if (isAccepted(p.id)) {
            b.raw("\n                    <div class=\"ft-solution-tag\">✅ Solution</div>\n                ");
          };
          b.raw("\n                <div class=\"ft-post-row\">\n                    <div class=\"ft-avatar\">");
          b.text(avatarFor(p.author));
          b.raw("</div>\n                    <div class=\"ft-post-main\">\n                        <div class=\"ft-post-head\">\n                            <span class=\"ft-handle\">");
          b.text(p.authorHandle);
          b.raw("</span>\n                            ");
          if (isOp(p.replyToPost)) {
            b.raw("\n                                <span class=\"ft-op-badge\">OP</span>\n                            ");
          };
          b.raw("\n                            <span class=\"ft-when\">");
          b.text(when(p.at));
          b.raw("</span>\n                        </div>\n                        <div class=\"ft-body\">");
          b.text(p.body);
          b.raw("</div>\n                        <div class=\"ft-actions\">\n                            ");
          if (likedBy(p.id)) {
            b.raw("\n                                <button class=\"ft-act ft-liked\" title=\"Unlike\" data-mv-handler=\"toggleLike\" data-mv-event=\"click\"");
            b.attr("data-mv-arg0", Nat.toText(p.id));
            b.raw(">\n                                    <span class=\"ft-heart\">♥</span>\n                                    <span class=\"ft-count\">");
            b.text(Html.unquote(debug_show(p.likeCount)));
            b.raw("</span>\n                                </button>\n                            ");
          } else {
            b.raw("\n                                <button class=\"ft-act\" title=\"Like\" data-mv-handler=\"toggleLike\" data-mv-event=\"click\"");
            b.attr("data-mv-arg0", Nat.toText(p.id));
            b.raw(">\n                                    <span class=\"ft-heart\">♡</span>\n                                    ");
            if (hasLikes(p.likeCount)) {
              b.raw("\n                                        <span class=\"ft-count\">");
              b.text(Html.unquote(debug_show(p.likeCount)));
              b.raw("</span>\n                                    ");
            };
            b.raw("\n                                </button>\n                            ");
          };
          b.raw("\n                            <a class=\"ft-act\" href=\"#reply\" title=\"Reply\">↩ Reply</a>\n                            ");
          if (isAccepted(p.id)) {
            b.raw("\n                                ");
            if (isAuthor) {
              b.raw("\n                                    <button class=\"ft-act ft-act-accepted\" title=\"Unmark solution\" data-mv-handler=\"unaccept\" data-mv-event=\"click\">✓ Solution</button>\n                                ");
            };
            b.raw("\n                            ");
          } else if (canAccept(p.replyToPost)) {
            b.raw("\n                                <button class=\"ft-act ft-act-accept\" title=\"Mark as solution\" data-mv-handler=\"acceptPost\" data-mv-event=\"click\"");
            b.attr("data-mv-arg0", Nat.toText(p.id));
            b.raw(">Accept answer</button>\n                            ");
          };
          b.raw("\n                        </div>\n                    </div>\n                </div>\n            </article>\n        ");
        };
        b.raw("\n    </div>\n\n    ");
        if (closed) {
          b.raw("\n        <div class=\"ft-closed-note\">\n            🔒 This topic is closed. New replies are disabled.\n        </div>\n    ");
        } else {
          b.raw("\n        <div class=\"ft-composer bz-card\" id=\"reply\">\n            <h3 class=\"ft-composer-title\">Reply</h3>\n            ");
          if (signedIn) {
            b.raw("\n                <form novalidate data-mv-handler=\"submitReply\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
            b.attr("data-mv-token", ctx.mintToken("submitReply", "body"));
            b.raw(" data-mv-schema=\"body\">\n                    ");
            if (mvErrors.size() > 0) {
              b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
              for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
              b.raw("</ul></div>");
            };
            b.raw("\n                    <div class=\"mv-field\"><label>Your reply *</label><textarea class=\"mv-textarea\" name=\"body\" data-mv-key=\"body\" required>");
            b.text(body);
            b.raw("</textarea>");
            for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "body") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
            b.raw("</div>\n                    <div class=\"ft-composer-actions\">\n                        <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Reply</button>\n                    </div>\n                </form>\n            ");
          } else {
            b.raw("\n                <p class=\"ft-signin-note\">Pick a handle on <a href=\"/me\">your profile</a> to join the discussion.</p>\n            ");
          };
          b.raw("\n        </div>\n    ");
        };
        b.raw("\n\n");
      } else {
        b.raw("\n\n    <div class=\"ft-empty bz-card\">\n        <h2>Topic not found</h2>\n        <p>This topic doesn't exist or may have been removed.</p>\n        <a class=\"ft-back\" href=\"/forum\">← Back to the forum</a>\n    </div>\n\n");
      };
      b.raw("\n\n</div>\n\n<style>\n    .ft-wrap { max-width: 1100px; margin: 0 auto; color: #1a1a1a; }\n\n    .ft-head { padding: 0 0 1rem; border-bottom: 1px solid #e9ecef; margin-bottom: 1.25rem; }\n    .ft-cat { display: flex; align-items: center; gap: .45rem; margin-bottom: .55rem; }\n    .ft-cat-sq { width: 13px; height: 13px; border-radius: 3px; background: var(--c, #9aa0a6); display: inline-block; }\n    .ft-cat-name { color: #6b7177; text-decoration: none; font-size: .85rem; font-weight: 600; }\n    .ft-cat-name:hover { color: #0088CC; }\n    .ft-title { margin: 0; font-size: 1.7rem; line-height: 1.25; letter-spacing: -.01em; font-weight: 700; }\n    .ft-glyph { font-size: 1.15rem; margin-right: .2rem; }\n    .ft-tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: .7rem; }\n    .ft-tag { background: #f1f3f5; color: #5c6166; font-size: .76rem; padding: .18rem .55rem; border-radius: 999px; border: 1px solid #e3e6e9; }\n    .ft-sub { margin-top: .7rem; color: #8a9097; font-size: .82rem; display: flex; flex-wrap: wrap; gap: .4rem; align-items: center; }\n    .ft-dot { color: #c4c9ce; }\n\n    .ft-mod { display: flex; flex-wrap: wrap; align-items: center; gap: .5rem; margin-bottom: 1.1rem;\n        background: #fff8f0; border: 1px solid #ffe2c2; border-radius: 10px; padding: .55rem .8rem; }\n    .ft-mod-label { font-size: .78rem; font-weight: 700; color: #b3621a; margin-right: .25rem; text-transform: uppercase; letter-spacing: .03em; }\n    .ft-mod-btn { background: #fff; border: 1px solid #e3a76a; color: #b3621a; border-radius: 8px;\n        padding: .32rem .7rem; font-size: .82rem; font-weight: 600; cursor: pointer; }\n    .ft-mod-btn:hover { background: #F15A24; border-color: #F15A24; color: #fff; }\n\n    .ft-stream { display: flex; flex-direction: column; gap: 0; }\n    .ft-post { background: #fff; border-bottom: 1px solid #ededed; padding: 1.15rem .25rem 1.25rem; position: relative; }\n    .ft-post:first-child { padding-top: .25rem; }\n    .ft-post.is-accepted { background: #f3fbf3; border: 1px solid #b7e3b7; border-radius: 12px;\n        margin: .4rem 0; padding: .9rem 1rem 1.1rem; }\n\n    .ft-solution-tag { display: inline-flex; align-items: center; gap: .3rem; color: #fff;\n        background: #009900; font-size: .74rem; font-weight: 700; padding: .2rem .6rem;\n        border-radius: 999px; margin-bottom: .6rem; letter-spacing: .02em; }\n\n    .ft-post-row { display: flex; gap: .9rem; align-items: flex-start; }\n    .ft-avatar { width: 45px; height: 45px; border-radius: 50%; flex: 0 0 45px;\n        display: grid; place-items: center; font-size: 1.35rem;\n        background: linear-gradient(135deg, #ede7fb, #e2d9fa); box-shadow: inset 0 0 0 1px rgba(109,40,217,.12); }\n    .ft-post-main { flex: 1; min-width: 0; }\n    .ft-post-head { display: flex; align-items: baseline; flex-wrap: wrap; gap: .5rem; margin-bottom: .35rem; }\n    .ft-handle { font-weight: 700; color: #1a1a1a; font-size: .98rem; }\n    .ft-op-badge { font-size: .66rem; font-weight: 700; color: #6d28d9; background: #ede7fb;\n        border-radius: 4px; padding: .08rem .35rem; text-transform: uppercase; letter-spacing: .04em; }\n    .ft-when { color: #9aa0a6; font-size: .8rem; }\n    .ft-body { color: #2b2f33; line-height: 1.62; font-size: .96rem; white-space: pre-wrap; word-wrap: break-word; }\n\n    .ft-actions { display: flex; align-items: center; gap: .3rem; margin-top: .8rem; flex-wrap: wrap; }\n    .ft-act { display: inline-flex; align-items: center; gap: .28rem; background: transparent; border: none;\n        color: #8a9097; font-size: .84rem; font-weight: 600; padding: .3rem .55rem; border-radius: 7px;\n        cursor: pointer; text-decoration: none; }\n    .ft-act:hover { background: #f1f3f5; color: #5c6166; }\n    .ft-heart { font-size: 1rem; line-height: 1; }\n    .ft-act.ft-liked { color: #fa6c8d; }\n    .ft-act.ft-liked:hover { background: #fff0f3; }\n    .ft-count { font-variant-numeric: tabular-nums; }\n    .ft-act-accept { color: #009900; }\n    .ft-act-accept:hover { background: #eafaea; color: #007a00; }\n    .ft-act-accepted { color: #009900; }\n\n    .ft-closed-note { margin-top: 1.5rem; background: #fbf3f3; border: 1px solid #f0d6d6; color: #9a4040;\n        border-radius: 12px; padding: 1rem 1.2rem; font-weight: 600; text-align: center; }\n\n    .ft-composer { margin-top: 1.75rem; padding: 1.2rem 1.3rem 1.4rem; }\n    .ft-composer-title { margin: 0 0 .7rem; font-size: 1.1rem; }\n    .ft-composer-actions { margin-top: .7rem; }\n    .ft-signin-note { color: #6b7177; margin: 0; }\n    .ft-signin-note a { color: #0088CC; }\n\n    .ft-empty { padding: 2.5rem 2rem; text-align: center; }\n    .ft-empty h2 { margin: 0 0 .5rem; }\n    .ft-empty p { color: #6b7177; margin: 0 0 1rem; }\n    .ft-back { color: #0088CC; text-decoration: none; font-weight: 600; }\n\n    @media (max-width: 640px) {\n        .ft-title { font-size: 1.35rem; }\n        .ft-avatar { width: 38px; height: 38px; flex-basis: 38px; font-size: 1.1rem; }\n        .ft-post-row { gap: .65rem; }\n    }\n</style>\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); Html.unquote(debug_show((topicTitle # " — Bzzz Forum"))) };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); { title = Html.unquote(debug_show((topicTitle # " — Bzzz Forum"))); description = topicDescription; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      id := mvNat(mvParamGet(ctx, "id"));
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "body")) { case (?mvV) { body := mvV }; case null {} };
      switch mvH {
        case "toggleLike" { toggleLike(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "acceptPost" { acceptPost(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "unaccept" { unaccept(ctx) };
        case "clearSolution" { clearSolution(ctx) };
        case "togglePin" { togglePin(ctx) };
        case "toggleClose" { toggleClose(ctx) };
        case "submitReply" { submitReply(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Greet.mview
  // ===== Page: Greet (/greet/{name}) =====
  let GreetPage = object {
    var name : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      name := mvParamGet(ctx, "name");
      b.raw("<section class=\"bz-hero\"><h1>Hello, ");
      b.text(name);
      b.raw(" 👋</h1>\n<p>This parameterized public page is certified with a wildcard (/greet/&lt;*&gt;) and served as a fast certified query — any name under /greet is covered by one cert entry.</p></section>\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; name := mvParamGet(ctx, "name"); "Hello" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; name := mvParamGet(ctx, "name"); { title = "Hello"; description = "A public, parameterized page served as a certified query via a wildcard."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; name := mvParamGet(ctx, "name");  };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      name := mvParamGet(ctx, "name");
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch mvH {
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Home.mview
  // ===== Page: Home (/) =====
  let HomePage = object {
    var bound : Bool = false;
    var me : Text = "";
    var avatar : Text = "";
    var memberCount : Nat = 0;
    var handle : Text = "";
    var display : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        bound := Identity.isBound(ctx.caller);
        me := Identity.handleOf(ctx.caller);
        avatar := Identity.avatarOf(ctx.caller);
        memberCount := Identity.count();
    };
    func claim(ctx : Context) : () {
         mvErrors.clear(); if (handle == "") { mvErrors.add(("handle", "Choose a handle.")) }; if (handle.size() < 2) { mvErrors.add(("handle", "Handle must be at least 2 characters.")) }; if (mvErrors.size() > 0) { return }; 
        if (Identity.bind(ctx.caller, handle, display)) {
            bound := true;
            me := Identity.handleOf(ctx.caller);
            avatar := Identity.avatarOf(ctx.caller);
            memberCount := Identity.count();
            toast("Welcome to Bzzz, " # me # "!");
        } else {
            toast("That handle is taken — try another.");
        };
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<section class=\"bz-hero\">\n    <h1>One app. Every conversation.</h1>\n    <p>Servers and channels like Discord. A public feed like X. A full forum. Encrypted direct messages and groups like WhatsApp. All on-chain, all in one canister.</p>\n</section>\n\n");
      if (bound) {
        b.raw("\n    <p style=\"margin-top:1.25rem;color:var(--mv-text-soft)\">Signed in as <strong>");
        b.text(me);
        b.raw("</strong> ");
        b.text(avatar);
        b.raw(" · ");
        b.text(Nat.toText(memberCount));
        b.raw(" members on Bzzz.</p>\n");
      } else {
        b.raw("\n    <div class=\"bz-card mv-anim-fadein\" style=\"margin-top:1.25rem;padding:1.2rem 1.3rem;max-width:520px\">\n        <h3 style=\"margin:0 0 .6rem\">Pick a handle to get started</h3>\n        <form novalidate data-mv-handler=\"claim\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("claim", "display,handle"));
        b.raw(" data-mv-schema=\"display,handle\">\n            ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n            <div class=\"mv-field\"><label>Handle *</label><input type=\"text\" class=\"mv-input\" name=\"handle\" data-mv-key=\"handle\" required");
        b.attr("value", handle);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "handle") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n            <div class=\"mv-field\"><label>Display name</label><input type=\"text\" class=\"mv-input\" name=\"display\" data-mv-key=\"display\"");
        b.attr("value", display);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "display") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n            <div style=\"margin-top:.6rem\">\n                <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Join Bzzz</button>\n            </div>\n        </form>\n    </div>\n");
      };
      b.raw("\n\n<div class=\"bz-tiles\">\n    <a class=\"bz-tile\" href=\"/servers\">\n        <div class=\"bz-tile-ico\">💬</div>\n        <h3>Servers</h3>\n        <p>Communities with channels, roles, threads and moderation — Discord-style.</p>\n    </a>\n    <a class=\"bz-tile\" href=\"/forum\">\n        <div class=\"bz-tile-ico\">📋</div>\n        <h3>Forum</h3>\n        <p>Categories, topics, replies, likes and accepted answers — a full Discourse-style forum.</p>\n    </a>\n    <a class=\"bz-tile\" href=\"/feed\">\n        <div class=\"bz-tile-ico\">⚡</div>\n        <h3>Feed</h3>\n        <p>Post, follow, repost and read a home timeline — X-style.</p>\n    </a>\n    <a class=\"bz-tile\" href=\"/messages\">\n        <div class=\"bz-tile-ico\">🔒</div>\n        <h3>Messages</h3>\n        <p>End-to-end encrypted 1:1 and group chats — WhatsApp-style.</p>\n    </a>\n    <a class=\"bz-tile\" href=\"/status\">\n        <div class=\"bz-tile-ico\">📸</div>\n        <h3>Status</h3>\n        <p>Ephemeral 24-hour status updates for your contacts.</p>\n    </a>\n    <a class=\"bz-tile\" href=\"/me\">\n        <div class=\"bz-tile-ico\">👤</div>\n        <h3>Profile</h3>\n        <p>Your handle, avatar and bio across every corner of Bzzz.</p>\n    </a>\n</div>\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Bzzz — social super-app on the Internet Computer" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Bzzz — social super-app on the Internet Computer"; description = "Bzzz is a Discord, X, forum and WhatsApp super-app running entirely on-chain as a single Internet Computer canister, built with MotoView."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "display")) { case (?mvV) { display := mvV }; case null {} };
      switch (mvFormGet(ctx, "handle")) { case (?mvV) { handle := mvV }; case null {} };
      switch mvH {
        case "claim" { claim(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Me.mview
  // ===== Page: Me (/me) =====
  let MePage = object {
    var bound : Bool = false;
    var handle : Text = "";
    var display : Text = "";
    var bio : Text = "";
    var avatar : Text = "🐝";
    var followers : Nat = 0;
    var followingN : Nat = 0;
    var postCount : Nat = 0;
    var myPosts : [Feed.FeedPost] = [];
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        load(ctx);
    };
    func load(ctx : Context) {
        bound := Identity.isBound(ctx.caller);
        avatar := Identity.avatarOf(ctx.caller);
        followers := Feed.followerCount(ctx.caller);
        followingN := Feed.followingCount(ctx.caller);
        switch (Identity.profileOf(ctx.caller)) {
            case (?p) {
                handle := p.handle;
                display := p.display;
                bio := p.bio;
                myPosts := Feed.byAuthor(p.handle);
            };
            case null {
                myPosts := [];
            };
        };
        postCount := myPosts.size();
    };
    func ago(at : Int) : Text { Feed.relativeTime(at) };
    func saveIdentity(ctx : Context) : () {
         mvErrors.clear(); if (handle == "") { mvErrors.add(("handle", "Choose a handle.")) }; if (handle.size() < 2) { mvErrors.add(("handle", "Handle must be at least 2 characters.")) }; if (mvErrors.size() > 0) { return }; 
        if (Identity.bind(ctx.caller, handle, display)) {
            toast("Profile saved.");
        } else {
            toast("That handle is taken — try another.");
        };
        load(ctx);
    };
    func saveBio(ctx : Context) : () {
        if (Identity.setBio(ctx.caller, bio)) {
            toast("Bio updated.");
        } else {
            toast("Claim a handle before adding a bio.");
        };
        load(ctx);
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<section class=\"bz-prof-head bz-card mv-anim-fadein\">\n    <div class=\"bz-prof-ava\">");
      b.text(avatar);
      b.raw("</div>\n    <div class=\"bz-prof-id\">\n        ");
      if (bound) {
        b.raw("\n            <h1>");
        b.text(display);
        b.raw("</h1>\n            <p class=\"bz-prof-handle\">@");
        b.text(handle);
        b.raw("</p>\n            ");
        if ((Text.size(bio) > 0)) {
          b.raw("\n                <p class=\"bz-prof-bio\">");
          b.text(bio);
          b.raw("</p>\n            ");
        } else {
          b.raw("\n                <p class=\"bz-prof-bio bz-prof-bio-empty\">No bio yet — add one below.</p>\n            ");
        };
        b.raw("\n        ");
      } else {
        b.raw("\n            <h1>Claim your profile</h1>\n            <p class=\"bz-prof-handle\">Pick a handle to join Bzzz and start posting.</p>\n        ");
      };
      b.raw("\n    </div>\n</section>\n\n<div class=\"bz-prof-stats\">\n    <div class=\"bz-stat\">\n        <span class=\"bz-stat-n\">");
      b.text(Nat.toText(postCount));
      b.raw("</span>\n        <span class=\"bz-stat-l\">Posts</span>\n    </div>\n    <div class=\"bz-stat\">\n        <span class=\"bz-stat-n\">");
      b.text(Nat.toText(followers));
      b.raw("</span>\n        <span class=\"bz-stat-l\">Followers</span>\n    </div>\n    <div class=\"bz-stat\">\n        <span class=\"bz-stat-n\">");
      b.text(Nat.toText(followingN));
      b.raw("</span>\n        <span class=\"bz-stat-l\">Following</span>\n    </div>\n</div>\n\n<div class=\"bz-prof-grid\">\n    <div class=\"bz-prof-col\">\n        <div class=\"bz-card bz-prof-panel\">\n            <h2>Identity</h2>\n            <p class=\"bz-panel-sub\">Your handle is unique across Bzzz and links your posts, forum topics and messages.</p>\n            <form novalidate data-mv-handler=\"saveIdentity\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
      b.attr("data-mv-token", ctx.mintToken("saveIdentity", "display,handle"));
      b.raw(" data-mv-schema=\"display,handle\">\n                ");
      if (mvErrors.size() > 0) {
        b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
        for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
        b.raw("</ul></div>");
      };
      b.raw("\n                <div class=\"mv-field\"><label>Handle *</label><input type=\"text\" class=\"mv-input\" name=\"handle\" data-mv-key=\"handle\" required");
      b.attr("value", handle);
      b.raw(">");
      for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "handle") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
      b.raw("</div>\n                <div class=\"mv-field\"><label>Display name</label><input type=\"text\" class=\"mv-input\" name=\"display\" data-mv-key=\"display\"");
      b.attr("value", display);
      b.raw(">");
      for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "display") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
      b.raw("</div>\n                <div class=\"bz-form-actions\">\n                    <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Save handle</button>\n                </div>\n            </form>\n        </div>\n\n        ");
      if (bound) {
        b.raw("\n            <div class=\"bz-card bz-prof-panel\">\n                <h2>Bio</h2>\n                <p class=\"bz-panel-sub\">A short line about you, shown on your public profile.</p>\n                <form novalidate data-mv-handler=\"saveBio\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("saveBio", "bio"));
        b.raw(" data-mv-schema=\"bio\">\n                    ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n                    <div class=\"mv-field\"><label>Bio</label><textarea class=\"mv-textarea\" name=\"bio\" data-mv-key=\"bio\">");
        b.text(bio);
        b.raw("</textarea>");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "bio") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n                    <div class=\"bz-form-actions\">\n                        <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Save bio</button>\n                    </div>\n                </form>\n            </div>\n        ");
      };
      b.raw("\n    </div>\n\n    <div class=\"bz-prof-col\">\n        <div class=\"bz-card bz-prof-panel\">\n            <h2>Your posts</h2>\n            ");
      if ((myPosts.size() > 0)) {
        b.raw("\n                <div class=\"bz-posts\">\n                    ");
        for (p in (myPosts).vals()) {
          b.raw("\n                        <article class=\"bz-post\">\n                            <div class=\"bz-post-head\">\n                                <span class=\"bz-post-ava\">");
          b.text(avatar);
          b.raw("</span>\n                                <span class=\"bz-post-name\">");
          b.text(display);
          b.raw("</span>\n                                <span class=\"bz-post-handle\">@");
          b.text(handle);
          b.raw("</span>\n                                <span class=\"bz-post-dot\">·</span>\n                                <span class=\"bz-post-time\">");
          b.text(ago(p.at));
          b.raw("</span>\n                            </div>\n                            <p class=\"bz-post-text\">");
          b.text(Html.unquote(debug_show(p.text)));
          b.raw("</p>\n                            <div class=\"bz-post-meta\">\n                                <span>❤️ ");
          b.text(Html.unquote(debug_show(p.likes)));
          b.raw("</span>\n                                <span>🔁 ");
          b.text(Nat.toText(p.reposts));
          b.raw("</span>\n                                <span>💬 ");
          b.text(Nat.toText(p.replyCount));
          b.raw("</span>\n                            </div>\n                        </article>\n                    ");
        };
        b.raw("\n                </div>\n            ");
      } else {
        b.raw("\n                <div class=\"bz-empty\">\n                    <div class=\"bz-empty-ico\">⚡</div>\n                    <p>You haven't posted yet.</p>\n                    <a class=\"bz-link\" href=\"/feed\">Write your first post →</a>\n                </div>\n            ");
      };
      b.raw("\n        </div>\n    </div>\n</div>\n\n<style>\n    .bz-prof-head { display: flex; align-items: center; gap: 1.1rem; padding: 1.4rem 1.5rem; }\n    .bz-prof-ava { width: 76px; height: 76px; border-radius: 50%; flex: 0 0 auto;\n        background: linear-gradient(135deg, #6d28d9, #c026d3); color: #fff;\n        display: grid; place-items: center; font-size: 2.2rem;\n        box-shadow: 0 6px 18px rgba(109,40,217,.28); }\n    .bz-prof-id h1 { margin: 0 0 .15rem; font-size: 1.55rem; letter-spacing: -.02em; }\n    .bz-prof-handle { margin: 0; color: var(--bz-accent); font-weight: 600; font-size: .95rem; }\n    .bz-prof-bio { margin: .5rem 0 0; color: var(--mv-text); font-size: .95rem; max-width: 60ch; }\n    .bz-prof-bio-empty { color: var(--mv-text-soft); font-style: italic; }\n\n    .bz-prof-stats { display: flex; gap: .75rem; margin: 1rem 0 1.25rem; }\n    .bz-stat { flex: 1; background: var(--mv-surface); border: 1px solid var(--mv-border);\n        border-radius: 12px; padding: .85rem 1rem; text-align: center; box-shadow: var(--mv-shadow); }\n    .bz-stat-n { display: block; font-size: 1.4rem; font-weight: 800; letter-spacing: -.02em; }\n    .bz-stat-l { display: block; color: var(--mv-text-soft); font-size: .78rem; text-transform: uppercase; letter-spacing: .04em; }\n\n    .bz-prof-grid { display: grid; grid-template-columns: minmax(280px, 380px) 1fr; gap: 1rem; align-items: start; }\n    .bz-prof-col { display: flex; flex-direction: column; gap: 1rem; }\n    .bz-prof-panel { padding: 1.2rem 1.3rem; }\n    .bz-prof-panel h2 { margin: 0 0 .25rem; font-size: 1.1rem; }\n    .bz-panel-sub { margin: 0 0 .9rem; color: var(--mv-text-soft); font-size: .85rem; }\n    .bz-form-actions { margin-top: .7rem; }\n\n    .bz-posts { display: flex; flex-direction: column; gap: .25rem; }\n    .bz-post { padding: .9rem .25rem; border-top: 1px solid var(--mv-border); }\n    .bz-post:first-child { border-top: none; padding-top: .25rem; }\n    .bz-post-head { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }\n    .bz-post-ava { width: 30px; height: 30px; border-radius: 50%; background: var(--mv-muted);\n        display: grid; place-items: center; font-size: 1rem; }\n    .bz-post-name { font-weight: 700; }\n    .bz-post-handle, .bz-post-time, .bz-post-dot { color: var(--mv-text-soft); font-size: .85rem; }\n    .bz-post-text { margin: .4rem 0 .5rem; white-space: pre-wrap; line-height: 1.45; }\n    .bz-post-meta { display: flex; gap: 1.1rem; color: var(--mv-text-soft); font-size: .85rem; }\n\n    .bz-empty { text-align: center; padding: 2rem 1rem; color: var(--mv-text-soft); }\n    .bz-empty-ico { font-size: 2rem; margin-bottom: .4rem; }\n    .bz-link { color: var(--bz-accent); font-weight: 600; text-decoration: none; }\n    .bz-link:hover { text-decoration: underline; }\n\n    @media (max-width: 820px) {\n        .bz-prof-grid { grid-template-columns: 1fr; }\n    }\n    @media (max-width: 520px) {\n        .bz-prof-head { flex-direction: column; text-align: center; }\n        .bz-prof-stats { flex-direction: row; }\n    }\n</style>\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Your profile — Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Your profile — Bzzz"; description = "Set your Bzzz handle, display name and bio, see your follower and following counts, and read back everything you have posted to the feed."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "bio")) { case (?mvV) { bio := mvV }; case null {} };
      switch (mvFormGet(ctx, "display")) { case (?mvV) { display := mvV }; case null {} };
      switch (mvFormGet(ctx, "handle")) { case (?mvV) { handle := mvV }; case null {} };
      switch mvH {
        case "saveIdentity" { saveIdentity(ctx) };
        case "saveBio" { saveBio(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Messages.mview
  // ===== Page: Messages (/messages) =====
  let MessagesPage = object {
    var bound : Bool = false;
    var me : Principal = Principal.fromText("2vxsx-fae");
    var convos : [Messenger.Conversation] = [];
    var peerHandle : Text = "";
    var groupName : Text = "";
    var groupHandles : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        me := ctx.caller;
        bound := Identity.isBound(ctx.caller);
        convos := Messenger.conversations(ctx.caller);
    };
    func rowTitle(c : Messenger.Conversation) : Text {
        switch (c.kind) {
            case (#Group) { Messenger.titleFor(c.id, "") };
            case (#Direct) {
                switch (Messenger.directPeer(me, c.id)) {
                    case (?p) { Identity.handleOf(p) };
                    case null { c.name };
                };
            };
        };
    };
    func rowAvatar(c : Messenger.Conversation) : Text {
        switch (c.kind) {
            case (#Group) { "👥" };
            case (#Direct) {
                switch (Messenger.directPeer(me, c.id)) {
                    case (?p) { Identity.avatarOf(p) };
                    case null { "🔒" };
                };
            };
        };
    };
    func rowKind(c : Messenger.Conversation) : Text {
        switch (c.kind) {
            case (#Group) { Nat.toText(Messenger.memberCount(c.id)) # " members · encrypted" };
            case (#Direct) { "Direct message · encrypted" };
        };
    };
    func rowTime(c : Messenger.Conversation) : Text { Messenger.relativeTime(c.lastAt) };
    func rowUnread(c : Messenger.Conversation) : Nat { Messenger.unreadCount(me, c.id) };
    func startChat(ctx : Context) : () {
         mvErrors.clear(); if (peerHandle == "") { mvErrors.add(("peerHandle", "Enter a handle to message.")) }; if (peerHandle.size() < 2) { mvErrors.add(("peerHandle", "Handles are at least 2 characters.")) }; if (mvErrors.size() > 0) { return }; 
        switch (Identity.byHandleLookup(peerHandle)) {
            case null { toast("No Bzzz user with that handle."); };
            case (?prof) {
                if (prof.principal == ctx.caller) {
                    toast("You can't start a chat with yourself.");
                } else {
                    let id = Messenger.startDirect(ctx.caller, prof.principal);
                    peerHandle := "";
                    toast("Chat with " # prof.handle # " ready.");
                };
            };
        };
    };
    func startGroupChat(ctx : Context) : () {
         mvErrors.clear(); if (groupName == "") { mvErrors.add(("groupName", "Give your group a name.")) }; if (mvErrors.size() > 0) { return }; 
        // Resolve comma-separated handles to principals; skip unknown / self.
        var members : [Principal] = [];
        var missing : Nat = 0;
        for (raw in Text.split(groupHandles, #char ',')) {
            let h = Text.trim(raw, #char ' ');
            if (h != "") {
                switch (Identity.byHandleLookup(h)) {
                    case null { missing += 1; };
                    case (?prof) {
                        if (prof.principal != ctx.caller) {
                            members := Array.append(members, [prof.principal]);
                        };
                    };
                };
            };
        };
        let id = Messenger.startGroup(ctx.caller, groupName, members);
        groupName := "";
        groupHandles := "";
        if (missing > 0) {
            toast("Group created — " # Nat.toText(missing) # " handle(s) weren't found.");
        } else {
            toast("Group created.");
        };
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<div class=\"bz-msg-wrap\">\n    <header class=\"bz-msg-head\">\n        <div>\n            <h1>Messages</h1>\n            <p class=\"bz-msg-sub\">🔒 End-to-end encrypted · 1:1 &amp; group chats</p>\n        </div>\n        <span class=\"bz-msg-e2ee\">End-to-end encrypted</span>\n    </header>\n\n    ");
      if (bound) {
        b.raw("\n        <div class=\"bz-msg-new\">\n            <div class=\"bz-card bz-msg-newcard\">\n                <h3>New chat</h3>\n                <p class=\"bz-msg-hint\">Start a direct message by their Bzzz handle.</p>\n                <form novalidate data-mv-handler=\"startChat\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("startChat", "peerHandle"));
        b.raw(" data-mv-schema=\"peerHandle\">\n                    ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n                    <div class=\"mv-field\"><label>Handle *</label><input type=\"text\" class=\"mv-input\" name=\"peerHandle\" data-mv-key=\"peerHandle\" required");
        b.attr("value", peerHandle);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "peerHandle") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n                    <div class=\"bz-msg-actions\">\n                        <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Start chat</button>\n                    </div>\n                </form>\n            </div>\n            <div class=\"bz-card bz-msg-newcard\">\n                <h3>New group</h3>\n                <p class=\"bz-msg-hint\">Name your group and add members by handle (comma separated).</p>\n                <form novalidate data-mv-handler=\"startGroupChat\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("startGroupChat", "groupHandles,groupName"));
        b.raw(" data-mv-schema=\"groupHandles,groupName\">\n                    ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n                    <div class=\"mv-field\"><label>Group name *</label><input type=\"text\" class=\"mv-input\" name=\"groupName\" data-mv-key=\"groupName\" required");
        b.attr("value", groupName);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "groupName") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n                    <div class=\"mv-field\"><label>Member handles</label><input type=\"text\" class=\"mv-input\" name=\"groupHandles\" data-mv-key=\"groupHandles\"");
        b.attr("value", groupHandles);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "groupHandles") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n                    <div class=\"bz-msg-actions\">\n                        <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Create group</button>\n                    </div>\n                </form>\n            </div>\n        </div>\n\n        <h2 class=\"bz-msg-listtitle\">Conversations</h2>\n        ");
        if ((convos.size() == 0)) {
          b.raw("\n            <div class=\"bz-card bz-msg-empty\">\n                <div class=\"bz-msg-empty-ico\">💬</div>\n                <h3>No conversations yet</h3>\n                <p>Start a direct message or create a group above to begin chatting securely.</p>\n            </div>\n        ");
        } else {
          b.raw("\n            <ul class=\"bz-msg-list\">\n                ");
          for (c in (convos).vals()) {
            b.raw("\n                    <li>\n                        <a class=\"bz-msg-row\" href=\"/messages/");
            b.text(Nat.toText(c.id));
            b.raw("\">\n                            <span class=\"bz-msg-avatar\">");
            b.text(rowAvatar(c));
            b.raw("</span>\n                            <span class=\"bz-msg-body\">\n                                <span class=\"bz-msg-toprow\">\n                                    <span class=\"bz-msg-name\">");
            b.text(rowTitle(c));
            b.raw("</span>\n                                    <span class=\"bz-msg-time\">");
            b.text(rowTime(c));
            b.raw("</span>\n                                </span>\n                                <span class=\"bz-msg-preview\">");
            b.text(rowKind(c));
            b.raw("</span>\n                            </span>\n                            ");
            if ((rowUnread(c) > 0)) {
              b.raw("\n                                <span class=\"bz-msg-badge\">");
              b.text(Nat.toText(rowUnread(c)));
              b.raw("</span>\n                            ");
            };
            b.raw("\n                        </a>\n                    </li>\n                ");
          };
          b.raw("\n            </ul>\n        ");
        };
        b.raw("\n    ");
      } else {
        b.raw("\n        <div class=\"bz-card bz-msg-empty\">\n            <div class=\"bz-msg-empty-ico\">🔒</div>\n            <h3>Pick a handle first</h3>\n            <p>You need a Bzzz handle before you can send encrypted messages. <a href=\"/\">Claim your handle</a> to get started.</p>\n        </div>\n    ");
      };
      b.raw("\n</div>\n\n<style>\n    .bz-msg-wrap { max-width: 720px; margin: 0 auto; }\n    .bz-msg-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1.25rem; }\n    .bz-msg-head h1 { margin: 0; font-size: 1.7rem; letter-spacing: -.02em; }\n    .bz-msg-sub { margin: .25rem 0 0; color: var(--mv-text-soft); font-size: .9rem; }\n    .bz-msg-e2ee { flex: none; background: #e7f8ef; color: #047857; border: 1px solid #a7f3d0;\n        font-size: .72rem; font-weight: 700; padding: .3rem .6rem; border-radius: 999px; white-space: nowrap; }\n\n    .bz-msg-new { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.75rem; }\n    .bz-msg-newcard { padding: 1.1rem 1.2rem; }\n    .bz-msg-newcard h3 { margin: 0 0 .25rem; font-size: 1.02rem; }\n    .bz-msg-hint { margin: 0 0 .7rem; color: var(--mv-text-soft); font-size: .82rem; }\n    .bz-msg-actions { margin-top: .6rem; }\n\n    .bz-msg-listtitle { font-size: 1.05rem; margin: 0 0 .6rem; color: var(--mv-text-soft); text-transform: uppercase; letter-spacing: .04em; }\n\n    .bz-msg-list { list-style: none; margin: 0; padding: 0; border: 1px solid var(--mv-border);\n        border-radius: 14px; overflow: hidden; background: var(--mv-surface); box-shadow: var(--mv-shadow); }\n    .bz-msg-list li + li .bz-msg-row { border-top: 1px solid var(--mv-border); }\n    .bz-msg-row { display: flex; align-items: center; gap: .85rem; padding: .85rem 1rem; text-decoration: none; color: inherit;\n        transition: background .12s ease; }\n    .bz-msg-row:hover { background: var(--mv-muted); }\n    .bz-msg-avatar { flex: none; width: 46px; height: 46px; border-radius: 50%; background: var(--mv-muted);\n        display: grid; place-items: center; font-size: 1.4rem; }\n    .bz-msg-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: .15rem; }\n    .bz-msg-toprow { display: flex; align-items: baseline; justify-content: space-between; gap: .6rem; }\n    .bz-msg-name { font-weight: 700; font-size: .98rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n    .bz-msg-time { flex: none; color: var(--mv-text-soft); font-size: .76rem; }\n    .bz-msg-preview { color: var(--mv-text-soft); font-size: .84rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n    .bz-msg-badge { flex: none; min-width: 22px; height: 22px; padding: 0 .4rem; border-radius: 999px;\n        background: var(--bz-accent, #6d28d9); color: #fff; font-size: .76rem; font-weight: 700;\n        display: grid; place-items: center; }\n\n    .bz-msg-empty { text-align: center; padding: 2.5rem 1.5rem; }\n    .bz-msg-empty-ico { font-size: 2.4rem; }\n    .bz-msg-empty h3 { margin: .6rem 0 .3rem; }\n    .bz-msg-empty p { margin: 0 auto; color: var(--mv-text-soft); max-width: 42ch; }\n\n    @media (max-width: 640px) {\n        .bz-msg-new { grid-template-columns: 1fr; }\n        .bz-msg-head { flex-direction: column; gap: .5rem; }\n    }\n</style>\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Messages — end-to-end encrypted chats on Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Messages — end-to-end encrypted chats on Bzzz"; description = "Your private WhatsApp-style conversations on Bzzz: encrypted 1:1 direct messages and group chats, running entirely on-chain on the Internet Computer."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "groupHandles")) { case (?mvV) { groupHandles := mvV }; case null {} };
      switch (mvFormGet(ctx, "groupName")) { case (?mvV) { groupName := mvV }; case null {} };
      switch (mvFormGet(ctx, "peerHandle")) { case (?mvV) { peerHandle := mvV }; case null {} };
      switch mvH {
        case "startChat" { startChat(ctx) };
        case "startGroupChat" { startGroupChat(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Profile.mview
  // ===== Page: Profile (/u/{handle}) =====
  let ProfilePage = object {
    var handle : Text = "";
    var exists : Bool = false;
    var isSelf : Bool = false;
    var following : Bool = false;
    var handleText : Text = "";
    var display : Text = "";
    var bio : Text = "";
    var avatar : Text = "🐝";
    var pageTitle : Text = "Profile — Bzzz";
    var pageDesc : Text = "A Bzzz user profile — their posts, followers and bio.";
    var target : Principal = Principal.fromText("aaaaa-aa");
    var followers : Nat = 0;
    var followingN : Nat = 0;
    var postCount : Nat = 0;
    var posts : [Feed.FeedPost] = [];
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        load(ctx);
    };
    func load(ctx : Context) {
        handleText := handle;
        switch (Identity.byHandleLookup(handle)) {
            case (?p) {
                exists := true;
                handleText := p.handle;
                display := p.display;
                bio := p.bio;
                avatar := p.avatar;
                target := p.principal;
                isSelf := p.principal == ctx.caller;
                following := Feed.isFollowing(ctx.caller, p.principal);
                followers := Feed.followerCount(p.principal);
                followingN := Feed.followingCount(p.principal);
                posts := Feed.byAuthor(p.handle);
                postCount := posts.size();
                pageTitle := p.display # " (@" # p.handle # ") — Bzzz";
                pageDesc := p.display # " on Bzzz: " # Nat.toText(followers) # " followers, " # Nat.toText(postCount) # " posts." # (if (Text.size(p.bio) > 0) { " " # p.bio } else { "" });
            };
            case null {
                exists := false;
                posts := [];
                pageTitle := "Profile not found — Bzzz";
                pageDesc := "No Bzzz user with that handle yet.";
            };
        };
    };
    func ago(at : Int) : Text { Feed.relativeTime(at) };
    func toggleFollow(ctx : Context) : () {
        if (Feed.follow(ctx.caller, target)) {
            toast("Following " # display # ".");
        } else {
            toast("Unfollowed " # display # ".");
        };
        load(ctx);
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      handle := mvParamGet(ctx, "handle");
      if (exists) {
        b.raw("\n    <section class=\"bz-prof-head bz-card mv-anim-fadein\">\n        <div class=\"bz-prof-ava\">");
        b.text(avatar);
        b.raw("</div>\n        <div class=\"bz-prof-id\">\n            <h1>");
        b.text(display);
        b.raw("</h1>\n            <p class=\"bz-prof-handle\">@");
        b.text(handleText);
        b.raw("</p>\n            ");
        if ((Text.size(bio) > 0)) {
          b.raw("\n                <p class=\"bz-prof-bio\">");
          b.text(bio);
          b.raw("</p>\n            ");
        };
        b.raw("\n        </div>\n        ");
        if (isSelf) {
          b.raw("\n            <a class=\"bz-followbtn bz-followbtn-self\" href=\"/me\">Edit profile</a>\n        ");
        } else {
          b.raw("\n            <form novalidate class=\"bz-followform\" data-mv-handler=\"toggleFollow\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
          b.attr("data-mv-token", ctx.mintToken("toggleFollow", ""));
          b.raw(" data-mv-schema=\"\">\n                ");
          if (following) {
            b.raw("\n                    <button type=\"submit\" class=\"bz-followbtn bz-followbtn-on\">Following</button>\n                ");
          } else {
            b.raw("\n                    <button type=\"submit\" class=\"bz-followbtn\">Follow</button>\n                ");
          };
          b.raw("\n            </form>\n        ");
        };
        b.raw("\n    </section>\n\n    <div class=\"bz-prof-stats\">\n        <div class=\"bz-stat\">\n            <span class=\"bz-stat-n\">");
        b.text(Nat.toText(postCount));
        b.raw("</span>\n            <span class=\"bz-stat-l\">Posts</span>\n        </div>\n        <div class=\"bz-stat\">\n            <span class=\"bz-stat-n\">");
        b.text(Nat.toText(followers));
        b.raw("</span>\n            <span class=\"bz-stat-l\">Followers</span>\n        </div>\n        <div class=\"bz-stat\">\n            <span class=\"bz-stat-n\">");
        b.text(Nat.toText(followingN));
        b.raw("</span>\n            <span class=\"bz-stat-l\">Following</span>\n        </div>\n    </div>\n\n    <div class=\"bz-card bz-prof-panel\">\n        <h2>Posts</h2>\n        ");
        if ((posts.size() > 0)) {
          b.raw("\n            <div class=\"bz-posts\">\n                ");
          for (p in (posts).vals()) {
            b.raw("\n                    <article class=\"bz-post\">\n                        <div class=\"bz-post-head\">\n                            <span class=\"bz-post-ava\">");
            b.text(avatar);
            b.raw("</span>\n                            <span class=\"bz-post-name\">");
            b.text(display);
            b.raw("</span>\n                            <span class=\"bz-post-handle\">@");
            b.text(handleText);
            b.raw("</span>\n                            <span class=\"bz-post-dot\">·</span>\n                            <span class=\"bz-post-time\">");
            b.text(ago(p.at));
            b.raw("</span>\n                        </div>\n                        <p class=\"bz-post-text\">");
            b.text(Html.unquote(debug_show(p.text)));
            b.raw("</p>\n                        <div class=\"bz-post-meta\">\n                            <span>❤️ ");
            b.text(Html.unquote(debug_show(p.likes)));
            b.raw("</span>\n                            <span>🔁 ");
            b.text(Nat.toText(p.reposts));
            b.raw("</span>\n                            <span>💬 ");
            b.text(Nat.toText(p.replyCount));
            b.raw("</span>\n                        </div>\n                    </article>\n                ");
          };
          b.raw("\n            </div>\n        ");
        } else {
          b.raw("\n            <div class=\"bz-empty\">\n                <div class=\"bz-empty-ico\">⚡</div>\n                <p>");
          b.text(display);
          b.raw(" hasn't posted anything yet.</p>\n            </div>\n        ");
        };
        b.raw("\n    </div>\n");
      } else {
        b.raw("\n    <section class=\"bz-prof-head bz-card mv-anim-fadein\">\n        <div class=\"bz-prof-ava\">❓</div>\n        <div class=\"bz-prof-id\">\n            <h1>User not found</h1>\n            <p class=\"bz-prof-handle\">No one on Bzzz has claimed @");
        b.text(handleText);
        b.raw(" yet.</p>\n        </div>\n    </section>\n    <div class=\"bz-empty\">\n        <a class=\"bz-link\" href=\"/feed\">← Back to the feed</a>\n    </div>\n");
      };
      b.raw("\n\n<style>\n    .bz-prof-head { display: flex; align-items: center; gap: 1.1rem; padding: 1.4rem 1.5rem; }\n    .bz-prof-ava { width: 76px; height: 76px; border-radius: 50%; flex: 0 0 auto;\n        background: linear-gradient(135deg, #6d28d9, #c026d3); color: #fff;\n        display: grid; place-items: center; font-size: 2.2rem;\n        box-shadow: 0 6px 18px rgba(109,40,217,.28); }\n    .bz-prof-id { flex: 1; }\n    .bz-prof-id h1 { margin: 0 0 .15rem; font-size: 1.55rem; letter-spacing: -.02em; }\n    .bz-prof-handle { margin: 0; color: var(--bz-accent); font-weight: 600; font-size: .95rem; }\n    .bz-prof-bio { margin: .5rem 0 0; color: var(--mv-text); font-size: .95rem; max-width: 60ch; }\n\n    .bz-followform { margin: 0; flex: 0 0 auto; }\n    .bz-followbtn { display: inline-block; border: 1px solid var(--bz-accent); background: var(--bz-accent);\n        color: #fff; font-weight: 700; font-size: .92rem; padding: .55rem 1.3rem; border-radius: 999px;\n        cursor: pointer; text-decoration: none; transition: background .12s ease, color .12s ease; }\n    .bz-followbtn:hover { background: #5b21b6; border-color: #5b21b6; }\n    .bz-followbtn-on { background: transparent; color: var(--bz-accent); }\n    .bz-followbtn-on:hover { background: #fde8ec; color: #c80001; border-color: #c80001; }\n    .bz-followbtn-self { background: transparent; color: var(--mv-text); border-color: var(--mv-border); }\n    .bz-followbtn-self:hover { background: var(--mv-muted); border-color: var(--mv-border); color: var(--mv-text); }\n\n    .bz-prof-stats { display: flex; gap: .75rem; margin: 1rem 0 1.25rem; }\n    .bz-stat { flex: 1; background: var(--mv-surface); border: 1px solid var(--mv-border);\n        border-radius: 12px; padding: .85rem 1rem; text-align: center; box-shadow: var(--mv-shadow); }\n    .bz-stat-n { display: block; font-size: 1.4rem; font-weight: 800; letter-spacing: -.02em; }\n    .bz-stat-l { display: block; color: var(--mv-text-soft); font-size: .78rem; text-transform: uppercase; letter-spacing: .04em; }\n\n    .bz-prof-panel { padding: 1.2rem 1.3rem; }\n    .bz-prof-panel h2 { margin: 0 0 .6rem; font-size: 1.1rem; }\n\n    .bz-posts { display: flex; flex-direction: column; gap: .25rem; }\n    .bz-post { padding: .9rem .25rem; border-top: 1px solid var(--mv-border); }\n    .bz-post:first-child { border-top: none; padding-top: .25rem; }\n    .bz-post-head { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }\n    .bz-post-ava { width: 30px; height: 30px; border-radius: 50%; background: var(--mv-muted);\n        display: grid; place-items: center; font-size: 1rem; }\n    .bz-post-name { font-weight: 700; }\n    .bz-post-handle, .bz-post-time, .bz-post-dot { color: var(--mv-text-soft); font-size: .85rem; }\n    .bz-post-text { margin: .4rem 0 .5rem; white-space: pre-wrap; line-height: 1.45; }\n    .bz-post-meta { display: flex; gap: 1.1rem; color: var(--mv-text-soft); font-size: .85rem; }\n\n    .bz-empty { text-align: center; padding: 2rem 1rem; color: var(--mv-text-soft); }\n    .bz-empty-ico { font-size: 2rem; margin-bottom: .4rem; }\n    .bz-link { color: var(--bz-accent); font-weight: 600; text-decoration: none; }\n    .bz-link:hover { text-decoration: underline; }\n\n    @media (max-width: 520px) {\n        .bz-prof-head { flex-direction: column; text-align: center; }\n    }\n</style>\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; handle := mvParamGet(ctx, "handle"); pageTitle };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; handle := mvParamGet(ctx, "handle"); { title = pageTitle; description = pageDesc; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; handle := mvParamGet(ctx, "handle"); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      handle := mvParamGet(ctx, "handle");
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch mvH {
        case "toggleFollow" { toggleFollow(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Server.mview
  // ===== Page: Server (/servers/{id:Nat}) =====
  let ServerPage = object {
    var id : Nat = 0;
    var exists : Bool = false;
    var serverName : Text = "Server";
    var kindLabel : Text = "";
    var kindClass : Text = "discussion";
    var private_ : Bool = false;
    var createdRel : Text = "";
    var memberCount : Nat = 0;
    var channels = Chat.listRooms(0);
    var memberRows = Servers.memberRecords(0);
    var isMember : Bool = false;
    var isOwner : Bool = false;
    var canMod : Bool = false;
    var canAdmin : Bool = false;
    var myRole : Text = "Member";
    var channelName : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func paramNat(ctx : Context, k : Text) : Nat {
        for ((kk, vv) in ctx.params.vals()) { if (kk == k) { return mvNat(vv) } };
        0;
    };
    func onLoad(ctx : Context) {
        id := paramNat(ctx, "id");
        switch (Servers.server(id)) {
            case null { exists := false };
            case (?s) {
                exists := true;
                serverName := s.name;
                kindLabel := Servers.kindLabel(s.kind);
                kindClass := (switch (s.kind) {
                    case (#Discussion) "discussion";
                    case (#Forum) "forum";
                    case (#Feed) "feed";
                });
                private_ := s.private_;
                createdRel := Servers.relativeTime(s.createdAt);
            };
        };
        memberCount := Servers.memberCount(id);
        memberRows := Servers.memberRecords(id);
        channels := Chat.listRooms(id);

        isMember := Servers.isMember(id, ctx.caller);
        isOwner := Servers.isOwner(id, ctx.caller);
        canMod := Servers.canModerate(id, ctx.caller);
        canAdmin := Servers.canAdmin(id, ctx.caller);
        myRole := Servers.roleLabel(id, ctx.caller);
    };
    func msgCount(rid : Nat) : Nat { Chat.messageCount(rid) };
    func isLocked(rid : Nat) : Bool { Servers.isLocked(rid) };
    func handleOf(p : Principal) : Text { Identity.handleOf(p) };
    func avatarOf(p : Principal) : Text { Identity.avatarOf(p) };
    func roleLabel(p : Principal) : Text { Servers.roleLabel(id, p) };
    func roleClass(p : Principal) : Text {
        switch (Servers.roleOf(id, p)) {
            case (#Owner) "owner";
            case (#Admin) "admin";
            case (#Moderator) "moderator";
            case (#None) "member";
        };
    };
    func isOwnerPrincipal(p : Principal) : Bool { Servers.isOwner(id, p) };
    func isAdminPrincipal(p : Principal) : Bool { Servers.roleOf(id, p) == #Admin };
    func isMod(p : Principal) : Bool {
        switch (Servers.roleOf(id, p)) {
            case (#Moderator) true;
            case (#Admin) true;
            case (_) false;
        };
    };
    func plural(n : Nat, one : Text, many : Text) : Text {
        if (n == 1) one else many;
    };
    func pidText(p : Principal) : Text { Principal.toText(p) };
    func join(ctx : Context) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.joinAs(ctx.caller, sid, Identity.handleOf(ctx.caller));
        toast("Joined the server.");
    };
    func leave(ctx : Context) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.leave(ctx.caller, sid);
        toast("Left the server.");
    };
    func createChannel(ctx : Context) : () {
         mvErrors.clear(); if (channelName == "") { mvErrors.add(("channelName", "Name the channel.")) }; if (channelName.size() < 2) { mvErrors.add(("channelName", "Channel name must be at least 2 characters.")) }; if (mvErrors.size() > 0) { return }; 
        let sid = paramNat(ctx, "id");
        let newRid = Chat.createRoom(channelName, sid);
        if (newRid == 0) {
            toast("Pick a valid channel name (a-z, 0-9, - or _).");
            return;
        };
        ignore Servers.addChannel(ctx.caller, sid, newRid);
        channelName := "";
        toast("Channel created.");
    };
    func lock(ctx : Context, rid : Nat) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.lock(ctx.caller, sid, rid, true);
        toast("Channel locked.");
    };
    func unlock(ctx : Context, rid : Nat) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.lock(ctx.caller, sid, rid, false);
        toast("Channel unlocked.");
    };
    func makeMod(ctx : Context, targetText : Text) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.grant(ctx.caller, sid, Principal.fromText(targetText), #Moderator);
        toast("Granted moderator.");
    };
    func makeAdmin(ctx : Context, targetText : Text) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.grant(ctx.caller, sid, Principal.fromText(targetText), #Admin);
        toast("Granted admin.");
    };
    func revoke(ctx : Context, targetText : Text) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.revoke(ctx.caller, sid, Principal.fromText(targetText));
        toast("Role revoked.");
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      id := mvNat(mvParamGet(ctx, "id"));
      if (not exists) {
        b.raw("\n    <div class=\"bz-card sv-missing\">\n        <div class=\"sv-missing-ico\">🚫</div>\n        <h2>Server not found</h2>\n        <p>This server does not exist (or was deleted). <a href=\"/servers\">Back to all servers</a>.</p>\n    </div>\n");
      } else {
        b.raw("\n    <div class=\"sv-head bz-card\">\n        <div class=\"sv-head-main\">\n            <div class=\"sv-title-row\">\n                <h1>");
        b.text(serverName);
        b.raw("</h1>\n                <span class=\"sv-badge sv-badge-");
        b.text(kindClass);
        b.raw("\">");
        b.text(kindLabel);
        b.raw("</span>\n                ");
        if (private_) {
          b.raw("\n                    <span class=\"sv-lockchip\">🔒 Private</span>\n                ");
        };
        b.raw("\n            </div>\n            <p class=\"sv-meta\">");
        b.text(Nat.toText(memberCount));
        b.raw(" ");
        b.text(plural(memberCount, "member", "members"));
        b.raw(" · ");
        b.text(Html.unquote(debug_show(channels.size())));
        b.raw(" ");
        b.text(plural(channels.size(), "channel", "channels"));
        b.raw(" · created ");
        b.text(createdRel);
        b.raw("</p>\n            <p class=\"sv-role\">Your role: <strong>");
        b.text(myRole);
        b.raw("</strong></p>\n        </div>\n        <div class=\"sv-head-actions\">\n            ");
        if (isMember) {
          b.raw("\n                ");
          if (isOwner) {
            b.raw("\n                    <span class=\"sv-owner-note\">You own this server</span>\n                ");
          } else {
            b.raw("\n                    <button class=\"sv-btn sv-btn-ghost\" data-mv-handler=\"leave\" data-mv-event=\"click\">Leave server</button>\n                ");
          };
          b.raw("\n            ");
        } else {
          b.raw("\n                <button class=\"sv-btn sv-btn-primary\" data-mv-handler=\"join\" data-mv-event=\"click\">Join server</button>\n            ");
        };
        b.raw("\n        </div>\n    </div>\n\n    <div class=\"sv-layout\">\n        <section class=\"sv-col-main\">\n            <div class=\"bz-card sv-panel\">\n                <div class=\"sv-panel-head\">\n                    <h2>Channels</h2>\n                    <span class=\"sv-count\">");
        b.text(Html.unquote(debug_show(channels.size())));
        b.raw("</span>\n                </div>\n\n                ");
        if (channels.size() == 0) {
          b.raw("\n                    <p class=\"sv-empty\">No channels yet. ");
          if (canMod) {
            b.raw(" Create the first one below. ");
          } else {
            b.raw(" A moderator can create channels. ");
          };
          b.raw("</p>\n                ");
        } else {
          b.raw("\n                    <ul class=\"sv-channels\">\n                        ");
          for (c in (channels).vals()) {
            b.raw("\n                            <li class=\"sv-channel\">\n                                <a class=\"sv-channel-link\" href=\"/channel/");
            b.text(Html.unquote(debug_show(c.id)));
            b.raw("\">\n                                    <span class=\"sv-hash\">#</span><span class=\"sv-cname\">");
            b.text(Html.unquote(debug_show(c.name)));
            b.raw("</span>\n                                </a>\n                                <span class=\"sv-channel-meta\">\n                                    ");
            if (isLocked(c.id)) {
              b.raw(" <span class=\"sv-lockchip sv-lockchip-sm\">🔒 locked</span> ");
            };
            b.raw("\n                                    <span class=\"sv-msgcount\">");
            b.text(Nat.toText(msgCount(c.id)));
            b.raw(" msgs</span>\n                                </span>\n                                ");
            if (canMod) {
              b.raw("\n                                    <span class=\"sv-channel-mod\">\n                                        ");
              if (isLocked(c.id)) {
                b.raw("\n                                            <button class=\"sv-chip-btn\" data-mv-handler=\"unlock\" data-mv-event=\"click\"");
                b.attr("data-mv-arg0", Html.unquote(debug_show(c.id)));
                b.raw(">Unlock</button>\n                                        ");
              } else {
                b.raw("\n                                            <button class=\"sv-chip-btn\" data-mv-handler=\"lock\" data-mv-event=\"click\"");
                b.attr("data-mv-arg0", Html.unquote(debug_show(c.id)));
                b.raw(">Lock</button>\n                                        ");
              };
              b.raw("\n                                    </span>\n                                ");
            };
            b.raw("\n                            </li>\n                        ");
          };
          b.raw("\n                    </ul>\n                ");
        };
        b.raw("\n\n                ");
        if (canMod) {
          b.raw("\n                    <form novalidate class=\"sv-channel-form\" data-mv-handler=\"createChannel\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
          b.attr("data-mv-token", ctx.mintToken("createChannel", "channelName"));
          b.raw(" data-mv-schema=\"channelName\">\n                        ");
          if (mvErrors.size() > 0) {
            b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
            for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
            b.raw("</ul></div>");
          };
          b.raw("\n                        <div class=\"sv-channel-form-row\">\n                            <div class=\"mv-field\"><label>New channel name *</label><input type=\"text\" class=\"mv-input\" name=\"channelName\" data-mv-key=\"channelName\" required");
          b.attr("value", channelName);
          b.raw(">");
          for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "channelName") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
          b.raw("</div>\n                            <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Add channel</button>\n                        </div>\n                        <p class=\"sv-hint\">Lowercase letters, numbers, - and _ only (max 20 chars).</p>\n                    </form>\n                ");
        };
        b.raw("\n            </div>\n\n            ");
        if (canMod) {
          b.raw("\n                <div class=\"bz-card sv-panel sv-modpanel\">\n                    <div class=\"sv-panel-head\">\n                        <h2>Moderation</h2>\n                        <span class=\"sv-modtag\">");
          b.text(myRole);
          b.raw(" tools</span>\n                    </div>\n                    <p class=\"sv-modnote\">You can moderate this server. Lock channels above to stop non-mods from posting, and manage member roles in the rail.</p>\n                </div>\n            ");
        };
        b.raw("\n        </section>\n\n        <aside class=\"sv-col-rail\">\n            <div class=\"bz-card sv-panel\">\n                <div class=\"sv-panel-head\">\n                    <h2>Members</h2>\n                    <span class=\"sv-count\">");
        b.text(Nat.toText(memberCount));
        b.raw("</span>\n                </div>\n                ");
        if (memberRows.size() == 0) {
          b.raw("\n                    <p class=\"sv-empty\">No members yet.</p>\n                ");
        } else {
          b.raw("\n                    <ul class=\"sv-members\">\n                        ");
          for (mr in (memberRows).vals()) {
            b.raw("\n                            <li class=\"sv-member\">\n                                <span class=\"sv-ava\">");
            b.text(avatarOf(mr.principal));
            b.raw("</span>\n                                <span class=\"sv-member-main\">\n                                    <span class=\"sv-member-handle\">");
            b.text(handleOf(mr.principal));
            b.raw("</span>\n                                    <span class=\"sv-member-role sv-role-");
            b.text(roleClass(mr.principal));
            b.raw("\">");
            b.text(roleLabel(mr.principal));
            b.raw("</span>\n                                </span>\n                                ");
            if (canAdmin) {
              b.raw("\n                                    ");
              if (isOwnerPrincipal(mr.principal)) {
                b.raw("\n                                        <span class=\"sv-member-actions sv-owner-pill\">Owner</span>\n                                    ");
              } else {
                b.raw("\n                                        <span class=\"sv-member-actions\">\n                                            ");
                if (isMod(mr.principal)) {
                  b.raw("\n                                                <button class=\"sv-chip-btn\" data-mv-handler=\"revoke\" data-mv-event=\"click\"");
                  b.attr("data-mv-arg0", pidText(mr.principal));
                  b.raw(">Revoke</button>\n                                            ");
                } else {
                  b.raw("\n                                                <button class=\"sv-chip-btn\" data-mv-handler=\"makeMod\" data-mv-event=\"click\"");
                  b.attr("data-mv-arg0", pidText(mr.principal));
                  b.raw(">Make mod</button>\n                                            ");
                };
                b.raw("\n                                            ");
                if (isOwner) {
                  b.raw("\n                                                ");
                  if (isAdminPrincipal(mr.principal)) {
                    b.raw("\n                                                    <button class=\"sv-chip-btn\" data-mv-handler=\"revoke\" data-mv-event=\"click\"");
                    b.attr("data-mv-arg0", pidText(mr.principal));
                    b.raw(">Demote</button>\n                                                ");
                  } else {
                    b.raw("\n                                                    <button class=\"sv-chip-btn\" data-mv-handler=\"makeAdmin\" data-mv-event=\"click\"");
                    b.attr("data-mv-arg0", pidText(mr.principal));
                    b.raw(">Make admin</button>\n                                                ");
                  };
                  b.raw("\n                                            ");
                };
                b.raw("\n                                        </span>\n                                    ");
              };
              b.raw("\n                                ");
            };
            b.raw("\n                            </li>\n                        ");
          };
          b.raw("\n                    </ul>\n                ");
        };
        b.raw("\n            </div>\n        </aside>\n    </div>\n");
      };
      b.raw("\n\n<style>\n    .sv-missing { text-align:center; padding:2.5rem 1.2rem; }\n    .sv-missing-ico { font-size:2.4rem; }\n    .sv-missing a { color:var(--bz-accent); font-weight:600; }\n\n    .sv-head { padding:1.2rem 1.3rem; display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; margin-bottom:1.25rem; }\n    .sv-title-row { display:flex; align-items:center; gap:.6rem; flex-wrap:wrap; }\n    .sv-title-row h1 { margin:0; font-size:1.6rem; letter-spacing:-.02em; }\n    .sv-meta { margin:.45rem 0 .15rem; color:var(--mv-text-soft); font-size:.9rem; }\n    .sv-role { margin:0; color:var(--mv-text-soft); font-size:.85rem; }\n    .sv-role strong { color:var(--mv-text); }\n\n    .sv-badge { font-size:.72rem; font-weight:700; padding:.2rem .55rem; border-radius:999px;\n        text-transform:uppercase; letter-spacing:.03em; }\n    .sv-badge-discussion { background:#ede9fe; color:#6d28d9; }\n    .sv-badge-forum { background:#dbeafe; color:#1d4ed8; }\n    .sv-badge-feed { background:#fce7f3; color:#be185d; }\n    .sv-lockchip { font-size:.74rem; font-weight:600; color:#92400e; background:#fef3c7; padding:.16rem .45rem; border-radius:999px; }\n    .sv-lockchip-sm { font-size:.68rem; }\n\n    .sv-btn { font-size:.85rem; font-weight:700; padding:.5rem .9rem; border-radius:10px; cursor:pointer; border:1px solid transparent; }\n    .sv-btn-primary { background:var(--bz-accent); color:#fff; }\n    .sv-btn-primary:hover { filter:brightness(1.08); }\n    .sv-btn-ghost { background:transparent; border-color:var(--mv-border); color:var(--mv-text); }\n    .sv-btn-ghost:hover { background:var(--mv-muted); }\n    .sv-owner-note { font-size:.82rem; color:var(--mv-text-soft); }\n\n    .sv-layout { display:grid; grid-template-columns:1fr 300px; gap:1.25rem; align-items:start; }\n    .sv-col-main { display:flex; flex-direction:column; gap:1.25rem; min-width:0; }\n    .sv-panel { padding:1.1rem 1.2rem; }\n    .sv-panel-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:.8rem; }\n    .sv-panel-head h2 { margin:0; font-size:1.1rem; }\n    .sv-count { font-size:.78rem; font-weight:700; color:var(--mv-text-soft); background:var(--mv-muted); padding:.16rem .5rem; border-radius:999px; }\n    .sv-modtag { font-size:.72rem; font-weight:700; color:#6d28d9; background:#ede9fe; padding:.16rem .5rem; border-radius:999px; }\n    .sv-empty { color:var(--mv-text-soft); font-size:.9rem; margin:0; }\n\n    .sv-channels { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:.2rem; }\n    .sv-channel { display:flex; align-items:center; gap:.6rem; padding:.5rem .6rem; border-radius:9px; }\n    .sv-channel:hover { background:var(--mv-muted); }\n    .sv-channel-link { display:flex; align-items:baseline; gap:.15rem; text-decoration:none; color:var(--mv-text); font-weight:600; }\n    .sv-channel-link:hover .sv-cname { color:var(--bz-accent); }\n    .sv-hash { color:var(--mv-text-soft); font-weight:700; }\n    .sv-channel-meta { margin-left:auto; display:flex; align-items:center; gap:.5rem; }\n    .sv-msgcount { font-size:.76rem; color:var(--mv-text-soft); }\n    .sv-channel-mod { display:flex; gap:.3rem; }\n\n    .sv-channel-form { margin-top:1rem; padding-top:1rem; border-top:1px solid var(--mv-border); }\n    .sv-channel-form-row { display:flex; gap:.6rem; align-items:end; }\n    .sv-hint { margin:.4rem 0 0; font-size:.76rem; color:var(--mv-text-soft); }\n\n    .sv-modpanel { background:linear-gradient(180deg, rgba(109,40,217,.04), transparent); }\n    .sv-modnote { margin:0; color:var(--mv-text-soft); font-size:.88rem; }\n\n    .sv-members { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:.35rem; }\n    .sv-member { display:flex; align-items:center; gap:.55rem; padding:.4rem .35rem; border-radius:9px; }\n    .sv-member:hover { background:var(--mv-muted); }\n    .sv-ava { width:30px; height:30px; border-radius:50%; background:var(--mv-muted); display:grid; place-items:center; font-size:1.05rem; flex:none; }\n    .sv-member-main { display:flex; flex-direction:column; min-width:0; }\n    .sv-member-handle { font-weight:700; font-size:.9rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }\n    .sv-member-role { font-size:.7rem; font-weight:700; }\n    .sv-role-owner { color:#b45309; }\n    .sv-role-admin { color:#6d28d9; }\n    .sv-role-moderator { color:#1d4ed8; }\n    .sv-role-member { color:var(--mv-text-soft); }\n    .sv-member-actions { margin-left:auto; display:flex; gap:.25rem; }\n    .sv-owner-pill { font-size:.7rem; font-weight:700; color:#b45309; background:#fef3c7; padding:.14rem .45rem; border-radius:999px; }\n\n    .sv-chip-btn { font-size:.72rem; font-weight:700; padding:.22rem .5rem; border-radius:7px; cursor:pointer;\n        border:1px solid var(--mv-border); background:var(--mv-surface); color:var(--mv-text); }\n    .sv-chip-btn:hover { background:var(--bz-accent); color:#fff; border-color:var(--bz-accent); }\n\n    @media (max-width: 860px) {\n        .sv-layout { grid-template-columns:1fr; }\n        .sv-head { flex-direction:column; }\n    }\n</style>\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); Html.unquote(debug_show(serverName # " — Bzzz server")) };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); { title = Html.unquote(debug_show(serverName # " — Bzzz server")); description = Html.unquote(debug_show(serverName # " on Bzzz — channels, members, roles and moderation for a Discord-style community running on the Internet Computer.")); canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      id := mvNat(mvParamGet(ctx, "id"));
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "channelName")) { case (?mvV) { channelName := mvV }; case null {} };
      switch mvH {
        case "join" { join(ctx) };
        case "leave" { leave(ctx) };
        case "createChannel" { createChannel(ctx) };
        case "lock" { lock(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "unlock" { unlock(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "makeMod" { makeMod(ctx, (if (mvArgs.size() > 0) mvArgs[0] else "")) };
        case "makeAdmin" { makeAdmin(ctx, (if (mvArgs.size() > 0) mvArgs[0] else "")) };
        case "revoke" { revoke(ctx, (if (mvArgs.size() > 0) mvArgs[0] else "")) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Servers.mview
  // ===== Page: Servers (/servers) =====
  let ServersPage = object {
    var serverList = Servers.servers();
    var bound : Bool = false;
    var me : Principal = Principal.fromText("2vxsx-fae");
    var myHandle : Text = "";
    var name : Text = "";
    var kind : Text = "Discussion";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        me := ctx.caller;
        bound := Identity.isBound(ctx.caller);
        myHandle := Identity.handleOf(ctx.caller);
        serverList := Servers.servers();
    };
    func summaryOf(id : Nat) : Text { Servers.summaryOf(id) };
    func isMemberOf(id : Nat) : Bool { Servers.isMember(id, me) };
    func isOwnerOf(id : Nat) : Bool { Servers.isOwner(id, me) };
    func roleOf(id : Nat) : Text { Servers.roleLabel(id, me) };
    func plural(n : Nat, one : Text, many : Text) : Text {
        if (n == 1) one else many;
    };
    func create(ctx : Context) : () {
         mvErrors.clear(); if (name == "") { mvErrors.add(("name", "Give your server a name.")) }; if (name.size() < 2) { mvErrors.add(("name", "Server name must be at least 2 characters.")) }; if (mvErrors.size() > 0) { return }; 
        let newId = if (kind == "Forum") {
            Servers.createServer(ctx.caller, name, #Forum);
        } else if (kind == "Feed") {
            Servers.createServer(ctx.caller, name, #Feed);
        } else {
            Servers.createServer(ctx.caller, name, #Discussion);
        };
        ignore Servers.joinAs(ctx.caller, newId, Identity.handleOf(ctx.caller));
        serverList := Servers.servers();
        name := "";
        toast("Server created!");
    };
    func join(ctx : Context, id : Nat) : () {
        ignore Servers.joinAs(ctx.caller, id, Identity.handleOf(ctx.caller));
        serverList := Servers.servers();
        toast("Joined the server.");
    };
    func leave(ctx : Context, id : Nat) : () {
        ignore Servers.leave(ctx.caller, id);
        serverList := Servers.servers();
        toast("Left the server.");
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<div class=\"srv-head\">\n    <div>\n        <h1>Servers</h1>\n        <p class=\"srv-sub\">");
      b.text(Html.unquote(debug_show(serverList.size())));
      b.raw(" ");
      b.text(plural(serverList.size(), "community", "communities"));
      b.raw(" on Bzzz · pick one to jump into its channels.</p>\n    </div>\n</div>\n\n");
      if (not bound) {
        b.raw("\n    <div class=\"bz-card srv-notice\">\n        <p>You are browsing as a guest. <a href=\"/me\">Claim a handle</a> to create servers and join the conversation.</p>\n    </div>\n");
      };
      b.raw("\n\n<div class=\"bz-card srv-create\">\n    <h3>Create a server</h3>\n    <form novalidate data-mv-handler=\"create\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
      b.attr("data-mv-token", ctx.mintToken("create", "kind,name"));
      b.raw(" data-mv-schema=\"kind,name\">\n        ");
      if (mvErrors.size() > 0) {
        b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
        for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
        b.raw("</ul></div>");
      };
      b.raw("\n        <div class=\"srv-create-grid\">\n            <div class=\"mv-field\"><label>Server name *</label><input type=\"text\" class=\"mv-input\" name=\"name\" data-mv-key=\"name\" required");
      b.attr("value", name);
      b.raw(">");
      for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "name") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
      b.raw("</div>\n            <div class=\"srv-field\">\n                <span class=\"srv-label\">Kind</span>\n                <select name=\"kind\" class=\"srv-select\">\n                    <option value=\"Discussion\">Discussion (channels &amp; chat)</option>\n                    <option value=\"Forum\">Forum (topics &amp; replies)</option>\n                    <option value=\"Feed\">Feed (timeline)</option>\n                </select>\n            </div>\n        </div>\n        <div class=\"srv-create-actions\">\n            <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Create server</button>\n        </div>\n    </form>\n</div>\n\n");
      if (serverList.size() == 0) {
        b.raw("\n    <div class=\"bz-card srv-empty\">\n        <div class=\"srv-empty-ico\">💬</div>\n        <h3>No servers yet</h3>\n        <p>Be the first to start a community. Create a server above.</p>\n    </div>\n");
      } else {
        b.raw("\n    <div class=\"srv-grid\">\n        ");
        for (s in (serverList).vals()) {
          b.raw("\n            <article class=\"bz-card srv-card\">\n                <div class=\"srv-card-top\">\n                    <a class=\"srv-name\" href=\"/servers/");
          b.text(Html.unquote(debug_show(s.id)));
          b.raw("\">");
          b.text(Html.unquote(debug_show(s.name)));
          b.raw("</a>\n                    ");
          switch (s.kind) {
            case (#Discussion) {
              b.raw(" <span class=\"srv-badge srv-badge-discussion\">Discussion</span> ");
            };
            case (#Forum) {
              b.raw(" <span class=\"srv-badge srv-badge-forum\">Forum</span> ");
            };
            case (#Feed) {
              b.raw(" <span class=\"srv-badge srv-badge-feed\">Feed</span> ");
            };
          };
          b.raw("\n                </div>\n                <p class=\"srv-summary\">");
          b.text(summaryOf(s.id));
          b.raw("</p>\n                <div class=\"srv-card-foot\">\n                    <span class=\"srv-role\">");
          b.text(roleOf(s.id));
          b.raw("</span>\n                    ");
          if (isMemberOf(s.id)) {
            b.raw("\n                        ");
            if (isOwnerOf(s.id)) {
              b.raw("\n                            <span class=\"srv-owner-note\">You own this server</span>\n                        ");
            } else {
              b.raw("\n                            <button class=\"srv-btn srv-btn-ghost\" data-mv-handler=\"leave\" data-mv-event=\"click\"");
              b.attr("data-mv-arg0", Html.unquote(debug_show(s.id)));
              b.raw(">Leave</button>\n                        ");
            };
            b.raw("\n                    ");
          } else {
            b.raw("\n                        <button class=\"srv-btn srv-btn-primary\" data-mv-handler=\"join\" data-mv-event=\"click\"");
            b.attr("data-mv-arg0", Html.unquote(debug_show(s.id)));
            b.raw(">Join</button>\n                    ");
          };
          b.raw("\n                    <a class=\"srv-btn srv-btn-link\" href=\"/servers/");
          b.text(Html.unquote(debug_show(s.id)));
          b.raw("\">Open →</a>\n                </div>\n            </article>\n        ");
        };
        b.raw("\n    </div>\n");
      };
      b.raw("\n\n<style>\n    .srv-head { display:flex; align-items:flex-end; justify-content:space-between; gap:1rem; margin-bottom:1rem; }\n    .srv-head h1 { margin:0 0 .2rem; font-size:1.7rem; letter-spacing:-.02em; }\n    .srv-sub { margin:0; color:var(--mv-text-soft); }\n    .srv-notice { padding:.85rem 1.1rem; margin-bottom:1rem; }\n    .srv-notice p { margin:0; color:var(--mv-text-soft); }\n    .srv-notice a { color:var(--bz-accent); font-weight:600; }\n\n    .srv-create { padding:1.1rem 1.2rem; margin-bottom:1.5rem; }\n    .srv-create h3 { margin:0 0 .8rem; font-size:1.1rem; }\n    .srv-create-grid { display:grid; grid-template-columns:2fr 1fr; gap:1rem; align-items:end; }\n    .srv-field { display:flex; flex-direction:column; gap:.35rem; }\n    .srv-label { font-size:.82rem; font-weight:600; color:var(--mv-text-soft); }\n    .srv-select { padding:.55rem .65rem; border:1px solid var(--mv-border); border-radius:10px;\n        background:var(--mv-surface); font-size:.92rem; color:var(--mv-text); }\n    .srv-create-actions { margin-top:.9rem; }\n\n    .srv-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:1rem; }\n    .srv-card { padding:1.1rem 1.2rem; display:flex; flex-direction:column; gap:.6rem; }\n    .srv-card-top { display:flex; align-items:center; justify-content:space-between; gap:.6rem; }\n    .srv-name { font-size:1.12rem; font-weight:800; color:var(--mv-text); text-decoration:none; letter-spacing:-.01em; }\n    .srv-name:hover { color:var(--bz-accent); }\n    .srv-summary { margin:0; color:var(--mv-text-soft); font-size:.88rem; }\n\n    .srv-badge { font-size:.72rem; font-weight:700; padding:.2rem .5rem; border-radius:999px; white-space:nowrap;\n        text-transform:uppercase; letter-spacing:.03em; }\n    .srv-badge-discussion { background:#ede9fe; color:#6d28d9; }\n    .srv-badge-forum { background:#dbeafe; color:#1d4ed8; }\n    .srv-badge-feed { background:#fce7f3; color:#be185d; }\n\n    .srv-card-foot { display:flex; align-items:center; gap:.55rem; flex-wrap:wrap; margin-top:.2rem;\n        padding-top:.7rem; border-top:1px solid var(--mv-border); }\n    .srv-role { font-size:.74rem; font-weight:700; color:var(--mv-text-soft); background:var(--mv-muted);\n        padding:.16rem .5rem; border-radius:999px; }\n    .srv-owner-note { font-size:.78rem; color:var(--mv-text-soft); }\n\n    .srv-btn { font-size:.82rem; font-weight:700; padding:.4rem .75rem; border-radius:9px; cursor:pointer;\n        border:1px solid transparent; text-decoration:none; }\n    .srv-btn-primary { background:var(--bz-accent); color:#fff; }\n    .srv-btn-primary:hover { filter:brightness(1.08); }\n    .srv-btn-ghost { background:transparent; border-color:var(--mv-border); color:var(--mv-text); }\n    .srv-btn-ghost:hover { background:var(--mv-muted); }\n    .srv-btn-link { margin-left:auto; background:transparent; color:var(--bz-accent); padding:.4rem .3rem; }\n\n    .srv-empty { text-align:center; padding:2.5rem 1.2rem; }\n    .srv-empty-ico { font-size:2.4rem; }\n    .srv-empty h3 { margin:.5rem 0 .3rem; }\n    .srv-empty p { margin:0; color:var(--mv-text-soft); }\n\n    @media (max-width: 600px) {\n        .srv-create-grid { grid-template-columns:1fr; }\n    }\n</style>\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Servers — Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Servers — Bzzz"; description = "Browse and create Bzzz servers (guilds) — Discord-style communities with channels, roles and moderation, running on-chain on the Internet Computer."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "name")) { case (?mvV) { name := mvV }; case null {} };
      switch mvH {
        case "create" { create(ctx) };
        case "join" { join(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "leave" { leave(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Status.mview
  // ===== Page: Status (/status) =====
  let StatusPage = object {
    var bound : Bool = false;
    var statuses : [Status.Update] = [];
    var activeCount : Nat = 0;
    var authorCount : Nat = 0;
    var authorWord : Text = "authors";
    var defaultColor : Text = "#075E54";
    var text : Text = "";
    var swatches : [Swatch] = [
        { hex = "#075E54"; name = "Teal"; checked = true },
        { hex = "#6d28d9"; name = "Violet"; checked = false },
        { hex = "#c026d3"; name = "Magenta"; checked = false },
        { hex = "#0088CC"; name = "Blue"; checked = false },
        { hex = "#F15A24"; name = "Orange"; checked = false },
        { hex = "#009900"; name = "Green"; checked = false },
        { hex = "#c80001"; name = "Red"; checked = false },
        { hex = "#1a1a1a"; name = "Ink"; checked = false },
    ];
    type Swatch = { hex : Text; name : Text; checked : Bool };
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        bound := Identity.isBound(ctx.caller);
        statuses := Status.active();
        activeCount := Status.activeCount();
        authorCount := Status.authorCount();
        authorWord := if (authorCount == 1) "author" else "authors";
    };
    func previewText() : Text {
        if (Text.trim(text, #char ' ') == "") "Your status will look like this" else text;
    };
    func formField(ctx : Context, key : Text) : Text {
        switch (Array.find<(Text, Text)>(ctx.form, func((k, _v) : (Text, Text)) : Bool { k == key })) {
            case (?kv) kv.1;
            case null "";
        };
    };
    func post(ctx : Context) : () {
         mvErrors.clear(); if (text == "") { mvErrors.add(("text", "Write something to share.")) }; if (text.size() < 1) { mvErrors.add(("text", "Write something to share.")) }; if (mvErrors.size() > 0) { return }; 
        let handle = Identity.handleOf(ctx.caller);
        let picked = formField(ctx, "color");
        let chosen = if (Text.trim(picked, #char ' ') == "") defaultColor else picked;
        let _id = Status.postStatus(ctx.caller, handle, text, chosen);
        text := "";
        statuses := Status.active();
        activeCount := Status.activeCount();
        authorCount := Status.authorCount();
        authorWord := if (authorCount == 1) "author" else "authors";
        toast("Status posted — live for 24 hours.");
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<section class=\"bz-status-head\">\n    <div>\n        <h1>Status</h1>\n        <p>Share a thought that vanishes in 24 hours. ");
      b.text(Nat.toText(activeCount));
      b.raw(" live · ");
      b.text(Nat.toText(authorCount));
      b.raw(" ");
      b.text(authorWord);
      b.raw("</p>\n    </div>\n</section>\n\n");
      if (bound) {
        b.raw("\n    <div class=\"bz-card bz-status-compose\">\n        <h3>Post a status</h3>\n        <form novalidate data-mv-handler=\"post\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("post", "color,color,text"));
        b.raw(" data-mv-schema=\"color,color,text\">\n            ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n            <div class=\"mv-field\"><label>What's on your mind? *</label><textarea class=\"mv-textarea\" name=\"text\" data-mv-key=\"text\" required>");
        b.text(text);
        b.raw("</textarea>");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "text") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n\n            <div class=\"bz-swatches\" role=\"radiogroup\" aria-label=\"Status color\">\n                ");
        for (sw in (swatches).vals()) {
          b.raw("\n                    <label class=\"bz-swatch\" style=\"--sw:");
          b.text(Html.unquote(debug_show(sw.hex)));
          b.raw("\"");
          b.attr("title", Html.unquote(debug_show(sw.name)));
          b.raw(">\n                        ");
          if (sw.checked) {
            b.raw("\n                            <input type=\"radio\" name=\"color\"");
            b.attr("value", Html.unquote(debug_show(sw.hex)));
            b.raw(" checked>\n                        ");
          } else {
            b.raw("\n                            <input type=\"radio\" name=\"color\"");
            b.attr("value", Html.unquote(debug_show(sw.hex)));
            b.raw(">\n                        ");
          };
          b.raw("\n                        <span class=\"bz-swatch-dot\"></span>\n                    </label>\n                ");
        };
        b.raw("\n            </div>\n\n            <div class=\"bz-preview\" style=\"--c:");
        b.text(defaultColor);
        b.raw("\">\n                <span class=\"bz-preview-label\">Preview</span>\n                <span class=\"bz-preview-text\">");
        b.text(previewText());
        b.raw("</span>\n            </div>\n\n            <div class=\"bz-status-actions\">\n                <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Share status</button>\n            </div>\n        </form>\n    </div>\n");
      } else {
        b.raw("\n    <div class=\"mv-alert mv-alert-info\">\n        Pick a handle on your <a href=\"/me\">profile</a> to post a status.\n    </div>\n");
      };
      b.raw("\n\n<h2 class=\"bz-section-title\">Live now</h2>\n\n");
      if ((statuses.size() == 0)) {
        b.raw("\n    <div class=\"bz-empty bz-card\">\n        <div class=\"bz-empty-ico\">📭</div>\n        <p>No active statuses. Be the first to share something today.</p>\n    </div>\n");
      } else {
        b.raw("\n    <div class=\"bz-status-grid\">\n        ");
        for (s in (statuses).vals()) {
          b.raw("\n            <article class=\"bz-status-card\" style=\"--c:");
          b.text(s.color);
          b.raw("\">\n                <header class=\"bz-status-author\">\n                    <span class=\"bz-status-ava\">");
          b.text(Html.unquote(debug_show(Identity.avatarOf(s.author))));
          b.raw("</span>\n                    <div class=\"bz-status-meta\">\n                        <span class=\"bz-status-handle\">@");
          b.text(s.authorHandle);
          b.raw("</span>\n                        <span class=\"bz-status-time\">");
          b.text(Html.unquote(debug_show(Status.relativeTime(s.at))));
          b.raw("</span>\n                    </div>\n                    <span class=\"bz-status-kind\">");
          b.text(Html.unquote(debug_show(Status.kindLabel(s.kind))));
          b.raw("</span>\n                </header>\n                ");
          switch (s.kind) {
            case (#Text) {
              b.raw("\n                        <p class=\"bz-status-text\">");
              b.text(Html.unquote(debug_show(s.text)));
              b.raw("</p>\n                    ");
            };
            case (#Image) {
              b.raw("\n                        <div class=\"bz-status-image\">\n                            <span class=\"bz-status-image-ico\">🖼️</span>\n                            <span class=\"bz-status-image-ref\">");
              b.text(Html.unquote(debug_show(s.text)));
              b.raw("</span>\n                        </div>\n                    ");
            };
          };
          b.raw("\n                <footer class=\"bz-status-foot\">\n                    <span class=\"bz-status-expires\">⏳ ");
          b.text(Html.unquote(debug_show(Status.timeLeft(s.expiresAt))));
          b.raw("</span>\n                    <span class=\"bz-status-views\">");
          b.text(Html.unquote(debug_show(s.views)));
          b.raw(" views</span>\n                </footer>\n            </article>\n        ");
        };
        b.raw("\n    </div>\n");
      };
      b.raw("\n\n<style>\n    .bz-status-head { margin-bottom: 1.25rem; }\n    .bz-status-head h1 { margin: 0 0 .25rem; font-size: 1.6rem; letter-spacing: -.02em; }\n    .bz-status-head p { margin: 0; color: var(--mv-text-soft); font-size: .9rem; }\n\n    .bz-status-compose { padding: 1.2rem 1.3rem; margin-bottom: 1.5rem; }\n    .bz-status-compose h3 { margin: 0 0 .8rem; font-size: 1.1rem; }\n\n    .bz-swatches { display: flex; flex-wrap: wrap; gap: .55rem; margin: .8rem 0 .2rem; }\n    .bz-swatch { position: relative; cursor: pointer; display: inline-flex; }\n    .bz-swatch input { position: absolute; opacity: 0; width: 0; height: 0; }\n    .bz-swatch-dot { width: 30px; height: 30px; border-radius: 50%; background: var(--sw);\n        display: inline-block; box-shadow: 0 0 0 2px var(--mv-surface), 0 0 0 3px var(--mv-border);\n        transition: transform .1s ease, box-shadow .1s ease; }\n    .bz-swatch:hover .bz-swatch-dot { transform: scale(1.08); }\n    .bz-swatch input:checked + .bz-swatch-dot { box-shadow: 0 0 0 2px var(--mv-surface), 0 0 0 4px var(--bz-accent); transform: scale(1.12); }\n\n    .bz-preview { margin: .9rem 0 .2rem; border-radius: 12px; padding: 1.5rem 1.2rem; min-height: 64px;\n        background: var(--c); color: #fff; display: flex; flex-direction: column; gap: .35rem;\n        text-shadow: 0 1px 2px rgba(0,0,0,.25); }\n    .bz-preview-label { font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; opacity: .8; }\n    .bz-preview-text { font-size: 1.25rem; font-weight: 700; word-break: break-word; }\n\n    .bz-status-actions { margin-top: 1rem; }\n\n    .bz-section-title { font-size: 1.15rem; margin: 0 0 1rem; }\n\n    .bz-empty { text-align: center; padding: 2.5rem 1.5rem; color: var(--mv-text-soft); }\n    .bz-empty-ico { font-size: 2.2rem; }\n    .bz-empty p { margin: .6rem 0 0; }\n\n    .bz-status-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; }\n    .bz-status-card { border-radius: 14px; overflow: hidden; background: var(--c); color: #fff;\n        box-shadow: 0 6px 20px rgba(16,16,40,.16); display: flex; flex-direction: column;\n        min-height: 180px; text-shadow: 0 1px 2px rgba(0,0,0,.25); }\n    .bz-status-author { display: flex; align-items: center; gap: .55rem; padding: .85rem 1rem .25rem; }\n    .bz-status-ava { width: 34px; height: 34px; border-radius: 50%; background: rgba(255,255,255,.25);\n        display: grid; place-items: center; font-size: 1.1rem; text-shadow: none; flex: 0 0 auto; }\n    .bz-status-meta { display: flex; flex-direction: column; line-height: 1.2; min-width: 0; }\n    .bz-status-handle { font-weight: 700; font-size: .92rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n    .bz-status-time { font-size: .75rem; opacity: .85; }\n    .bz-status-kind { margin-left: auto; font-size: .68rem; text-transform: uppercase; letter-spacing: .06em;\n        background: rgba(255,255,255,.22); padding: .15rem .45rem; border-radius: 999px; flex: 0 0 auto; }\n\n    .bz-status-text { flex: 1; margin: 0; padding: .6rem 1rem 1rem; font-size: 1.35rem; font-weight: 700;\n        line-height: 1.3; word-break: break-word; display: flex; align-items: center; }\n    .bz-status-image { flex: 1; margin: 0; padding: .6rem 1rem 1rem; display: flex; flex-direction: column;\n        align-items: center; justify-content: center; gap: .4rem; }\n    .bz-status-image-ico { font-size: 2rem; }\n    .bz-status-image-ref { font-size: .78rem; opacity: .85; word-break: break-all; text-align: center; }\n\n    .bz-status-foot { display: flex; align-items: center; justify-content: space-between;\n        padding: .6rem 1rem .85rem; font-size: .76rem; background: rgba(0,0,0,.16); }\n    .bz-status-expires { font-weight: 600; }\n    .bz-status-views { opacity: .85; }\n\n    @media (max-width: 560px) {\n        .bz-status-grid { grid-template-columns: 1fr; }\n    }\n</style>\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Status — ephemeral 24-hour updates on Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Status — ephemeral 24-hour updates on Bzzz"; description = "Post a colorful 24-hour status update and see what everyone on Bzzz is sharing right now — disappearing automatically after a day."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "text")) { case (?mvV) { text := mvV }; case null {} };
      switch mvH {
        case "post" { post(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Thread.mview
  // ===== Page: Thread (/messages/{id:Nat}) =====
  let ThreadPage = object {
    var id : Nat = 0;
    var me : Principal = Principal.fromText("2vxsx-fae");
    var member : Bool = false;
    var title : Text = "Conversation";
    var headerAvatar : Text = "🔒";
    var msgs : [Messenger.DmMessage] = [];
    var draft : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        me := ctx.caller;
        member := Messenger.isMember(id, ctx.caller);
        if (member) {
            // Title: group name, else the direct peer's handle.
            switch (Messenger.directPeer(ctx.caller, id)) {
                case (?p) {
                    title := Identity.handleOf(p);
                    headerAvatar := Identity.avatarOf(p);
                };
                case null {
                    title := Messenger.titleFor(id, "");
                    headerAvatar := "👥";
                };
            };
            msgs := Messenger.messages(ctx.caller, id);
            // Viewing a conversation marks every message in it as read.
            Messenger.markRead(ctx.caller, id);
        };
    };
    func bubbleSide(m : Messenger.DmMessage) : Text {
        if (m.sender == me) { "bz-th-sent" } else { "bz-th-recv" };
    };
    func relTime(m : Messenger.DmMessage) : Text { Messenger.relativeTime(m.at) };
    func sendMsg(ctx : Context) : () {
         mvErrors.clear(); if (draft == "") { mvErrors.add(("draft", "Type a message to send.")) }; if (mvErrors.size() > 0) { return }; 
        // NOTE: a real client encrypts `draft` (X25519 + AEAD) into a base64
        // envelope BEFORE calling send; here we store the text as the ciphertext
        // field so the flow is honest end-to-end without a browser crypto stub.
        let handle = Identity.handleOf(ctx.caller);
        let id2 = Messenger.send(ctx.caller, id, handle, draft);
        draft := "";
        if (id2 == 0) {
            toast("Couldn't send — you're not a member of this conversation.");
        } else {
            scrollTo("#bz-th-stream");
        };
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      id := mvNat(mvParamGet(ctx, "id"));
      b.raw("<div class=\"bz-th-wrap\">\n    ");
      if ((not member)) {
        b.raw("\n        <div class=\"bz-card bz-th-empty\">\n            <div class=\"bz-th-empty-ico\">🔒</div>\n            <h3>Conversation unavailable</h3>\n            <p>This conversation doesn't exist, or you're not a member of it. <a href=\"/messages\">Back to Messages</a>.</p>\n        </div>\n    ");
      } else {
        b.raw("\n        <header class=\"bz-th-head\">\n            <a class=\"bz-th-back\" href=\"/messages\" aria-label=\"Back to conversations\">←</a>\n            <span class=\"bz-th-avatar\">");
        b.text(headerAvatar);
        b.raw("</span>\n            <div class=\"bz-th-titlewrap\">\n                <h1 class=\"bz-th-title\">");
        b.text(title);
        b.raw("</h1>\n                <span class=\"bz-th-e2ee\">🔒 End-to-end encrypted</span>\n            </div>\n        </header>\n\n        <div class=\"bz-th-banner\">\n            🔒 Messages here are end-to-end encrypted. The on-chain canister only ever stores opaque ciphertext envelopes — decryption happens entirely in your client.\n        </div>\n\n        <div class=\"bz-th-stream\" id=\"bz-th-stream\">\n            ");
        if ((msgs.size() == 0)) {
          b.raw("\n                <div class=\"bz-th-empty-inline\">\n                    <div class=\"bz-th-empty-ico\">💬</div>\n                    <p>No messages yet. Say hello — your message is encrypted before it leaves your device.</p>\n                </div>\n            ");
        } else {
          b.raw("\n                ");
          for (m in (msgs).vals()) {
            b.raw("\n                    <div class=\"bz-th-msg ");
            b.text(bubbleSide(m));
            b.raw("\">\n                        ");
            if ((m.sender != me)) {
              b.raw("\n                            <span class=\"bz-th-sender\">");
              b.text(m.senderHandle);
              b.raw("</span>\n                        ");
            };
            b.raw("\n                        <div class=\"bz-th-bubble\">\n                            <span class=\"bz-th-cipher\" title=\"Stored ciphertext envelope — decrypted client-side\">");
            b.text(m.ciphertext);
            b.raw("</span>\n                        </div>\n                        <span class=\"bz-th-meta\">\n                            <span class=\"bz-th-lock\" title=\"End-to-end encrypted — decrypted in your client\">🔒</span>\n                            ");
            b.text(relTime(m));
            b.raw("\n                        </span>\n                    </div>\n                ");
          };
          b.raw("\n            ");
        };
        b.raw("\n        </div>\n\n        <form novalidate class=\"bz-th-composer\" data-mv-handler=\"sendMsg\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("sendMsg", "draft"));
        b.raw(" data-mv-schema=\"draft\">\n            ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n            <div class=\"bz-th-composer-row\">\n                <div class=\"mv-field\"><label>Message *</label><input type=\"text\" class=\"mv-input\" name=\"draft\" data-mv-key=\"draft\" required");
        b.attr("value", draft);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "draft") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n                <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Send</button>\n            </div>\n            <p class=\"bz-th-composer-note\">🔒 In production this body is encrypted client-side (X25519 / AEAD) before sending; the canister stores only the ciphertext envelope.</p>\n        </form>\n    ");
      };
      b.raw("\n</div>\n\n<style>\n    .bz-th-wrap { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; min-height: 60vh; }\n\n    .bz-th-head { display: flex; align-items: center; gap: .75rem; padding: .6rem 0 .9rem; }\n    .bz-th-back { text-decoration: none; font-size: 1.4rem; color: var(--mv-text-soft); line-height: 1;\n        width: 36px; height: 36px; display: grid; place-items: center; border-radius: 8px; }\n    .bz-th-back:hover { background: var(--mv-muted); color: var(--mv-text); }\n    .bz-th-avatar { flex: none; width: 44px; height: 44px; border-radius: 50%; background: var(--mv-muted);\n        display: grid; place-items: center; font-size: 1.35rem; }\n    .bz-th-titlewrap { display: flex; flex-direction: column; gap: .1rem; }\n    .bz-th-title { margin: 0; font-size: 1.2rem; letter-spacing: -.01em; }\n    .bz-th-e2ee { color: #047857; font-size: .76rem; font-weight: 600; }\n\n    .bz-th-banner { background: #e7f8ef; border: 1px solid #a7f3d0; color: #065f46; border-radius: 12px;\n        padding: .65rem .85rem; font-size: .8rem; line-height: 1.45; margin-bottom: 1rem; }\n\n    .bz-th-stream { flex: 1; display: flex; flex-direction: column; gap: .7rem; padding: .25rem 0 1rem; }\n    .bz-th-msg { display: flex; flex-direction: column; max-width: 78%; }\n    .bz-th-recv { align-self: flex-start; align-items: flex-start; }\n    .bz-th-sent { align-self: flex-end; align-items: flex-end; }\n    .bz-th-sender { font-size: .74rem; font-weight: 700; color: var(--bz-accent, #6d28d9); margin: 0 .35rem .15rem; }\n    .bz-th-bubble { padding: .55rem .8rem; border-radius: 16px; font-size: .92rem; line-height: 1.4; word-break: break-word; }\n    .bz-th-recv .bz-th-bubble { background: var(--mv-surface); border: 1px solid var(--mv-border); border-bottom-left-radius: 4px; color: var(--mv-text); }\n    .bz-th-sent .bz-th-bubble { background: var(--bz-accent, #6d28d9); color: #fff; border-bottom-right-radius: 4px; }\n    .bz-th-cipher { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: .86rem; }\n    .bz-th-meta { font-size: .7rem; color: var(--mv-text-soft); margin: .2rem .35rem 0; display: inline-flex; align-items: center; gap: .25rem; }\n    .bz-th-lock { font-size: .72rem; }\n\n    .bz-th-empty-inline { text-align: center; color: var(--mv-text-soft); margin: auto; padding: 2rem 1rem; }\n    .bz-th-empty-inline p { max-width: 36ch; margin: .5rem auto 0; }\n    .bz-th-empty-ico { font-size: 2.2rem; }\n\n    .bz-th-empty { text-align: center; padding: 2.5rem 1.5rem; }\n    .bz-th-empty h3 { margin: .6rem 0 .3rem; }\n    .bz-th-empty p { margin: 0 auto; color: var(--mv-text-soft); max-width: 42ch; }\n\n    .bz-th-composer { position: sticky; bottom: 0; background: var(--mv-muted); padding: .75rem 0 .5rem; border-top: 1px solid var(--mv-border); }\n    .bz-th-composer-row { display: flex; align-items: flex-end; gap: .6rem; }\n    .bz-th-composer-row > :first-child { flex: 1; }\n    .bz-th-composer-note { margin: .4rem 0 0; font-size: .72rem; color: var(--mv-text-soft); }\n\n    @media (max-width: 640px) {\n        .bz-th-msg { max-width: 88%; }\n    }\n</style>\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); "Conversation — end-to-end encrypted on Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); { title = "Conversation — end-to-end encrypted on Bzzz"; description = "A private, end-to-end encrypted conversation on Bzzz. Message bodies are stored as ciphertext envelopes and decrypted only in your client — never on-chain."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      id := mvNat(mvParamGet(ctx, "id"));
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "draft")) { case (?mvV) { draft := mvV }; case null {} };
      switch mvH {
        case "sendMsg" { sendMsg(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };


