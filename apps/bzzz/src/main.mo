          b.raw(">");
          b.text(ago(p.at));
          b.raw("</span>");
          b.raw("\n                            ");
          b.raw("</div>");
          b.raw("\n                            ");
          b.raw("<p");
          b.raw(" class=\"bz-post-text\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(p.text)));
          b.raw("</p>");
          b.raw("\n                            ");
          b.raw("<div");
          b.raw(" class=\"bz-post-meta\"");
          b.raw(">");
          b.raw("\n                                ");
          b.raw("<span");
          b.raw(">");
          b.raw("❤️ ");
          b.text(Html.unquote(debug_show(p.likes)));
          b.raw("</span>");
          b.raw("\n                                ");
          b.raw("<span");
          b.raw(">");
          b.raw("🔁 ");
          b.text(Html.unquote(debug_show(p.reposts)));
          b.raw("</span>");
          b.raw("\n                                ");
          b.raw("<span");
          b.raw(">");
          b.raw("💬 ");
          b.text(Html.unquote(debug_show(p.replyCount)));
          b.raw("</span>");
          b.raw("\n                            ");
          b.raw("</div>");
          b.raw("\n                        ");
          b.raw("</article>");
          b.raw("\n                    ");
        };
        b.raw("\n                ");
        b.raw("</div>");
        b.raw("\n            ");
      } else {
        b.raw("\n                ");
        b.raw("<div");
        b.raw(" class=\"bz-empty\"");
        b.raw(">");
        b.raw("\n                    ");
        b.raw("<div");
        b.raw(" class=\"bz-empty-ico\"");
        b.raw(">");
        b.raw("⚡");
        b.raw("</div>");
        b.raw("\n                    ");
        b.raw("<p");
        b.raw(">");
        b.raw("You haven't posted yet.");
        b.raw("</p>");
        b.raw("\n                    ");
        b.raw("<a");
        b.raw(" class=\"bz-link\"");
        b.raw(" href=\"/feed\"");
        b.raw(">");
        b.raw("Write your first post →");
        b.raw("</a>");
        b.raw("\n                ");
        b.raw("</div>");
        b.raw("\n            ");
      };
      b.raw("\n        ");
      b.raw("</div>");
      b.raw("\n    ");
      b.raw("</div>");
      b.raw("\n");
      b.raw("</div>");
      b.raw("\n\n");
      b.raw("<style");
      b.raw(">");
      b.raw("\n    .bz-prof-head { display: flex; align-items: center; gap: 1.1rem; padding: 1.4rem 1.5rem; }\n    .bz-prof-ava { width: 76px; height: 76px; border-radius: 50%; flex: 0 0 auto;\n        background: linear-gradient(135deg, #6d28d9, #c026d3); color: #fff;\n        display: grid; place-items: center; font-size: 2.2rem;\n        box-shadow: 0 6px 18px rgba(109,40,217,.28); }\n    .bz-prof-id h1 { margin: 0 0 .15rem; font-size: 1.55rem; letter-spacing: -.02em; }\n    .bz-prof-handle { margin: 0; color: var(--bz-accent); font-weight: 600; font-size: .95rem; }\n    .bz-prof-bio { margin: .5rem 0 0; color: var(--mv-text); font-size: .95rem; max-width: 60ch; }\n    .bz-prof-bio-empty { color: var(--mv-text-soft); font-style: italic; }\n\n    .bz-prof-stats { display: flex; gap: .75rem; margin: 1rem 0 1.25rem; }\n    .bz-stat { flex: 1; background: var(--mv-surface); border: 1px solid var(--mv-border);\n        border-radius: 12px; padding: .85rem 1rem; text-align: center; box-shadow: var(--mv-shadow); }\n    .bz-stat-n { display: block; font-size: 1.4rem; font-weight: 800; letter-spacing: -.02em; }\n    .bz-stat-l { display: block; color: var(--mv-text-soft); font-size: .78rem; text-transform: uppercase; letter-spacing: .04em; }\n\n    .bz-prof-grid { display: grid; grid-template-columns: minmax(280px, 380px) 1fr; gap: 1rem; align-items: start; }\n    .bz-prof-col { display: flex; flex-direction: column; gap: 1rem; }\n    .bz-prof-panel { padding: 1.2rem 1.3rem; }\n    .bz-prof-panel h2 { margin: 0 0 .25rem; font-size: 1.1rem; }\n    .bz-panel-sub { margin: 0 0 .9rem; color: var(--mv-text-soft); font-size: .85rem; }\n    .bz-form-actions { margin-top: .7rem; }\n\n    .bz-posts { display: flex; flex-direction: column; gap: .25rem; }\n    .bz-post { padding: .9rem .25rem; border-top: 1px solid var(--mv-border); }\n    .bz-post:first-child { border-top: none; padding-top: .25rem; }\n    .bz-post-head { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }\n    .bz-post-ava { width: 30px; height: 30px; border-radius: 50%; background: var(--mv-muted);\n        display: grid; place-items: center; font-size: 1rem; }\n    .bz-post-name { font-weight: 700; }\n    .bz-post-handle, .bz-post-time, .bz-post-dot { color: var(--mv-text-soft); font-size: .85rem; }\n    .bz-post-text { margin: .4rem 0 .5rem; white-space: pre-wrap; line-height: 1.45; }\n    .bz-post-meta { display: flex; gap: 1.1rem; color: var(--mv-text-soft); font-size: .85rem; }\n\n    .bz-empty { text-align: center; padding: 2rem 1rem; color: var(--mv-text-soft); }\n    .bz-empty-ico { font-size: 2rem; margin-bottom: .4rem; }\n    .bz-link { color: var(--bz-accent); font-weight: 600; text-decoration: none; }\n    .bz-link:hover { text-decoration: underline; }\n\n    @media (max-width: 820px) {\n        .bz-prof-grid { grid-template-columns: 1fr; }\n    }\n    @media (max-width: 520px) {\n        .bz-prof-head { flex-direction: column; text-align: center; }\n        .bz-prof-stats { flex-direction: row; }\n    }\n");
      b.raw("</style>");
      b.raw("\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Your profile — Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Your profile — Bzzz"; description = "Set your Bzzz handle, display name and bio, see your follower and following counts, and read back everything you have posted to the feed."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "bio")) { case (?mvV) { bio := mvV }; case null {} };
      switch (mvFormGet(ctx, "display")) { case (?mvV) { display := mvV }; case null {} };
      switch (mvFormGet(ctx, "handle")) { case (?mvV) { handle := mvV }; case null {} };
      switch mvH {
        case "saveIdentity" { saveIdentity(ctx) };
        case "saveBio" { saveBio(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Messages.mview
  // ===== Page: Messages (/messages) =====
  let MessagesPage = object {
    var bound : Bool = false;
    var me : Principal = Principal.fromText("2vxsx-fae");
    var convos : [Messenger.Conversation] = [];
    var peerHandle : Text = "";
    var groupName : Text = "";
    var groupHandles : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        me := ctx.caller;
        bound := Identity.isBound(ctx.caller);
        convos := Messenger.conversations(ctx.caller);
    };
    func rowTitle(c : Messenger.Conversation) : Text {
        switch (c.kind) {
            case (#Group) { Messenger.titleFor(c.id, "") };
            case (#Direct) {
                switch (Messenger.directPeer(me, c.id)) {
                    case (?p) { Identity.handleOf(p) };
                    case null { c.name };
                };
            };
        };
    };
    func rowAvatar(c : Messenger.Conversation) : Text {
        switch (c.kind) {
            case (#Group) { "👥" };
            case (#Direct) {
                switch (Messenger.directPeer(me, c.id)) {
                    case (?p) { Identity.avatarOf(p) };
                    case null { "🔒" };
                };
            };
        };
    };
    func rowKind(c : Messenger.Conversation) : Text {
        switch (c.kind) {
            case (#Group) { Nat.toText(Messenger.memberCount(c.id)) # " members · encrypted" };
            case (#Direct) { "Direct message · encrypted" };
        };
    };
    func rowTime(c : Messenger.Conversation) : Text { Messenger.relativeTime(c.lastAt) };
    func rowUnread(c : Messenger.Conversation) : Nat { Messenger.unreadCount(me, c.id) };
    func startChat(ctx : Context) : () {
         mvErrors.clear(); if (peerHandle == "") { mvErrors.add(("peerHandle", "Enter a handle to message.")) }; if (peerHandle.size() < 2) { mvErrors.add(("peerHandle", "Handles are at least 2 characters.")) }; if (mvErrors.size() > 0) { return }; 
        switch (Identity.byHandleLookup(peerHandle)) {
            case null { toast("No Bzzz user with that handle."); };
            case (?prof) {
                if (prof.principal == ctx.caller) {
                    toast("You can't start a chat with yourself.");
                } else {
                    let id = Messenger.startDirect(ctx.caller, prof.principal);
                    peerHandle := "";
                    toast("Chat with " # prof.handle # " ready.");
                };
            };
        };
    };
    func startGroupChat(ctx : Context) : () {
         mvErrors.clear(); if (groupName == "") { mvErrors.add(("groupName", "Give your group a name.")) }; if (mvErrors.size() > 0) { return }; 
        // Resolve comma-separated handles to principals; skip unknown / self.
        var members : [Principal] = [];
        var missing : Nat = 0;
        for (raw in Text.split(groupHandles, #char ',')) {
            let h = Text.trim(raw, #char ' ');
            if (h != "") {
                switch (Identity.byHandleLookup(h)) {
                    case null { missing += 1; };
                    case (?prof) {
                        if (prof.principal != ctx.caller) {
                            members := Array.append(members, [prof.principal]);
                        };
                    };
                };
            };
        };
        let id = Messenger.startGroup(ctx.caller, groupName, members);
        groupName := "";
        groupHandles := "";
        if (missing > 0) {
            toast("Group created — " # Nat.toText(missing) # " handle(s) weren't found.");
        } else {
            toast("Group created.");
        };
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<div");
      b.raw(" class=\"bz-msg-wrap\"");
      b.raw(">");
      b.raw("\n    ");
      b.raw("<header");
      b.raw(" class=\"bz-msg-head\"");
      b.raw(">");
      b.raw("\n        ");
      b.raw("<div");
      b.raw(">");
      b.raw("\n            ");
      b.raw("<h1");
      b.raw(">");
      b.raw("Messages");
      b.raw("</h1>");
      b.raw("\n            ");
      b.raw("<p");
      b.raw(" class=\"bz-msg-sub\"");
      b.raw(">");
      b.raw("🔒 End-to-end encrypted · 1:1 &amp; group chats");
      b.raw("</p>");
      b.raw("\n        ");
      b.raw("</div>");
      b.raw("\n        ");
      b.raw("<span");
      b.raw(" class=\"bz-msg-e2ee\"");
      b.raw(">");
      b.raw("End-to-end encrypted");
      b.raw("</span>");
      b.raw("\n    ");
      b.raw("</header>");
      b.raw("\n\n    ");
      if (bound) {
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-msg-new\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"bz-card bz-msg-newcard\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<h3");
        b.raw(">");
        b.raw("New chat");
        b.raw("</h3>");
        b.raw("\n                ");
        b.raw("<p");
        b.raw(" class=\"bz-msg-hint\"");
        b.raw(">");
        b.raw("Start a direct message by their Bzzz handle.");
        b.raw("</p>");
        b.raw("\n                ");
        b.raw("<form");
        b.raw(" novalidate");
        b.raw(" data-mv-handler=\"startChat\" data-mv-event=\"submit\"");
        b.raw(" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("startChat", "peerHandle"));
        b.raw(" data-mv-schema=\"peerHandle\"");
        b.raw(">");
        b.raw("\n                    ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n                    ");
        b.raw("<div class=\"mv-field\">");
        b.raw("<label>Handle *</label>");
        b.raw("<input type=\"text\" class=\"mv-input\" name=\"peerHandle\" data-mv-key=\"peerHandle\"");
        b.raw(" required");
        b.attr("value", peerHandle);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "peerHandle") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>");
        b.raw("\n                    ");
        b.raw("<div");
        b.raw(" class=\"bz-msg-actions\"");
        b.raw(">");
        b.raw("\n                        ");
        b.raw("<button type=\"submit\" class=\"mv-btn mv-btn-primary\"");
        b.raw(">");
        b.raw("Start chat");
        b.raw("</button>");
        b.raw("\n                    ");
        b.raw("</div>");
        b.raw("\n                ");
        b.raw("</form>");
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"bz-card bz-msg-newcard\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<h3");
        b.raw(">");
        b.raw("New group");
        b.raw("</h3>");
        b.raw("\n                ");
        b.raw("<p");
        b.raw(" class=\"bz-msg-hint\"");
        b.raw(">");
        b.raw("Name your group and add members by handle (comma separated).");
        b.raw("</p>");
        b.raw("\n                ");
        b.raw("<form");
        b.raw(" novalidate");
        b.raw(" data-mv-handler=\"startGroupChat\" data-mv-event=\"submit\"");
        b.raw(" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("startGroupChat", "groupHandles,groupName"));
        b.raw(" data-mv-schema=\"groupHandles,groupName\"");
        b.raw(">");
        b.raw("\n                    ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n                    ");
        b.raw("<div class=\"mv-field\">");
        b.raw("<label>Group name *</label>");
        b.raw("<input type=\"text\" class=\"mv-input\" name=\"groupName\" data-mv-key=\"groupName\"");
        b.raw(" required");
        b.attr("value", groupName);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "groupName") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>");
        b.raw("\n                    ");
        b.raw("<div class=\"mv-field\">");
        b.raw("<label>Member handles</label>");
        b.raw("<input type=\"text\" class=\"mv-input\" name=\"groupHandles\" data-mv-key=\"groupHandles\"");
        b.attr("value", groupHandles);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "groupHandles") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>");
        b.raw("\n                    ");
        b.raw("<div");
        b.raw(" class=\"bz-msg-actions\"");
        b.raw(">");
        b.raw("\n                        ");
        b.raw("<button type=\"submit\" class=\"mv-btn mv-btn-primary\"");
        b.raw(">");
        b.raw("Create group");
        b.raw("</button>");
        b.raw("\n                    ");
        b.raw("</div>");
        b.raw("\n                ");
        b.raw("</form>");
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n\n        ");
        b.raw("<h2");
        b.raw(" class=\"bz-msg-listtitle\"");
        b.raw(">");
        b.raw("Conversations");
        b.raw("</h2>");
        b.raw("\n        ");
        if ((convos.size() == 0)) {
          b.raw("\n            ");
          b.raw("<div");
          b.raw(" class=\"bz-card bz-msg-empty\"");
          b.raw(">");
          b.raw("\n                ");
          b.raw("<div");
          b.raw(" class=\"bz-msg-empty-ico\"");
          b.raw(">");
          b.raw("💬");
          b.raw("</div>");
          b.raw("\n                ");
          b.raw("<h3");
          b.raw(">");
          b.raw("No conversations yet");
          b.raw("</h3>");
          b.raw("\n                ");
          b.raw("<p");
          b.raw(">");
          b.raw("Start a direct message or create a group above to begin chatting securely.");
          b.raw("</p>");
          b.raw("\n            ");
          b.raw("</div>");
          b.raw("\n        ");
        } else {
          b.raw("\n            ");
          b.raw("<ul");
          b.raw(" class=\"bz-msg-list\"");
          b.raw(">");
          b.raw("\n                ");
          for (c in (convos).vals()) {
            b.raw("\n                    ");
            b.raw("<li");
            b.raw(">");
            b.raw("\n                        ");
            b.raw("<a");
            b.raw(" class=\"bz-msg-row\"");
            b.raw(" href=\"");
            b.raw("/messages/");
            b.text(Html.unquote(debug_show(c.id)));
            b.raw("\"");
            b.raw(">");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(" class=\"bz-msg-avatar\"");
            b.raw(">");
            b.text(rowAvatar(c));
            b.raw("</span>");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(" class=\"bz-msg-body\"");
            b.raw(">");
            b.raw("\n                                ");
            b.raw("<span");
            b.raw(" class=\"bz-msg-toprow\"");
            b.raw(">");
            b.raw("\n                                    ");
            b.raw("<span");
            b.raw(" class=\"bz-msg-name\"");
            b.raw(">");
            b.text(rowTitle(c));
            b.raw("</span>");
            b.raw("\n                                    ");
            b.raw("<span");
            b.raw(" class=\"bz-msg-time\"");
            b.raw(">");
            b.text(rowTime(c));
            b.raw("</span>");
            b.raw("\n                                ");
            b.raw("</span>");
            b.raw("\n                                ");
            b.raw("<span");
            b.raw(" class=\"bz-msg-preview\"");
            b.raw(">");
            b.text(rowKind(c));
            b.raw("</span>");
            b.raw("\n                            ");
            b.raw("</span>");
            b.raw("\n                            ");
            if ((rowUnread(c) > 0)) {
              b.raw("\n                                ");
              b.raw("<span");
              b.raw(" class=\"bz-msg-badge\"");
              b.raw(">");
              b.text(Nat.toText(rowUnread(c)));
              b.raw("</span>");
              b.raw("\n                            ");
            };
            b.raw("\n                        ");
            b.raw("</a>");
            b.raw("\n                    ");
            b.raw("</li>");
            b.raw("\n                ");
          };
          b.raw("\n            ");
          b.raw("</ul>");
          b.raw("\n        ");
        };
        b.raw("\n    ");
      } else {
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-card bz-msg-empty\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"bz-msg-empty-ico\"");
        b.raw(">");
        b.raw("🔒");
        b.raw("</div>");
        b.raw("\n            ");
        b.raw("<h3");
        b.raw(">");
        b.raw("Pick a handle first");
        b.raw("</h3>");
        b.raw("\n            ");
        b.raw("<p");
        b.raw(">");
        b.raw("You need a Bzzz handle before you can send encrypted messages. ");
        b.raw("<a");
        b.raw(" href=\"/\"");
        b.raw(">");
        b.raw("Claim your handle");
        b.raw("</a>");
        b.raw(" to get started.");
        b.raw("</p>");
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n    ");
      };
      b.raw("\n");
      b.raw("</div>");
      b.raw("\n\n");
      b.raw("<style");
      b.raw(">");
      b.raw("\n    .bz-msg-wrap { max-width: 720px; margin: 0 auto; }\n    .bz-msg-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1.25rem; }\n    .bz-msg-head h1 { margin: 0; font-size: 1.7rem; letter-spacing: -.02em; }\n    .bz-msg-sub { margin: .25rem 0 0; color: var(--mv-text-soft); font-size: .9rem; }\n    .bz-msg-e2ee { flex: none; background: #e7f8ef; color: #047857; border: 1px solid #a7f3d0;\n        font-size: .72rem; font-weight: 700; padding: .3rem .6rem; border-radius: 999px; white-space: nowrap; }\n\n    .bz-msg-new { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.75rem; }\n    .bz-msg-newcard { padding: 1.1rem 1.2rem; }\n    .bz-msg-newcard h3 { margin: 0 0 .25rem; font-size: 1.02rem; }\n    .bz-msg-hint { margin: 0 0 .7rem; color: var(--mv-text-soft); font-size: .82rem; }\n    .bz-msg-actions { margin-top: .6rem; }\n\n    .bz-msg-listtitle { font-size: 1.05rem; margin: 0 0 .6rem; color: var(--mv-text-soft); text-transform: uppercase; letter-spacing: .04em; }\n\n    .bz-msg-list { list-style: none; margin: 0; padding: 0; border: 1px solid var(--mv-border);\n        border-radius: 14px; overflow: hidden; background: var(--mv-surface); box-shadow: var(--mv-shadow); }\n    .bz-msg-list li + li .bz-msg-row { border-top: 1px solid var(--mv-border); }\n    .bz-msg-row { display: flex; align-items: center; gap: .85rem; padding: .85rem 1rem; text-decoration: none; color: inherit;\n        transition: background .12s ease; }\n    .bz-msg-row:hover { background: var(--mv-muted); }\n    .bz-msg-avatar { flex: none; width: 46px; height: 46px; border-radius: 50%; background: var(--mv-muted);\n        display: grid; place-items: center; font-size: 1.4rem; }\n    .bz-msg-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: .15rem; }\n    .bz-msg-toprow { display: flex; align-items: baseline; justify-content: space-between; gap: .6rem; }\n    .bz-msg-name { font-weight: 700; font-size: .98rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n    .bz-msg-time { flex: none; color: var(--mv-text-soft); font-size: .76rem; }\n    .bz-msg-preview { color: var(--mv-text-soft); font-size: .84rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n    .bz-msg-badge { flex: none; min-width: 22px; height: 22px; padding: 0 .4rem; border-radius: 999px;\n        background: var(--bz-accent, #6d28d9); color: #fff; font-size: .76rem; font-weight: 700;\n        display: grid; place-items: center; }\n\n    .bz-msg-empty { text-align: center; padding: 2.5rem 1.5rem; }\n    .bz-msg-empty-ico { font-size: 2.4rem; }\n    .bz-msg-empty h3 { margin: .6rem 0 .3rem; }\n    .bz-msg-empty p { margin: 0 auto; color: var(--mv-text-soft); max-width: 42ch; }\n\n    @media (max-width: 640px) {\n        .bz-msg-new { grid-template-columns: 1fr; }\n        .bz-msg-head { flex-direction: column; gap: .5rem; }\n    }\n");
      b.raw("</style>");
      b.raw("\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Messages — end-to-end encrypted chats on Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Messages — end-to-end encrypted chats on Bzzz"; description = "Your private WhatsApp-style conversations on Bzzz: encrypted 1:1 direct messages and group chats, running entirely on-chain on the Internet Computer."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "groupHandles")) { case (?mvV) { groupHandles := mvV }; case null {} };
      switch (mvFormGet(ctx, "groupName")) { case (?mvV) { groupName := mvV }; case null {} };
      switch (mvFormGet(ctx, "peerHandle")) { case (?mvV) { peerHandle := mvV }; case null {} };
      switch mvH {
        case "startChat" { startChat(ctx) };
        case "startGroupChat" { startGroupChat(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Profile.mview
  // ===== Page: Profile (/u/{handle}) =====
  let ProfilePage = object {
    var handle : Text = "";
    var exists : Bool = false;
    var isSelf : Bool = false;
    var following : Bool = false;
    var handleText : Text = "";
    var display : Text = "";
    var bio : Text = "";
    var avatar : Text = "🐝";
    var pageTitle : Text = "Profile — Bzzz";
    var pageDesc : Text = "A Bzzz user profile — their posts, followers and bio.";
    var target : Principal = Principal.fromText("aaaaa-aa");
    var followers : Nat = 0;
    var followingN : Nat = 0;
    var postCount : Nat = 0;
    var posts : [Feed.FeedPost] = [];
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        load(ctx);
    };
    func load(ctx : Context) {
        handleText := handle;
        switch (Identity.byHandleLookup(handle)) {
            case (?p) {
                exists := true;
                handleText := p.handle;
                display := p.display;
                bio := p.bio;
                avatar := p.avatar;
                target := p.principal;
                isSelf := p.principal == ctx.caller;
                following := Feed.isFollowing(ctx.caller, p.principal);
                followers := Feed.followerCount(p.principal);
                followingN := Feed.followingCount(p.principal);
                posts := Feed.byAuthor(p.handle);
                postCount := posts.size();
                pageTitle := p.display # " (@" # p.handle # ") — Bzzz";
                pageDesc := p.display # " on Bzzz: " # Nat.toText(followers) # " followers, " # Nat.toText(postCount) # " posts." # (if (Text.size(p.bio) > 0) { " " # p.bio } else { "" });
            };
            case null {
                exists := false;
                posts := [];
                pageTitle := "Profile not found — Bzzz";
                pageDesc := "No Bzzz user with that handle yet.";
            };
        };
    };
    func ago(at : Int) : Text { Feed.relativeTime(at) };
    func toggleFollow(ctx : Context) : () {
        if (Feed.follow(ctx.caller, target)) {
            toast("Following " # display # ".");
        } else {
            toast("Unfollowed " # display # ".");
        };
        load(ctx);
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      handle := mvParamGet(ctx, "handle");
      if (exists) {
        b.raw("\n    ");
        b.raw("<section");
        b.raw(" class=\"bz-prof-head bz-card mv-anim-fadein\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-prof-ava\"");
        b.raw(">");
        b.text(avatar);
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-prof-id\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<h1");
        b.raw(">");
        b.text(display);
        b.raw("</h1>");
        b.raw("\n            ");
        b.raw("<p");
        b.raw(" class=\"bz-prof-handle\"");
        b.raw(">");
        b.raw("@");
        b.text(handleText);
        b.raw("</p>");
        b.raw("\n            ");
        if ((Text.size(bio) > 0)) {
          b.raw("\n                ");
          b.raw("<p");
          b.raw(" class=\"bz-prof-bio\"");
          b.raw(">");
          b.text(bio);
          b.raw("</p>");
          b.raw("\n            ");
        };
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n        ");
        if (isSelf) {
          b.raw("\n            ");
          b.raw("<a");
          b.raw(" class=\"bz-followbtn bz-followbtn-self\"");
          b.raw(" href=\"/me\"");
          b.raw(">");
          b.raw("Edit profile");
          b.raw("</a>");
          b.raw("\n        ");
        } else {
          b.raw("\n            ");
          b.raw("<form");
          b.raw(" novalidate");
          b.raw(" class=\"bz-followform\"");
          b.raw(" data-mv-handler=\"toggleFollow\" data-mv-event=\"submit\"");
          b.raw(" data-mv-secure=\"1\"");
          b.attr("data-mv-token", ctx.mintToken("toggleFollow", ""));
          b.raw(" data-mv-schema=\"\"");
          b.raw(">");
          b.raw("\n                ");
          if (following) {
            b.raw("\n                    ");
            b.raw("<button");
            b.raw(" type=\"submit\"");
            b.raw(" class=\"bz-followbtn bz-followbtn-on\"");
            b.raw(">");
            b.raw("Following");
            b.raw("</button>");
            b.raw("\n                ");
          } else {
            b.raw("\n                    ");
            b.raw("<button");
            b.raw(" type=\"submit\"");
            b.raw(" class=\"bz-followbtn\"");
            b.raw(">");
            b.raw("Follow");
            b.raw("</button>");
            b.raw("\n                ");
          };
          b.raw("\n            ");
          b.raw("</form>");
          b.raw("\n        ");
        };
        b.raw("\n    ");
        b.raw("</section>");
        b.raw("\n\n    ");
        b.raw("<div");
        b.raw(" class=\"bz-prof-stats\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-stat\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(" class=\"bz-stat-n\"");
        b.raw(">");
        b.text(Nat.toText(postCount));
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(" class=\"bz-stat-l\"");
        b.raw(">");
        b.raw("Posts");
        b.raw("</span>");
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-stat\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(" class=\"bz-stat-n\"");
        b.raw(">");
        b.text(Nat.toText(followers));
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(" class=\"bz-stat-l\"");
        b.raw(">");
        b.raw("Followers");
        b.raw("</span>");
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-stat\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(" class=\"bz-stat-n\"");
        b.raw(">");
        b.text(Nat.toText(followingN));
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(" class=\"bz-stat-l\"");
        b.raw(">");
        b.raw("Following");
        b.raw("</span>");
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n\n    ");
        b.raw("<div");
        b.raw(" class=\"bz-card bz-prof-panel\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<h2");
        b.raw(">");
        b.raw("Posts");
        b.raw("</h2>");
        b.raw("\n        ");
        if ((posts.size() > 0)) {
          b.raw("\n            ");
          b.raw("<div");
          b.raw(" class=\"bz-posts\"");
          b.raw(">");
          b.raw("\n                ");
          for (p in (posts).vals()) {
            b.raw("\n                    ");
            b.raw("<article");
            b.raw(" class=\"bz-post\"");
            b.raw(">");
            b.raw("\n                        ");
            b.raw("<div");
            b.raw(" class=\"bz-post-head\"");
            b.raw(">");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(" class=\"bz-post-ava\"");
            b.raw(">");
            b.text(avatar);
            b.raw("</span>");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(" class=\"bz-post-name\"");
            b.raw(">");
            b.text(display);
            b.raw("</span>");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(" class=\"bz-post-handle\"");
            b.raw(">");
            b.raw("@");
            b.text(handleText);
            b.raw("</span>");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(" class=\"bz-post-dot\"");
            b.raw(">");
            b.raw("·");
            b.raw("</span>");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(" class=\"bz-post-time\"");
            b.raw(">");
            b.text(ago(p.at));
            b.raw("</span>");
            b.raw("\n                        ");
            b.raw("</div>");
            b.raw("\n                        ");
            b.raw("<p");
            b.raw(" class=\"bz-post-text\"");
            b.raw(">");
            b.text(Html.unquote(debug_show(p.text)));
            b.raw("</p>");
            b.raw("\n                        ");
            b.raw("<div");
            b.raw(" class=\"bz-post-meta\"");
            b.raw(">");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(">");
            b.raw("❤️ ");
            b.text(Html.unquote(debug_show(p.likes)));
            b.raw("</span>");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(">");
            b.raw("🔁 ");
            b.text(Html.unquote(debug_show(p.reposts)));
            b.raw("</span>");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(">");
            b.raw("💬 ");
            b.text(Html.unquote(debug_show(p.replyCount)));
            b.raw("</span>");
            b.raw("\n                        ");
            b.raw("</div>");
            b.raw("\n                    ");
            b.raw("</article>");
            b.raw("\n                ");
          };
          b.raw("\n            ");
          b.raw("</div>");
          b.raw("\n        ");
        } else {
          b.raw("\n            ");
          b.raw("<div");
          b.raw(" class=\"bz-empty\"");
          b.raw(">");
          b.raw("\n                ");
          b.raw("<div");
          b.raw(" class=\"bz-empty-ico\"");
          b.raw(">");
          b.raw("⚡");
          b.raw("</div>");
          b.raw("\n                ");
          b.raw("<p");
          b.raw(">");
          b.text(display);
          b.raw(" hasn't posted anything yet.");
          b.raw("</p>");
          b.raw("\n            ");
          b.raw("</div>");
          b.raw("\n        ");
        };
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      } else {
        b.raw("\n    ");
        b.raw("<section");
        b.raw(" class=\"bz-prof-head bz-card mv-anim-fadein\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-prof-ava\"");
        b.raw(">");
        b.raw("❓");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-prof-id\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<h1");
        b.raw(">");
        b.raw("User not found");
        b.raw("</h1>");
        b.raw("\n            ");
        b.raw("<p");
        b.raw(" class=\"bz-prof-handle\"");
        b.raw(">");
        b.raw("No one on Bzzz has claimed @");
        b.text(handleText);
        b.raw(" yet.");
        b.raw("</p>");
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n    ");
        b.raw("</section>");
        b.raw("\n    ");
        b.raw("<div");
        b.raw(" class=\"bz-empty\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<a");
        b.raw(" class=\"bz-link\"");
        b.raw(" href=\"/feed\"");
        b.raw(">");
        b.raw("← Back to the feed");
        b.raw("</a>");
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      };
      b.raw("\n\n");
      b.raw("<style");
      b.raw(">");
      b.raw("\n    .bz-prof-head { display: flex; align-items: center; gap: 1.1rem; padding: 1.4rem 1.5rem; }\n    .bz-prof-ava { width: 76px; height: 76px; border-radius: 50%; flex: 0 0 auto;\n        background: linear-gradient(135deg, #6d28d9, #c026d3); color: #fff;\n        display: grid; place-items: center; font-size: 2.2rem;\n        box-shadow: 0 6px 18px rgba(109,40,217,.28); }\n    .bz-prof-id { flex: 1; }\n    .bz-prof-id h1 { margin: 0 0 .15rem; font-size: 1.55rem; letter-spacing: -.02em; }\n    .bz-prof-handle { margin: 0; color: var(--bz-accent); font-weight: 600; font-size: .95rem; }\n    .bz-prof-bio { margin: .5rem 0 0; color: var(--mv-text); font-size: .95rem; max-width: 60ch; }\n\n    .bz-followform { margin: 0; flex: 0 0 auto; }\n    .bz-followbtn { display: inline-block; border: 1px solid var(--bz-accent); background: var(--bz-accent);\n        color: #fff; font-weight: 700; font-size: .92rem; padding: .55rem 1.3rem; border-radius: 999px;\n        cursor: pointer; text-decoration: none; transition: background .12s ease, color .12s ease; }\n    .bz-followbtn:hover { background: #5b21b6; border-color: #5b21b6; }\n    .bz-followbtn-on { background: transparent; color: var(--bz-accent); }\n    .bz-followbtn-on:hover { background: #fde8ec; color: #c80001; border-color: #c80001; }\n    .bz-followbtn-self { background: transparent; color: var(--mv-text); border-color: var(--mv-border); }\n    .bz-followbtn-self:hover { background: var(--mv-muted); border-color: var(--mv-border); color: var(--mv-text); }\n\n    .bz-prof-stats { display: flex; gap: .75rem; margin: 1rem 0 1.25rem; }\n    .bz-stat { flex: 1; background: var(--mv-surface); border: 1px solid var(--mv-border);\n        border-radius: 12px; padding: .85rem 1rem; text-align: center; box-shadow: var(--mv-shadow); }\n    .bz-stat-n { display: block; font-size: 1.4rem; font-weight: 800; letter-spacing: -.02em; }\n    .bz-stat-l { display: block; color: var(--mv-text-soft); font-size: .78rem; text-transform: uppercase; letter-spacing: .04em; }\n\n    .bz-prof-panel { padding: 1.2rem 1.3rem; }\n    .bz-prof-panel h2 { margin: 0 0 .6rem; font-size: 1.1rem; }\n\n    .bz-posts { display: flex; flex-direction: column; gap: .25rem; }\n    .bz-post { padding: .9rem .25rem; border-top: 1px solid var(--mv-border); }\n    .bz-post:first-child { border-top: none; padding-top: .25rem; }\n    .bz-post-head { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }\n    .bz-post-ava { width: 30px; height: 30px; border-radius: 50%; background: var(--mv-muted);\n        display: grid; place-items: center; font-size: 1rem; }\n    .bz-post-name { font-weight: 700; }\n    .bz-post-handle, .bz-post-time, .bz-post-dot { color: var(--mv-text-soft); font-size: .85rem; }\n    .bz-post-text { margin: .4rem 0 .5rem; white-space: pre-wrap; line-height: 1.45; }\n    .bz-post-meta { display: flex; gap: 1.1rem; color: var(--mv-text-soft); font-size: .85rem; }\n\n    .bz-empty { text-align: center; padding: 2rem 1rem; color: var(--mv-text-soft); }\n    .bz-empty-ico { font-size: 2rem; margin-bottom: .4rem; }\n    .bz-link { color: var(--bz-accent); font-weight: 600; text-decoration: none; }\n    .bz-link:hover { text-decoration: underline; }\n\n    @media (max-width: 520px) {\n        .bz-prof-head { flex-direction: column; text-align: center; }\n    }\n");
      b.raw("</style>");
      b.raw("\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; handle := mvParamGet(ctx, "handle"); pageTitle };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; handle := mvParamGet(ctx, "handle"); { title = pageTitle; description = pageDesc; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; handle := mvParamGet(ctx, "handle"); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      handle := mvParamGet(ctx, "handle");
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch mvH {
        case "toggleFollow" { toggleFollow(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Server.mview
  // ===== Page: Server (/servers/{id:Nat}) =====
  let ServerPage = object {
    var id : Nat = 0;
    var exists : Bool = false;
    var serverName : Text = "Server";
    var kindLabel : Text = "";
    var kindClass : Text = "discussion";
    var private_ : Bool = false;
    var createdRel : Text = "";
    var memberCount : Nat = 0;
    var channels = Chat.listRooms(0);
    var memberRows = Servers.memberRecords(0);
    var isMember : Bool = false;
    var isOwner : Bool = false;
    var canMod : Bool = false;
    var canAdmin : Bool = false;
    var myRole : Text = "Member";
    var channelName : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func paramNat(ctx : Context, k : Text) : Nat {
        for ((kk, vv) in ctx.params.vals()) { if (kk == k) { return mvNat(vv) } };
        0;
    };
    func onLoad(ctx : Context) {
        id := paramNat(ctx, "id");
        switch (Servers.server(id)) {
            case null { exists := false };
            case (?s) {
                exists := true;
                serverName := s.name;
                kindLabel := Servers.kindLabel(s.kind);
                kindClass := (switch (s.kind) {
                    case (#Discussion) "discussion";
                    case (#Forum) "forum";
                    case (#Feed) "feed";
                });
                private_ := s.private_;
                createdRel := Servers.relativeTime(s.createdAt);
            };
        };
        memberCount := Servers.memberCount(id);
        memberRows := Servers.memberRecords(id);
        channels := Chat.listRooms(id);

        isMember := Servers.isMember(id, ctx.caller);
        isOwner := Servers.isOwner(id, ctx.caller);
        canMod := Servers.canModerate(id, ctx.caller);
        canAdmin := Servers.canAdmin(id, ctx.caller);
        myRole := Servers.roleLabel(id, ctx.caller);
    };
    func msgCount(rid : Nat) : Nat { Chat.messageCount(rid) };
    func isLocked(rid : Nat) : Bool { Servers.isLocked(rid) };
    func handleOf(p : Principal) : Text { Identity.handleOf(p) };
    func avatarOf(p : Principal) : Text { Identity.avatarOf(p) };
    func roleLabel(p : Principal) : Text { Servers.roleLabel(id, p) };
    func roleClass(p : Principal) : Text {
        switch (Servers.roleOf(id, p)) {
            case (#Owner) "owner";
            case (#Admin) "admin";
            case (#Moderator) "moderator";
            case (#None) "member";
        };
    };
    func isOwnerPrincipal(p : Principal) : Bool { Servers.isOwner(id, p) };
    func isAdminPrincipal(p : Principal) : Bool { Servers.roleOf(id, p) == #Admin };
    func isMod(p : Principal) : Bool {
        switch (Servers.roleOf(id, p)) {
            case (#Moderator) true;
            case (#Admin) true;
            case (_) false;
        };
    };
    func plural(n : Nat, one : Text, many : Text) : Text {
        if (n == 1) one else many;
    };
    func pidText(p : Principal) : Text { Principal.toText(p) };
    func join(ctx : Context) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.joinAs(ctx.caller, sid, Identity.handleOf(ctx.caller));
        toast("Joined the server.");
    };
    func leave(ctx : Context) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.leave(ctx.caller, sid);
        toast("Left the server.");
    };
    func createChannel(ctx : Context) : () {
         mvErrors.clear(); if (channelName == "") { mvErrors.add(("channelName", "Name the channel.")) }; if (channelName.size() < 2) { mvErrors.add(("channelName", "Channel name must be at least 2 characters.")) }; if (mvErrors.size() > 0) { return }; 
        let sid = paramNat(ctx, "id");
        let newRid = Chat.createRoom(channelName, sid);
        if (newRid == 0) {
            toast("Pick a valid channel name (a-z, 0-9, - or _).");
            return;
        };
        ignore Servers.addChannel(ctx.caller, sid, newRid);
        channelName := "";
        toast("Channel created.");
    };
    func lock(ctx : Context, rid : Nat) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.lock(ctx.caller, sid, rid, true);
        toast("Channel locked.");
    };
    func unlock(ctx : Context, rid : Nat) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.lock(ctx.caller, sid, rid, false);
        toast("Channel unlocked.");
    };
    func makeMod(ctx : Context, targetText : Text) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.grant(ctx.caller, sid, Principal.fromText(targetText), #Moderator);
        toast("Granted moderator.");
    };
    func makeAdmin(ctx : Context, targetText : Text) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.grant(ctx.caller, sid, Principal.fromText(targetText), #Admin);
        toast("Granted admin.");
    };
    func revoke(ctx : Context, targetText : Text) : () {
        let sid = paramNat(ctx, "id");
        ignore Servers.revoke(ctx.caller, sid, Principal.fromText(targetText));
        toast("Role revoked.");
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      id := mvNat(mvParamGet(ctx, "id"));
      if (not exists) {
        b.raw("\n    ");
        b.raw("<div");
        b.raw(" class=\"bz-card sv-missing\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"sv-missing-ico\"");
        b.raw(">");
        b.raw("🚫");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("<h2");
        b.raw(">");
        b.raw("Server not found");
        b.raw("</h2>");
        b.raw("\n        ");
        b.raw("<p");
        b.raw(">");
        b.raw("This server does not exist (or was deleted). ");
        b.raw("<a");
        b.raw(" href=\"/servers\"");
        b.raw(">");
        b.raw("Back to all servers");
        b.raw("</a>");
        b.raw(".");
        b.raw("</p>");
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      } else {
        b.raw("\n    ");
        b.raw("<div");
        b.raw(" class=\"sv-head bz-card\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"sv-head-main\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"sv-title-row\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<h1");
        b.raw(">");
        b.text(serverName);
        b.raw("</h1>");
        b.raw("\n                ");
        b.raw("<span");
        b.raw(" class=\"");
        b.raw("sv-badge sv-badge-");
        b.text(kindClass);
        b.raw("\"");
        b.raw(">");
        b.text(kindLabel);
        b.raw("</span>");
        b.raw("\n                ");
        if (private_) {
          b.raw("\n                    ");
          b.raw("<span");
          b.raw(" class=\"sv-lockchip\"");
          b.raw(">");
          b.raw("🔒 Private");
          b.raw("</span>");
          b.raw("\n                ");
        };
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n            ");
        b.raw("<p");
        b.raw(" class=\"sv-meta\"");
        b.raw(">");
        b.text(Nat.toText(memberCount));
        b.raw(" ");
        b.text(plural(memberCount, "member", "members"));
        b.raw(" · ");
        b.text(Html.unquote(debug_show(channels.size())));
        b.raw(" ");
        b.text(plural(channels.size(), "channel", "channels"));
        b.raw(" · created ");
        b.text(createdRel);
        b.raw("</p>");
        b.raw("\n            ");
        b.raw("<p");
        b.raw(" class=\"sv-role\"");
        b.raw(">");
        b.raw("Your role: ");
        b.raw("<strong");
        b.raw(">");
        b.text(myRole);
        b.raw("</strong>");
        b.raw("</p>");
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"sv-head-actions\"");
        b.raw(">");
        b.raw("\n            ");
        if (isMember) {
          b.raw("\n                ");
          if (isOwner) {
            b.raw("\n                    ");
            b.raw("<span");
            b.raw(" class=\"sv-owner-note\"");
            b.raw(">");
            b.raw("You own this server");
            b.raw("</span>");
            b.raw("\n                ");
          } else {
            b.raw("\n                    ");
            b.raw("<button");
            b.raw(" class=\"sv-btn sv-btn-ghost\"");
            b.raw(" data-mv-handler=\"leave\" data-mv-event=\"click\"");
            b.raw(">");
            b.raw("Leave server");
            b.raw("</button>");
            b.raw("\n                ");
          };
          b.raw("\n            ");
        } else {
          b.raw("\n                ");
          b.raw("<button");
          b.raw(" class=\"sv-btn sv-btn-primary\"");
          b.raw(" data-mv-handler=\"join\" data-mv-event=\"click\"");
          b.raw(">");
          b.raw("Join server");
          b.raw("</button>");
          b.raw("\n            ");
        };
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n\n    ");
        b.raw("<div");
        b.raw(" class=\"sv-layout\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<section");
        b.raw(" class=\"sv-col-main\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"bz-card sv-panel\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<div");
        b.raw(" class=\"sv-panel-head\"");
        b.raw(">");
        b.raw("\n                    ");
        b.raw("<h2");
        b.raw(">");
        b.raw("Channels");
        b.raw("</h2>");
        b.raw("\n                    ");
        b.raw("<span");
        b.raw(" class=\"sv-count\"");
        b.raw(">");
        b.text(Html.unquote(debug_show(channels.size())));
        b.raw("</span>");
        b.raw("\n                ");
        b.raw("</div>");
        b.raw("\n\n                ");
        if (channels.size() == 0) {
          b.raw("\n                    ");
          b.raw("<p");
          b.raw(" class=\"sv-empty\"");
          b.raw(">");
          b.raw("No channels yet. ");
          if (canMod) {
            b.raw(" Create the first one below. ");
          } else {
            b.raw(" A moderator can create channels. ");
          };
          b.raw("</p>");
          b.raw("\n                ");
        } else {
          b.raw("\n                    ");
          b.raw("<ul");
          b.raw(" class=\"sv-channels\"");
          b.raw(">");
          b.raw("\n                        ");
          for (c in (channels).vals()) {
            b.raw("\n                            ");
            b.raw("<li");
            b.raw(" class=\"sv-channel\"");
            b.raw(">");
            b.raw("\n                                ");
            b.raw("<a");
            b.raw(" class=\"sv-channel-link\"");
            b.raw(" href=\"");
            b.raw("/channel/");
            b.text(Html.unquote(debug_show(c.id)));
            b.raw("\"");
            b.raw(">");
            b.raw("\n                                    ");
            b.raw("<span");
            b.raw(" class=\"sv-hash\"");
            b.raw(">");
            b.raw("#");
            b.raw("</span>");
            b.raw("<span");
            b.raw(" class=\"sv-cname\"");
            b.raw(">");
            b.text(Html.unquote(debug_show(c.name)));
            b.raw("</span>");
            b.raw("\n                                ");
            b.raw("</a>");
            b.raw("\n                                ");
            b.raw("<span");
            b.raw(" class=\"sv-channel-meta\"");
            b.raw(">");
            b.raw("\n                                    ");
            if (isLocked(c.id)) {
              b.raw(" ");
              b.raw("<span");
              b.raw(" class=\"sv-lockchip sv-lockchip-sm\"");
              b.raw(">");
              b.raw("🔒 locked");
              b.raw("</span>");
              b.raw(" ");
            };
            b.raw("\n                                    ");
            b.raw("<span");
            b.raw(" class=\"sv-msgcount\"");
            b.raw(">");
            b.text(Nat.toText(msgCount(c.id)));
            b.raw(" msgs");
            b.raw("</span>");
            b.raw("\n                                ");
            b.raw("</span>");
            b.raw("\n                                ");
            if (canMod) {
              b.raw("\n                                    ");
              b.raw("<span");
              b.raw(" class=\"sv-channel-mod\"");
              b.raw(">");
              b.raw("\n                                        ");
              if (isLocked(c.id)) {
                b.raw("\n                                            ");
                b.raw("<button");
                b.raw(" class=\"sv-chip-btn\"");
                b.raw(" data-mv-handler=\"unlock\" data-mv-event=\"click\"");
                b.attr("data-mv-arg0", Html.unquote(debug_show(c.id)));
                b.raw(">");
                b.raw("Unlock");
                b.raw("</button>");
                b.raw("\n                                        ");
              } else {
                b.raw("\n                                            ");
                b.raw("<button");
                b.raw(" class=\"sv-chip-btn\"");
                b.raw(" data-mv-handler=\"lock\" data-mv-event=\"click\"");
                b.attr("data-mv-arg0", Html.unquote(debug_show(c.id)));
                b.raw(">");
                b.raw("Lock");
                b.raw("</button>");
                b.raw("\n                                        ");
              };
              b.raw("\n                                    ");
              b.raw("</span>");
              b.raw("\n                                ");
            };
            b.raw("\n                            ");
            b.raw("</li>");
            b.raw("\n                        ");
          };
          b.raw("\n                    ");
          b.raw("</ul>");
          b.raw("\n                ");
        };
        b.raw("\n\n                ");
        if (canMod) {
          b.raw("\n                    ");
          b.raw("<form");
          b.raw(" novalidate");
          b.raw(" class=\"sv-channel-form\"");
          b.raw(" data-mv-handler=\"createChannel\" data-mv-event=\"submit\"");
          b.raw(" data-mv-secure=\"1\"");
          b.attr("data-mv-token", ctx.mintToken("createChannel", "channelName"));
          b.raw(" data-mv-schema=\"channelName\"");
          b.raw(">");
          b.raw("\n                        ");
          if (mvErrors.size() > 0) {
            b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
            for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
            b.raw("</ul></div>");
          };
          b.raw("\n                        ");
          b.raw("<div");
          b.raw(" class=\"sv-channel-form-row\"");
          b.raw(">");
          b.raw("\n                            ");
          b.raw("<div class=\"mv-field\">");
          b.raw("<label>New channel name *</label>");
          b.raw("<input type=\"text\" class=\"mv-input\" name=\"channelName\" data-mv-key=\"channelName\"");
          b.raw(" required");
          b.attr("value", channelName);
          b.raw(">");
          for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "channelName") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
          b.raw("</div>");
          b.raw("\n                            ");
          b.raw("<button type=\"submit\" class=\"mv-btn mv-btn-primary\"");
          b.raw(">");
          b.raw("Add channel");
          b.raw("</button>");
          b.raw("\n                        ");
          b.raw("</div>");
          b.raw("\n                        ");
          b.raw("<p");
          b.raw(" class=\"sv-hint\"");
          b.raw(">");
          b.raw("Lowercase letters, numbers, - and _ only (max 20 chars).");
          b.raw("</p>");
          b.raw("\n                    ");
          b.raw("</form>");
          b.raw("\n                ");
        };
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n\n            ");
        if (canMod) {
          b.raw("\n                ");
          b.raw("<div");
          b.raw(" class=\"bz-card sv-panel sv-modpanel\"");
          b.raw(">");
          b.raw("\n                    ");
          b.raw("<div");
          b.raw(" class=\"sv-panel-head\"");
          b.raw(">");
          b.raw("\n                        ");
          b.raw("<h2");
          b.raw(">");
          b.raw("Moderation");
          b.raw("</h2>");
          b.raw("\n                        ");
          b.raw("<span");
          b.raw(" class=\"sv-modtag\"");
          b.raw(">");
          b.text(myRole);
          b.raw(" tools");
          b.raw("</span>");
          b.raw("\n                    ");
          b.raw("</div>");
          b.raw("\n                    ");
          b.raw("<p");
          b.raw(" class=\"sv-modnote\"");
          b.raw(">");
          b.raw("You can moderate this server. Lock channels above to stop non-mods from posting, and manage member roles in the rail.");
          b.raw("</p>");
          b.raw("\n                ");
          b.raw("</div>");
          b.raw("\n            ");
        };
        b.raw("\n        ");
        b.raw("</section>");
        b.raw("\n\n        ");
        b.raw("<aside");
        b.raw(" class=\"sv-col-rail\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"bz-card sv-panel\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<div");
        b.raw(" class=\"sv-panel-head\"");
        b.raw(">");
        b.raw("\n                    ");
        b.raw("<h2");
        b.raw(">");
        b.raw("Members");
        b.raw("</h2>");
        b.raw("\n                    ");
        b.raw("<span");
        b.raw(" class=\"sv-count\"");
        b.raw(">");
        b.text(Nat.toText(memberCount));
        b.raw("</span>");
        b.raw("\n                ");
        b.raw("</div>");
        b.raw("\n                ");
        if (memberRows.size() == 0) {
          b.raw("\n                    ");
          b.raw("<p");
          b.raw(" class=\"sv-empty\"");
          b.raw(">");
          b.raw("No members yet.");
          b.raw("</p>");
          b.raw("\n                ");
        } else {
          b.raw("\n                    ");
          b.raw("<ul");
          b.raw(" class=\"sv-members\"");
          b.raw(">");
          b.raw("\n                        ");
          for (mr in (memberRows).vals()) {
            b.raw("\n                            ");
            b.raw("<li");
            b.raw(" class=\"sv-member\"");
            b.raw(">");
            b.raw("\n                                ");
            b.raw("<span");
            b.raw(" class=\"sv-ava\"");
            b.raw(">");
            b.text(avatarOf(mr.principal));
            b.raw("</span>");
            b.raw("\n                                ");
            b.raw("<span");
            b.raw(" class=\"sv-member-main\"");
            b.raw(">");
            b.raw("\n                                    ");
            b.raw("<span");
            b.raw(" class=\"sv-member-handle\"");
            b.raw(">");
            b.text(handleOf(mr.principal));
            b.raw("</span>");
            b.raw("\n                                    ");
            b.raw("<span");
            b.raw(" class=\"");
            b.raw("sv-member-role sv-role-");
            b.text(roleClass(mr.principal));
            b.raw("\"");
            b.raw(">");
            b.text(roleLabel(mr.principal));
            b.raw("</span>");
            b.raw("\n                                ");
            b.raw("</span>");
            b.raw("\n                                ");
            if (canAdmin) {
              b.raw("\n                                    ");
              if (isOwnerPrincipal(mr.principal)) {
                b.raw("\n                                        ");
                b.raw("<span");
                b.raw(" class=\"sv-member-actions sv-owner-pill\"");
                b.raw(">");
                b.raw("Owner");
                b.raw("</span>");
                b.raw("\n                                    ");
              } else {
                b.raw("\n                                        ");
                b.raw("<span");
                b.raw(" class=\"sv-member-actions\"");
                b.raw(">");
                b.raw("\n                                            ");
                if (isMod(mr.principal)) {
                  b.raw("\n                                                ");
                  b.raw("<button");
                  b.raw(" class=\"sv-chip-btn\"");
                  b.raw(" data-mv-handler=\"revoke\" data-mv-event=\"click\"");
                  b.attr("data-mv-arg0", pidText(mr.principal));
                  b.raw(">");
                  b.raw("Revoke");
                  b.raw("</button>");
                  b.raw("\n                                            ");
                } else {
                  b.raw("\n                                                ");
                  b.raw("<button");
                  b.raw(" class=\"sv-chip-btn\"");
                  b.raw(" data-mv-handler=\"makeMod\" data-mv-event=\"click\"");
                  b.attr("data-mv-arg0", pidText(mr.principal));
                  b.raw(">");
                  b.raw("Make mod");
                  b.raw("</button>");
                  b.raw("\n                                            ");
                };
                b.raw("\n                                            ");
                if (isOwner) {
                  b.raw("\n                                                ");
                  if (isAdminPrincipal(mr.principal)) {
                    b.raw("\n                                                    ");
                    b.raw("<button");
                    b.raw(" class=\"sv-chip-btn\"");
                    b.raw(" data-mv-handler=\"revoke\" data-mv-event=\"click\"");
                    b.attr("data-mv-arg0", pidText(mr.principal));
                    b.raw(">");
                    b.raw("Demote");
                    b.raw("</button>");
                    b.raw("\n                                                ");
                  } else {
                    b.raw("\n                                                    ");
                    b.raw("<button");
                    b.raw(" class=\"sv-chip-btn\"");
                    b.raw(" data-mv-handler=\"makeAdmin\" data-mv-event=\"click\"");
                    b.attr("data-mv-arg0", pidText(mr.principal));
                    b.raw(">");
                    b.raw("Make admin");
                    b.raw("</button>");
                    b.raw("\n                                                ");
                  };
                  b.raw("\n                                            ");
                };
                b.raw("\n                                        ");
                b.raw("</span>");
                b.raw("\n                                    ");
              };
              b.raw("\n                                ");
            };
            b.raw("\n                            ");
            b.raw("</li>");
            b.raw("\n                        ");
          };
          b.raw("\n                    ");
          b.raw("</ul>");
          b.raw("\n                ");
        };
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("</aside>");
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      };
      b.raw("\n\n");
      b.raw("<style");
      b.raw(">");
      b.raw("\n    .sv-missing { text-align:center; padding:2.5rem 1.2rem; }\n    .sv-missing-ico { font-size:2.4rem; }\n    .sv-missing a { color:var(--bz-accent); font-weight:600; }\n\n    .sv-head { padding:1.2rem 1.3rem; display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; margin-bottom:1.25rem; }\n    .sv-title-row { display:flex; align-items:center; gap:.6rem; flex-wrap:wrap; }\n    .sv-title-row h1 { margin:0; font-size:1.6rem; letter-spacing:-.02em; }\n    .sv-meta { margin:.45rem 0 .15rem; color:var(--mv-text-soft); font-size:.9rem; }\n    .sv-role { margin:0; color:var(--mv-text-soft); font-size:.85rem; }\n    .sv-role strong { color:var(--mv-text); }\n\n    .sv-badge { font-size:.72rem; font-weight:700; padding:.2rem .55rem; border-radius:999px;\n        text-transform:uppercase; letter-spacing:.03em; }\n    .sv-badge-discussion { background:#ede9fe; color:#6d28d9; }\n    .sv-badge-forum { background:#dbeafe; color:#1d4ed8; }\n    .sv-badge-feed { background:#fce7f3; color:#be185d; }\n    .sv-lockchip { font-size:.74rem; font-weight:600; color:#92400e; background:#fef3c7; padding:.16rem .45rem; border-radius:999px; }\n    .sv-lockchip-sm { font-size:.68rem; }\n\n    .sv-btn { font-size:.85rem; font-weight:700; padding:.5rem .9rem; border-radius:10px; cursor:pointer; border:1px solid transparent; }\n    .sv-btn-primary { background:var(--bz-accent); color:#fff; }\n    .sv-btn-primary:hover { filter:brightness(1.08); }\n    .sv-btn-ghost { background:transparent; border-color:var(--mv-border); color:var(--mv-text); }\n    .sv-btn-ghost:hover { background:var(--mv-muted); }\n    .sv-owner-note { font-size:.82rem; color:var(--mv-text-soft); }\n\n    .sv-layout { display:grid; grid-template-columns:1fr 300px; gap:1.25rem; align-items:start; }\n    .sv-col-main { display:flex; flex-direction:column; gap:1.25rem; min-width:0; }\n    .sv-panel { padding:1.1rem 1.2rem; }\n    .sv-panel-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:.8rem; }\n    .sv-panel-head h2 { margin:0; font-size:1.1rem; }\n    .sv-count { font-size:.78rem; font-weight:700; color:var(--mv-text-soft); background:var(--mv-muted); padding:.16rem .5rem; border-radius:999px; }\n    .sv-modtag { font-size:.72rem; font-weight:700; color:#6d28d9; background:#ede9fe; padding:.16rem .5rem; border-radius:999px; }\n    .sv-empty { color:var(--mv-text-soft); font-size:.9rem; margin:0; }\n\n    .sv-channels { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:.2rem; }\n    .sv-channel { display:flex; align-items:center; gap:.6rem; padding:.5rem .6rem; border-radius:9px; }\n    .sv-channel:hover { background:var(--mv-muted); }\n    .sv-channel-link { display:flex; align-items:baseline; gap:.15rem; text-decoration:none; color:var(--mv-text); font-weight:600; }\n    .sv-channel-link:hover .sv-cname { color:var(--bz-accent); }\n    .sv-hash { color:var(--mv-text-soft); font-weight:700; }\n    .sv-channel-meta { margin-left:auto; display:flex; align-items:center; gap:.5rem; }\n    .sv-msgcount { font-size:.76rem; color:var(--mv-text-soft); }\n    .sv-channel-mod { display:flex; gap:.3rem; }\n\n    .sv-channel-form { margin-top:1rem; padding-top:1rem; border-top:1px solid var(--mv-border); }\n    .sv-channel-form-row { display:flex; gap:.6rem; align-items:end; }\n    .sv-hint { margin:.4rem 0 0; font-size:.76rem; color:var(--mv-text-soft); }\n\n    .sv-modpanel { background:linear-gradient(180deg, rgba(109,40,217,.04), transparent); }\n    .sv-modnote { margin:0; color:var(--mv-text-soft); font-size:.88rem; }\n\n    .sv-members { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:.35rem; }\n    .sv-member { display:flex; align-items:center; gap:.55rem; padding:.4rem .35rem; border-radius:9px; }\n    .sv-member:hover { background:var(--mv-muted); }\n    .sv-ava { width:30px; height:30px; border-radius:50%; background:var(--mv-muted); display:grid; place-items:center; font-size:1.05rem; flex:none; }\n    .sv-member-main { display:flex; flex-direction:column; min-width:0; }\n    .sv-member-handle { font-weight:700; font-size:.9rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }\n    .sv-member-role { font-size:.7rem; font-weight:700; }\n    .sv-role-owner { color:#b45309; }\n    .sv-role-admin { color:#6d28d9; }\n    .sv-role-moderator { color:#1d4ed8; }\n    .sv-role-member { color:var(--mv-text-soft); }\n    .sv-member-actions { margin-left:auto; display:flex; gap:.25rem; }\n    .sv-owner-pill { font-size:.7rem; font-weight:700; color:#b45309; background:#fef3c7; padding:.14rem .45rem; border-radius:999px; }\n\n    .sv-chip-btn { font-size:.72rem; font-weight:700; padding:.22rem .5rem; border-radius:7px; cursor:pointer;\n        border:1px solid var(--mv-border); background:var(--mv-surface); color:var(--mv-text); }\n    .sv-chip-btn:hover { background:var(--bz-accent); color:#fff; border-color:var(--bz-accent); }\n\n    @media (max-width: 860px) {\n        .sv-layout { grid-template-columns:1fr; }\n        .sv-head { flex-direction:column; }\n    }\n");
      b.raw("</style>");
      b.raw("\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); Html.unquote(debug_show(serverName # " — Bzzz server")) };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); { title = Html.unquote(debug_show(serverName # " — Bzzz server")); description = Html.unquote(debug_show(serverName # " on Bzzz — channels, members, roles and moderation for a Discord-style community running on the Internet Computer.")); canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      id := mvNat(mvParamGet(ctx, "id"));
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "channelName")) { case (?mvV) { channelName := mvV }; case null {} };
      switch mvH {
        case "join" { join(ctx) };
        case "leave" { leave(ctx) };
        case "createChannel" { createChannel(ctx) };
        case "lock" { lock(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "unlock" { unlock(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "makeMod" { makeMod(ctx, (if (mvArgs.size() > 0) mvArgs[0] else "")) };
        case "makeAdmin" { makeAdmin(ctx, (if (mvArgs.size() > 0) mvArgs[0] else "")) };
        case "revoke" { revoke(ctx, (if (mvArgs.size() > 0) mvArgs[0] else "")) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Servers.mview
  // ===== Page: Servers (/servers) =====
  let ServersPage = object {
    var serverList = Servers.servers();
    var bound : Bool = false;
    var me : Principal = Principal.fromText("2vxsx-fae");
    var myHandle : Text = "";
    var name : Text = "";
    var kind : Text = "Discussion";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        me := ctx.caller;
        bound := Identity.isBound(ctx.caller);
        myHandle := Identity.handleOf(ctx.caller);
        serverList := Servers.servers();
    };
    func summaryOf(id : Nat) : Text { Servers.summaryOf(id) };
    func isMemberOf(id : Nat) : Bool { Servers.isMember(id, me) };
    func isOwnerOf(id : Nat) : Bool { Servers.isOwner(id, me) };
    func roleOf(id : Nat) : Text { Servers.roleLabel(id, me) };
    func plural(n : Nat, one : Text, many : Text) : Text {
        if (n == 1) one else many;
    };
    func create(ctx : Context) : () {
         mvErrors.clear(); if (name == "") { mvErrors.add(("name", "Give your server a name.")) }; if (name.size() < 2) { mvErrors.add(("name", "Server name must be at least 2 characters.")) }; if (mvErrors.size() > 0) { return }; 
        let newId = if (kind == "Forum") {
            Servers.createServer(ctx.caller, name, #Forum);
        } else if (kind == "Feed") {
            Servers.createServer(ctx.caller, name, #Feed);
        } else {
            Servers.createServer(ctx.caller, name, #Discussion);
        };
        ignore Servers.joinAs(ctx.caller, newId, Identity.handleOf(ctx.caller));
        serverList := Servers.servers();
        name := "";
        toast("Server created!");
    };
    func join(ctx : Context, id : Nat) : () {
        ignore Servers.joinAs(ctx.caller, id, Identity.handleOf(ctx.caller));
        serverList := Servers.servers();
        toast("Joined the server.");
    };
    func leave(ctx : Context, id : Nat) : () {
        ignore Servers.leave(ctx.caller, id);
        serverList := Servers.servers();
        toast("Left the server.");
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<div");
      b.raw(" class=\"srv-head\"");
      b.raw(">");
      b.raw("\n    ");
      b.raw("<div");
      b.raw(">");
      b.raw("\n        ");
      b.raw("<h1");
      b.raw(">");
      b.raw("Servers");
      b.raw("</h1>");
      b.raw("\n        ");
      b.raw("<p");
      b.raw(" class=\"srv-sub\"");
      b.raw(">");
      b.text(Html.unquote(debug_show(serverList.size())));
      b.raw(" ");
      b.text(plural(serverList.size(), "community", "communities"));
      b.raw(" on Bzzz · pick one to jump into its channels.");
      b.raw("</p>");
      b.raw("\n    ");
      b.raw("</div>");
      b.raw("\n");
      b.raw("</div>");
      b.raw("\n\n");
      if (not bound) {
        b.raw("\n    ");
        b.raw("<div");
        b.raw(" class=\"bz-card srv-notice\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<p");
        b.raw(">");
        b.raw("You are browsing as a guest. ");
        b.raw("<a");
        b.raw(" href=\"/me\"");
        b.raw(">");
        b.raw("Claim a handle");
        b.raw("</a>");
        b.raw(" to create servers and join the conversation.");
        b.raw("</p>");
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      };
      b.raw("\n\n");
      b.raw("<div");
      b.raw(" class=\"bz-card srv-create\"");
      b.raw(">");
      b.raw("\n    ");
      b.raw("<h3");
      b.raw(">");
      b.raw("Create a server");
      b.raw("</h3>");
      b.raw("\n    ");
      b.raw("<form");
      b.raw(" novalidate");
      b.raw(" data-mv-handler=\"create\" data-mv-event=\"submit\"");
      b.raw(" data-mv-secure=\"1\"");
      b.attr("data-mv-token", ctx.mintToken("create", "kind,name"));
      b.raw(" data-mv-schema=\"kind,name\"");
      b.raw(">");
      b.raw("\n        ");
      if (mvErrors.size() > 0) {
        b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
        for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
        b.raw("</ul></div>");
      };
      b.raw("\n        ");
      b.raw("<div");
      b.raw(" class=\"srv-create-grid\"");
      b.raw(">");
      b.raw("\n            ");
      b.raw("<div class=\"mv-field\">");
      b.raw("<label>Server name *</label>");
      b.raw("<input type=\"text\" class=\"mv-input\" name=\"name\" data-mv-key=\"name\"");
      b.raw(" required");
      b.attr("value", name);
      b.raw(">");
      for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "name") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
      b.raw("</div>");
      b.raw("\n            ");
      b.raw("<div");
      b.raw(" class=\"srv-field\"");
      b.raw(">");
      b.raw("\n                ");
      b.raw("<span");
      b.raw(" class=\"srv-label\"");
      b.raw(">");
      b.raw("Kind");
      b.raw("</span>");
      b.raw("\n                ");
      b.raw("<select");
      b.raw(" name=\"kind\"");
      b.raw(" class=\"srv-select\"");
      b.raw(">");
      b.raw("\n                    ");
      b.raw("<option");
      b.raw(" value=\"Discussion\"");
      b.raw(">");
      b.raw("Discussion (channels &amp; chat)");
      b.raw("</option>");
      b.raw("\n                    ");
      b.raw("<option");
      b.raw(" value=\"Forum\"");
      b.raw(">");
      b.raw("Forum (topics &amp; replies)");
      b.raw("</option>");
      b.raw("\n                    ");
      b.raw("<option");
      b.raw(" value=\"Feed\"");
      b.raw(">");
      b.raw("Feed (timeline)");
      b.raw("</option>");
      b.raw("\n                ");
      b.raw("</select>");
      b.raw("\n            ");
      b.raw("</div>");
      b.raw("\n        ");
      b.raw("</div>");
      b.raw("\n        ");
      b.raw("<div");
      b.raw(" class=\"srv-create-actions\"");
      b.raw(">");
      b.raw("\n            ");
      b.raw("<button type=\"submit\" class=\"mv-btn mv-btn-primary\"");
      b.raw(">");
      b.raw("Create server");
      b.raw("</button>");
      b.raw("\n        ");
      b.raw("</div>");
      b.raw("\n    ");
      b.raw("</form>");
      b.raw("\n");
      b.raw("</div>");
      b.raw("\n\n");
      if (serverList.size() == 0) {
        b.raw("\n    ");
        b.raw("<div");
        b.raw(" class=\"bz-card srv-empty\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"srv-empty-ico\"");
        b.raw(">");
        b.raw("💬");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("<h3");
        b.raw(">");
        b.raw("No servers yet");
        b.raw("</h3>");
        b.raw("\n        ");
        b.raw("<p");
        b.raw(">");
        b.raw("Be the first to start a community. Create a server above.");
        b.raw("</p>");
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      } else {
        b.raw("\n    ");
        b.raw("<div");
        b.raw(" class=\"srv-grid\"");
        b.raw(">");
        b.raw("\n        ");
        for (s in (serverList).vals()) {
          b.raw("\n            ");
          b.raw("<article");
          b.raw(" class=\"bz-card srv-card\"");
          b.raw(">");
          b.raw("\n                ");
          b.raw("<div");
          b.raw(" class=\"srv-card-top\"");
          b.raw(">");
          b.raw("\n                    ");
          b.raw("<a");
          b.raw(" class=\"srv-name\"");
          b.raw(" href=\"");
          b.raw("/servers/");
          b.text(Html.unquote(debug_show(s.id)));
          b.raw("\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(s.name)));
          b.raw("</a>");
          b.raw("\n                    ");
          switch (s.kind) {
            case (#Discussion) {
              b.raw(" ");
              b.raw("<span");
              b.raw(" class=\"srv-badge srv-badge-discussion\"");
              b.raw(">");
              b.raw("Discussion");
              b.raw("</span>");
              b.raw(" ");
            };
            case (#Forum) {
              b.raw(" ");
              b.raw("<span");
              b.raw(" class=\"srv-badge srv-badge-forum\"");
              b.raw(">");
              b.raw("Forum");
              b.raw("</span>");
              b.raw(" ");
            };
            case (#Feed) {
              b.raw(" ");
              b.raw("<span");
              b.raw(" class=\"srv-badge srv-badge-feed\"");
              b.raw(">");
              b.raw("Feed");
              b.raw("</span>");
              b.raw(" ");
            };
          };
          b.raw("\n                ");
          b.raw("</div>");
          b.raw("\n                ");
          b.raw("<p");
          b.raw(" class=\"srv-summary\"");
          b.raw(">");
          b.text(summaryOf(s.id));
          b.raw("</p>");
          b.raw("\n                ");
          b.raw("<div");
          b.raw(" class=\"srv-card-foot\"");
          b.raw(">");
          b.raw("\n                    ");
          b.raw("<span");
          b.raw(" class=\"srv-role\"");
          b.raw(">");
          b.text(roleOf(s.id));
          b.raw("</span>");
          b.raw("\n                    ");
          if (isMemberOf(s.id)) {
            b.raw("\n                        ");
            if (isOwnerOf(s.id)) {
              b.raw("\n                            ");
              b.raw("<span");
              b.raw(" class=\"srv-owner-note\"");
              b.raw(">");
              b.raw("You own this server");
              b.raw("</span>");
              b.raw("\n                        ");
            } else {
              b.raw("\n                            ");
              b.raw("<button");
              b.raw(" class=\"srv-btn srv-btn-ghost\"");
              b.raw(" data-mv-handler=\"leave\" data-mv-event=\"click\"");
              b.attr("data-mv-arg0", Html.unquote(debug_show(s.id)));
              b.raw(">");
              b.raw("Leave");
              b.raw("</button>");
              b.raw("\n                        ");
            };
            b.raw("\n                    ");
          } else {
            b.raw("\n                        ");
            b.raw("<button");
            b.raw(" class=\"srv-btn srv-btn-primary\"");
            b.raw(" data-mv-handler=\"join\" data-mv-event=\"click\"");
            b.attr("data-mv-arg0", Html.unquote(debug_show(s.id)));
            b.raw(">");
            b.raw("Join");
            b.raw("</button>");
            b.raw("\n                    ");
          };
          b.raw("\n                    ");
          b.raw("<a");
          b.raw(" class=\"srv-btn srv-btn-link\"");
          b.raw(" href=\"");
          b.raw("/servers/");
          b.text(Html.unquote(debug_show(s.id)));
          b.raw("\"");
          b.raw(">");
          b.raw("Open →");
          b.raw("</a>");
          b.raw("\n                ");
          b.raw("</div>");
          b.raw("\n            ");
          b.raw("</article>");
          b.raw("\n        ");
        };
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      };
      b.raw("\n\n");
      b.raw("<style");
      b.raw(">");
      b.raw("\n    .srv-head { display:flex; align-items:flex-end; justify-content:space-between; gap:1rem; margin-bottom:1rem; }\n    .srv-head h1 { margin:0 0 .2rem; font-size:1.7rem; letter-spacing:-.02em; }\n    .srv-sub { margin:0; color:var(--mv-text-soft); }\n    .srv-notice { padding:.85rem 1.1rem; margin-bottom:1rem; }\n    .srv-notice p { margin:0; color:var(--mv-text-soft); }\n    .srv-notice a { color:var(--bz-accent); font-weight:600; }\n\n    .srv-create { padding:1.1rem 1.2rem; margin-bottom:1.5rem; }\n    .srv-create h3 { margin:0 0 .8rem; font-size:1.1rem; }\n    .srv-create-grid { display:grid; grid-template-columns:2fr 1fr; gap:1rem; align-items:end; }\n    .srv-field { display:flex; flex-direction:column; gap:.35rem; }\n    .srv-label { font-size:.82rem; font-weight:600; color:var(--mv-text-soft); }\n    .srv-select { padding:.55rem .65rem; border:1px solid var(--mv-border); border-radius:10px;\n        background:var(--mv-surface); font-size:.92rem; color:var(--mv-text); }\n    .srv-create-actions { margin-top:.9rem; }\n\n    .srv-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:1rem; }\n    .srv-card { padding:1.1rem 1.2rem; display:flex; flex-direction:column; gap:.6rem; }\n    .srv-card-top { display:flex; align-items:center; justify-content:space-between; gap:.6rem; }\n    .srv-name { font-size:1.12rem; font-weight:800; color:var(--mv-text); text-decoration:none; letter-spacing:-.01em; }\n    .srv-name:hover { color:var(--bz-accent); }\n    .srv-summary { margin:0; color:var(--mv-text-soft); font-size:.88rem; }\n\n    .srv-badge { font-size:.72rem; font-weight:700; padding:.2rem .5rem; border-radius:999px; white-space:nowrap;\n        text-transform:uppercase; letter-spacing:.03em; }\n    .srv-badge-discussion { background:#ede9fe; color:#6d28d9; }\n    .srv-badge-forum { background:#dbeafe; color:#1d4ed8; }\n    .srv-badge-feed { background:#fce7f3; color:#be185d; }\n\n    .srv-card-foot { display:flex; align-items:center; gap:.55rem; flex-wrap:wrap; margin-top:.2rem;\n        padding-top:.7rem; border-top:1px solid var(--mv-border); }\n    .srv-role { font-size:.74rem; font-weight:700; color:var(--mv-text-soft); background:var(--mv-muted);\n        padding:.16rem .5rem; border-radius:999px; }\n    .srv-owner-note { font-size:.78rem; color:var(--mv-text-soft); }\n\n    .srv-btn { font-size:.82rem; font-weight:700; padding:.4rem .75rem; border-radius:9px; cursor:pointer;\n        border:1px solid transparent; text-decoration:none; }\n    .srv-btn-primary { background:var(--bz-accent); color:#fff; }\n    .srv-btn-primary:hover { filter:brightness(1.08); }\n    .srv-btn-ghost { background:transparent; border-color:var(--mv-border); color:var(--mv-text); }\n    .srv-btn-ghost:hover { background:var(--mv-muted); }\n    .srv-btn-link { margin-left:auto; background:transparent; color:var(--bz-accent); padding:.4rem .3rem; }\n\n    .srv-empty { text-align:center; padding:2.5rem 1.2rem; }\n    .srv-empty-ico { font-size:2.4rem; }\n    .srv-empty h3 { margin:.5rem 0 .3rem; }\n    .srv-empty p { margin:0; color:var(--mv-text-soft); }\n\n    @media (max-width: 600px) {\n        .srv-create-grid { grid-template-columns:1fr; }\n    }\n");
      b.raw("</style>");
      b.raw("\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Servers — Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Servers — Bzzz"; description = "Browse and create Bzzz servers (guilds) — Discord-style communities with channels, roles and moderation, running on-chain on the Internet Computer."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "name")) { case (?mvV) { name := mvV }; case null {} };
      switch mvH {
        case "create" { create(ctx) };
        case "join" { join(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "leave" { leave(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Status.mview
  // ===== Page: Status (/status) =====
  let StatusPage = object {
    var bound : Bool = false;
    var statuses : [Status.Update] = [];
    var activeCount : Nat = 0;
    var authorCount : Nat = 0;
    var authorWord : Text = "authors";
    var defaultColor : Text = "#075E54";
    var text : Text = "";
    var swatches : [Swatch] = [
        { hex = "#075E54"; name = "Teal"; checked = true },
        { hex = "#6d28d9"; name = "Violet"; checked = false },
        { hex = "#c026d3"; name = "Magenta"; checked = false },
        { hex = "#0088CC"; name = "Blue"; checked = false },
        { hex = "#F15A24"; name = "Orange"; checked = false },
        { hex = "#009900"; name = "Green"; checked = false },
        { hex = "#c80001"; name = "Red"; checked = false },
        { hex = "#1a1a1a"; name = "Ink"; checked = false },
    ];
    type Swatch = { hex : Text; name : Text; checked : Bool };
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        bound := Identity.isBound(ctx.caller);
        statuses := Status.active();
        activeCount := Status.activeCount();
        authorCount := Status.authorCount();
        authorWord := if (authorCount == 1) "author" else "authors";
    };
    func previewText() : Text {
        if (Text.trim(text, #char ' ') == "") "Your status will look like this" else text;
    };
    func formField(ctx : Context, key : Text) : Text {
        switch (Array.find<(Text, Text)>(ctx.form, func((k, _v) : (Text, Text)) : Bool { k == key })) {
            case (?kv) kv.1;
            case null "";
        };
    };
    func post(ctx : Context) : () {
         mvErrors.clear(); if (text == "") { mvErrors.add(("text", "Write something to share.")) }; if (text.size() < 1) { mvErrors.add(("text", "Write something to share.")) }; if (mvErrors.size() > 0) { return }; 
        let handle = Identity.handleOf(ctx.caller);
        let picked = formField(ctx, "color");
        let chosen = if (Text.trim(picked, #char ' ') == "") defaultColor else picked;
        let _id = Status.postStatus(ctx.caller, handle, text, chosen);
        text := "";
        statuses := Status.active();
        activeCount := Status.activeCount();
        authorCount := Status.authorCount();
        authorWord := if (authorCount == 1) "author" else "authors";
        toast("Status posted — live for 24 hours.");
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<section");
      b.raw(" class=\"bz-status-head\"");
      b.raw(">");
      b.raw("\n    ");
      b.raw("<div");
      b.raw(">");
      b.raw("\n        ");
      b.raw("<h1");
      b.raw(">");
      b.raw("Status");
      b.raw("</h1>");
      b.raw("\n        ");
      b.raw("<p");
      b.raw(">");
      b.raw("Share a thought that vanishes in 24 hours. ");
      b.text(Nat.toText(activeCount));
      b.raw(" live · ");
      b.text(Nat.toText(authorCount));
      b.raw(" ");
      b.text(authorWord);
      b.raw("</p>");
      b.raw("\n    ");
      b.raw("</div>");
      b.raw("\n");
      b.raw("</section>");
      b.raw("\n\n");
      if (bound) {
        b.raw("\n    ");
        b.raw("<div");
        b.raw(" class=\"bz-card bz-status-compose\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<h3");
        b.raw(">");
        b.raw("Post a status");
        b.raw("</h3>");
        b.raw("\n        ");
        b.raw("<form");
        b.raw(" novalidate");
        b.raw(" data-mv-handler=\"post\" data-mv-event=\"submit\"");
        b.raw(" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("post", "color,color,text"));
        b.raw(" data-mv-schema=\"color,color,text\"");
        b.raw(">");
        b.raw("\n            ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n            ");
        b.raw("<div class=\"mv-field\">");
        b.raw("<label>What's on your mind? *</label>");
        b.raw("<textarea class=\"mv-textarea\" name=\"text\" data-mv-key=\"text\"");
        b.raw(" required");
        b.raw(">");
        b.text(text);
        b.raw("</textarea>");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "text") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>");
        b.raw("\n\n            ");
        b.raw("<div");
        b.raw(" class=\"bz-swatches\"");
        b.raw(" role=\"radiogroup\"");
        b.raw(" aria-label=\"Status color\"");
        b.raw(">");
        b.raw("\n                ");
        for (sw in (swatches).vals()) {
          b.raw("\n                    ");
          b.raw("<label");
          b.raw(" class=\"bz-swatch\"");
          b.raw(" style=\"");
          b.raw("--sw:");
          b.text(Html.unquote(debug_show(sw.hex)));
          b.raw("\"");
          b.attr("title", Html.unquote(debug_show(sw.name)));
          b.raw(">");
          b.raw("\n                        ");
          if (sw.checked) {
            b.raw("\n                            ");
            b.raw("<input");
            b.raw(" type=\"radio\"");
            b.raw(" name=\"color\"");
            b.attr("value", Html.unquote(debug_show(sw.hex)));
            b.raw(" checked");
            b.raw(">");
            b.raw("\n                        ");
          } else {
            b.raw("\n                            ");
            b.raw("<input");
            b.raw(" type=\"radio\"");
            b.raw(" name=\"color\"");
            b.attr("value", Html.unquote(debug_show(sw.hex)));
            b.raw(">");
            b.raw("\n                        ");
          };
          b.raw("\n                        ");
          b.raw("<span");
          b.raw(" class=\"bz-swatch-dot\"");
          b.raw(">");
          b.raw("</span>");
          b.raw("\n                    ");
          b.raw("</label>");
          b.raw("\n                ");
        };
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n\n            ");
        b.raw("<div");
        b.raw(" class=\"bz-preview\"");
        b.raw(" style=\"");
        b.raw("--c:");
        b.text(defaultColor);
        b.raw("\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<span");
        b.raw(" class=\"bz-preview-label\"");
        b.raw(">");
        b.raw("Preview");
        b.raw("</span>");
        b.raw("\n                ");
        b.raw("<span");
        b.raw(" class=\"bz-preview-text\"");
        b.raw(">");
        b.text(previewText());
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n\n            ");
        b.raw("<div");
        b.raw(" class=\"bz-status-actions\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<button type=\"submit\" class=\"mv-btn mv-btn-primary\"");
        b.raw(">");
        b.raw("Share status");
        b.raw("</button>");
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("</form>");
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      } else {
        b.raw("\n    ");
        b.raw("<div class=\"mv-alert mv-alert-info\">");
        b.raw("\n        Pick a handle on your ");
        b.raw("<a");
        b.raw(" href=\"/me\"");
        b.raw(">");
        b.raw("profile");
        b.raw("</a>");
        b.raw(" to post a status.\n    ");
        b.raw("</div>");
        b.raw("\n");
      };
      b.raw("\n\n");
      b.raw("<h2");
      b.raw(" class=\"bz-section-title\"");
      b.raw(">");
      b.raw("Live now");
      b.raw("</h2>");
      b.raw("\n\n");
      if ((statuses.size() == 0)) {
        b.raw("\n    ");
        b.raw("<div");
        b.raw(" class=\"bz-empty bz-card\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-empty-ico\"");
        b.raw(">");
        b.raw("📭");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("<p");
        b.raw(">");
        b.raw("No active statuses. Be the first to share something today.");
        b.raw("</p>");
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      } else {
        b.raw("\n    ");
        b.raw("<div");
        b.raw(" class=\"bz-status-grid\"");
        b.raw(">");
        b.raw("\n        ");
        for (s in (statuses).vals()) {
          b.raw("\n            ");
          b.raw("<article");
          b.raw(" class=\"bz-status-card\"");
          b.raw(" style=\"");
          b.raw("--c:");
          b.text(Html.unquote(debug_show(s.color)));
          b.raw("\"");
          b.raw(">");
          b.raw("\n                ");
          b.raw("<header");
          b.raw(" class=\"bz-status-author\"");
          b.raw(">");
          b.raw("\n                    ");
          b.raw("<span");
          b.raw(" class=\"bz-status-ava\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(Identity.avatarOf(s.author))));
          b.raw("</span>");
          b.raw("\n                    ");
          b.raw("<div");
          b.raw(" class=\"bz-status-meta\"");
          b.raw(">");
          b.raw("\n                        ");
          b.raw("<span");
          b.raw(" class=\"bz-status-handle\"");
          b.raw(">");
          b.raw("@");
          b.text(Html.unquote(debug_show(s.authorHandle)));
          b.raw("</span>");
          b.raw("\n                        ");
          b.raw("<span");
          b.raw(" class=\"bz-status-time\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(Status.relativeTime(s.at))));
          b.raw("</span>");
          b.raw("\n                    ");
          b.raw("</div>");
          b.raw("\n                    ");
          b.raw("<span");
          b.raw(" class=\"bz-status-kind\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(Status.kindLabel(s.kind))));
          b.raw("</span>");
          b.raw("\n                ");
          b.raw("</header>");
          b.raw("\n                ");
          switch (s.kind) {
            case (#Text) {
              b.raw("\n                        ");
              b.raw("<p");
              b.raw(" class=\"bz-status-text\"");
              b.raw(">");
              b.text(Html.unquote(debug_show(s.text)));
              b.raw("</p>");
              b.raw("\n                    ");
            };
            case (#Image) {
              b.raw("\n                        ");
              b.raw("<div");
              b.raw(" class=\"bz-status-image\"");
              b.raw(">");
              b.raw("\n                            ");
              b.raw("<span");
              b.raw(" class=\"bz-status-image-ico\"");
              b.raw(">");
              b.raw("🖼️");
              b.raw("</span>");
              b.raw("\n                            ");
              b.raw("<span");
              b.raw(" class=\"bz-status-image-ref\"");
              b.raw(">");
              b.text(Html.unquote(debug_show(s.text)));
              b.raw("</span>");
              b.raw("\n                        ");
              b.raw("</div>");
              b.raw("\n                    ");
            };
          };
          b.raw("\n                ");
          b.raw("<footer");
          b.raw(" class=\"bz-status-foot\"");
          b.raw(">");
          b.raw("\n                    ");
          b.raw("<span");
          b.raw(" class=\"bz-status-expires\"");
          b.raw(">");
          b.raw("⏳ ");
          b.text(Html.unquote(debug_show(Status.timeLeft(s.expiresAt))));
          b.raw("</span>");
          b.raw("\n                    ");
          b.raw("<span");
          b.raw(" class=\"bz-status-views\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(s.views)));
          b.raw(" views");
          b.raw("</span>");
          b.raw("\n                ");
          b.raw("</footer>");
          b.raw("\n            ");
          b.raw("</article>");
          b.raw("\n        ");
        };
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      };
      b.raw("\n\n");
      b.raw("<style");
      b.raw(">");
      b.raw("\n    .bz-status-head { margin-bottom: 1.25rem; }\n    .bz-status-head h1 { margin: 0 0 .25rem; font-size: 1.6rem; letter-spacing: -.02em; }\n    .bz-status-head p { margin: 0; color: var(--mv-text-soft); font-size: .9rem; }\n\n    .bz-status-compose { padding: 1.2rem 1.3rem; margin-bottom: 1.5rem; }\n    .bz-status-compose h3 { margin: 0 0 .8rem; font-size: 1.1rem; }\n\n    .bz-swatches { display: flex; flex-wrap: wrap; gap: .55rem; margin: .8rem 0 .2rem; }\n    .bz-swatch { position: relative; cursor: pointer; display: inline-flex; }\n    .bz-swatch input { position: absolute; opacity: 0; width: 0; height: 0; }\n    .bz-swatch-dot { width: 30px; height: 30px; border-radius: 50%; background: var(--sw);\n        display: inline-block; box-shadow: 0 0 0 2px var(--mv-surface), 0 0 0 3px var(--mv-border);\n        transition: transform .1s ease, box-shadow .1s ease; }\n    .bz-swatch:hover .bz-swatch-dot { transform: scale(1.08); }\n    .bz-swatch input:checked + .bz-swatch-dot { box-shadow: 0 0 0 2px var(--mv-surface), 0 0 0 4px var(--bz-accent); transform: scale(1.12); }\n\n    .bz-preview { margin: .9rem 0 .2rem; border-radius: 12px; padding: 1.5rem 1.2rem; min-height: 64px;\n        background: var(--c); color: #fff; display: flex; flex-direction: column; gap: .35rem;\n        text-shadow: 0 1px 2px rgba(0,0,0,.25); }\n    .bz-preview-label { font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; opacity: .8; }\n    .bz-preview-text { font-size: 1.25rem; font-weight: 700; word-break: break-word; }\n\n    .bz-status-actions { margin-top: 1rem; }\n\n    .bz-section-title { font-size: 1.15rem; margin: 0 0 1rem; }\n\n    .bz-empty { text-align: center; padding: 2.5rem 1.5rem; color: var(--mv-text-soft); }\n    .bz-empty-ico { font-size: 2.2rem; }\n    .bz-empty p { margin: .6rem 0 0; }\n\n    .bz-status-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; }\n    .bz-status-card { border-radius: 14px; overflow: hidden; background: var(--c); color: #fff;\n        box-shadow: 0 6px 20px rgba(16,16,40,.16); display: flex; flex-direction: column;\n        min-height: 180px; text-shadow: 0 1px 2px rgba(0,0,0,.25); }\n    .bz-status-author { display: flex; align-items: center; gap: .55rem; padding: .85rem 1rem .25rem; }\n    .bz-status-ava { width: 34px; height: 34px; border-radius: 50%; background: rgba(255,255,255,.25);\n        display: grid; place-items: center; font-size: 1.1rem; text-shadow: none; flex: 0 0 auto; }\n    .bz-status-meta { display: flex; flex-direction: column; line-height: 1.2; min-width: 0; }\n    .bz-status-handle { font-weight: 700; font-size: .92rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n    .bz-status-time { font-size: .75rem; opacity: .85; }\n    .bz-status-kind { margin-left: auto; font-size: .68rem; text-transform: uppercase; letter-spacing: .06em;\n        background: rgba(255,255,255,.22); padding: .15rem .45rem; border-radius: 999px; flex: 0 0 auto; }\n\n    .bz-status-text { flex: 1; margin: 0; padding: .6rem 1rem 1rem; font-size: 1.35rem; font-weight: 700;\n        line-height: 1.3; word-break: break-word; display: flex; align-items: center; }\n    .bz-status-image { flex: 1; margin: 0; padding: .6rem 1rem 1rem; display: flex; flex-direction: column;\n        align-items: center; justify-content: center; gap: .4rem; }\n    .bz-status-image-ico { font-size: 2rem; }\n    .bz-status-image-ref { font-size: .78rem; opacity: .85; word-break: break-all; text-align: center; }\n\n    .bz-status-foot { display: flex; align-items: center; justify-content: space-between;\n        padding: .6rem 1rem .85rem; font-size: .76rem; background: rgba(0,0,0,.16); }\n    .bz-status-expires { font-weight: 600; }\n    .bz-status-views { opacity: .85; }\n\n    @media (max-width: 560px) {\n        .bz-status-grid { grid-template-columns: 1fr; }\n    }\n");
      b.raw("</style>");
      b.raw("\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Status — ephemeral 24-hour updates on Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Status — ephemeral 24-hour updates on Bzzz"; description = "Post a colorful 24-hour status update and see what everyone on Bzzz is sharing right now — disappearing automatically after a day."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "text")) { case (?mvV) { text := mvV }; case null {} };
      switch mvH {
        case "post" { post(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Thread.mview
  // ===== Page: Thread (/messages/{id:Nat}) =====
  let ThreadPage = object {
    var id : Nat = 0;
    var me : Principal = Principal.fromText("2vxsx-fae");
    var member : Bool = false;
    var title : Text = "Conversation";
    var headerAvatar : Text = "🔒";
    var msgs : [Messenger.DmMessage] = [];
    var draft : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        me := ctx.caller;
        member := Messenger.isMember(id, ctx.caller);
        if (member) {
            // Title: group name, else the direct peer's handle.
            switch (Messenger.directPeer(ctx.caller, id)) {
                case (?p) {
                    title := Identity.handleOf(p);
                    headerAvatar := Identity.avatarOf(p);
                };
                case null {
                    title := Messenger.titleFor(id, "");
                    headerAvatar := "👥";
                };
            };
            msgs := Messenger.messages(ctx.caller, id);
            // Viewing a conversation marks every message in it as read.
            Messenger.markRead(ctx.caller, id);
        };
    };
    func bubbleSide(m : Messenger.DmMessage) : Text {
        if (m.sender == me) { "bz-th-sent" } else { "bz-th-recv" };
    };
    func relTime(m : Messenger.DmMessage) : Text { Messenger.relativeTime(m.at) };
    func sendMsg(ctx : Context) : () {
         mvErrors.clear(); if (draft == "") { mvErrors.add(("draft", "Type a message to send.")) }; if (mvErrors.size() > 0) { return }; 
        // NOTE: a real client encrypts `draft` (X25519 + AEAD) into a base64
        // envelope BEFORE calling send; here we store the text as the ciphertext
        // field so the flow is honest end-to-end without a browser crypto stub.
        let handle = Identity.handleOf(ctx.caller);
        let id2 = Messenger.send(ctx.caller, id, handle, draft);
        draft := "";
        if (id2 == 0) {
            toast("Couldn't send — you're not a member of this conversation.");
        } else {
            scrollTo("#bz-th-stream");
        };
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      id := mvNat(mvParamGet(ctx, "id"));
      b.raw("<div");
      b.raw(" class=\"bz-th-wrap\"");
      b.raw(">");
      b.raw("\n    ");
      if ((not member)) {
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-card bz-th-empty\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"bz-th-empty-ico\"");
        b.raw(">");
        b.raw("🔒");
        b.raw("</div>");
        b.raw("\n            ");
        b.raw("<h3");
        b.raw(">");
        b.raw("Conversation unavailable");
        b.raw("</h3>");
        b.raw("\n            ");
        b.raw("<p");
        b.raw(">");
        b.raw("This conversation doesn't exist, or you're not a member of it. ");
        b.raw("<a");
        b.raw(" href=\"/messages\"");
        b.raw(">");
        b.raw("Back to Messages");
        b.raw("</a>");
        b.raw(".");
        b.raw("</p>");
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n    ");
      } else {
        b.raw("\n        ");
        b.raw("<header");
        b.raw(" class=\"bz-th-head\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<a");
        b.raw(" class=\"bz-th-back\"");
        b.raw(" href=\"/messages\"");
        b.raw(" aria-label=\"Back to conversations\"");
        b.raw(">");
        b.raw("←");
        b.raw("</a>");
        b.raw("\n            ");
        b.raw("<span");
        b.raw(" class=\"bz-th-avatar\"");
        b.raw(">");
        b.text(headerAvatar);
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"bz-th-titlewrap\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<h1");
        b.raw(" class=\"bz-th-title\"");
        b.raw(">");
        b.text(title);
        b.raw("</h1>");
        b.raw("\n                ");
        b.raw("<span");
        b.raw(" class=\"bz-th-e2ee\"");
        b.raw(">");
        b.raw("🔒 End-to-end encrypted");
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("</header>");
        b.raw("\n\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-th-banner\"");
        b.raw(">");
        b.raw("\n            🔒 Messages here are end-to-end encrypted. The on-chain canister only ever stores opaque ciphertext envelopes — decryption happens entirely in your client.\n        ");
        b.raw("</div>");
        b.raw("\n\n        ");
        b.raw("<div");
        b.raw(" class=\"bz-th-stream\"");
        b.raw(" id=\"bz-th-stream\"");
        b.raw(">");
        b.raw("\n            ");
        if ((msgs.size() == 0)) {
          b.raw("\n                ");
          b.raw("<div");
          b.raw(" class=\"bz-th-empty-inline\"");
          b.raw(">");
          b.raw("\n                    ");
          b.raw("<div");
          b.raw(" class=\"bz-th-empty-ico\"");
          b.raw(">");
          b.raw("💬");
          b.raw("</div>");
          b.raw("\n                    ");
          b.raw("<p");
          b.raw(">");
          b.raw("No messages yet. Say hello — your message is encrypted before it leaves your device.");
          b.raw("</p>");
          b.raw("\n                ");
          b.raw("</div>");
          b.raw("\n            ");
        } else {
          b.raw("\n                ");
          for (m in (msgs).vals()) {
            b.raw("\n                    ");
            b.raw("<div");
            b.raw(" class=\"");
            b.raw("bz-th-msg ");
            b.text(bubbleSide(m));
            b.raw("\"");
            b.raw(">");
            b.raw("\n                        ");
            if ((m.sender != me)) {
              b.raw("\n                            ");
              b.raw("<span");
              b.raw(" class=\"bz-th-sender\"");
              b.raw(">");
              b.text(Html.unquote(debug_show(m.senderHandle)));
              b.raw("</span>");
              b.raw("\n                        ");
            };
            b.raw("\n                        ");
            b.raw("<div");
            b.raw(" class=\"bz-th-bubble\"");
            b.raw(">");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(" class=\"bz-th-cipher\"");
            b.raw(" title=\"Stored ciphertext envelope — decrypted client-side\"");
            b.raw(">");
            b.text(Html.unquote(debug_show(m.ciphertext)));
            b.raw("</span>");
            b.raw("\n                        ");
            b.raw("</div>");
            b.raw("\n                        ");
            b.raw("<span");
            b.raw(" class=\"bz-th-meta\"");
            b.raw(">");
            b.raw("\n                            ");
            b.raw("<span");
            b.raw(" class=\"bz-th-lock\"");
            b.raw(" title=\"End-to-end encrypted — decrypted in your client\"");
            b.raw(">");
            b.raw("🔒");
            b.raw("</span>");
            b.raw("\n                            ");
            b.text(relTime(m));
            b.raw("\n                        ");
            b.raw("</span>");
            b.raw("\n                    ");
            b.raw("</div>");
            b.raw("\n                ");
          };
          b.raw("\n            ");
        };
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n\n        ");
        b.raw("<form");
        b.raw(" novalidate");
        b.raw(" class=\"bz-th-composer\"");
        b.raw(" data-mv-handler=\"sendMsg\" data-mv-event=\"submit\"");
        b.raw(" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("sendMsg", "draft"));
        b.raw(" data-mv-schema=\"draft\"");
        b.raw(">");
        b.raw("\n            ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"bz-th-composer-row\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<div class=\"mv-field\">");
        b.raw("<label>Message *</label>");
        b.raw("<input type=\"text\" class=\"mv-input\" name=\"draft\" data-mv-key=\"draft\"");
        b.raw(" required");
        b.attr("value", draft);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "draft") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>");
        b.raw("\n                ");
        b.raw("<button type=\"submit\" class=\"mv-btn mv-btn-primary\"");
        b.raw(">");
        b.raw("Send");
        b.raw("</button>");
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n            ");
        b.raw("<p");
        b.raw(" class=\"bz-th-composer-note\"");
        b.raw(">");
        b.raw("🔒 In production this body is encrypted client-side (X25519 / AEAD) before sending; the canister stores only the ciphertext envelope.");
        b.raw("</p>");
        b.raw("\n        ");
        b.raw("</form>");
        b.raw("\n    ");
      };
      b.raw("\n");
      b.raw("</div>");
      b.raw("\n\n");
      b.raw("<style");
      b.raw(">");
      b.raw("\n    .bz-th-wrap { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; min-height: 60vh; }\n\n    .bz-th-head { display: flex; align-items: center; gap: .75rem; padding: .6rem 0 .9rem; }\n    .bz-th-back { text-decoration: none; font-size: 1.4rem; color: var(--mv-text-soft); line-height: 1;\n        width: 36px; height: 36px; display: grid; place-items: center; border-radius: 8px; }\n    .bz-th-back:hover { background: var(--mv-muted); color: var(--mv-text); }\n    .bz-th-avatar { flex: none; width: 44px; height: 44px; border-radius: 50%; background: var(--mv-muted);\n        display: grid; place-items: center; font-size: 1.35rem; }\n    .bz-th-titlewrap { display: flex; flex-direction: column; gap: .1rem; }\n    .bz-th-title { margin: 0; font-size: 1.2rem; letter-spacing: -.01em; }\n    .bz-th-e2ee { color: #047857; font-size: .76rem; font-weight: 600; }\n\n    .bz-th-banner { background: #e7f8ef; border: 1px solid #a7f3d0; color: #065f46; border-radius: 12px;\n        padding: .65rem .85rem; font-size: .8rem; line-height: 1.45; margin-bottom: 1rem; }\n\n    .bz-th-stream { flex: 1; display: flex; flex-direction: column; gap: .7rem; padding: .25rem 0 1rem; }\n    .bz-th-msg { display: flex; flex-direction: column; max-width: 78%; }\n    .bz-th-recv { align-self: flex-start; align-items: flex-start; }\n    .bz-th-sent { align-self: flex-end; align-items: flex-end; }\n    .bz-th-sender { font-size: .74rem; font-weight: 700; color: var(--bz-accent, #6d28d9); margin: 0 .35rem .15rem; }\n    .bz-th-bubble { padding: .55rem .8rem; border-radius: 16px; font-size: .92rem; line-height: 1.4; word-break: break-word; }\n    .bz-th-recv .bz-th-bubble { background: var(--mv-surface); border: 1px solid var(--mv-border); border-bottom-left-radius: 4px; color: var(--mv-text); }\n    .bz-th-sent .bz-th-bubble { background: var(--bz-accent, #6d28d9); color: #fff; border-bottom-right-radius: 4px; }\n    .bz-th-cipher { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: .86rem; }\n    .bz-th-meta { font-size: .7rem; color: var(--mv-text-soft); margin: .2rem .35rem 0; display: inline-flex; align-items: center; gap: .25rem; }\n    .bz-th-lock { font-size: .72rem; }\n\n    .bz-th-empty-inline { text-align: center; color: var(--mv-text-soft); margin: auto; padding: 2rem 1rem; }\n    .bz-th-empty-inline p { max-width: 36ch; margin: .5rem auto 0; }\n    .bz-th-empty-ico { font-size: 2.2rem; }\n\n    .bz-th-empty { text-align: center; padding: 2.5rem 1.5rem; }\n    .bz-th-empty h3 { margin: .6rem 0 .3rem; }\n    .bz-th-empty p { margin: 0 auto; color: var(--mv-text-soft); max-width: 42ch; }\n\n    .bz-th-composer { position: sticky; bottom: 0; background: var(--mv-muted); padding: .75rem 0 .5rem; border-top: 1px solid var(--mv-border); }\n    .bz-th-composer-row { display: flex; align-items: flex-end; gap: .6rem; }\n    .bz-th-composer-row > :first-child { flex: 1; }\n    .bz-th-composer-note { margin: .4rem 0 0; font-size: .72rem; color: var(--mv-text-soft); }\n\n    @media (max-width: 640px) {\n        .bz-th-msg { max-width: 88%; }\n    }\n");
      b.raw("</style>");
      b.raw("\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); "Conversation — end-to-end encrypted on Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); { title = "Conversation — end-to-end encrypted on Bzzz"; description = "A private, end-to-end encrypted conversation on Bzzz. Message bodies are stored as ciphertext envelopes and decrypted only in your client — never on-chain."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; id := mvNat(mvParamGet(ctx, "id")); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      id := mvNat(mvParamGet(ctx, "id"));
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "draft")) { case (?mvV) { draft := mvV }; case null {} };
      switch mvH {
        case "sendMsg" { sendMsg(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };


