      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "addHandle")) { case (?mvV) { addHandle := mvV }; case null {} };
      switch mvH {
        case "claim" { claim(ctx) };
        case "add" { add(ctx) };
        case "remove" { remove(ctx, (if (mvArgs.size() > 0) mvArgs[0] else "")) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Channel.mview
  // ===== Page: Channel (/channel/{rid:Nat}) =====
  let ChannelPage = object {
    var rid : Nat = 0;
    var exists : Bool = false;
    var roomName : Text = "channel";
    var serverId : Nat = 0;
    var messages = Chat.messages(0);
    var emojiSet : [Text] = [];
    var typing : [Text] = [];
    var typingText : Text = "";
    var liveCount : Nat = 0;
    var onlineCount : Nat = 0;
    var bound : Bool = false;
    var canMod : Bool = false;
    var locked : Bool = false;
    var muted : Bool = false;
    var myHandle : Text = "";
    var me : Principal = Principal.fromText("2vxsx-fae");
    var replyingTo : Nat = 0;
    var editingId : Nat = 0;
    var openThreadId : Nat = 0;
    var draft : Text = "";
    var editText : Text = "";
    var threadText : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func paramNat(ctx : Context, k : Text) : Nat {
        for ((kk, vv) in ctx.params.vals()) { if (kk == k) { return mvNat(vv) } };
        0;
    };
    func onLoad(ctx : Context) {
        rid := paramNat(ctx, "rid");
        me := ctx.caller;
        bound := Identity.isBound(ctx.caller);
        myHandle := Identity.handleOf(ctx.caller);

        switch (Chat.room(rid)) {
            case null { exists := false };
            case (?r) {
                exists := true;
                roomName := r.name;
                serverId := r.serverId;
            };
        };

        Chat.ping(ctx.caller, myHandle, rid);

        messages := Chat.messages(rid);
        emojiSet := Chat.emojiSet();
        liveCount := Chat.messageCount(rid);
        onlineCount := Chat.onlineCount();

        typing := Chat.typingIn(rid, myHandle);
        typingText := joinHandles(typing);

        locked := Servers.isLocked(rid);
        canMod := Servers.canModerate(serverId, ctx.caller);
        muted := Servers.isMuted(serverId, ctx.caller);
    };
    func authorLabel(handle : Text, author : Principal) : Text {
        if (handle != "") handle else Identity.handleOf(author);
    };
    func avatarFor(p : Principal) : Text { Identity.avatarOf(p) };
    func timeOf(at : Int) : Text { Chat.relativeTime(at) };
    func isMineP(author : Principal) : Bool { author == me };
    func isDel(deleted : Int) : Bool { deleted != 0 };
    func emo(e : Text) : Text { e };
    func reactionsFor(msgId : Nat) : [(Text, Nat)] { Chat.reactions(msgId) };
    func threadCountOf(msgId : Nat) : Nat { Chat.threadCount(msgId) };
    func replySnippet(msgId : Nat) : Text {
        switch (Chat.message(msgId)) {
            case null { "a message" };
            case (?m) {
                let who = if (m.authorHandle != "") m.authorHandle else Identity.handleOf(m.author);
                if (m.deleted != 0) { who # ": (deleted)" }
                else { who # ": " # snippet(m.text) };
            };
        };
    };
    func snippet(t : Text) : Text {
        let chars = Text.toArray(t);
        if (chars.size() <= 40) { t }
        else { Text.fromIter(Array.subArray(chars, 0, 40).vals()) # "…" };
    };
    func joinHandles(hs : [Text]) : Text {
        if (hs.size() == 0) { return "" };
        if (hs.size() == 1) { return hs[0] };
        if (hs.size() == 2) { return hs[0] # " and " # hs[1] };
        Nat.toText(hs.size()) # " people";
    };
    func plural(n : Nat, one : Text, many : Text) : Text {
        if (n == 1) one else many;
    };
    func send(ctx : Context) : () {
         mvErrors.clear(); if (draft == "") { mvErrors.add(("draft", "Type a message.")) }; if (mvErrors.size() > 0) { return }; 
        let roomId = paramNat(ctx, "rid");
        let newId = Chat.post(ctx.caller, Identity.handleOf(ctx.caller), roomId, draft, replyingTo);
        if (newId == 0) {
            toast("Could not send — channel may be missing.");
            return;
        };
        draft := "";
        replyingTo := 0;
        scrollTo("#ch-stream");
    };
    func react(ctx : Context, msgId : Nat, emoji : Text) : () {
        ignore Chat.react(ctx.caller, msgId, emoji);
    };
    func startReply(id : Nat) : () {
        replyingTo := id;
        focusOn("#draft");
    };
    func cancelReply() : () { replyingTo := 0; };
    func startEdit(ctx : Context, id : Nat) : () {
        switch (Chat.message(id)) {
            case (?m) { if (m.author == ctx.caller) { editingId := id; editText := m.text } };
            case null {};
        };
    };
    func cancelEdit() : () { editingId := 0; editText := ""; };
    func saveEdit(ctx : Context) : () {
         mvErrors.clear(); if (editText == "") { mvErrors.add(("editText", "Message can't be empty.")) }; if (mvErrors.size() > 0) { return }; 
        if (editingId != 0) {
            ignore Chat.edit(ctx.caller, editingId, editText);
        };
        editingId := 0;
        editText := "";
        toast("Message updated.");
    };
    func del(ctx : Context, id : Nat) : () {
        ignore Chat.del(ctx.caller, id);
        toast("Message deleted.");
    };
    func openThread(id : Nat) : () {
        openThreadId := if (openThreadId == id) 0 else id;
    };
    func postThread(ctx : Context) : () {
         mvErrors.clear(); if (threadText == "") { mvErrors.add(("threadText", "Type a thread reply.")) }; if (mvErrors.size() > 0) { return }; 
        if (openThreadId != 0) {
            ignore Chat.replyThread(ctx.caller, Identity.handleOf(ctx.caller), openThreadId, threadText);
        };
        threadText := "";
        toast("Thread reply posted.");
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      rid := mvNat(mvParamGet(ctx, "rid"));
      if (not exists) {
        b.raw("\n    ");
        b.raw("<div");
        b.raw(" class=\"bz-card ch-missing\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<div");
        b.raw(" class=\"ch-missing-ico\"");
        b.raw(">");
        b.raw("🚫");
        b.raw("</div>");
        b.raw("\n        ");
        b.raw("<h2");
        b.raw(">");
        b.raw("Channel not found");
        b.raw("</h2>");
        b.raw("\n        ");
        b.raw("<p");
        b.raw(">");
        b.raw("This channel does not exist. ");
        b.raw("<a");
        b.raw(" href=\"/servers\"");
        b.raw(">");
        b.raw("Browse servers");
        b.raw("</a>");
        b.raw(".");
        b.raw("</p>");
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      } else {
        b.raw("\n    ");
        b.raw("<div");
        b.raw(" class=\"ch-wrap bz-card\"");
        b.raw(">");
        b.raw("\n        ");
        b.raw("<header");
        b.raw(" class=\"ch-head\"");
        b.raw(">");
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"ch-head-main\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<h1");
        b.raw(">");
        b.raw("<span");
        b.raw(" class=\"ch-hash\"");
        b.raw(">");
        b.raw("#");
        b.raw("</span>");
        b.text(roomName);
        b.raw("</h1>");
        b.raw("\n                ");
        b.raw("<span");
        b.raw(" class=\"ch-sub\"");
        b.raw(">");
        b.text(Nat.toText(liveCount));
        b.raw(" ");
        b.text(plural(liveCount, "message", "messages"));
        b.raw(" · ");
        b.text(Nat.toText(onlineCount));
        b.raw(" online");
        b.raw("</span>");
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n            ");
        if (locked) {
          b.raw("\n                ");
          b.raw("<span");
          b.raw(" class=\"ch-lockchip\"");
          b.raw(">");
          b.raw("🔒 Locked — only moderators can post");
          b.raw("</span>");
          b.raw("\n            ");
        };
        b.raw("\n            ");
        b.raw("<a");
        b.raw(" class=\"ch-back\"");
        b.raw(" href=\"");
        b.raw("/servers/");
        b.text(Nat.toText(serverId));
        b.raw("\"");
        b.raw(">");
        b.raw("↩ server");
        b.raw("</a>");
        b.raw("\n        ");
        b.raw("</header>");
        b.raw("\n\n        ");
        b.raw("<div");
        b.raw(" class=\"ch-stream\"");
        b.raw(" id=\"ch-stream\"");
        b.raw(">");
        b.raw("\n            ");
        if (messages.size() == 0) {
          b.raw("\n                ");
          b.raw("<div");
          b.raw(" class=\"ch-empty\"");
          b.raw(">");
          b.raw("\n                    ");
          b.raw("<div");
          b.raw(" class=\"ch-empty-ico\"");
          b.raw(">");
          b.raw("👋");
          b.raw("</div>");
          b.raw("\n                    ");
          b.raw("<p");
          b.raw(">");
          b.raw("No messages yet — say hello in ");
          b.raw("<strong");
          b.raw(">");
          b.raw("#");
          b.text(roomName);
          b.raw("</strong>");
          b.raw(".");
          b.raw("</p>");
          b.raw("\n                ");
          b.raw("</div>");
          b.raw("\n            ");
        } else {
          b.raw("\n                ");
          for (m in (messages).vals()) {
            b.raw("\n                    ");
            b.raw("<article");
            b.raw(" class=\"ch-msg\"");
            b.raw(" id=\"");
            b.raw("msg-");
            b.text(Html.unquote(debug_show(m.id)));
            b.raw("\"");
            b.raw(">");
            b.raw("\n                        ");
            b.raw("<div");
            b.raw(" class=\"ch-ava\"");
            b.raw(">");
            b.text(avatarFor(m.author));
            b.raw("</div>");
            b.raw("\n                        ");
            b.raw("<div");
            b.raw(" class=\"ch-msg-body\"");
            b.raw(">");
            b.raw("\n                            ");
            b.raw("<div");
            b.raw(" class=\"ch-msg-top\"");
            b.raw(">");
            b.raw("\n                                ");
            b.raw("<span");
            b.raw(" class=\"ch-author\"");
            b.raw(">");
            b.text(authorLabel(m.authorHandle, m.author));
            b.raw("</span>");
            b.raw("\n                                ");
            b.raw("<span");
            b.raw(" class=\"ch-time\"");
            b.raw(">");
            b.text(timeOf(m.at));
            b.raw("</span>");
            b.raw("\n                                ");
            if (m.edited != 0) {
              b.raw(" ");
              b.raw("<span");
              b.raw(" class=\"ch-edited\"");
              b.raw(">");
              b.raw("(edited)");
              b.raw("</span>");
              b.raw(" ");
            };
            b.raw("\n                            ");
            b.raw("</div>");
            b.raw("\n\n                            ");
            if (m.replyTo != 0) {
              b.raw("\n                                ");
              b.raw("<div");
              b.raw(" class=\"ch-reply-ctx\"");
              b.raw(">");
              b.raw("↪ replying to ");
              b.raw("<span");
              b.raw(" class=\"ch-reply-snip\"");
              b.raw(">");
              b.text(replySnippet(m.replyTo));
              b.raw("</span>");
              b.raw("</div>");
              b.raw("\n                            ");
            };
            b.raw("\n\n                            ");
            if (isDel(m.deleted)) {
              b.raw("\n                                ");
              b.raw("<div");
              b.raw(" class=\"ch-text ch-deleted\"");
              b.raw(">");
              b.raw("message deleted");
              b.raw("</div>");
              b.raw("\n                            ");
            } else if (editingId == m.id) {
              b.raw("\n                                ");
              b.raw("<form");
              b.raw(" novalidate");
              b.raw(" class=\"ch-edit-form\"");
              b.raw(" data-mv-handler=\"saveEdit\" data-mv-event=\"submit\"");
              b.raw(" data-mv-secure=\"1\"");
              b.attr("data-mv-token", ctx.mintToken("saveEdit", "editText"));
              b.raw(" data-mv-schema=\"editText\"");
              b.raw(">");
              b.raw("\n                                    ");
              b.raw("<div class=\"mv-field\">");
              b.raw("<label>Edit message *</label>");
              b.raw("<input type=\"text\" class=\"mv-input\" name=\"editText\" data-mv-key=\"editText\"");
              b.raw(" required");
              b.attr("value", editText);
              b.raw(">");
              for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "editText") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
              b.raw("</div>");
              b.raw("\n                                    ");
              b.raw("<div");
              b.raw(" class=\"ch-edit-actions\"");
              b.raw(">");
              b.raw("\n                                        ");
              b.raw("<button type=\"submit\" class=\"mv-btn mv-btn-primary\"");
              b.raw(">");
              b.raw("Save");
              b.raw("</button>");
              b.raw("\n                                        ");
              b.raw("<button");
              b.raw(" type=\"button\"");
              b.raw(" class=\"ch-mini-btn\"");
              b.raw(" data-mv-handler=\"cancelEdit\" data-mv-event=\"click\"");
              b.raw(">");
              b.raw("Cancel");
              b.raw("</button>");
              b.raw("\n                                    ");
              b.raw("</div>");
              b.raw("\n                                ");
              b.raw("</form>");
              b.raw("\n                            ");
            } else {
              b.raw("\n                                ");
              b.raw("<div");
              b.raw(" class=\"ch-text\"");
              b.raw(">");
              b.text(Html.unquote(debug_show(m.text)));
              b.raw("</div>");
              b.raw("\n                            ");
            };
            b.raw("\n\n                            ");
            if (not isDel(m.deleted)) {
              b.raw("\n                                ");
              b.raw("<div");
              b.raw(" class=\"ch-reactions\"");
              b.raw(">");
              b.raw("\n                                    ");
              for (r in (reactionsFor(m.id)).vals()) {
                b.raw("\n                                        ");
                b.raw("<span");
                b.raw(" class=\"ch-react-pill\"");
                b.raw(">");
                b.text(Html.unquote(debug_show(r.0)));
                b.raw(" ");
                b.text(Html.unquote(debug_show(r.1)));
                b.raw("</span>");
                b.raw("\n                                    ");
              };
              b.raw("\n                                    ");
              b.raw("<span");
              b.raw(" class=\"ch-react-quick\"");
              b.raw(">");
              b.raw("\n                                        ");
              for (e in (emojiSet).vals()) {
                b.raw("\n                                            ");
                b.raw("<button");
                b.raw(" class=\"ch-react-btn\"");
                b.raw(" data-mv-handler=\"react\" data-mv-event=\"click\"");
                b.attr("data-mv-arg0", Html.unquote(debug_show(m.id)));
                b.attr("data-mv-arg1", emo(e));
                b.raw(">");
                b.text(Html.unquote(debug_show(e)));
                b.raw("</button>");
                b.raw("\n                                        ");
              };
              b.raw("\n                                    ");
              b.raw("</span>");
              b.raw("\n                                ");
              b.raw("</div>");
              b.raw("\n\n                                ");
              b.raw("<div");
              b.raw(" class=\"ch-msg-actions\"");
              b.raw(">");
              b.raw("\n                                    ");
              b.raw("<button");
              b.raw(" class=\"ch-mini-btn\"");
              b.raw(" data-mv-handler=\"startReply\" data-mv-event=\"click\"");
              b.attr("data-mv-arg0", Html.unquote(debug_show(m.id)));
              b.raw(">");
              b.raw("Reply");
              b.raw("</button>");
              b.raw("\n                                    ");
              b.raw("<button");
              b.raw(" type=\"button\"");
              b.raw(" class=\"ch-mini-btn ch-thread-link\"");
              b.raw(" data-mv-handler=\"openThread\" data-mv-event=\"click\"");
              b.attr("data-mv-arg0", Html.unquote(debug_show(m.id)));
              b.raw(">");
              b.raw("🧵 Thread (");
              b.text(Nat.toText(threadCountOf(m.id)));
              b.raw(")");
              b.raw("</button>");
              b.raw("\n                                    ");
              if (isMineP(m.author)) {
                b.raw("\n                                        ");
                b.raw("<button");
                b.raw(" class=\"ch-mini-btn\"");
                b.raw(" data-mv-handler=\"startEdit\" data-mv-event=\"click\"");
                b.attr("data-mv-arg0", Html.unquote(debug_show(m.id)));
                b.raw(">");
                b.raw("Edit");
                b.raw("</button>");
                b.raw("\n                                        ");
                b.raw("<button");
                b.raw(" class=\"ch-mini-btn ch-mini-danger\"");
                b.raw(" data-mv-handler=\"del\" data-mv-event=\"click\"");
                b.attr("data-mv-arg0", Html.unquote(debug_show(m.id)));
                b.raw(">");
                b.raw("Delete");
                b.raw("</button>");
                b.raw("\n                                    ");
              };
              b.raw("\n                                ");
              b.raw("</div>");
              b.raw("\n\n                                ");
              if (openThreadId == m.id) {
                b.raw("\n                                    ");
                b.raw("<div");
                b.raw(" class=\"ch-thread\"");
                b.raw(">");
                b.raw("\n                                        ");
                if (threadCountOf(m.id) == 0) {
                  b.raw("\n                                            ");
                  b.raw("<p");
                  b.raw(" class=\"ch-thread-empty\"");
                  b.raw(">");
                  b.raw("No replies in this thread yet.");
                  b.raw("</p>");
                  b.raw("\n                                        ");
                } else {
                  b.raw("\n                                            ");
                  for (t in (Chat.thread(m.id)).vals()) {
                    b.raw("\n                                                ");
                    b.raw("<div");
                    b.raw(" class=\"ch-thread-msg\"");
                    b.raw(">");
                    b.raw("\n                                                    ");
                    b.raw("<span");
                    b.raw(" class=\"ch-thread-author\"");
                    b.raw(">");
                    b.text(Html.unquote(debug_show(t.handle)));
                    b.raw("</span>");
                    b.raw("\n                                                    ");
                    b.raw("<span");
                    b.raw(" class=\"ch-thread-time\"");
                    b.raw(">");
                    b.text(timeOf(t.at));
                    b.raw("</span>");
                    b.raw("\n                                                    ");
                    b.raw("<div");
                    b.raw(" class=\"ch-thread-text\"");
                    b.raw(">");
                    b.text(Html.unquote(debug_show(t.text)));
                    b.raw("</div>");
                    b.raw("\n                                                ");
                    b.raw("</div>");
                    b.raw("\n                                            ");
                  };
                  b.raw("\n                                        ");
                };
                b.raw("\n                                        ");
                b.raw("<form");
                b.raw(" novalidate");
                b.raw(" class=\"ch-thread-form\"");
                b.raw(" data-mv-handler=\"postThread\" data-mv-event=\"submit\"");
                b.raw(" data-mv-secure=\"1\"");
                b.attr("data-mv-token", ctx.mintToken("postThread", "threadText"));
                b.raw(" data-mv-schema=\"threadText\"");
                b.raw(">");
                b.raw("\n                                            ");
                b.raw("<div class=\"mv-field\">");
                b.raw("<label>Reply in thread *</label>");
                b.raw("<input type=\"text\" class=\"mv-input\" name=\"threadText\" data-mv-key=\"threadText\"");
                b.raw(" required");
                b.attr("value", threadText);
                b.raw(">");
                for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "threadText") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
                b.raw("</div>");
                b.raw("\n                                            ");
                b.raw("<button type=\"submit\" class=\"mv-btn mv-btn-primary\"");
                b.raw(">");
                b.raw("Send");
                b.raw("</button>");
                b.raw("\n                                        ");
                b.raw("</form>");
                b.raw("\n                                    ");
                b.raw("</div>");
                b.raw("\n                                ");
              };
              b.raw("\n                            ");
            };
            b.raw("\n                        ");
            b.raw("</div>");
            b.raw("\n                    ");
            b.raw("</article>");
            b.raw("\n                ");
          };
          b.raw("\n            ");
        };
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n\n        ");
        b.raw("<div");
        b.raw(" class=\"ch-typing\"");
        b.raw(">");
        b.raw("\n            ");
        if (typing.size() > 0) {
          b.raw("\n                ");
          b.raw("<span");
          b.raw(" class=\"ch-typing-dot\"");
          b.raw(">");
          b.raw("</span>");
          b.raw("<span");
          b.raw(" class=\"ch-typing-dot\"");
          b.raw(">");
          b.raw("</span>");
          b.raw("<span");
          b.raw(" class=\"ch-typing-dot\"");
          b.raw(">");
          b.raw("</span>");
          b.raw("\n                ");
          b.raw("<span");
          b.raw(" class=\"ch-typing-text\"");
          b.raw(">");
          b.text(typingText);
          b.raw(" is typing…");
          b.raw("</span>");
          b.raw("\n            ");
        };
        b.raw("\n        ");
        b.raw("</div>");
        b.raw("\n\n        ");
        if (replyingTo != 0) {
          b.raw("\n            ");
          b.raw("<div");
          b.raw(" class=\"ch-replybar\"");
          b.raw(">");
          b.raw("\n                ↪ Replying to ");
          b.raw("<span");
          b.raw(" class=\"ch-reply-snip\"");
          b.raw(">");
          b.text(replySnippet(replyingTo));
          b.raw("</span>");
          b.raw("\n                ");
          b.raw("<button");
          b.raw(" class=\"ch-mini-btn\"");
          b.raw(" data-mv-handler=\"cancelReply\" data-mv-event=\"click\"");
          b.raw(">");
          b.raw("✕");
          b.raw("</button>");
          b.raw("\n            ");
          b.raw("</div>");
          b.raw("\n        ");
        };
        b.raw("\n\n        ");
        if (locked and not canMod) {
          b.raw("\n            ");
          b.raw("<div");
          b.raw(" class=\"ch-composer-locked\"");
          b.raw(">");
          b.raw("This channel is locked. Only moderators can post right now.");
          b.raw("</div>");
          b.raw("\n        ");
        } else if (muted) {
          b.raw("\n            ");
          b.raw("<div");
          b.raw(" class=\"ch-composer-locked\"");
          b.raw(">");
          b.raw("You are muted in this server and cannot post.");
          b.raw("</div>");
          b.raw("\n        ");
        } else if (not bound) {
          b.raw("\n            ");
          b.raw("<div");
          b.raw(" class=\"ch-composer-locked\"");
          b.raw(">");
          b.raw("<a");
          b.raw(" href=\"/me\"");
          b.raw(">");
          b.raw("Claim a handle");
          b.raw("</a>");
          b.raw(" to join the conversation.");
          b.raw("</div>");
          b.raw("\n        ");
        } else {
          b.raw("\n            ");
          b.raw("<form");
          b.raw(" novalidate");
          b.raw(" class=\"ch-composer\"");
          b.raw(" data-mv-handler=\"send\" data-mv-event=\"submit\"");
          b.raw(" data-mv-secure=\"1\"");
          b.attr("data-mv-token", ctx.mintToken("send", "draft"));
          b.raw(" data-mv-schema=\"draft\"");
          b.raw(">");
          b.raw("\n                ");
          if (mvErrors.size() > 0) {
            b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
            for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
            b.raw("</ul></div>");
          };
          b.raw("\n                ");
          b.raw("<div");
          b.raw(" class=\"ch-composer-row\"");
          b.raw(">");
          b.raw("\n                    ");
          b.raw("<div class=\"mv-field\">");
          b.raw("<label>Type a message *</label>");
          b.raw("<input type=\"text\" class=\"mv-input\" name=\"draft\" data-mv-key=\"draft\"");
          b.raw(" required");
          b.attr("value", draft);
          b.raw(">");
          for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "draft") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
          b.raw("</div>");
          b.raw("\n                    ");
          b.raw("<button type=\"submit\" class=\"mv-btn mv-btn-primary\"");
          b.raw(">");
          b.raw("Send");
          b.raw("</button>");
          b.raw("\n                ");
          b.raw("</div>");
          b.raw("\n            ");
          b.raw("</form>");
          b.raw("\n        ");
        };
        b.raw("\n    ");
        b.raw("</div>");
        b.raw("\n");
      };
      b.raw("\n\n");
      b.raw("<style");
      b.raw(">");
      b.raw("\n    .ch-missing { text-align:center; padding:2.5rem 1.2rem; }\n    .ch-missing-ico { font-size:2.4rem; }\n    .ch-missing a { color:var(--bz-accent); font-weight:600; }\n\n    .ch-wrap { display:flex; flex-direction:column; height:calc(100vh - var(--bz-nav-h) - 6rem); min-height:520px; overflow:hidden; }\n\n    .ch-head { display:flex; align-items:center; gap:.75rem; padding:.9rem 1.1rem; border-bottom:1px solid var(--mv-border); flex:none; }\n    .ch-head-main { display:flex; flex-direction:column; }\n    .ch-head h1 { margin:0; font-size:1.2rem; letter-spacing:-.01em; }\n    .ch-hash { color:var(--mv-text-soft); }\n    .ch-sub { font-size:.8rem; color:var(--mv-text-soft); }\n    .ch-lockchip { font-size:.75rem; font-weight:600; color:#92400e; background:#fef3c7; padding:.2rem .5rem; border-radius:999px; }\n    .ch-back { margin-left:auto; font-size:.82rem; font-weight:600; color:var(--bz-accent); text-decoration:none; }\n\n    .ch-stream { flex:1; overflow-y:auto; padding:1rem 1.1rem; display:flex; flex-direction:column; gap:.65rem; }\n    .ch-empty { text-align:center; color:var(--mv-text-soft); margin:auto; }\n    .ch-empty-ico { font-size:2rem; }\n\n    .ch-msg { display:flex; gap:.65rem; padding:.35rem .4rem; border-radius:10px; }\n    .ch-msg:hover { background:var(--mv-muted); }\n    .ch-ava { width:38px; height:38px; border-radius:50%; background:var(--mv-muted); display:grid; place-items:center; font-size:1.25rem; flex:none; }\n    .ch-msg-body { min-width:0; flex:1; }\n    .ch-msg-top { display:flex; align-items:baseline; gap:.5rem; }\n    .ch-author { font-weight:800; font-size:.92rem; }\n    .ch-time { font-size:.74rem; color:var(--mv-text-soft); }\n    .ch-edited { font-size:.72rem; color:var(--mv-text-soft); font-style:italic; }\n\n    .ch-reply-ctx { font-size:.78rem; color:var(--mv-text-soft); margin:.1rem 0 .15rem; }\n    .ch-reply-snip { font-style:italic; }\n\n    .ch-text { font-size:.95rem; line-height:1.45; word-wrap:break-word; overflow-wrap:anywhere; }\n    .ch-deleted { color:var(--mv-text-soft); font-style:italic; }\n\n    .ch-reactions { display:flex; flex-wrap:wrap; align-items:center; gap:.3rem; margin-top:.35rem; }\n    .ch-react-pill { font-size:.82rem; background:var(--mv-muted); border:1px solid var(--mv-border); border-radius:999px; padding:.1rem .45rem; }\n    .ch-react-quick { display:inline-flex; gap:.1rem; opacity:0; transition:opacity .12s ease; }\n    .ch-msg:hover .ch-react-quick { opacity:1; }\n    .ch-react-btn { font-size:.9rem; background:transparent; border:1px solid transparent; border-radius:7px; padding:.05rem .25rem; cursor:pointer; }\n    .ch-react-btn:hover { background:var(--mv-surface); border-color:var(--mv-border); }\n\n    .ch-msg-actions { display:flex; gap:.35rem; margin-top:.3rem; opacity:0; transition:opacity .12s ease; }\n    .ch-msg:hover .ch-msg-actions { opacity:1; }\n    .ch-mini-btn { font-size:.74rem; font-weight:600; padding:.18rem .45rem; border-radius:7px; cursor:pointer;\n        border:1px solid var(--mv-border); background:var(--mv-surface); color:var(--mv-text); text-decoration:none; }\n    .ch-mini-btn:hover { background:var(--bz-accent); color:#fff; border-color:var(--bz-accent); }\n    .ch-mini-danger:hover { background:#dc2626; border-color:#dc2626; }\n    .ch-thread-link { color:var(--mv-text-soft); }\n\n    .ch-edit-form { margin:.3rem 0; }\n    .ch-edit-actions { display:flex; gap:.4rem; align-items:center; margin-top:.3rem; }\n\n    .ch-thread { margin-top:.5rem; padding:.6rem .7rem; border-left:3px solid var(--bz-accent); background:var(--mv-muted); border-radius:0 10px 10px 0; }\n    .ch-thread-empty { margin:0 0 .5rem; font-size:.82rem; color:var(--mv-text-soft); }\n    .ch-thread-msg { margin-bottom:.5rem; }\n    .ch-thread-author { font-weight:700; font-size:.84rem; }\n    .ch-thread-time { font-size:.72rem; color:var(--mv-text-soft); margin-left:.4rem; }\n    .ch-thread-text { font-size:.88rem; line-height:1.4; }\n    .ch-thread-form { display:flex; gap:.5rem; align-items:end; margin-top:.4rem; }\n\n    .ch-typing { height:1.2rem; padding:0 1.1rem; display:flex; align-items:center; gap:.2rem; flex:none; }\n    .ch-typing-dot { width:5px; height:5px; border-radius:50%; background:var(--mv-text-soft); animation:chBlink 1.2s infinite ease-in-out; }\n    .ch-typing-dot:nth-child(2) { animation-delay:.2s; }\n    .ch-typing-dot:nth-child(3) { animation-delay:.4s; }\n    .ch-typing-text { font-size:.78rem; color:var(--mv-text-soft); margin-left:.3rem; }\n    @keyframes chBlink { 0%, 80%, 100% { opacity:.3; } 40% { opacity:1; } }\n\n    .ch-replybar { display:flex; align-items:center; gap:.5rem; padding:.5rem 1.1rem; font-size:.82rem;\n        color:var(--mv-text-soft); background:var(--mv-muted); border-top:1px solid var(--mv-border); flex:none; }\n\n    .ch-composer { padding:.8rem 1.1rem; border-top:1px solid var(--mv-border); flex:none; }\n    .ch-composer-row { display:flex; gap:.6rem; align-items:end; }\n    .ch-composer-locked { padding:.9rem 1.1rem; border-top:1px solid var(--mv-border); color:var(--mv-text-soft); font-size:.9rem; flex:none; }\n    .ch-composer-locked a { color:var(--bz-accent); font-weight:600; }\n");
      b.raw("</style>");
      b.raw("\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; rid := mvNat(mvParamGet(ctx, "rid")); "#" # roomName # " — Bzzz channel" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; rid := mvNat(mvParamGet(ctx, "rid")); { title = "#" # roomName # " — Bzzz channel"; description = "Live chat in #" # roomName # " on Bzzz — post messages, react, reply and thread in a Discord-style channel running on the Internet Computer."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; rid := mvNat(mvParamGet(ctx, "rid")); onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      rid := mvNat(mvParamGet(ctx, "rid"));
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "draft")) { case (?mvV) { draft := mvV }; case null {} };
      switch (mvFormGet(ctx, "editText")) { case (?mvV) { editText := mvV }; case null {} };
      switch (mvFormGet(ctx, "threadText")) { case (?mvV) { threadText := mvV }; case null {} };
      switch mvH {
        case "send" { send(ctx) };
        case "react" { react(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else "")), (if (mvArgs.size() > 1) mvArgs[1] else "")) };
        case "startReply" { startReply(mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "cancelReply" { cancelReply() };
        case "startEdit" { startEdit(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "cancelEdit" { cancelEdit() };
        case "saveEdit" { saveEdit(ctx) };
        case "del" { del(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "openThread" { openThread(mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "postThread" { postThread(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Feed.mview
  // ===== Page: Feed (/feed) =====
  let FeedPage = object {
    var bound : Bool = false;
    var me : Principal = Principal.fromText("2vxsx-fae");
    var meAvatar : Text = "🐝";
    var timeline : [Feed.FeedPost] = [];
    var hasPosts : Bool = false;
    var postCount : Nat = 0;
    var suggestions : [Identity.Profile] = [];
    var hasSuggestions : Bool = false;
    var followingCount : Nat = 0;
    var followerCount : Nat = 0;
    var body : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        me := ctx.caller;
        bound := Identity.isBound(ctx.caller);
        meAvatar := Identity.avatarOf(ctx.caller);

        timeline := Feed.homeTimeline(ctx.caller);
        hasPosts := timeline.size() > 0;
        postCount := Feed.postCount();

        suggestions := whoToFollow(ctx.caller);
        hasSuggestions := suggestions.size() > 0;
        followingCount := Feed.followingCount(ctx.caller);
        followerCount := Feed.followerCount(ctx.caller);
    };
    func whoToFollow(caller : Principal) : [Identity.Profile] {
        let all = Identity.all();
        let keep = Array.filter<Identity.Profile>(all, func(p : Identity.Profile) : Bool {
            p.principal != caller
        });
        if (keep.size() <= 5) { keep } else { Array.subArray(keep, 0, 5) };
    };
    func avatarOf(p : Principal) : Text { Identity.avatarOf(p) };
    func rel(t : Int) : Text { Feed.relativeTime(t) };
    func at(handle : Text) : Text { "@" # handle };
    func remaining() : Nat {
        let n = Text.size(body);
        if (n >= 280) { 0 } else { 280 - n };
    };
    func heart(id : Nat) : Text {
        if (Feed.hasLiked(me, id)) { "❤️" } else { "🤍" };
    };
    func likeClass(id : Nat) : Text {
        if (Feed.hasLiked(me, id)) { "is-on" } else { "" };
    };
    func repostClass(id : Nat) : Text {
        if (Feed.hasReposted(me, id)) { "is-on" } else { "" };
    };
    func followClass(p : Principal) : Text {
        if (Feed.isFollowing(me, p)) { "is-on" } else { "" };
    };
    func followLabel(p : Principal) : Text {
        if (Feed.isFollowing(me, p)) { "Following" } else { "Follow" };
    };
    func post(ctx : Context) : () {
         mvErrors.clear(); if (body == "") { mvErrors.add(("body", "Write something first.")) }; if (mvErrors.size() > 0) { return }; 
        let id = Feed.post(ctx.caller, Identity.handleOf(ctx.caller), body);
        if (id == 0) {
            toast("Couldn't post that — check the length.");
        } else {
            body := "";
            toast("Posted to Bzzz.");
        };
    };
    func like(ctx : Context, id : Nat) : () {
        let _ = Feed.like(ctx.caller, id);
    };
    func repost(ctx : Context, id : Nat) : () {
        let _ = Feed.repost(ctx.caller, id);
    };
    func toggleFollow(ctx : Context, handle : Text) : () {
        switch (Identity.byHandleLookup(handle)) {
            case (?prof) {
                let nowFollowing = Feed.follow(ctx.caller, prof.principal);
                if (nowFollowing) { toast("Following @" # handle); }
                else { toast("Unfollowed @" # handle); };
            };
            case null { toast("Couldn't find that user."); };
        };
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<div");
      b.raw(" class=\"fd-wrap\"");
      b.raw(">");
      b.raw("\n    ");
      b.raw("<div");
      b.raw(" class=\"fd-main\"");
      b.raw(">");
      b.raw("\n        ");
      b.raw("<header");
      b.raw(" class=\"fd-head\"");
      b.raw(">");
      b.raw("\n            ");
      b.raw("<h1");
      b.raw(">");
      b.raw("Home");
      b.raw("</h1>");
      b.raw("\n            ");
      b.raw("<p");
      b.raw(" class=\"fd-sub\"");
      b.raw(">");
      b.text(Nat.toText(postCount));
      b.raw(" posts on Bzzz · following ");
      b.text(Nat.toText(followingCount));
      b.raw("</p>");
      b.raw("\n        ");
      b.raw("</header>");
      b.raw("\n\n        ");
      if (bound) {
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"fd-composer bz-card\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<div");
        b.raw(" class=\"fd-ava\"");
        b.raw(">");
        b.text(meAvatar);
        b.raw("</div>");
        b.raw("\n                ");
        b.raw("<form");
        b.raw(" novalidate");
        b.raw(" class=\"fd-composer-form\"");
        b.raw(" data-mv-handler=\"post\" data-mv-event=\"submit\"");
        b.raw(" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("post", "body"));
        b.raw(" data-mv-schema=\"body\"");
        b.raw(">");
        b.raw("\n                    ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n                    ");
        b.raw("<div class=\"mv-field\">");
        b.raw("<label> *</label>");
        b.raw("<textarea class=\"mv-textarea\" name=\"body\" data-mv-key=\"body\"");
        b.raw(" required");
        b.raw(">");
        b.text(body);
        b.raw("</textarea>");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "body") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>");
        b.raw("\n                    ");
        b.raw("<div");
        b.raw(" class=\"fd-composer-foot\"");
        b.raw(">");
        b.raw("\n                        ");
        b.raw("<span");
        b.raw(" class=\"fd-counter\"");
        b.raw(">");
        b.text(Nat.toText(remaining()));
        b.raw(" left");
        b.raw("</span>");
        b.raw("\n                        ");
        b.raw("<button type=\"submit\" class=\"mv-btn mv-btn-primary\"");
        b.raw(">");
        b.raw("Bzzz it");
        b.raw("</button>");
        b.raw("\n                    ");
        b.raw("</div>");
        b.raw("\n                ");
        b.raw("</form>");
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n        ");
      } else {
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"fd-claim bz-card\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<span");
        b.raw(" class=\"fd-claim-ico\"");
        b.raw(">");
        b.raw("🐝");
        b.raw("</span>");
        b.raw("\n                ");
        b.raw("<div");
        b.raw(">");
        b.raw("\n                    ");
        b.raw("<strong");
        b.raw(">");
        b.raw("Claim a handle to start posting.");
        b.raw("</strong>");
        b.raw("\n                    ");
        b.raw("<p");
        b.raw(">");
        b.raw("Pick your handle on the ");
        b.raw("<a");
        b.raw(" href=\"/me\"");
        b.raw(">");
        b.raw("profile");
        b.raw("</a>");
        b.raw(" page, then come back to share your first Bzzz.");
        b.raw("</p>");
        b.raw("\n                ");
        b.raw("</div>");
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n        ");
      };
      b.raw("\n\n        ");
      if (hasPosts) {
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"fd-stream\"");
        b.raw(">");
        b.raw("\n                ");
        for (p in (timeline).vals()) {
          b.raw("\n                    ");
          b.raw("<article");
          b.raw(" class=\"fd-post bz-card\"");
          b.raw(" id=\"");
          b.raw("post-");
          b.text(Html.unquote(debug_show(p.id)));
          b.raw("\"");
          b.raw(">");
          b.raw("\n                        ");
          b.raw("<div");
          b.raw(" class=\"fd-ava\"");
          b.raw(">");
          b.text(avatarOf(p.author));
          b.raw("</div>");
          b.raw("\n                        ");
          b.raw("<div");
          b.raw(" class=\"fd-body\"");
          b.raw(">");
          b.raw("\n                            ");
          b.raw("<div");
          b.raw(" class=\"fd-post-head\"");
          b.raw(">");
          b.raw("\n                                ");
          b.raw("<span");
          b.raw(" class=\"fd-handle\"");
          b.raw(">");
          b.text(at(p.authorHandle));
          b.raw("</span>");
          b.raw("\n                                ");
          b.raw("<span");
          b.raw(" class=\"fd-dot\"");
          b.raw(">");
          b.raw("·");
          b.raw("</span>");
          b.raw("\n                                ");
          b.raw("<span");
          b.raw(" class=\"fd-time\"");
          b.raw(">");
          b.text(rel(p.at));
          b.raw("</span>");
          b.raw("\n                            ");
          b.raw("</div>");
          b.raw("\n                            ");
          b.raw("<div");
          b.raw(" class=\"fd-text\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(p.text)));
          b.raw("</div>");
          b.raw("\n                            ");
          b.raw("<div");
          b.raw(" class=\"fd-actions\"");
          b.raw(">");
          b.raw("\n                                ");
          b.raw("<a");
          b.raw(" class=\"fd-act\"");
          b.raw(" href=\"/feed\"");
          b.raw(">");
          b.raw("\n                                    ");
          b.raw("<span");
          b.raw(" class=\"fd-act-ico\"");
          b.raw(">");
          b.raw("💬");
          b.raw("</span>");
          b.raw("\n                                    ");
          b.raw("<span");
          b.raw(" class=\"fd-act-n\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(p.replyCount)));
          b.raw("</span>");
          b.raw("\n                                ");
          b.raw("</a>");
          b.raw("\n                                ");
          b.raw("<button");
          b.raw(" class=\"");
          b.raw("fd-act fd-act-repost ");
          b.text(repostClass(p.id));
          b.raw("\"");
          b.raw(" type=\"button\"");
          b.raw(" title=\"Repost\"");
          b.raw(" data-mv-handler=\"repost\" data-mv-event=\"click\"");
          b.attr("data-mv-arg0", Html.unquote(debug_show(p.id)));
          b.raw(">");
          b.raw("\n                                    ");
          b.raw("<span");
          b.raw(" class=\"fd-act-ico\"");
          b.raw(">");
          b.raw("🔁");
          b.raw("</span>");
          b.raw("\n                                    ");
          b.raw("<span");
          b.raw(" class=\"fd-act-n\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(p.reposts)));
          b.raw("</span>");
          b.raw("\n                                ");
          b.raw("</button>");
          b.raw("\n                                ");
          b.raw("<button");
          b.raw(" class=\"");
          b.raw("fd-act fd-act-like ");
          b.text(likeClass(p.id));
          b.raw("\"");
          b.raw(" type=\"button\"");
          b.raw(" title=\"Like\"");
          b.raw(" data-mv-handler=\"like\" data-mv-event=\"click\"");
          b.attr("data-mv-arg0", Html.unquote(debug_show(p.id)));
          b.raw(">");
          b.raw("\n                                    ");
          b.raw("<span");
          b.raw(" class=\"fd-act-ico\"");
          b.raw(">");
          b.text(heart(p.id));
          b.raw("</span>");
          b.raw("\n                                    ");
          b.raw("<span");
          b.raw(" class=\"fd-act-n\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(p.likes)));
          b.raw("</span>");
          b.raw("\n                                ");
          b.raw("</button>");
          b.raw("\n                            ");
          b.raw("</div>");
          b.raw("\n                        ");
          b.raw("</div>");
          b.raw("\n                    ");
          b.raw("</article>");
          b.raw("\n                ");
        };
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n        ");
      } else {
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"fd-empty bz-card\"");
        b.raw(">");
        b.raw("\n                ");
        b.raw("<span");
        b.raw(" class=\"fd-empty-ico\"");
        b.raw(">");
        b.raw("⚡");
        b.raw("</span>");
        b.raw("\n                ");
        b.raw("<h3");
        b.raw(">");
        b.raw("Your timeline is quiet");
        b.raw("</h3>");
        b.raw("\n                ");
        b.raw("<p");
        b.raw(">");
        b.raw("Be the first to post, or follow a few people to fill your home feed.");
        b.raw("</p>");
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n        ");
      };
      b.raw("\n    ");
      b.raw("</div>");
      b.raw("\n\n    ");
      b.raw("<aside");
      b.raw(" class=\"fd-rail\"");
      b.raw(">");
      b.raw("\n        ");
      b.raw("<div");
      b.raw(" class=\"fd-panel bz-card\"");
      b.raw(">");
      b.raw("\n            ");
      b.raw("<h3");
      b.raw(" class=\"fd-panel-title\"");
      b.raw(">");
      b.raw("Who to follow");
      b.raw("</h3>");
      b.raw("\n            ");
      if (hasSuggestions) {
        b.raw("\n                ");
        b.raw("<ul");
        b.raw(" class=\"fd-suggest\"");
        b.raw(">");
        b.raw("\n                    ");
        for (s in (suggestions).vals()) {
          b.raw("\n                        ");
          b.raw("<li");
          b.raw(" class=\"fd-suggest-row\"");
          b.raw(">");
          b.raw("\n                            ");
          b.raw("<a");
          b.raw(" class=\"fd-suggest-id\"");
          b.raw(" href=\"");
          b.raw("/u/");
          b.text(Html.unquote(debug_show(s.handle)));
          b.raw("\"");
          b.raw(">");
          b.raw("\n                                ");
          b.raw("<span");
          b.raw(" class=\"fd-ava fd-ava-sm\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(s.avatar)));
          b.raw("</span>");
          b.raw("\n                                ");
          b.raw("<span");
          b.raw(" class=\"fd-suggest-meta\"");
          b.raw(">");
          b.raw("\n                                    ");
          b.raw("<span");
          b.raw(" class=\"fd-suggest-name\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(s.display)));
          b.raw("</span>");
          b.raw("\n                                    ");
          b.raw("<span");
          b.raw(" class=\"fd-suggest-handle\"");
          b.raw(">");
          b.text(at(s.handle));
          b.raw("</span>");
          b.raw("\n                                ");
          b.raw("</span>");
          b.raw("\n                            ");
          b.raw("</a>");
          b.raw("\n                            ");
          if (bound) {
            b.raw("\n                                ");
            b.raw("<button");
            b.raw(" class=\"");
            b.raw("fd-follow ");
            b.text(followClass(s.principal));
            b.raw("\"");
            b.raw(" type=\"button\"");
            b.raw(" data-mv-handler=\"toggleFollow\" data-mv-event=\"click\"");
            b.attr("data-mv-arg0", Html.unquote(debug_show(s.handle)));
            b.raw(">");
            b.text(followLabel(s.principal));
            b.raw("</button>");
            b.raw("\n                            ");
          };
          b.raw("\n                        ");
          b.raw("</li>");
          b.raw("\n                    ");
        };
        b.raw("\n                ");
        b.raw("</ul>");
        b.raw("\n            ");
      } else {
        b.raw("\n                ");
        b.raw("<p");
        b.raw(" class=\"fd-panel-empty\"");
        b.raw(">");
        b.raw("No one else here yet. Invite a friend to Bzzz.");
        b.raw("</p>");
        b.raw("\n            ");
      };
      b.raw("\n        ");
      b.raw("</div>");
      b.raw("\n\n        ");
      b.raw("<div");
      b.raw(" class=\"fd-panel bz-card\"");
      b.raw(">");
      b.raw("\n            ");
      b.raw("<h3");
      b.raw(" class=\"fd-panel-title\"");
      b.raw(">");
      b.raw("Your network");
      b.raw("</h3>");
      b.raw("\n            ");
      b.raw("<div");
      b.raw(" class=\"fd-stats\"");
      b.raw(">");
      b.raw("\n                ");
      b.raw("<div");
      b.raw(" class=\"fd-stat\"");
      b.raw(">");
      b.raw("\n                    ");
      b.raw("<span");
      b.raw(" class=\"fd-stat-n\"");
      b.raw(">");
      b.text(Nat.toText(followingCount));
      b.raw("</span>");
      b.raw("\n                    ");
      b.raw("<span");
      b.raw(" class=\"fd-stat-l\"");
      b.raw(">");
      b.raw("Following");
      b.raw("</span>");
      b.raw("\n                ");
      b.raw("</div>");
      b.raw("\n                ");
      b.raw("<div");
      b.raw(" class=\"fd-stat\"");
      b.raw(">");
      b.raw("\n                    ");
      b.raw("<span");
      b.raw(" class=\"fd-stat-n\"");
      b.raw(">");
      b.text(Nat.toText(followerCount));
      b.raw("</span>");
      b.raw("\n                    ");
      b.raw("<span");
      b.raw(" class=\"fd-stat-l\"");
      b.raw(">");
      b.raw("Followers");
      b.raw("</span>");
      b.raw("\n                ");
      b.raw("</div>");
      b.raw("\n            ");
      b.raw("</div>");
      b.raw("\n        ");
      b.raw("</div>");
      b.raw("\n    ");
      b.raw("</aside>");
      b.raw("\n");
      b.raw("</div>");
      b.raw("\n\n");
      b.raw("<style");
      b.raw(">");
      b.raw("\n    .fd-wrap { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 1.25rem; align-items: start; }\n    .fd-main { min-width: 0; display: flex; flex-direction: column; gap: 1rem; }\n\n    .fd-head h1 { margin: 0; font-size: 1.5rem; letter-spacing: -.02em; }\n    .fd-sub { margin: .2rem 0 0; color: var(--mv-text-soft); font-size: .88rem; }\n\n    .fd-composer { display: flex; gap: .75rem; padding: 1rem 1.1rem; }\n    .fd-composer-form { flex: 1; min-width: 0; }\n    .fd-composer-form textarea, .fd-composer-form .mv-input, .fd-composer-form input { width: 100%; box-sizing: border-box; }\n    .fd-composer-foot { display: flex; align-items: center; justify-content: space-between; gap: .75rem; margin-top: .4rem; }\n    .fd-counter { color: var(--mv-text-soft); font-size: .82rem; font-variant-numeric: tabular-nums; }\n\n    .fd-ava { width: 44px; height: 44px; flex: 0 0 44px; border-radius: 50%;\n        background: linear-gradient(135deg, #ede9fe, #f5d0fe); display: grid; place-items: center;\n        font-size: 1.4rem; box-shadow: inset 0 0 0 1px var(--mv-border); }\n    .fd-ava-sm { width: 36px; height: 36px; flex: 0 0 36px; font-size: 1.1rem; }\n\n    .fd-claim { display: flex; align-items: center; gap: .9rem; padding: 1rem 1.2rem; }\n    .fd-claim-ico { font-size: 1.8rem; }\n    .fd-claim strong { display: block; }\n    .fd-claim p { margin: .2rem 0 0; color: var(--mv-text-soft); font-size: .9rem; }\n    .fd-claim a { color: var(--bz-accent); font-weight: 600; text-decoration: none; }\n\n    .fd-stream { display: flex; flex-direction: column; gap: .75rem; }\n    .fd-post { display: flex; gap: .75rem; padding: 1rem 1.1rem; transition: box-shadow .12s ease; }\n    .fd-post:hover { box-shadow: 0 6px 20px rgba(16,16,40,.10); }\n    .fd-body { flex: 1; min-width: 0; }\n    .fd-post-head { display: flex; align-items: baseline; gap: .4rem; font-size: .92rem; }\n    .fd-handle { font-weight: 700; color: var(--mv-text); }\n    .fd-dot { color: var(--mv-text-soft); }\n    .fd-time { color: var(--mv-text-soft); font-size: .85rem; }\n    .fd-text { margin: .25rem 0 .55rem; line-height: 1.45; white-space: pre-wrap; word-wrap: break-word; overflow-wrap: anywhere; }\n\n    .fd-actions { display: flex; gap: 1.4rem; align-items: center; }\n    .fd-act { display: inline-flex; align-items: center; gap: .35rem; background: none; border: 0; cursor: pointer;\n        color: var(--mv-text-soft); font-size: .85rem; padding: .25rem .35rem; border-radius: 999px;\n        text-decoration: none; font: inherit; line-height: 1; transition: color .12s ease, background .12s ease; }\n    .fd-act-ico { font-size: 1rem; }\n    .fd-act-n { font-variant-numeric: tabular-nums; }\n    .fd-act:hover { background: var(--mv-muted); }\n    .fd-act-repost:hover, .fd-act-repost.is-on { color: #16a34a; }\n    .fd-act-like:hover, .fd-act-like.is-on { color: #e11d6b; }\n\n    .fd-empty { text-align: center; padding: 2.5rem 1.5rem; color: var(--mv-text-soft); }\n    .fd-empty-ico { font-size: 2.2rem; display: block; }\n    .fd-empty h3 { margin: .6rem 0 .25rem; color: var(--mv-text); }\n    .fd-empty p { margin: 0; font-size: .9rem; }\n\n    .fd-rail { display: flex; flex-direction: column; gap: 1rem; position: sticky; top: calc(var(--bz-nav-h) + 1.25rem); }\n    .fd-panel { padding: 1rem 1.1rem; }\n    .fd-panel-title { margin: 0 0 .75rem; font-size: 1.05rem; }\n    .fd-panel-empty { margin: 0; color: var(--mv-text-soft); font-size: .88rem; }\n\n    .fd-suggest { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .65rem; }\n    .fd-suggest-row { display: flex; align-items: center; justify-content: space-between; gap: .6rem; }\n    .fd-suggest-id { display: flex; align-items: center; gap: .55rem; text-decoration: none; color: inherit; min-width: 0; }\n    .fd-suggest-meta { display: flex; flex-direction: column; min-width: 0; }\n    .fd-suggest-name { font-weight: 600; font-size: .9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n    .fd-suggest-handle { color: var(--mv-text-soft); font-size: .8rem; }\n    .fd-follow { border: 1px solid var(--bz-accent); background: var(--bz-accent); color: #fff; font-weight: 600;\n        font-size: .8rem; padding: .35rem .8rem; border-radius: 999px; cursor: pointer; white-space: nowrap; }\n    .fd-follow:hover { filter: brightness(1.05); }\n    .fd-follow.is-on { background: transparent; color: var(--bz-accent); }\n\n    .fd-stats { display: flex; gap: 1.5rem; }\n    .fd-stat { display: flex; flex-direction: column; }\n    .fd-stat-n { font-size: 1.35rem; font-weight: 800; letter-spacing: -.02em; font-variant-numeric: tabular-nums; }\n    .fd-stat-l { color: var(--mv-text-soft); font-size: .82rem; }\n\n    @media (max-width: 920px) {\n        .fd-wrap { grid-template-columns: 1fr; }\n        .fd-rail { position: static; order: -1; }\n    }\n");
      b.raw("</style>");
      b.raw("\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Feed — Bzzz" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Feed — Bzzz"; description = "Your Bzzz home timeline. Post short updates, follow people, repost and like — an X-style public feed running entirely on-chain on the Internet Computer."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "body")) { case (?mvV) { body := mvV }; case null {} };
      switch mvH {
        case "post" { post(ctx) };
        case "like" { like(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "repost" { repost(ctx, mvNat((if (mvArgs.size() > 0) mvArgs[0] else ""))) };
        case "toggleFollow" { toggleFollow(ctx, (if (mvArgs.size() > 0) mvArgs[0] else "")) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Forum.mview
  // ===== Page: Forum (/forum) =====
  let ForumPage = object {
    var categories : [Forum.Category] = [];
    var topics : [Forum.Topic] = [];
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        categories := Forum.categories();
        topics := Forum.topicsLatest();
    };
    func glyphs(id : Nat) : Text { Forum.statusGlyphs(id) };
    func replies(id : Nat) : Nat { Forum.replyCount(id) };
    func activity(id : Nat) : Text { Forum.topicActivity(id) };
    func catColor(id : Nat) : Text { Forum.categoryColor(id) };
    func catName(id : Nat) : Text { Forum.categoryName(id) };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<div");
      b.raw(" class=\"fr-wrap\"");
      b.raw(">");
      b.raw("\n    ");
      b.raw("<nav");
      b.raw(" class=\"fr-subnav\"");
      b.raw(">");
      b.raw("\n        ");
      b.raw("<a");
      b.raw(" class=\"fr-tab active\"");
      b.raw(" href=\"/forum\"");
      b.raw(">");
      b.raw("Latest");
      b.raw("</a>");
      b.raw("\n        ");
      b.raw("<a");
      b.raw(" class=\"fr-tab\"");
      b.raw(" href=\"/forum?sort=new\"");
      b.raw(">");
      b.raw("New");
      b.raw("</a>");
      b.raw("\n        ");
      b.raw("<a");
      b.raw(" class=\"fr-tab\"");
      b.raw(" href=\"/forum?sort=top\"");
      b.raw(">");
      b.raw("Top");
      b.raw("</a>");
      b.raw("\n        ");
      b.raw("<a");
      b.raw(" class=\"fr-tab\"");
      b.raw(" href=\"#categories\"");
      b.raw(">");
      b.raw("Categories");
      b.raw("</a>");
      b.raw("\n        ");
      b.raw("<span");
      b.raw(" class=\"fr-subnav-spacer\"");
      b.raw(">");
      b.raw("</span>");
      b.raw("\n        ");
      b.raw("<a");
      b.raw(" class=\"fr-newbtn\"");
      b.raw(" href=\"/forum/new\"");
      b.raw(">");
      b.raw("+ New Topic");
      b.raw("</a>");
      b.raw("\n    ");
      b.raw("</nav>");
      b.raw("\n\n    ");
      b.raw("<section");
      b.raw(" id=\"categories\"");
      b.raw(" class=\"fr-section\"");
      b.raw(">");
      b.raw("\n        ");
      b.raw("<h2");
      b.raw(" class=\"fr-section-h\"");
      b.raw(">");
      b.raw("Categories");
      b.raw("</h2>");
      b.raw("\n        ");
      if ((categories.size() == 0)) {
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"fr-empty\"");
        b.raw(">");
        b.raw("No categories yet.");
        b.raw("</div>");
        b.raw("\n        ");
      } else {
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"fr-cats\"");
        b.raw(">");
        b.raw("\n                ");
        for (c in (categories).vals()) {
          b.raw("\n                    ");
          b.raw("<a");
          b.raw(" class=\"fr-cat\"");
          b.raw(" href=\"");
          b.raw("/forum/c/");
          b.text(Html.unquote(debug_show(c.id)));
          b.raw("\"");
          b.raw(">");
          b.raw("\n                        ");
          b.raw("<span");
          b.raw(" class=\"fr-sq\"");
          b.raw(" style=\"");
          b.raw("background:");
          b.text(Html.unquote(debug_show(c.color)));
          b.raw("\"");
          b.raw(">");
          b.raw("</span>");
          b.raw("\n                        ");
          b.raw("<span");
          b.raw(" class=\"fr-cat-body\"");
          b.raw(">");
          b.raw("\n                            ");
          b.raw("<span");
          b.raw(" class=\"fr-cat-name\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(c.name)));
          b.raw("</span>");
          b.raw("\n                            ");
          b.raw("<span");
          b.raw(" class=\"fr-cat-desc\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(c.description)));
          b.raw("</span>");
          b.raw("\n                            ");
          b.raw("<span");
          b.raw(" class=\"fr-cat-counts\"");
          b.raw(">");
          b.text(Html.unquote(debug_show(c.topicCount)));
          b.raw(" topics · ");
          b.text(Html.unquote(debug_show(c.postCount)));
          b.raw(" posts");
          b.raw("</span>");
          b.raw("\n                        ");
          b.raw("</span>");
          b.raw("\n                    ");
          b.raw("</a>");
          b.raw("\n                ");
        };
        b.raw("\n            ");
        b.raw("</div>");
        b.raw("\n        ");
      };
      b.raw("\n    ");
      b.raw("</section>");
      b.raw("\n\n    ");
      b.raw("<section");
      b.raw(" class=\"fr-section\"");
      b.raw(">");
      b.raw("\n        ");
      b.raw("<h2");
      b.raw(" class=\"fr-section-h\"");
      b.raw(">");
      b.raw("Latest");
      b.raw("</h2>");
      b.raw("\n        ");
      if ((topics.size() == 0)) {
        b.raw("\n            ");
        b.raw("<div");
        b.raw(" class=\"fr-empty\"");
        b.raw(">");
        b.raw("No topics yet. ");
        b.raw("<a");
        b.raw(" href=\"/forum/new\"");
        b.raw(">");
        b.raw("Start the first one →");
        b.raw("</a>");
        b.raw("</div>");
        b.raw("\n        ");
      } else {
        b.raw("\n            ");
        b.raw("<table");
        b.raw(" class=\"fr-table\"");
