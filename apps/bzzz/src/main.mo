        b.raw("</h1>");
        b.raw("\n            ");
        b.raw("<p");
        b.raw(" class=\"bz-prof-handle\"");
        b.raw(">");
        b.raw("Pick a handle to join Bzzz and start posting.");
        b.raw("</p>");
        b.raw("\n        ");
      };
      b.raw("\n    ");
      b.raw("</div>");
      b.raw("\n");
      b.raw("</section>");
