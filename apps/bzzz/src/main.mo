  // mv:src src/Pages/Admin.mview
  // ===== Page: Admin (/admin) =====
  let AdminPage = object {
    var isAdmin : Bool = false;
    var whoamiPrincipal : Text = "";
    var adminCount : Nat = 0;
    var admins : [Admin.AdminEntry] = [];
    var canRemove : Bool = false;
    var now : Int = 0;
    var adminVerb : Text = "are";
    var adminNoun : Text = "admins";
    var addHandle : Text = "";
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        let who = Admin.whoami(ctx.caller);
        isAdmin := who.isAdmin;
        whoamiPrincipal := who.principalText;
        adminCount := who.adminCount;
        admins := Admin.adminEntries();
        // The last remaining admin can never be removed.
        canRemove := adminCount > 1;
        now := Time.now();
        adminVerb := if (adminCount == 1) "is" else "are";
        adminNoun := if (adminCount == 1) "admin" else "admins";
    };
    func roleLine() : Text {
        if (isAdmin) {
            "You have super-admin rights on this canister."
        } else if (adminCount == 0) {
            "No admins exist yet — the allowlist is open for bootstrap."
        } else {
            "You are signed in as a member."
        };
    };
    func handleLabel(handle : Text) : Text {
        if (Text.trim(handle, #char ' ') == "") "(no handle)" else "@" # handle;
    };
    func claim(ctx : Context) : () {
        let handle = Identity.handleOf(ctx.caller);
        if (Admin.claimBootstrapWithHandle(ctx.caller, handle)) {
            toast("You are now the founding admin of Bzzz.");
        } else {
            toast("Bootstrap is no longer available — an admin already exists.");
        };
    };
    func add(ctx : Context) : () {
         mvErrors.clear(); if (addHandle == "") { mvErrors.add(("addHandle", "Enter a handle to grant admin.")) }; if (mvErrors.size() > 0) { return }; 
        switch (Identity.byHandleLookup(addHandle)) {
            case (?prof) {
                if (Admin.addAdminWithHandle(ctx.caller, prof.principal, prof.handle)) {
                    addHandle := "";
                    toast("Granted admin to @" # prof.handle # ".");
                } else {
                    toast("You don't have permission to add admins.");
                };
            };
            case null {
                toast("No member found with that handle.");
            };
        };
    };
    func remove(ctx : Context, targetText : Text) : () {
        let target = Principal.fromText(targetText);
        if (Admin.removeAdmin(ctx.caller, target)) {
            toast("Admin removed.");
        } else {
            toast("Couldn't remove that admin.");
        };
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<section class=\"bz-admin-head\">\n    <h1>Admin console</h1>\n    <p class=\"bz-admin-sub\">");
      b.text(roleLine());
      b.raw("</p>\n</section>\n\n");
      if (isAdmin) {
        b.raw("\n    <div class=\"bz-card bz-whoami\">\n        <div class=\"bz-whoami-row\">\n            <span class=\"bz-whoami-label\">You are</span>\n            <span class=\"bz-badge bz-badge-admin\">Admin</span>\n        </div>\n        <div class=\"bz-whoami-row\">\n            <span class=\"bz-whoami-label\">Principal</span>\n            <code class=\"bz-principal\">");
        b.text(whoamiPrincipal);
        b.raw("</code>\n        </div>\n        <div class=\"bz-whoami-row\">\n            <span class=\"bz-whoami-label\">Total admins</span>\n            <span>");
        b.text(Nat.toText(adminCount));
        b.raw("</span>\n        </div>\n    </div>\n\n    <h2 class=\"bz-section-title\">Admins</h2>\n    <div class=\"bz-card bz-admin-list\">\n        ");
        for (a in (admins).vals()) {
          b.raw("\n            <div class=\"bz-admin-row\">\n                <div class=\"bz-admin-id\">\n                    <span class=\"bz-admin-handle\">");
          b.text(handleLabel(a.handle));
          b.raw("</span>\n                    <code class=\"bz-principal bz-principal-sm\">");
          b.text(a.principalText);
          b.raw("</code>\n                </div>\n                <span class=\"bz-admin-granted\">");
          b.text(Html.unquote(debug_show(Admin.relativeTime(a.grantedAt, now))));
          b.raw("</span>\n                ");
          if ((canRemove and a.principalText != whoamiPrincipal)) {
            b.raw("\n                    <button type=\"button\" class=\"mv-btn mv-btn-danger\" data-mv-handler=\"remove\" data-mv-event=\"click\"");
            b.attr("data-mv-arg0", a.principalText);
            b.raw(">Remove</button>\n                ");
          } else if ((a.principalText == whoamiPrincipal)) {
            b.raw("\n                    <span class=\"bz-admin-you\">you</span>\n                ");
          } else {
            b.raw("\n                    <span class=\"bz-admin-locked\" title=\"The last admin cannot be removed\">🔒</span>\n                ");
          };
          b.raw("\n            </div>\n        ");
        };
        b.raw("\n    </div>\n\n    <h2 class=\"bz-section-title\">Add an admin</h2>\n    <div class=\"bz-card bz-add-admin\">\n        <p class=\"bz-add-hint\">Enter the handle of an existing Bzzz member to grant them admin rights.</p>\n        <form novalidate data-mv-handler=\"add\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("add", "addHandle"));
        b.raw(" data-mv-schema=\"addHandle\">\n            ");
        if (mvErrors.size() > 0) {
          b.raw("<div class=\"mv-validation\"><strong>Please fix the following:</strong><ul>");
          for ((mvF, mvM) in mvErrors.vals()) { b.raw("<li>"); b.text(mvM); b.raw("</li>") };
          b.raw("</ul></div>");
        };
        b.raw("\n            <div class=\"mv-field\"><label>Handle *</label><input type=\"text\" class=\"mv-input\" name=\"addHandle\" data-mv-key=\"addHandle\" required");
        b.attr("value", addHandle);
        b.raw(">");
        for ((mvF, mvM) in mvErrors.vals()) { if (mvF == "addHandle") { b.raw("<div class=\"mv-error\">"); b.text(mvM); b.raw("</div>") } };
        b.raw("</div>\n            <div class=\"bz-add-actions\">\n                <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Grant admin</button>\n            </div>\n        </form>\n    </div>\n");
      } else {
        b.raw("\n    <div class=\"mv-alert mv-alert-info\">\n        This page is gated to the Bzzz admin allowlist. Your principal\n        (<code class=\"bz-principal\">");
        b.text(whoamiPrincipal);
        b.raw("</code>) is not an admin.\n    </div>\n\n    ");
        if ((adminCount == 0)) {
          b.raw("\n        <div class=\"bz-card bz-bootstrap\">\n            <div class=\"bz-bootstrap-ico\">🛡️</div>\n            <h3>No admins yet</h3>\n            <p>The allowlist is empty. Claim the founding admin seat for this canister — the first caller becomes the bootstrap admin.</p>\n            <form novalidate data-mv-handler=\"claim\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
          b.attr("data-mv-token", ctx.mintToken("claim", ""));
          b.raw(" data-mv-schema=\"\">\n                <button type=\"submit\" class=\"mv-btn mv-btn-primary\">Claim bootstrap admin</button>\n            </form>\n        </div>\n    ");
        } else {
          b.raw("\n        <p class=\"bz-admin-sub\">There ");
          b.text(adminVerb);
          b.raw(" currently ");
          b.text(Nat.toText(adminCount));
          b.raw(" ");
          b.text(adminNoun);
          b.raw(" on Bzzz. Ask one of them to add you.</p>\n    ");
        };
        b.raw("\n");
      };
      b.raw("\n\n<style>\n    .bz-admin-head { margin-bottom: 1.25rem; }\n    .bz-admin-head h1 { margin: 0 0 .25rem; font-size: 1.6rem; letter-spacing: -.02em; }\n    .bz-admin-sub { margin: 0; color: var(--mv-text-soft); font-size: .9rem; }\n\n    .bz-whoami { padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: .55rem; margin-bottom: 1.5rem; }\n    .bz-whoami-row { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; }\n    .bz-whoami-label { width: 110px; color: var(--mv-text-soft); font-size: .85rem; flex: 0 0 auto; }\n\n    .bz-badge { display: inline-flex; align-items: center; font-size: .72rem; font-weight: 700;\n        padding: .18rem .55rem; border-radius: 999px; text-transform: uppercase; letter-spacing: .05em; }\n    .bz-badge-admin { background: #ede9fe; color: #6d28d9; }\n\n    .bz-principal { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: .8rem;\n        background: var(--mv-muted); padding: .12rem .4rem; border-radius: 6px; word-break: break-all; }\n    .bz-principal-sm { font-size: .72rem; opacity: .8; }\n\n    .bz-section-title { font-size: 1.15rem; margin: 0 0 1rem; }\n\n    .bz-admin-list { padding: .35rem 0; margin-bottom: 1.5rem; }\n    .bz-admin-row { display: flex; align-items: center; gap: .8rem; padding: .7rem 1.2rem;\n        border-bottom: 1px solid var(--mv-border); }\n    .bz-admin-row:last-child { border-bottom: 0; }\n    .bz-admin-id { display: flex; flex-direction: column; gap: .15rem; min-width: 0; flex: 1; }\n    .bz-admin-handle { font-weight: 700; font-size: .95rem; }\n    .bz-admin-granted { font-size: .78rem; color: var(--mv-text-soft); white-space: nowrap; flex: 0 0 auto; }\n    .bz-admin-you { font-size: .76rem; color: var(--mv-text-soft); font-style: italic; flex: 0 0 auto; }\n    .bz-admin-locked { font-size: 1rem; flex: 0 0 auto; }\n\n    .bz-add-admin { padding: 1.1rem 1.2rem; }\n    .bz-add-hint { margin: 0 0 .8rem; color: var(--mv-text-soft); font-size: .88rem; }\n    .bz-add-actions { margin-top: .8rem; }\n\n    .bz-bootstrap { text-align: center; padding: 2rem 1.5rem; margin-top: 1rem; }\n    .bz-bootstrap-ico { font-size: 2.4rem; }\n    .bz-bootstrap h3 { margin: .6rem 0 .3rem; font-size: 1.2rem; }\n    .bz-bootstrap p { margin: 0 auto 1.1rem; max-width: 48ch; color: var(--mv-text-soft); font-size: .9rem; }\n\n    @media (max-width: 560px) {\n        .bz-admin-row { flex-wrap: wrap; }\n        .bz-whoami-label { width: auto; }\n    }\n</style>\n\n");
      b.build();
    };
    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Admin — manage the Bzzz allowlist" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Admin — manage the Bzzz allowlist"; description = "Super-admin console for Bzzz: see who you are, view the admin allowlist, and add or remove admins. Gated to the on-chain allowlist."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "addHandle")) { case (?mvV) { addHandle := mvV }; case null {} };
      switch mvH {
        case "claim" { claim(ctx) };
        case "add" { add(ctx) };
        case "remove" { remove(ctx, (if (mvArgs.size() > 0) mvArgs[0] else "")) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
