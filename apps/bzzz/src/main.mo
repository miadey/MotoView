  // mv:src src/Layouts/AppLayout.mview
  // ===== Layout: AppLayout =====
  func mvLayout_AppLayout(ctx : MV.Ctx, mvHead : MV.Head, mvBody : Text) : Text {
    ignore ctx;
    let b = Html.Builder();
    b.raw("<!DOCTYPE html>\n");
    b.raw("<html");
    b.raw(" lang=\"en\"");
    b.raw(">");
    b.raw("\n");
    b.raw("<head");
    b.raw(">");
    b.raw("\n    ");
    b.raw("<meta");
    b.raw(" charset=\"utf-8\"");
    b.raw(">");
    b.raw("\n    ");
    b.raw("<meta");
    b.raw(" name=\"viewport\"");
    b.raw(" content=\"width=device-width, initial-scale=1, viewport-fit=cover\"");
    b.raw(">");
    b.raw("\n    ");
    b.raw("<meta");
    b.raw(" name=\"theme-color\"");
    b.raw(" content=\"#6d28d9\"");
    b.raw(">");
    b.raw("\n    ");
    b.raw("<link");
    b.raw(" rel=\"manifest\"");
    b.raw(" href=\"/manifest.webmanifest\"");
    b.raw(">");
    b.raw("\n    ");
    b.raw("<link");
    b.raw(" rel=\"apple-touch-icon\"");
    b.raw(" href=\"/favicon.svg\"");
    b.raw(">");
    b.raw("\n    ");
    b.raw("<meta");
    b.raw(" name=\"apple-mobile-web-app-capable\"");
    b.raw(" content=\"yes\"");
    b.raw(">");
    b.raw("\n    ");
    b.raw("<meta");
    b.raw(" name=\"apple-mobile-web-app-status-bar-style\"");
    b.raw(" content=\"black-translucent\"");
    b.raw(">");
    b.raw("\n    ");
    b.raw("<meta");
    b.raw(" name=\"apple-mobile-web-app-title\"");
    b.raw(" content=\"Bzzz\"");
    b.raw(">");
    b.raw("\n    ");
    b.raw("<title");
    b.raw(">");
    b.text(mvHead.title);
    b.raw("</title>");
    b.raw("\n    ");
    b.raw(mvHead.extra);
    if (mvHead.description != "") { b.raw("<meta name=\"description\" content=\""); b.text(mvHead.description); b.raw("\">") };
    if (mvHead.canonical != "") { b.raw("<link rel=\"canonical\" href=\""); b.text(mvHead.canonical); b.raw("\">") };
    b.raw("\n    ");
    b.raw("<style");
    b.raw(">");
    b.raw("\n        :root { --bz-accent: #6d28d9; --bz-nav-h: 56px; }\n        body { background: var(--mv-muted); margin: 0; }\n        .bz-shell { min-height: 100vh; display: flex; flex-direction: column; }\n\n        .bz-nav { position: sticky; top: 0; z-index: 50; height: var(--bz-nav-h);\n            display: flex; align-items: center; gap: .25rem; padding: 0 1rem;\n            background: var(--bz-accent); color: #fff; box-shadow: 0 1px 0 rgba(0,0,0,.08); }\n        .bz-brand { font-weight: 800; font-size: 1.15rem; margin-right: .75rem; color: #fff; text-decoration: none; letter-spacing: -.02em; }\n        .bz-navlink { color: #ece9fb; text-decoration: none; padding: .45rem .7rem; border-radius: 8px; font-weight: 600; font-size: .92rem; }\n        .bz-navlink:hover { background: rgba(255,255,255,.14); color: #fff; }\n        .bz-navlink.active { background: rgba(255,255,255,.22); color: #fff; }\n        .bz-auth-btn { background: rgba(255,255,255,.16); border: none; cursor: pointer; font: inherit; }\n        .bz-auth-btn:hover { background: rgba(255,255,255,.28); }\n        .bz-nav-spacer { flex: 1; }\n        .bz-nav-me { display: flex; align-items: center; gap: .4rem; color: #fff; font-weight: 600; font-size: .9rem; }\n        .bz-ava { width: 28px; height: 28px; border-radius: 50%; background: rgba(255,255,255,.22);\n            display: grid; place-items: center; font-size: 1rem; }\n\n        .bz-main { flex: 1; width: 100%; max-width: 1180px; margin: 0 auto; padding: 1.25rem 1rem 3rem; box-sizing: border-box; }\n        .bz-foot { text-align: center; color: var(--mv-text-soft); font-size: .82rem; padding: 1.5rem 1rem 2rem; }\n\n        .bz-card { background: var(--mv-surface); border: 1px solid var(--mv-border); border-radius: 14px; box-shadow: var(--mv-shadow); }\n        .bz-hero { background: linear-gradient(135deg, #6d28d9, #9333ea 60%, #c026d3); color: #fff; border-radius: 18px; padding: 2rem 1.8rem; }\n        .bz-hero h1 { margin: 0 0 .4rem; font-size: 2rem; letter-spacing: -.02em; }\n        .bz-hero p { margin: 0; opacity: .92; max-width: 60ch; }\n\n        .bz-tiles { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-top: 1.25rem; }\n        .bz-tile { display: block; text-decoration: none; color: inherit; padding: 1.1rem 1.2rem; border-radius: 14px;\n            background: var(--mv-surface); border: 1px solid var(--mv-border); box-shadow: var(--mv-shadow);\n            transition: transform .12s ease, box-shadow .12s ease; }\n        .bz-tile:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(16,16,40,.12); }\n        .bz-tile-ico { font-size: 1.6rem; }\n        .bz-tile h3 { margin: .5rem 0 .2rem; font-size: 1.05rem; }\n        .bz-tile p { margin: 0; color: var(--mv-text-soft); font-size: .88rem; }\n\n        @media (max-width: 720px) {\n            .bz-nav { gap: 0; padding: 0 .4rem; overflow-x: auto; }\n            .bz-navlink { padding: .4rem .5rem; font-size: .82rem; }\n            .bz-brand { margin-right: .4rem; }\n        }\n    ");
    b.raw("</style>");
    b.raw("\n");
    b.raw("</head>");
    b.raw("\n");
    b.raw("<body");
    b.raw(">");
    b.raw("\n    ");
    b.raw("<div");
    b.raw(" class=\"bz-shell\"");
    b.raw(">");
    b.raw("\n        ");
    b.raw("<nav");
    b.raw(" class=\"bz-nav\"");
    b.raw(">");
    b.raw("\n            ");
    b.raw("<a");
    b.raw(" class=\"bz-brand\"");
    b.raw(" href=\"/\"");
    b.raw(">");
    b.raw("🐝 Bzzz");
    b.raw("</a>");
    b.raw("\n            ");
    b.raw("<a");
    b.raw(" class=\"bz-navlink\"");
    b.raw(" href=\"/servers\"");
    b.raw(">");
    b.raw("Servers");
    b.raw("</a>");
    b.raw("\n            ");
    b.raw("<a");
    b.raw(" class=\"bz-navlink\"");
    b.raw(" href=\"/forum\"");
    b.raw(">");
    b.raw("Forum");
    b.raw("</a>");
    b.raw("\n            ");
    b.raw("<a");
    b.raw(" class=\"bz-navlink\"");
    b.raw(" href=\"/feed\"");
    b.raw(">");
    b.raw("Feed");
    b.raw("</a>");
    b.raw("\n            ");
    b.raw("<a");
    b.raw(" class=\"bz-navlink\"");
    b.raw(" href=\"/messages\"");
    b.raw(">");
    b.raw("Messages");
    b.raw("</a>");
    b.raw("\n            ");
    b.raw("<a");
    b.raw(" class=\"bz-navlink\"");
    b.raw(" href=\"/status\"");
    b.raw(">");
    b.raw("Status");
    b.raw("</a>");
    b.raw("\n            ");
    b.raw("<span");
    b.raw(" class=\"bz-nav-spacer\"");
    b.raw(">");
    b.raw("</span>");
    b.raw("\n            ");
    b.raw("<a");
    b.raw(" class=\"bz-navlink\"");
    b.raw(" href=\"/me\"");
    b.raw(">");
    b.raw("Me");
    b.raw("</a>");
    b.raw("\n            ");
    b.raw("<button");
    b.raw(" data-mv-signin");
    b.raw(" class=\"bz-navlink bz-auth-btn\"");
    b.raw(" type=\"button\"");
    b.raw(">");
    b.raw("Sign in");
    b.raw("</button>");
    b.raw("\n        ");
    b.raw("</nav>");
    b.raw("\n        ");
    b.raw("<main");
    b.raw(" class=\"bz-main\"");
    b.raw(">");
    b.raw("\n            ");
    b.raw(mvBody);
    b.raw("\n        ");
    b.raw("</main>");
    b.raw("\n        ");
    b.raw("<footer");
    b.raw(" class=\"bz-foot\"");
    b.raw(">");
    b.raw("\n            Bzzz — a Discord × X × forum × WhatsApp super-app, built on MotoView, running entirely on the Internet Computer. No frontend JavaScript framework.\n        ");
    b.raw("</footer>");
    b.raw("\n    ");
    b.raw("</div>");
    b.raw("\n    ");
    b.raw("<script");
    b.raw(">");
    b.raw("\n        if ('serviceWorker' in navigator) {\n            window.addEventListener('load', function () {\n                navigator.serviceWorker.register('/sw.js').catch(function () {});\n            });\n        }\n    ");
    b.raw("</script>");
    b.raw("\n\n");
    b.raw("</body>");
    b.raw("\n");
    b.raw("</html>");
    b.raw("\n");
    b.build();
  };



  let mvPages : [MV.Page] = [AboutDef, AdminDef, ChannelDef, FeedDef, ForumDef, ForumCategoryDef, ForumNewDef, ForumTopicDef, GreetDef, HomeDef, MeDef, MessagesDef, ProfileDef, ServerDef, ServersDef, StatusDef, ThreadDef];
  let mvLayouts : [MV.Layout] = [{ name = "AppLayout"; render = mvLayout_AppLayout }];
  let mvConfig : MV.Config = { appName = "bzzz"; secret = "" : Blob; seo = true; altOrigins = [] };
  let mvApp = App.App(mvConfig, mvPages, mvLayouts, Lib.defaultAssets());

  // Session / secure-form HMAC secret: cryptographically random per canister
  // (from the IC's raw_rand), kept in a stable var so it survives upgrades, and
  // NEVER present in source. Installed lazily on the first update call below;
  // restored into the app instance here after an upgrade.
  stable var mvSecret : Blob = "" : Blob;
  // Per-principal session epochs (logout-everywhere revocation), kept stable.
  stable var mvEpochs : [(Text, Nat)] = [];
  if (mvSecret.size() == 32) { mvApp.setSecret(mvSecret) };
  mvApp.setEpochs(mvEpochs);

  public shared query (msg) func http_request(req : MV.HttpRequest) : async MV.HttpResponse {
    mvApp.httpRequest(req, msg.caller);
  };

  public shared (msg) func http_request_update(req : MV.HttpRequest) : async MV.HttpResponse {
    if (mvApp.needsSecret()) { mvSecret := await Random.blob(); mvApp.setSecret(mvSecret) };
    let mvResp = mvApp.httpRequestUpdate(req, msg.caller);
    mvEpochs := mvApp.dumpEpochs(); // persist any logout-bump
    mvResp;
  };

  // Internet Identity login bridge: an authenticated update call whose caller
  // the IC has verified. Records the principal under the client's nonce so a
  // following GET /mv-session can mint a session token bound to it.
  public shared (msg) func mvEstablish(nonce : Text) : async () {
    if (mvApp.needsSecret()) { mvSecret := await Random.blob(); mvApp.setSecret(mvSecret) };
    mvApp.establish(nonce, msg.caller);
  };
};
