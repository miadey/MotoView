    public func mvTitle(ctx : MV.Ctx) : Text { ignore ctx; "Bzzz — social super-app on the Internet Computer" };
    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Bzzz — social super-app on the Internet Computer"; description = "Bzzz is a Discord, X, forum and WhatsApp super-app running entirely on-chain as a single Internet Computer canister, built with MotoView."; canonical = ""; extra = "" } };
    public func mvOnLoad(ctx : MV.Ctx) { ignore ctx; onLoad(ctx) };
    public func mvDispatch(ctx : MV.Ctx, mvH : Text, mvArgs : [Text]) {
      ignore ctx; ignore mvArgs;
      mvErrors.clear(); // each interaction starts with a clean slate
      mvEffects.clear();
      switch (mvFormGet(ctx, "display")) { case (?mvV) { display := mvV }; case null {} };
      switch (mvFormGet(ctx, "handle")) { case (?mvV) { handle := mvV }; case null {} };
      switch mvH {
        case "claim" { claim(ctx) };
        case _ {};
      };
    };
    public func mvTakeErrors() : [(Text, Text)] { Buffer.toArray(mvErrors) };
    public func mvTakeRedirect() : Text { let r = mvRedirect; mvRedirect := ""; r };
    public func mvTakeEffects() : [MV.Effect] { let e = Buffer.toArray(mvEffects); mvEffects.clear(); e };
  };

  // mv:src src/Pages/Me.mview
  // ===== Page: Me (/me) =====
  let MePage = object {
    var bound : Bool = false;
    var handle : Text = "";
    var display : Text = "";
    var bio : Text = "";
    var avatar : Text = "🐝";
    var followers : Nat = 0;
    var followingN : Nat = 0;
    var postCount : Nat = 0;
    var myPosts : [Feed.FeedPost] = [];
    let mvErrors = Buffer.Buffer<(Text, Text)>(0);
    var mvRedirect : Text = "";
    let mvEffects = Buffer.Buffer<MV.Effect>(0);
    public func toast(m : Text) { mvEffects.add({ kind = "toast"; target = m; value = "" }) };
    public func animate(sel : Text, name : Text) { mvEffects.add({ kind = "animate"; target = sel; value = name }) };
    public func focusOn(sel : Text) { mvEffects.add({ kind = "focus"; target = sel; value = "" }) };
    public func scrollTo(sel : Text) { mvEffects.add({ kind = "scrollTo"; target = sel; value = "" }) };
    func onLoad(ctx : Context) {
        load(ctx);
    };
    func load(ctx : Context) {
        bound := Identity.isBound(ctx.caller);
        avatar := Identity.avatarOf(ctx.caller);
        followers := Feed.followerCount(ctx.caller);
        followingN := Feed.followingCount(ctx.caller);
        switch (Identity.profileOf(ctx.caller)) {
            case (?p) {
                handle := p.handle;
                display := p.display;
                bio := p.bio;
                myPosts := Feed.byAuthor(p.handle);
            };
            case null {
                myPosts := [];
            };
        };
        postCount := myPosts.size();
    };
    func ago(at : Int) : Text { Feed.relativeTime(at) };
    func saveIdentity(ctx : Context) : () {
         mvErrors.clear(); if (handle == "") { mvErrors.add(("handle", "Choose a handle.")) }; if (handle.size() < 2) { mvErrors.add(("handle", "Handle must be at least 2 characters.")) }; if (mvErrors.size() > 0) { return }; 
        if (Identity.bind(ctx.caller, handle, display)) {
            toast("Profile saved.");
        } else {
            toast("That handle is taken — try another.");
        };
        load(ctx);
    };
    func saveBio(ctx : Context) : () {
        if (Identity.setBio(ctx.caller, bio)) {
            toast("Bio updated.");
        } else {
            toast("Claim a handle before adding a bio.");
        };
        load(ctx);
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<section");
      b.raw(" class=\"bz-prof-head bz-card mv-anim-fadein\"");
