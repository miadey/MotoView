@page "/messages/{id:Nat}"
@layout AppLayout
@authorize redirect="/welcome"
@title Lang.tc(ctx.caller, "conversation.title")
@description Lang.tc(ctx.caller, "conversation.desc")

<div class="pdm">
    @if (not member) {
        <section class="pdm-empty">
            <div class="pdm-empty-ico">🔒</div>
            <h1>@Lang.tc(ctx.caller, "conversation.unavailable")</h1>
            <p>@Lang.tc(ctx.caller, "conversation.unavailable_body") <a href="/messages">@Lang.tc(ctx.caller, "conversation.back_to_messages")</a>.</p>
        </section>
    } else {
        <section class="pdm-thread">
            <header class="pdm-head">
                <a class="pdm-back" href="/messages" aria-label='@(Lang.tc(ctx.caller, "conversation.back_to_conversations"))'>←</a>
                <span class="pdm-avatar">@headerAvatar</span>
                <div class="pdm-id">
                    <span class="pdm-name">@title</span>
                    <span class="pdm-e2ee"><span class="pdm-lock">🔒</span> @Lang.tc(ctx.caller, "conversation.e2ee")</span>
                </div>
            </header>

            <div class="pdm-stream" id="wa-thread-stream">
                <div class="pdm-note">
                    🔒 @Lang.tc(ctx.caller, "conversation.stream_note")
                </div>

                @if (msgs.size() == 0) {
                    <div class="pdm-blank">
                        <div class="pdm-blank-ico">💬</div>
                        <p>@Lang.tc(ctx.caller, "conversation.blank")</p>
                    </div>
                } else {
                    @for m in msgs {
                        <div class="pdm-row @bubbleSide(m)">
                            <div class="pdm-bubble">
                                @if (showSender(m)) {
                                    <span class="pdm-sender">@m.senderHandle</span>
                                }
                                <span class="pdm-text" data-mv-decrypt="@(Messenger.envelopeFor(m, me))" title='@(Lang.tc(ctx.caller, "conversation.bubble_title"))'>🔒</span>
                                <span class="pdm-meta">
                                    <span class="pdm-time">@relTime(m)</span>
                                    @if (m.sender == me) {
                                        <span class="pdm-ticks @(tickClass(m))" title='@(Lang.tc(ctx.caller, "conversation.ticks_title"))'>✓✓</span>
                                    }
                                </span>
                            </div>
                        </div>
                    }
                }
            </div>

            <form class="pdm-composer" @submit="sendMsg" secure>
                <div class="pdm-composer-row">
                    <textarea class="mv-textarea pdm-input" name="draft" data-mv-key="draft" data-mv-encrypt-to="@recipients" placeholder='@(Lang.tc(ctx.caller, "conversation.composer_ph"))' rows="1" required></textarea>
                    <Button kind="primary" type="submit">@Lang.tc(ctx.caller, "common.send")</Button>
                </div>
                <p class="pdm-composer-note">🔒 @Lang.tc(ctx.caller, "conversation.composer_note")</p>
            </form>
        </section>
    }
</div>

@code {
    // Viewer identity, cached for thin bubble + list helpers.
    var me : Principal = Principal.fromText("2vxsx-fae");
    var meName : Text = "You";
    var meAvatar : Text = "🙂";
    var member : Bool = false;

    // Left-rail conversation list (same store the index page renders).
    var convos : [Messenger.Conversation] = [];

    // Open conversation header + message stream.
    var title : Text = "Conversation";
    var subtitle : Text = "encrypted";
    var headerAvatar : Text = "🔒";
    var msgs : [Messenger.DmMessage] = [];

    // Space-joined member principals — the composer's encrypt-to recipient list.
    var recipients : Text = "";

    func onLoad(ctx : Context) {
        me := ctx.caller;
        meName := Identity.handleOf(ctx.caller);
        meAvatar := Identity.avatarOf(ctx.caller);
        convos := Messenger.conversations(ctx.caller);
        member := Messenger.isMember(id, ctx.caller);
        if (member) {
            recipients := Messenger.recipientList(id);
            // Title + subtitle: group name + member count, else peer handle + "online".
            switch (Messenger.directPeer(ctx.caller, id)) {
                case (?p) {
                    title := Identity.handleOf(p);
                    headerAvatar := Identity.avatarOf(p);
                    subtitle := "online · encrypted";
                };
                case null {
                    title := Messenger.titleFor(id, "");
                    headerAvatar := "👥";
                    subtitle := Nat.toText(Messenger.memberCount(id)) # " members · encrypted";
                };
            };
            msgs := Messenger.messages(ctx.caller, id);
            // Viewing a conversation marks every message in it as read.
            Messenger.markRead(ctx.caller, id);
        };
    };

    // ---- thread bubble helpers ------------------------------------------

    // Bubble alignment: own messages on the right, others on the left.
    func bubbleSide(m : Messenger.DmMessage) : Text {
        if (m.sender == me) { "wa-sent" } else { "wa-recv" };
    };

    // Show the sender label only for incoming group messages (WhatsApp).
    func showSender(m : Messenger.DmMessage) : Bool {
        m.sender != me and Messenger.memberCount(id) > 2;
    };

    // ✓✓ read state for our own messages: green once a peer has read it
    // (readBy holds more than just the sender), grey otherwise.
    func tickClass(m : Messenger.DmMessage) : Text {
        if (m.readBy.size() > 1) { "is-read" } else { "" };
    };

    func relTime(m : Messenger.DmMessage) : Text { Messenger.relativeTime(m.at) };

    // ---- left-rail list helpers (mirror the /messages index page) -------

    func rowTitle(c : Messenger.Conversation) : Text {
        switch (c.kind) {
            case (#Group) { Messenger.titleFor(c.id, "") };
            case (#Direct) {
                switch (Messenger.directPeer(me, c.id)) {
                    case (?p) { Identity.handleOf(p) };
                    case null { c.name };
                };
            };
        };
    };

    func rowAvatar(c : Messenger.Conversation) : Text {
        switch (c.kind) {
            case (#Group) { "👥" };
            case (#Direct) {
                switch (Messenger.directPeer(me, c.id)) {
                    case (?p) { Identity.avatarOf(p) };
                    case null { "🔒" };
                };
            };
        };
    };

    // List previews are metadata-only by design: message BODIES are E2EE
    // envelopes the server can't read, so the rail shows who/when + a lock,
    // never plaintext. (The open thread decrypts in-browser via data-mv-decrypt.)
    func rowPreview(c : Messenger.Conversation) : Text {
        switch (Messenger.lastMessage(me, c.id)) {
            case null {
                switch (c.kind) {
                    case (#Group) { Nat.toText(Messenger.memberCount(c.id)) # " members · encrypted" };
                    case (#Direct) { "Encrypted conversation" };
                };
            };
            case (?m) {
                let who = if (m.sender == me) "You" else m.senderHandle;
                who # ": 🔒 encrypted message";
            };
        };
    };

    func rowTime(c : Messenger.Conversation) : Text { Messenger.relativeTime(c.lastAt) };

    func rowUnread(c : Messenger.Conversation) : Nat { Messenger.unreadCount(me, c.id) };

    func unreadClass(c : Messenger.Conversation) : Text {
        if (Messenger.unreadCount(me, c.id) > 0) { "is-unread" } else { "" };
    };

    // Highlight the conversation currently open in the right pane.
    func activeClass(c : Messenger.Conversation) : Text {
        if (c.id == id) { "is-active" } else { "" };
    };

    // ---- composer handler -----------------------------------------------

    func formGet(ctx : Context, k : Text) : Text {
        for ((kk, vv) in ctx.form.vals()) { if (kk == k) { return vv } };
        "";
    };

    // The composer field arrives already encrypted by the framework glue
    // (data-mv-encrypt-to): newline-separated "<recipientPrincipal> <ciphertext>"
    // lines — one IBE envelope per member. Parse it back into envelopes.
    func parseEnvelopes(bundle : Text) : [(Text, Text)] {
        var out : [(Text, Text)] = [];
        for (line in Text.split(bundle, #char '\n')) {
            var p : Text = "";
            var c : Text = "";
            var n : Nat = 0;
            for (tok in Text.split(line, #char ' ')) {
                if (n == 0) { p := tok } else if (n == 1) { c := tok };
                n += 1;
            };
            if (p != "" and c != "") { out := Array.append(out, [(p, c)]) };
        };
        out;
    };

    func sendMsg(ctx : Context) : async () {
        let envs = parseEnvelopes(formGet(ctx, "draft"));
        if (envs.size() == 0) {
            toast(Lang.tc(ctx.caller, "conversation.type_message"));
            return;
        };
        let handle = Identity.handleOf(ctx.caller);
        let mid = Messenger.send(ctx.caller, id, handle, envs);
        if (mid == 0) {
            toast(Lang.tc(ctx.caller, "conversation.send_not_member"));
        } else {
            // Refresh the stream so the new bubble (carrying MY envelope) renders
            // and the glue decrypts it in place.
            msgs := Messenger.messages(ctx.caller, id);
            scrollTo("#wa-thread-stream");
        };
    };
}

<style>
    /* ---- Pulse dark DM thread ------------------------------------------- */
    .pdm { display: flex; flex-direction: column;
        height: calc(100vh - 140px); min-height: 520px; min-width: 0;
        background: var(--pulse-surface); border: 1px solid var(--pulse-border);
        border-radius: 16px; overflow: hidden; color: var(--pulse-text); }

    /* ---- empty / unavailable state ------------------------------------- */
    .pdm-empty { flex: 1; display: flex; flex-direction: column; align-items: center;
        justify-content: center; text-align: center; padding: 2rem; gap: .35rem;
        background: var(--pulse-bg); }
    .pdm-empty-ico { font-size: 2.6rem; }
    .pdm-empty h1 { margin: .5rem 0 .25rem; font-size: 1.5rem; font-weight: 800;
        letter-spacing: -.02em; color: var(--pulse-text); }
    .pdm-empty p { margin: 0; max-width: 42ch; color: var(--pulse-text-2); }
    .pdm-empty a { color: var(--pulse-primary); text-decoration: none; font-weight: 600; }
    .pdm-empty a:hover { color: var(--pulse-primary-hover); }

    /* ---- thread shell --------------------------------------------------- */
    .pdm-thread { flex: 1; display: flex; flex-direction: column; min-width: 0;
        background: var(--pulse-bg); }

    /* ---- header: back + peer avatar + name + e2ee note ----------------- */
    .pdm-head { display: flex; align-items: center; gap: .75rem; flex: none;
        padding: .7rem 1rem; border-bottom: 1px solid var(--pulse-border);
        background: var(--pulse-surface); }
    .pdm-back { flex: none; display: grid; place-items: center;
        width: 36px; height: 36px; border-radius: 10px; text-decoration: none;
        font-size: 1.3rem; line-height: 1; color: var(--pulse-text-2);
        transition: background .12s ease, color .12s ease; }
    .pdm-back:hover { background: var(--pulse-surface-2); color: var(--pulse-text); }
    .pdm-avatar { flex: none; width: 44px; height: 44px; border-radius: 50%;
        display: grid; place-items: center; font-size: 1.3rem; color: #fff;
        background: var(--pulse-grad-profile); }
    .pdm-id { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: .12rem; }
    .pdm-name { font-weight: 700; font-size: 1.05rem; letter-spacing: -.015em;
        color: var(--pulse-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .pdm-e2ee { display: inline-flex; align-items: center; gap: .3rem;
        font-size: .76rem; font-weight: 600; color: var(--pulse-text-2); }
    .pdm-lock { color: var(--pulse-verified); }

    /* ---- message stream ------------------------------------------------- */
    .pdm-stream { flex: 1; overflow-y: auto; display: flex; flex-direction: column;
        gap: .4rem; padding: 1rem; }
    .pdm-note { align-self: center; max-width: 48ch; text-align: center; margin: 0 0 .75rem;
        padding: .55rem .8rem; border-radius: 12px; font-size: .76rem; line-height: 1.45;
        color: var(--pulse-text-2);
        background: var(--pulse-primary-soft); border: 1px solid var(--pulse-border); }

    .pdm-row { display: flex; max-width: 100%; }
    .wa-recv { justify-content: flex-start; }
    .wa-sent { justify-content: flex-end; }
    .pdm-bubble { max-width: 72%; padding: .5rem .7rem .35rem; border-radius: 16px;
        position: relative; }
    /* PEER bubbles: left-aligned surface. */
    .wa-recv .pdm-bubble { background: var(--pulse-surface); color: var(--pulse-text);
        border: 1px solid var(--pulse-border); border-bottom-left-radius: 6px; }
    /* OWN bubbles: right-aligned violet. */
    .wa-sent .pdm-bubble { background: var(--pulse-primary); color: #fff;
        border-bottom-right-radius: 6px; }
    .pdm-sender { display: block; font-size: .74rem; font-weight: 700;
        color: var(--pulse-primary); margin-bottom: .12rem; }
    .pdm-text { font-size: .92rem; line-height: 1.45; word-break: break-word; white-space: pre-wrap; }
    .pdm-meta { display: inline-flex; align-items: center; gap: .3rem; float: right;
        margin: .2rem 0 0 .7rem; }
    .pdm-time { font-size: .68rem; color: var(--pulse-text-3); }
    .wa-sent .pdm-time { color: rgba(255,255,255,.78); }
    .pdm-ticks { font-size: .72rem; letter-spacing: -.05em; color: rgba(255,255,255,.7); }
    .pdm-ticks.is-read { color: #d6c7ff; }

    /* ---- empty thread state -------------------------------------------- */
    .pdm-blank { text-align: center; color: var(--pulse-text-2); margin: auto; padding: 2rem 1rem; }
    .pdm-blank-ico { display: inline-grid; place-items: center; width: 80px; height: 80px;
        border-radius: 18px; font-size: 2.2rem; line-height: 1; margin-bottom: .5rem;
        color: #fff; background: var(--pulse-grad-profile); }
    .pdm-blank p { max-width: 38ch; margin: 0 auto; }

    /* ---- composer ------------------------------------------------------- */
    .pdm-composer { flex: none; padding: .75rem 1rem .6rem;
        border-top: 1px solid var(--pulse-border); background: var(--pulse-surface); }
    .pdm-composer-row { display: flex; align-items: flex-end; gap: .65rem; }
    .pdm-composer-row > :first-child { flex: 1; }
    .pdm-input { resize: none; min-height: 2.5rem; max-height: 8rem; padding: .6rem .85rem;
        border: 1px solid var(--pulse-border); border-radius: 12px; font: inherit; line-height: 1.35;
        background: var(--pulse-surface-2); color: var(--pulse-text); box-sizing: border-box; }
    .pdm-input::placeholder { color: var(--pulse-text-3); }
    .pdm-input:focus { outline: none; border-color: var(--pulse-primary); }
    .pdm-composer-row .mv-btn { background: var(--pulse-primary); color: #fff; border: none;
        border-radius: 10px; font-weight: 700; }
    .pdm-composer-row .mv-btn:hover { background: var(--pulse-primary-hover); }
    .pdm-composer-note { margin: .45rem 0 0; font-size: .7rem; color: var(--pulse-text-3); }

    @media (max-width: 720px) {
        .pdm { height: auto; min-height: 0; }
        .pdm-bubble { max-width: 84%; }
    }
</style>