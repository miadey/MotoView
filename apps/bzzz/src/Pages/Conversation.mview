@page "/messages/{id:Nat}"
@layout AppLayout
@title "Conversation — end-to-end encrypted on Bzzz"
@description "A private, end-to-end encrypted conversation on Bzzz. Message bodies are stored as ciphertext envelopes and decrypted only in your client — never on-chain."

<div class="wa">
    <aside class="wa-list">
        <header class="wa-list-head">
            <a class="wa-list-back" href="/messages" aria-label="All conversations">←</a>
            <Persona name="@meName" secondary="🔒 End-to-end encrypted" avatar="@meAvatar" />
        </header>

        <div class="wa-search" aria-hidden="true">
            <span class="wa-search-ico">🔍</span>
            <span class="wa-search-ph">Search or start a new chat</span>
        </div>

        <ul class="wa-chats">
            @for c in convos {
                <li>
                    <a class="wa-chat @(activeClass(c))" href="/messages/@c.id">
                        <span class="wa-chat-avatar">@rowAvatar(c)</span>
                        <span class="wa-chat-main">
                            <span class="wa-chat-top">
                                <span class="wa-chat-name">@rowTitle(c)</span>
                                <span class="wa-chat-time @(unreadClass(c))">@rowTime(c)</span>
                            </span>
                            <span class="wa-chat-bottom">
                                <span class="wa-chat-preview">@rowPreview(c)</span>
                                @if (rowUnread(c) > 0) {
                                    <Badge color="brand">@rowUnread(c)</Badge>
                                }
                            </span>
                        </span>
                    </a>
                </li>
            }
        </ul>
    </aside>

    @if (not member) {
        <section class="wa-pane wa-pane-empty">
            <div class="wa-welcome">
                <div class="wa-welcome-ico">🔒</div>
                <h1>Conversation unavailable</h1>
                <p>This conversation doesn't exist, or you're not a member of it. <a href="/messages">Back to Messages</a>.</p>
            </div>
        </section>
    } else {
        <section class="wa-pane wa-thread">
            <header class="wa-thread-head">
                <a class="wa-thread-back" href="/messages" aria-label="Back to conversations">←</a>
                <span class="wa-thread-avatar">@headerAvatar</span>
                <div class="wa-thread-titlewrap">
                    <span class="wa-thread-title">@title</span>
                    <span class="wa-thread-status">@subtitle</span>
                </div>
                <span class="wa-thread-e2ee" title="End-to-end encrypted">🔒</span>
            </header>

            <div class="wa-thread-stream" id="wa-thread-stream">
                <div class="wa-thread-e2ee-note">
                    🔒 Messages are end-to-end encrypted. The on-chain canister only stores opaque ciphertext envelopes — decryption happens entirely in your client.
                </div>

                @if (msgs.size() == 0) {
                    <div class="wa-thread-empty">
                        <div class="wa-welcome-ico">💬</div>
                        <p>No messages yet. Say hello — your message is encrypted before it leaves your device.</p>
                    </div>
                } else {
                    @for m in msgs {
                        <div class="wa-bubble-row @bubbleSide(m)">
                            <div class="wa-bubble">
                                @if (showSender(m)) {
                                    <span class="wa-bubble-sender">@m.senderHandle</span>
                                }
                                <span class="wa-bubble-text" title="Stored ciphertext envelope — decrypted client-side">@m.ciphertext</span>
                                <span class="wa-bubble-meta">
                                    <span class="wa-bubble-time">@relTime(m)</span>
                                    @if (m.sender == me) {
                                        <span class="wa-ticks @(tickClass(m))" title="Delivery / read receipt">✓✓</span>
                                    }
                                </span>
                            </div>
                        </div>
                    }
                }
            </div>

            <form class="wa-composer" @submit="sendMsg" secure>
                <ValidationSummary />
                <div class="wa-composer-row">
                    <InputText name="draft" label="Type a message" bind="@draft" required />
                    <Button kind="primary" type="submit">Send</Button>
                </div>
                <p class="wa-composer-note">🔒 In production this body is encrypted client-side (X25519 / AEAD) before sending; the canister stores only the ciphertext envelope.</p>
            </form>
        </section>
    }
</div>

@code {
    // Viewer identity, cached for thin bubble + list helpers.
    var me : Principal = Principal.fromText("2vxsx-fae");
    var meName : Text = "You";
    var meAvatar : Text = "🙂";
    var member : Bool = false;

    // Left-rail conversation list (same store the index page renders).
    var convos : [Messenger.Conversation] = [];

    // Open conversation header + message stream.
    var title : Text = "Conversation";
    var subtitle : Text = "encrypted";
    var headerAvatar : Text = "🔒";
    var msgs : [Messenger.DmMessage] = [];

    // Bound composer field.
    var draft : Text = "";

    func onLoad(ctx : Context) {
        me := ctx.caller;
        meName := Identity.handleOf(ctx.caller);
        meAvatar := Identity.avatarOf(ctx.caller);
        convos := Messenger.conversations(ctx.caller);
        member := Messenger.isMember(id, ctx.caller);
        if (member) {
            // Title + subtitle: group name + member count, else peer handle + "online".
            switch (Messenger.directPeer(ctx.caller, id)) {
                case (?p) {
                    title := Identity.handleOf(p);
                    headerAvatar := Identity.avatarOf(p);
                    subtitle := "online · encrypted";
                };
                case null {
                    title := Messenger.titleFor(id, "");
                    headerAvatar := "👥";
                    subtitle := Nat.toText(Messenger.memberCount(id)) # " members · encrypted";
                };
            };
            msgs := Messenger.messages(ctx.caller, id);
            // Viewing a conversation marks every message in it as read.
            Messenger.markRead(ctx.caller, id);
        };
    };

    // ---- thread bubble helpers ------------------------------------------

    // Bubble alignment: own messages on the right, others on the left.
    func bubbleSide(m : Messenger.DmMessage) : Text {
        if (m.sender == me) { "wa-sent" } else { "wa-recv" };
    };

    // Show the sender label only for incoming group messages (WhatsApp).
    func showSender(m : Messenger.DmMessage) : Bool {
        m.sender != me and Messenger.memberCount(id) > 2;
    };

    // ✓✓ read state for our own messages: green once a peer has read it
    // (readBy holds more than just the sender), grey otherwise.
    func tickClass(m : Messenger.DmMessage) : Text {
        if (m.readBy.size() > 1) { "is-read" } else { "" };
    };

    func relTime(m : Messenger.DmMessage) : Text { Messenger.relativeTime(m.at) };

    // ---- left-rail list helpers (mirror the /messages index page) -------

    func rowTitle(c : Messenger.Conversation) : Text {
        switch (c.kind) {
            case (#Group) { Messenger.titleFor(c.id, "") };
            case (#Direct) {
                switch (Messenger.directPeer(me, c.id)) {
                    case (?p) { Identity.handleOf(p) };
                    case null { c.name };
                };
            };
        };
    };

    func rowAvatar(c : Messenger.Conversation) : Text {
        switch (c.kind) {
            case (#Group) { "👥" };
            case (#Direct) {
                switch (Messenger.directPeer(me, c.id)) {
                    case (?p) { Identity.avatarOf(p) };
                    case null { "🔒" };
                };
            };
        };
    };

    func rowPreview(c : Messenger.Conversation) : Text {
        switch (Messenger.lastMessage(me, c.id)) {
            case null {
                switch (c.kind) {
                    case (#Group) { Nat.toText(Messenger.memberCount(c.id)) # " members · encrypted" };
                    case (#Direct) { "Direct message · encrypted" };
                };
            };
            case (?m) {
                let body = previewBody(m.ciphertext);
                switch (c.kind) {
                    case (#Group) {
                        let who = if (m.sender == me) "You" else m.senderHandle;
                        who # ": " # body;
                    };
                    case (#Direct) {
                        if (m.sender == me) "You: " # body else body;
                    };
                };
            };
        };
    };

    func previewBody(t : Text) : Text {
        if (Text.size(t) <= 38) { return t };
        var out = "";
        var i = 0;
        for (ch in t.chars()) {
            if (i < 36) { out #= Text.fromChar(ch) };
            i += 1;
        };
        out # "…";
    };

    func rowTime(c : Messenger.Conversation) : Text { Messenger.relativeTime(c.lastAt) };

    func rowUnread(c : Messenger.Conversation) : Nat { Messenger.unreadCount(me, c.id) };

    func unreadClass(c : Messenger.Conversation) : Text {
        if (Messenger.unreadCount(me, c.id) > 0) { "is-unread" } else { "" };
    };

    // Highlight the conversation currently open in the right pane.
    func activeClass(c : Messenger.Conversation) : Text {
        if (c.id == id) { "is-active" } else { "" };
    };

    // ---- composer handler -----------------------------------------------

    func sendMsg(ctx : Context) : async () {
        validate {
            draft required "Type a message to send.";
        };
        // NOTE: a real client encrypts `draft` (X25519 + AEAD) into a base64
        // envelope BEFORE calling send; here we store the text as the ciphertext
        // field so the flow is honest end-to-end without a browser crypto stub.
        let handle = Identity.handleOf(ctx.caller);
        let id2 = Messenger.send(ctx.caller, id, handle, draft);
        draft := "";
        if (id2 == 0) {
            toast("Couldn't send — you're not a member of this conversation.");
        } else {
            scrollTo("#wa-thread-stream");
        };
    };
}

<style>
    /* ---- two-pane WhatsApp shell ---------------------------------------- */
    .wa { display: grid; grid-template-columns: 360px 1fr; gap: 0;
        height: calc(100vh - 140px); min-height: 520px;
        border: 1px solid var(--mv-border); border-radius: 14px; overflow: hidden;
        background: var(--mv-surface); box-shadow: var(--mv-shadow); }

    /* ---- LEFT pane: chat list ------------------------------------------- */
    .wa-list { display: flex; flex-direction: column; min-width: 0;
        border-right: 1px solid var(--mv-border); background: var(--mv-surface); }
    .wa-list-head { display: flex; align-items: center; gap: .5rem;
        padding: .7rem .85rem; background: var(--mv-muted); border-bottom: 1px solid var(--mv-border); }
    .wa-list-back { text-decoration: none; font-size: 1.3rem; color: var(--mv-text-soft); line-height: 1;
        width: 34px; height: 34px; flex: none; display: grid; place-items: center; border-radius: 8px; }
    .wa-list-back:hover { background: var(--mv-surface); color: var(--mv-text); }

    .wa-search { display: flex; align-items: center; gap: .55rem; margin: .55rem .7rem;
        padding: .5rem .75rem; background: var(--mv-muted); border-radius: 999px;
        color: var(--mv-text-soft); font-size: .85rem; flex: none; }
    .wa-search-ico { font-size: .85rem; opacity: .7; }

    .wa-chats { list-style: none; margin: 0; padding: 0; overflow-y: auto; flex: 1; }
    .wa-chat { display: flex; align-items: center; gap: .75rem; padding: .7rem .85rem;
        text-decoration: none; color: inherit; border-bottom: 1px solid var(--mv-border);
        transition: background .12s ease; }
    .wa-chat:hover { background: var(--mv-muted); }
    .wa-chat.is-active { background: var(--mv-muted); }
    .wa-chat.is-active::before { content: ""; position: absolute; }
    .wa-chat-avatar { flex: none; width: 48px; height: 48px; border-radius: 50%;
        background: var(--mv-muted); display: grid; place-items: center; font-size: 1.45rem; }
    .wa-chat.is-active .wa-chat-avatar { background: var(--mv-surface); }
    .wa-chat-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: .15rem; }
    .wa-chat-top { display: flex; align-items: baseline; justify-content: space-between; gap: .6rem; }
    .wa-chat-name { font-weight: 600; font-size: .96rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .wa-chat-time { flex: none; color: var(--mv-text-soft); font-size: .72rem; }
    .wa-chat-time.is-unread { color: #1fa855; font-weight: 700; }
    .wa-chat-bottom { display: flex; align-items: center; justify-content: space-between; gap: .6rem; }
    .wa-chat-preview { color: var(--mv-text-soft); font-size: .84rem; overflow: hidden;
        text-overflow: ellipsis; white-space: nowrap; min-width: 0; }

    /* ---- RIGHT pane: thread --------------------------------------------- */
    .wa-pane { display: flex; flex-direction: column; min-width: 0; }
    .wa-pane-empty { align-items: center; justify-content: center; text-align: center; padding: 2rem;
        background: var(--mv-muted); }
    .wa-welcome { max-width: 42ch; }
    .wa-welcome-ico { font-size: 2.6rem; }
    .wa-welcome h1 { margin: .5rem 0 .35rem; font-size: 1.4rem; letter-spacing: -.02em; }
    .wa-welcome p { margin: 0 auto; color: var(--mv-text-soft); }

    .wa-thread { background:
        linear-gradient(180deg, rgba(0,0,0,.012), rgba(0,0,0,.012)), var(--mv-muted); }

    .wa-thread-head { display: flex; align-items: center; gap: .7rem; flex: none;
        padding: .6rem .9rem; background: var(--mv-muted); border-bottom: 1px solid var(--mv-border); }
    .wa-thread-back { display: none; text-decoration: none; font-size: 1.3rem; color: var(--mv-text-soft);
        line-height: 1; width: 30px; flex: none; }
    .wa-thread-avatar { flex: none; width: 42px; height: 42px; border-radius: 50%; background: var(--mv-surface);
        display: grid; place-items: center; font-size: 1.3rem; }
    .wa-thread-titlewrap { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: .05rem; }
    .wa-thread-title { font-weight: 600; font-size: 1.02rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .wa-thread-status { font-size: .76rem; color: #047857; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .wa-thread-e2ee { flex: none; font-size: 1rem; color: var(--mv-text-soft); }

    .wa-thread-stream { flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: .35rem;
        padding: 1rem; }
    .wa-thread-e2ee-note { align-self: center; max-width: 46ch; text-align: center; margin: 0 0 .75rem;
        background: #fdf6dd; border: 1px solid #f6e7a8; color: #6b5e1a; border-radius: 10px;
        padding: .5rem .75rem; font-size: .76rem; line-height: 1.4; }

    .wa-bubble-row { display: flex; max-width: 100%; }
    .wa-recv { justify-content: flex-start; }
    .wa-sent { justify-content: flex-end; }
    .wa-bubble { max-width: 72%; padding: .42rem .6rem .3rem; border-radius: 10px;
        box-shadow: 0 1px 1px rgba(0,0,0,.08); position: relative; }
    .wa-recv .wa-bubble { background: var(--mv-surface); color: var(--mv-text); border-top-left-radius: 2px; }
    .wa-sent .wa-bubble { background: #d9fdd3; color: #111b21; border-top-right-radius: 2px; }
    .wa-bubble-sender { display: block; font-size: .74rem; font-weight: 700; color: var(--bz-accent, #6d28d9); margin-bottom: .1rem; }
    .wa-bubble-text { font-size: .92rem; line-height: 1.4; word-break: break-word; white-space: pre-wrap; }
    .wa-bubble-meta { display: inline-flex; align-items: center; gap: .25rem; float: right;
        margin: .15rem 0 0 .6rem; }
    .wa-bubble-time { font-size: .68rem; color: rgba(0,0,0,.45); }
    .wa-recv .wa-bubble-time { color: var(--mv-text-soft); }
    .wa-ticks { font-size: .72rem; color: rgba(0,0,0,.35); letter-spacing: -.05em; }
    .wa-ticks.is-read { color: #53bdeb; }

    .wa-thread-empty { text-align: center; color: var(--mv-text-soft); margin: auto; padding: 2rem 1rem; }
    .wa-thread-empty p { max-width: 36ch; margin: .5rem auto 0; }

    .wa-composer { flex: none; background: var(--mv-muted); border-top: 1px solid var(--mv-border);
        padding: .7rem .9rem .55rem; }
    .wa-composer-row { display: flex; align-items: flex-end; gap: .6rem; }
    .wa-composer-row > :first-child { flex: 1; }
    .wa-composer-note { margin: .4rem 0 0; font-size: .7rem; color: var(--mv-text-soft); }

    @media (max-width: 720px) {
        .wa { grid-template-columns: 1fr; height: auto; min-height: 0; }
        .wa-list { display: none; }
        .wa-thread-back { display: block; }
    }
</style>