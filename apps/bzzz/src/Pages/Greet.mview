@page "/greet/{name}"
@layout AppLayout
@authorize redirect="/welcome"
@title Lang.tc(ctx.caller, "greet.title")
@description Lang.tc(ctx.caller, "greet.desc")
<section class="bz-hero"><h1>@Lang.tc(ctx.caller, "greet.hello"), @name 👋</h1>
<p>@Lang.tc(ctx.caller, "greet.demo")</p></section>
@code { }




