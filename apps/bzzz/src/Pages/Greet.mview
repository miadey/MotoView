@page "/greet/{name}"
@layout AppLayout
@title "Hello"
@description "A public, parameterized page served as a certified query via a wildcard."
<section class="bz-hero"><h1>Hello, @name 👋</h1>
<p>This parameterized public page is certified with a wildcard (/greet/&lt;*&gt;) and served as a fast certified query — any name under /greet is covered by one cert entry.</p></section>
@code { }
