# ============================================================================
# MotoView iOS — Fastlane release automation (Slice 11)
# ============================================================================
#
# Lanes:
#   build_core   cross-compile the Rust core for iOS device + simulator and
#                assemble the .xcframework (delegates to tools/native-build.sh).
#   beta         build the .ipa with `gym` and upload to TestFlight via `pilot`.
#   release      build and `deliver` to App Store Connect (production review).
#   certs        sync signing certs/profiles via `match` (read-only by default).
#
# ----------------------------------------------------------------------------
# EXTERNAL PREREQUISITES (NONE of these exist on the CI/build machine here —
# the lanes are COMPLETE but cannot run without the user supplying):
#   * Apple Developer Program membership ($99/yr) and an App Store Connect app
#     record for the bundle id in Appfile.
#   * FULL XCODE (not just Command-Line-Tools). `gym`/`xcodebuild`/
#     `-create-xcframework` and any .app/.ipa build REQUIRE full Xcode. The
#     build machine here is Command-Line-Tools-only, so `beta`/`release` DO NOT
#     run here — only `build_core`'s cargo step does (the xcframework step is
#     flagged by tools/native-build.sh when xcodebuild is absent).
#   * An App Store Connect API key (Issuer ID + Key ID + .p8), provided to CI as
#     secrets: ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_CONTENT (base64 .p8).
#   * A `match` certificates repo (private git) holding the distribution cert +
#     provisioning profiles, encrypted with MATCH_PASSWORD. See Matchfile.
#   * An actual Xcode app target / .xcodeproj or .xcworkspace. The Swift PACKAGE
#     here (Package.swift) builds the library + a host smoke executable; turning
#     it into a shippable .app needs an app target + signing — see README's
#     "What needs FULL XCODE" section. `gym` below points at that workspace once
#     it exists (XCODE_WORKSPACE / XCODE_SCHEME).
# ----------------------------------------------------------------------------

default_platform(:ios)

# Pull config from the environment so NO secrets live in this file.
WORKSPACE = ENV["XCODE_WORKSPACE"] || "MotoView.xcworkspace"
SCHEME    = ENV["XCODE_SCHEME"]    || "MotoView"
SCONFIG   = ENV["XCODE_CONFIG"]    || "Release"

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Cross-compile the Rust core for iOS (device + sim) and build the xcframework"
  lane :build_core do
    # The cargo iOS builds (these WORK on Command-Line-Tools). The xcframework
    # assembly step inside the wrapper needs full Xcode and self-flags if absent.
    sh("cd ../.. && bash tools/native-build.sh ios")
  end

  desc "Build a signed .ipa and upload to TestFlight"
  lane :beta do
    build_core

    # Authenticate to App Store Connect with an API key (no Apple ID 2FA in CI).
    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],   # base64-encoded .p8
      is_key_content_base64: true,
      in_house:    false
    )

    # Sync the distribution cert + appstore profile (read-only in CI).
    match(type: "appstore", readonly: true, api_key: api_key)

    # Bump build number to the next TestFlight value to avoid collisions.
    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key).to_i + 1
    )

    gym(
      workspace:     WORKSPACE,
      scheme:        SCHEME,
      configuration: SCONFIG,
      export_method: "app-store",
      clean:         true,
      output_directory: "build",
      output_name:   "MotoView.ipa"
    )

    pilot(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )

    UI.success("Uploaded to TestFlight")
  end

  desc "Build a signed .ipa and submit to the App Store"
  lane :release do
    build_core

    api_key = app_store_connect_api_key(
      key_id:      ENV["ASC_KEY_ID"],
      issuer_id:   ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house:    false
    )

    match(type: "appstore", readonly: true, api_key: api_key)

    gym(
      workspace:     WORKSPACE,
      scheme:        SCHEME,
      configuration: SCONFIG,
      export_method: "app-store",
      clean:         true,
      output_directory: "build",
      output_name:   "MotoView.ipa"
    )

    deliver(
      api_key: api_key,
      submit_for_review:    true,
      automatic_release:    false,
      force:                true,   # skip the interactive HTML preview in CI
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )

    UI.success("Submitted to App Store review")
  end

  desc "Sync signing certs/profiles via match (read-only)"
  lane :certs do
    match(type: "appstore", readonly: true)
    match(type: "development", readonly: true)
  end
end
