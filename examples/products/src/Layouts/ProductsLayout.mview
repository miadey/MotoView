<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@View.title</title>
    @head
    <style>
        body { background: #f4f4f8; }
        .shop-shell { max-width: 980px; margin: 0 auto; padding: 1.25rem; }
        .shop-nav { display: flex; align-items: center; gap: .75rem; padding: .6rem 0 1.4rem; }
        .shop-logo { font-weight: 800; color: var(--mv-primary); font-size: 1.15rem; }
        .shop-logo a { color: inherit; text-decoration: none; }
        .shop-pill { font-size: .72rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; color: var(--mv-text-soft); background: #eceaf6; padding: .2rem .55rem; border-radius: 999px; }

        .shop-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1.25rem; }
        .shop-header h1 { margin: 0; font-size: 1.8rem; }
        .shop-sub { margin: .15rem 0 0; color: var(--mv-text-soft); }

        .shop-card { background: #fff; border: 1px solid var(--mv-border); border-radius: 14px; padding: 1.1rem 1.3rem; box-shadow: var(--mv-shadow); }
        .shop-form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: .25rem 1rem; }
        .shop-form-actions { display: flex; gap: .6rem; margin-top: .8rem; align-items: center; }

        .prod-table td .row-actions { display: flex; gap: .4rem; }
        .price { font-weight: 700; color: var(--mv-primary); }
        .stock-out { color: var(--mv-danger); font-weight: 600; }
        .stock-low { color: var(--mv-warning); font-weight: 600; }

        .empty { text-align: center; color: var(--mv-text-soft); padding: 2rem 0; }
        .back-link { display: inline-block; margin-bottom: 1rem; color: var(--mv-text-soft); font-size: .9rem; }
    </style>
</head>
<body>
    <div class="shop-shell">
        <nav class="shop-nav">
            <span class="shop-logo"><a href="/">▼ MotoView Store</a></span>
            <span class="shop-pill">Products</span>
        </nav>
        @yield
    </div>
</body>
</html>
