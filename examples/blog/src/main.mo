        b.raw("</a></h2>\n            <p class=\"post-excerpt\">");
        b.text(Html.unquote(debug_show(post.excerpt)));
        b.raw("</p>\n            <a class=\"post-readmore\" href=\"/post/");
        b.text(post.slug);
        b.raw("\">Read post →</a>\n        </li>\n    ");
      };
