<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@View.title</title>
    @head
</head>
<body>
    <header class="mv-container" style="padding-top:1rem;padding-bottom:0;display:flex;gap:1rem;align-items:center;border-bottom:1px solid var(--mv-border)">
        <strong>▼ MotoView</strong>
        <span style="color:var(--mv-text-soft)">contact example</span>
    </header>

    <main>
        @yield
    </main>

    <footer class="mv-container" style="color:var(--mv-text-soft);font-size:.9rem">
        Secure forms by default · powered by MotoView on the Internet Computer.
    </footer>
</body>
</html>
