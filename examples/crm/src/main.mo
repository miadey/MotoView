    func toggleCreate() : () {
        creating := not creating;
    };
    func createDeal() : () {
         mvErrors.clear(); if (title == "") { mvErrors.add(("title", "Give the deal a name.")) }; if (company == "") { mvErrors.add(("company", "Which company is this for?")) }; if (value < 1) { mvErrors.add(("value", "Set a deal value greater than zero.")) }; if (mvErrors.size() > 0) { return }; 

        deals := Crm.add(deals, nextId, title, company, contact, value);
        nextId += 1;
        creating := false;
        title := "";
        company := "";
        contact := "";
        value := 0;
        toast("Deal added to Lead");
    };
    func moveFwd(id : Nat) : () {
        deals := Crm.advance(deals, id, 1);
        toast("Moved forward");
    };
    func moveBack(id : Nat) : () {
        deals := Crm.advance(deals, id, -1);
    };
    func removeDeal(id : Nat) : () {
        deals := Crm.remove(deals, id);
        toast("Deal removed");
    };
    func dropDeal(id : Nat, stage : Text) : () {
        deals := Crm.move(deals, id, stage);
        toast("Moved to " # stage);
        animate("#col-" # stage, "pulse");
    };
    public func mvRender(ctx : MV.Ctx) : Text {
      let b = Html.Builder();
      ignore ctx;
      b.raw("<div class=\"crm-header\">\n    <div>\n        <h1>Pipeline</h1>\n        <p class=\"crm-sub\">");
      b.text(Nat.toText(dealCount()));
      b.raw(" open deals · <strong>");
      b.text(money(pipelineValue()));
      b.raw("</strong> in flight</p>\n    </div>\n    <button class=\"mv-btn mv-btn-primary mv-btn-large\" data-mv-handler=\"toggleCreate\" data-mv-event=\"click\">+ New deal</button>\n</div>\n\n");
      if (creating) {
        b.raw("\n    <div class=\"crm-form mv-anim-fadein\">\n        <form novalidate data-mv-handler=\"createDeal\" data-mv-event=\"submit\" data-mv-secure=\"1\"");
        b.attr("data-mv-token", ctx.mintToken("createDeal", "company,contact,title,value"));
        b.raw(" data-mv-schema=\"company,contact,title,value\">\n            ");
