    public func mvHead(ctx : MV.Ctx) : MV.Head { ignore ctx; { title = "Pipeline — MotoView CRM"; description = "A drag-and-drop sales pipeline built with MotoView — no frontend JavaScript."; canonical = ""; extra = "" } };
